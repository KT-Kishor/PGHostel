{
    "sap.app": {
        "id": "sap.ui.com.project1.cards.CustomerCard",
        "type": "card"
    },
    "sap.card": {
        "type": "Object",
   "configuration": {
  "parameters": {
    "CustomerName": { "type": "string" },
    "BedType": { "type": "string" },
    "BranchName": { "type": "string" },
    "OverallRating": { "type": "number" },
    "Comments": { "type": "string" },
    "FeedbackDate": { "type": "string" }
  }
},
        "content": {
            "groups": [
                {
                    "title": "Customer Name:",
                    "items": [
                        {
                            "value": "{parameters>/CustomerName/value}"
                        }
                    ]
                },
                {
                    "title": "Bed Type:",
                    "items": [
                        {
                            "value": "{parameters>/BedType/value}"
                        }
                    ]
                },
                {
                    "title": "Branch Name:",
                    "items": [
                        {
                            "value": "{parameters>/BranchName/value}"
                        }
                    ]
                },
                {
                    "title": "Rating:",
                    "items": [
                        {
                            "type": "RatingIndicator",
                            "value": "{parameters>/OverallRating/value}",
                            "maxValue": 5
                        },
                        {
                            "text": "{parameters>/OverallRating/value} / 5"
                        }
                    ]
                },
                {
                    "title": "Comments:",
                    "items": [
                        {
                            "value": "{parameters>/Comments/value}"
                        }
                    ]
                },
                {
                    "title": "Feedback Date:",
                    "items": [
                        {
                            "value": "{parameters>/FeedbackDate/value}"
                        }
                    ]
                }
            ]
        }
    }
}