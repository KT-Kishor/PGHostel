{
  "sap.app": {
    "id": "today.booking.card",
    "type": "card"
  },
  "sap.card": {
    "type": "Object",

    "header": {
      "title": "Booking ID: {data>/BookingID}",
      "subTitle": "Customer Name: {data>/CustomerName} ({data>/BookingID})"
    },

    "content": {
      "groups": [
        {
          "items": [
            {
              "value": "Booking Date: {data>/BookingDate}"
            },
            {
              "value": "Status: {data>/Status}"
            },
            {
              "value": "Stay: {data>/StartDate} to {data>/EndDate}"
            }
          ]
        }
      ]
    },

    "footer": {
      "actionsStrip": [
        {
          "text": "View Booking",
          "actions": [
            {
              "type": "Custom",
              "parameters": {
                "BookingID": "{data>/BookingID}",
                "MemberID" : "{data>/MemberID}"
              }
            }
          ]
        }
      ]
    }
  }
}