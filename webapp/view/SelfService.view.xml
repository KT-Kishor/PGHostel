<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
    controllerName="sap.kt.com.minihrsolution.controller.SelfService" 
    displayBlock="true"
	xmlns:core="sap.ui.core">
	<Page id="SS_id_Page" >
		<headerContent>
		<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
		</headerContent>
		<content>
			<IconTabBar
			id="SS_id_IconTab"
			select="SS_onTabSelect"
			expanded="{device>/isNoPhone}"
			selectedKey="employeeDetailsKey"
			class="sapUiResponsiveContentPadding"  busyIndicatorDelay="0">
				<items>
					<IconTabFilter
					design="Horizontal"
					key="employeeDetailsKey"
					text="{i18n>headerEmpDetails}"
					icon="sap-icon://person-placeholder">
						<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.BasicDetails" type="XML"/>
					</IconTabFilter>
					<IconTabFilter
    design="Horizontal"
	key="educationDetailKey"
    text="{i18n>educationalDetails}"
    icon="sap-icon://education">
						<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.EducationDetails" type="XML"/>
					</IconTabFilter>
					<IconTabFilter
			design="Horizontal"
			key="employmentKey"
			text="{i18n>employmentDetails}"
				icon="sap-icon://work-history">
						<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.EmploymentDetails" type="XML"/>
					</IconTabFilter>
					<IconTabFilter
					key="salaryKey"
			        design="Horizontal"
			        text="{i18n>salaryDetails}"
				    icon="sap-icon://money-bills">
						<!-- <VBox id="SS_id_FormsContainer" /> -->
						<VBox id="salaryVBox" />

					</IconTabFilter>
					<!-- <IconTabFilter text="{i18n>paySlip}"  icon="sap-icon://simple-payment" design="Horizontal" key="paySlipKey"></IconTabFilter> -->
				</items>
			</IconTabBar>
		</content>
		<footer>
			<Bar>
				 <contentLeft>
                    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
                </contentLeft>
				<contentRight>
					<Button text="{i18n>visit}" type="Attention" 
        press="onDownloadVisitCard" 
        enabled="{viewModel>/isVisitMode}" 
        tooltip="{i18n>visit}" 
        visible="{viewModel>/isEditButtonVisible}" />
					<Button text="{= ${viewModel>/isEditMode} ? 'Save' : 'Edit' }" 
        press="SS_onEditPress"
        type="{= ${viewModel>/isEditMode} ? 'Accept' : 'Ghost' }"   
        tooltip="{i18n>editDetails}" 
        visible="{viewModel>/isEditButtonVisible}" />
				</contentRight>
			</Bar>
		</footer>
	</Page>
</mvc:View>