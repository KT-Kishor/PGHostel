<mvc:View
    controllerName="sap.ui.com.project1.controller.Book_Room"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
>
    <Page
        showHeader="false"
        enableScrolling="false"
        class="sapUiResponsivePadding--footer sapUiResponsivePadding--floatingFooter"
    >
        <headerContent>
            <!-- <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.Header"
                type="XML"
            /> -->

             
        </headerContent>
        <content>
           <Bar
        design="Header"
    >
       <contentLeft>
					<Button
                        icon="sap-icon://nav-back"
                        press=".onNavBack"
                    />
					<Title
                        text="Shah Hostel"
                        class="customPageTitle"
                    />
				</contentLeft>
				<contentRight>
					<Button
                        icon="sap-icon://home"
                        press=".onHome"
                    />
				</contentRight>
    </Bar>
            <ScrollContainer
                width="100%"
                height="100%"
                vertical="true"
                horizontal="false"
            >
                <!-- Wizard -->
                <Wizard
                    class="sapUiResponsivePadding--header sapUiResponsivePadding--content"
                    showNextButton="false"
                    navigationChange="handleNavigationChange"
                    renderMode="Page"
                    id="TC_id_wizard"
                    finishButtonText="Step 4"
                >
                    <!-- Step 1: General Information -->
                    <WizardStep
                        id="TC_id_stepGeneralInfo"
                        title="Booking Information"
                        validated="true"
                        class="customPanelHeader"
                    >
                        <core:Fragment
                            fragmentName="sap.ui.com.project1.fragment.GeneralInfo"
                            type="XML"
                        />
                    </WizardStep>
                    <!-- Step 2: Service Selection -->
                    <WizardStep
                        id="idStepPersonal1"
                        title="Personal Information"
                        validated="true"
                    >
                        <ScrollContainer
                            width="100%"
                            height="100%"
                            vertical="true"
                            horizontal="false"
                        >
                            <!--  LOGIN BANNER HERE -->
                            <HBox
                                width="100%"
                                alignItems="Center"
                                justifyContent="SpaceBetween"
                                visible="{= !${LoginModel>/UserID} }"
                            >
                                <MessageStrip
                                    text="Login to prefill personal details and get access to secret deals"
                                    showIcon="true"
                                    showCloseButton="false"
                                />
                                
                                <!--  LOGIN BUTTON HERE -->
                                <Button
                                    text="LOGIN"
                                    type="Emphasized"
									tooltip="Click to Login"
                                    class="loginBannerButton"
                                    press="onPressLoginBanner"
                                />
                            </HBox>
                            <!-- Your dynamic content container -->
                            <VBox
                                id="idPersonalContainer1"
                                class="sapUiSmallMargin"
                                width="100%"
                            />
                        </ScrollContainer>
                    </WizardStep>
                    <!-- Step 3: Work Scope -->
                    <WizardStep
                        id="id_Summary"
                        title="Summary"
                    >
                        <mvc:XMLView
                            id="TC_id_childView"
                            viewName="sap.ui.com.project1.view.Book_RoomSummary"
                        />
                    </WizardStep>
                </Wizard>
            </ScrollContainer>
        </content>
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    text="Proceed To Pay"
					tooltip="Click to Proceed to Payment"
                    visible="{OBTNModel>/Submit}"
                    class="myUnifiedBtn"
                    press="onOpenProceedtoPay"
                />
                <Button
                    text="Cancel Booking"
					tooltip="Click to Cancel Booking"
                    visible="{OBTNModel>/Cancel}"
                    class="myUnifiedBtn"
                    press="onCancelPress"
                />
                <Button
                    text="Previous"
					tooltip="Click to go to Previous Step"
                    visible="{OBTNModel>/PERVIOUSVIS}"
                    class="myUnifiedBtn"
                    press="onDialogBackButton"
                />
                <Button
                    id="IdNextBtn"
                    text="Next"
					tooltip="Click to go to Next Step"
                    class="myUnifiedBtn"
                    enabled="{OBTNModel>/Next}"
                    visible="{OBTNModel>/NXTVis}"
                    press="onDialogNextButton"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>