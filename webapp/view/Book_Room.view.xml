<mvc:View
    controllerName="sap.ui.com.project1.controller.Book_Room"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
>
    <Page
        showHeader="false"
        enableScrolling="false"
        class="sapUiResponsivePadding--footer sapUiResponsivePadding--floatingFooter"
    >
        <core:Fragment
            fragmentName="sap.ui.com.project1.fragment.BookingHeader"
            type="XML"
        />

        <content>
            <!-- <Bar
        design="Header"
        visible="true"
    >
       <contentLeft>
					<Button
                        icon="sap-icon://nav-back"
                        press=".onNavBack"
                    />
					<Title
                        text="Shah Hostel"
                        class="customPageTitle"
                    />
				</contentLeft>
				<contentRight>
					<Button
                        icon="sap-icon://home"
                        press=".onHome"
                    />
				</contentRight>
    </Bar> -->
            <ScrollContainer
                width="100%"
                height="100%"
                vertical="true"
                horizontal="false"
            >
                <!-- Wizard -->
                <Wizard
                    class="sapUiResponsivePadding--header sapUiResponsivePadding--content"
                    showNextButton="false"
                    navigationChange="handleNavigationChange"
                    renderMode="Page"
                    id="TC_id_wizard"
                    finishButtonText="Step 4"
                >
                    <!-- Step 1: General Information -->
                    <WizardStep
                        id="TC_id_stepGeneralInfo"
                        title="{i18n>bookingInformation}"
                        validated="{HostelModel>/IsGeneralInfoValid}"
                        class="customPanelHeader"
                    >
                        <core:Fragment
                            fragmentName="sap.ui.com.project1.fragment.GeneralInfo"
                            type="XML"
                        />
                    </WizardStep>
                    <!-- Step 2: Service Selection -->
                    <WizardStep
                        id="idStepPersonal1"
                        title="{i18n>personalInformation}"
                        validated="{HostelModel>/IsGeneralInfoValid}"
                    >
                        <ScrollContainer
                            width="100%"
                            height="100%"
                            vertical="true"
                            horizontal="false"
                        >
                            <!--  LOGIN BANNER HERE -->
                            <HBox
                                width="100%"
                                alignItems="Center"
                                justifyContent="SpaceBetween"
                                visible="{= !${LoginModel>/UserID} &amp;&amp; !${LoginModel>/EmployeeID} }"
                            >
                                <MessageStrip
                                    text="{i18n>bookRoomMsg}"
                                    showIcon="true"
                                    showCloseButton="false"
                                />

                                <!--  LOGIN BUTTON HERE -->
                                <Button
                                    text="{i18n>login}"
                                    type="Emphasized"
                                    tooltip="{i18n>clickLogin}"
                                    class="loginBannerButton"
                                    press="onPressLoginBanner"
                                />
                            </HBox>
                            <!-- Your dynamic content container -->
                            <VBox
                                id="idPersonalContainer1"
                                width="100%"
                            />
                        </ScrollContainer>
                    </WizardStep>
                    <!-- Step 3: Work Scope -->
                    <WizardStep
                        id="id_Summary"
                        title="{i18n>summary}"
                    >
                        <mvc:XMLView
                            id="TC_id_childView"
                            viewName="sap.ui.com.project1.view.Book_RoomSummary"
                        />
                    </WizardStep>
                </Wizard>
            </ScrollContainer>
        </content>
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    text="{i18n>proceedToPay}"
                    tooltip="{i18n>proceedToPay}"
                    visible="{OBTNModel>/Submit}"
                    class="myUnifiedBtn"
                    press="onOpenProceedtoPay"
                />
                <Button
                    text="{i18n>cancelBooking}"
                    tooltip="{i18n>cancelBooking}"
                    visible="{OBTNModel>/Cancel}"
                    class="myUnifiedBtn"
                    press="onCancelPress"
                />
                <Button
                    text="{i18n>previous}"
                    tooltip="{i18n>previous}"
                    visible="{OBTNModel>/PERVIOUSVIS}"
                    class="myUnifiedBtn"
                    press="onDialogBackButton"
                />
                <Button
                    id="IdNextBtn"
                    text="{i18n>next}"
                    tooltip="{i18n>next}"
                    class="myUnifiedBtn"
                    enabled="{OBTNModel>/Next}"
                    visible="{OBTNModel>/NXTVis}"
                    press="onDialogNextButton"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>