<mvc:View
	controllerName="sap.kt.com.minihrsolution.controller.AutoMobile_Demo"
	xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
	displayBlock="true"
    xmlns:g="sap.f"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
	height="100%"
	busyIndicatorDelay="0"
    >
	<Page>
    <headerContent>
			<Avatar src="./image/logo.jpg" displaySize="XS" press="onAvatarPressed" tooltip="Company Logo"/>
			<Title level="H1" text="{i18n>companynameKT}" class="custom-text" wrapping="false"/>
			<ToolbarSpacer/>
			<Button icon="sap-icon://home" press="onpresshome" class="sapUiTinyMarginEnd" tooltip="{i18n>toolHome}"/>
		</headerContent>
        
        <Title level="H1" text="{i18n>automobile}" class="HeadDemoSection" wrapping="true"/>

            <!-- upload scheme -->
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiSmallMarginTop">
            <m:Title text="{i18n>uploadscheme}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>uploadscheme_Par}" class="jioParagraph" />
        </m:VBox>

        <!-- Right Column -->
         <m:VBox id="videoBoxA" class="sapUiMediumMarginTop">
    <core:HTML id="videoFrameHtmlA"
        content="&lt;div style='width:560px;height:315px;overflow:hidden;border-radius:15px;background:#f3f3f3;'&gt;
                    &lt;iframe src='../Videos/Scheme Upload.mp4' 
                             allowfullscreen 
                             style='width:100%;height:100%;border:none;'&gt;
                    &lt;/iframe&gt;
                 &lt;/div&gt;" />
</m:VBox>

<!-- Acreate Quotation -->
    </g:GridContainer>
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Right Column -->
         <m:VBox id="videoBoxB" class="sapUiMediumMarginTop">
    <core:HTML id="videoFrameHtmlB"
        content="&lt;div style='width:560px;height:315px;overflow:hidden;border-radius:15px;background:#f3f3f3;'&gt;
                    &lt;iframe src='../Videos/Create Quotation.mp4' 
                             allowfullscreen 
                             style='width:100%;height:100%;border:none;'&gt;
                    &lt;/iframe&gt;
                 &lt;/div&gt;" />
</m:VBox>

        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiMediumMarginTop">
            <m:Title text="{i18n>createquotation}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>createquotation_Par}" class="jioParagraph" />
        </m:VBox>
    </g:GridContainer>
     <!-- <m:Button
            text="Request Demo"
            press="onOpenDemoForm"
            class="demoBtn"
        /> -->
         <Image
        src="../image/Request_Demo.png"
        class="floatingButton"
        press="onOpenForm"
      />
  </Page>
   <!-- <l:Grid defaultSpan="L12 M12 S12"  vSpacing="2" hSpacing="2" class="sapUiTinyMargin">
        <l:content>
            <m:Carousel id="videoCarousel" showPageIndicator="false" loop="true" class="allvideo"/>
         </l:content>
     </l:Grid> -->
   
       
</mvc:View>
