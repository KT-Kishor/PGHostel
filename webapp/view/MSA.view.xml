<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
    controllerName="sap.kt.com.minihrsolution.controller.MSA"
	xmlns:fb="sap.ui.comp.filterbar"
    displayBlock="true">
	<Page  >
		<headerContent>
	     <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
			</headerContent>
		<content>
			<fb:FilterBar  class="sapUiTinyMargin" id="MSA_id_AdminFilter" persistencyKey="myPersKey" useToolbar="false" clear="onPressClear" showClearOnFB="true" search=".onSearch" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad" >
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="Company Name" label="{i18n>companyName}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox  showSecondaryValues= "true"  items="{CompanyNameModel>/}"  id="MSA_id_CompanyName" showClearIcon="true">
								<core:ListItem key="{CompanyNameModel>companyName}" text="{CompanyNameModel>companyName}" additionalText="{CompanyNameModel>name}" />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table id="MSA_id_Table" class="sapUiTinyMargin" items="{MSADisplayModel>/}"  busyIndicatorDelay="0"  width="auto"
                    growingScrollToLoad="true" growing="true"  growingThreshold="50"  alternateRowColors="true">
				 <headerToolbar>
                <OverflowToolbar >
                    <Title id="MSA_id_Title" text="{i18n>msaDetails}"/>
                    <ToolbarSpacer/>
                    <Button  text="{i18n>addMSA}" id="MSA_id_Add"  type="Accept" press="MSA_AddmsaDetails"  icon="sap-icon://company-view"/>
                    <Button text="{i18n>headerCustomer}" id="MSA_id_Customer" type="Emphasized"  press="MSA_onAddCustomer" icon="sap-icon://customer" />
                </OverflowToolbar>
            </headerToolbar>
				<columns>
					<Column demandPopin="true">
						<Text text="{i18n>companyName}"/>
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>panCardCommon}" />
					</Column>
					
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>companyHeadName}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>companyHeadPosition}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>createMSADate}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="OnPressNavigationMsaDet" >
						<cells>
						    <Text text="{MSADisplayModel>CompanyName}"/>							
							<Text text="{MSADisplayModel>PanCard}"/>
							<Text text="{MSADisplayModel>CompanyHeadName}"/>
							<Text text="{MSADisplayModel>CompanyHeadPosition}"/>
							<Text text="{MSADisplayModel>CreateMSADate}"/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar>
				<contentLeft>
                    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
				</contentLeft>
			</Bar>
		</footer>
	</Page>
</mvc:View>