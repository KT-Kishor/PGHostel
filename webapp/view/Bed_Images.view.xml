<mvc:View
    controllerName="sap.ui.com.project1.controller.Bed_Images"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns:suite="sap.suite.ui.commons"
    xmlns="sap.uxap"
    xmlns:uxap="sap.uxap"
    xmlns:richtexteditor="sap.ui.richtexteditor"
    xmlns:layout="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:c="sap.ui.core"
    displayBlock="true"
    height="100%"
    xmlns:core="sap.ui.core"
    busyIndicatorDelay="0"
    xmlns:u="sap.ui.unified"
>
    <m:Page
        navButtonPress="BI_onButtonPress"
        showNavButton="true"
        title="{i18n>bedDetails}"
    >
        <m:headerContent>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.Header"
                type="XML"
            />
        </m:headerContent>
        <ObjectPageLayout id="ObjectPageLayout">
            <sections>
                <ObjectPageSection
                    titleUppercase="false"
                    id="purchaseOrderHeaderSection1"
                    title="{i18n>bedInformation}"
                >
                    <subSections>
                        <ObjectPageSubSection id="dsd1">
                            <blocks>
                                <f:SimpleForm
                                    id="idsimpleCompanyDetails"
                                    busyIndicatorDelay="0"
                                    editable="true"
                                    layout="ColumnLayout"
                                    labelSpanXL="2"
                                    labelSpanL="3"
                                    labelSpanM="2"
                                    labelSpanS="12"
                                    adjustLabelSpan="false"
                                    emptySpanXL="0"
                                    emptySpanL="0"
                                    emptySpanM="0"
                                    emptySpanS="0"
                                    columnsXL="3"
                                    columnsL="2"
                                    columnsM="2"
                                    singleContainerFullSize="false"
                                >
                                    <f:content>
                                        <m:Label
                                            text="{i18n>MSbranchCode}"
                                            required="true"
                                        />
                                        <m:ComboBox
                                            id="idRoomType12"
                                            placeholder="{i18n>placeSelectBranchCode}"
                                            selectedKey="{BedImageModel>/BranchCode}"
                                            items="{BranchModel>/}"
                                            change="onbranchChange"
                                            showSecondaryValues="true"
                                            valueStateText="{i18n>placeSelectBranchCode}"
                                            editable="{editable>/Edit}"
                                        >
                                            <core:ListItem
                                                key="{BranchModel>BranchID}"
                                                text="{BranchModel>BranchID}"
                                                additionalText="{BranchModel>Name}"
                                            />
                                        </m:ComboBox>

                                        <m:Label
                                            text="{i18n>bedType}"
                                            required="true"
                                        />
                                        <m:Input
                                            id="idBedType"
                                            value="{BedImageModel>/Name}"
                                            placeholder="{i18n>enterBedType}"
                                            maxLength="60"
                                            liveChange="onNameInputLiveChange"
                                            valueStateText="{i18n>enterBedType}"
                                            editable="{editable>/Edit}"
                                        />

                                        <m:Label
                                            text="{i18n>roomtype}"
                                            required="true"
                                        />
                                        <m:ComboBox
                                            id="idRoomtype"
                                            placeholder="{i18n>selectRoomType}"
                                            selectedKey="{BedImageModel>/ACType}"
                                            change="onbranchChange"
                                            valueStateText="{i18n>selectRoomType}"
                                            editable="{editable>/Edit}"
                                        >
                                            <core:ListItem
                                                key="AC"
                                                text="AC"
                                            />
                                            <core:ListItem
                                                key="Non-Ac"
                                                text="Non-Ac"
                                            />
                                        </m:ComboBox>

                                        <m:Label
                                            text="{i18n>noofPerson}"
                                            required="true"
                                        />
                                        <m:Input
                                            id="idR"
                                            value="{BedImageModel>/NoOfPerson}"
                                            placeholder="{i18n>enterNoofPerson}"
                                            liveChange="onNameInputLiveChange"
                                            type="Number"
                                            valueStateText="{i18n>enterNoofPerson}"
                                            editable="{editable>/Edit}"
                                        />

                                        <m:Label
                                            text="{i18n>maxNoofRooms}"
                                            required="true"
                                        />
                                        <m:Input
                                            id="id_MaxBeds"
                                            value="{BedImageModel>/MaxBeds}"
                                            placeholder="{i18n>enterNoofRooms}"
                                            liveChange="onNameInputLiveChange"
                                            type="Number"
                                            valueStateText="{i18n>enterMaxNoofRooms}"
                                            editable="{editable>/Edit}"
                                        />

                                        <m:Label
                                            text="{i18n>description}"
                                            required="true"
                                        />
                                        <m:TextArea
                                            id="id_Description"
                                            value="{BedImageModel>/Description}"
                                            placeholder="{i18n>enterNoofDescription}"
                                            liveChange="onNameInputLiveChange"
                                            valueStateText="{i18n>enterDescription}"
                                            maxLength="150"
                                            editable="{editable>/Edit}"
                                        />
                                    </f:content>
                                </f:SimpleForm>
                            </blocks>
                        </ObjectPageSubSection>
                    </subSections>
                </ObjectPageSection>
                <ObjectPageSection
                    titleUppercase="false"
                    id="purchaseOrderSection"
                    title="Images"
                >
                    <subSections>
                        <ObjectPageSubSection id="POO_Purchaseordersection">
                            <blocks>
                                <m:HBox
                                    id="idImagesContainer"
                                    wrap="Wrap"
                                    justifyContent="Start"
                                    alignItems="Start"
                                    class="sapUiSmallMargin"
                                    items="{DisplayImagesModel>/DisplayImages}"
                                >
                                    <m:VBox
                                        class="sapUiSmallMarginEnd"
                                        width="150px"
                                        alignItems="Center"
                                        justifyContent="Center"
                                    >
                                        <!-- Normal Image Display -->
                                        <m:Image
                                            src="{DisplayImagesModel>src}"
                                            width="120px"
                                            height="120px"
                                            press="onImagePress"
                                            visible="{= ${DisplayImagesModel>isPlaceholder} === false }"
                                        />
                                        <!-- Placeholder Box (visible only when no image) -->
                                        <m:VBox
                                            visible="{= ${DisplayImagesModel>isPlaceholder} === true &amp;&amp; ${editable>/Edit} === true }"
                                            width="120px"
                                            height="120px"
                                            alignItems="Center"
                                            justifyContent="Center"
                                            class="placeholderBox"
                                        >
                                            <u:FileUploader
                                                id="fileUploader"
                                                icon="sap-icon://add"
                                                width="120px"
                                                style="Transparent"
                                                tooltip="{i18n>addImage}"
                                                placeholder=" "
                                                buttonOnly="true"
                                                fileType="jpg,jpeg,png"
                                                sameFilenameAllowed="true"
                                                visible="{= ${DisplayImagesModel>isPlaceholder} === true &amp;&amp; ${editable>/Edit} === true }"
                                                change=".onFileSelected"
                                            />
                                        </m:VBox>
                                        <!-- Delete icon -->
                                        <m:Button
                                            icon="sap-icon://delete"
                                            visible="{= ${editable>/Edit} === true &amp;&amp; ${DisplayImagesModel>isPlaceholder} === false }"
                                            press=".onDeleteImage"
                                            type="Reject"
                                            tooltip="{i18n>deleteImage}"
                                            width="100%"
                                        />
                                    </m:VBox>
                                </m:HBox>
                            </blocks>
                        </ObjectPageSubSection>
                    </subSections>
                </ObjectPageSection>
            </sections>
        </ObjectPageLayout>
        <m:footer>
            <m:Bar id="IA_id_FooterBar">
                <m:contentRight>
                    <m:Button
                        id="BI_ideditButton"
                        visible="{= !${editable>/Edit} }"
                        text="{i18n>MSedit}"
                        tooltip="{i18n>editBedDetails}"
                        class="myUnifiedBtn"
                        press="BI_onEditButtonPress"
                    />
                    <m:Button
                        id="POO_idSaveButton"
                        visible="{=${editable>/Edit}}"
                        text="{i18n>save}"
                        tooltip="{i18n>saveBedDetails}"
                        class="myUnifiedBtn"
                        press="BT_onsavebuttonpress"
                    />
                </m:contentRight>
            </m:Bar>
        </m:footer>
    </m:Page>
</mvc:View>