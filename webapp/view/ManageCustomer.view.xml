<mvc:View controllerName="sap.kt.com.minihrsolution.controller.ManageCustomer"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:fb="sap.ui.comp.filterbar">
	<Page id="MC_id_ManageCustomer">
		<headerContent>
			<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
		</headerContent>
		<content>
			<fb:FilterBar id="MC_id_CompanyFilter" persistencyKey="myPersKey" useToolbar="false" clear="MC_onClear" showClearOnFB="true" search="MC_onSearch" filterChange=".onFilterChange" showFilterConfiguration="false">
				<fb:filterGroupItems>
				<fb:FilterGroupItem name="companyName" label="{i18n>companyName}" groupName="Group1" visibleInFilterBar="true">
					<fb:control>
					<ComboBox items="{CreateCustomerModel>/}" id="MC_id_CompanyName" showClearIcon="true">
					<core:ListItem key="{CreateCustomerModel>/companyName}" text="{CreateCustomerModel>companyName}" />
					</ComboBox>
					</fb:control>
				</fb:FilterGroupItem>
			</fb:filterGroupItems>
			</fb:FilterBar>
			<Table id="MC_id_CustTable" mode="SingleSelectLeft" 
			 items="{path: 'CreateCustomerModel>/'}"
			 growing="true"
             growingThreshold="100"
             alternateRowColors="true">
				<headerToolbar>
					<OverflowToolbar>
						<Title id="MC_id_Title" text="{i18n>custDetails}"/>
						<ToolbarSpacer/>
						<Button icon="sap-icon://add-employee" tooltip="{i18n>custAddButToolTip}" press="MC_onAddCustomerDetails" />
						<ToolbarSeparator />
						<Button icon="sap-icon://edit" tooltip="{i18n>custEditButToolTip}" press="MC_onEditCustomerDetails" />
						<ToolbarSeparator />
						<Button icon="sap-icon://delete" tooltip="{i18n>custDeleteToolTip}" press="MC_onDeleteAddCustomer" />
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>companyName}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>name}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>gstNo}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>type}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>percentage}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>email}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>mobileNo}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem>
						<cells>
							<Text text="{CreateCustomerModel>companyName}" />
							<Text text="{CreateCustomerModel>name}" />
							<Text text="{CreateCustomerModel>GST}" />
							<Text text="{CreateCustomerModel>type}" />
							<Text text="{CreateCustomerModel>value}" />
							<Text text="{CreateCustomerModel>mailID}" />
							<Text text="{CreateCustomerModel>mobileNo}" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar>
				<contentLeft>
					<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
				</contentLeft>
				<contentRight></contentRight>
			</Bar>
		</footer>
	</Page>
</mvc:View>