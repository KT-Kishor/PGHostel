<mvc:View controllerName="sap.kt.com.minihrsolution.controller.ManageCustomer"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:fb="sap.ui.comp.filterbar">
	<Page id="MC_id_ManageCustomer">
		<headerContent>
			<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
		</headerContent>
		<content>
			<fb:FilterBar id="MC_id_CompanyFilter" persistencyKey="myPersKey" useToolbar="false" clear="onClear" showClearOnFB="true" search=".onSearch" filterChange=".onFilterChange" showFilterConfiguration="false">
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="CompanyName" label="{i18n>companyName}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<Input id="IC_id_CompanyName" value="{filters>/CompanyName}" showClearIcon="true" />
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table id="idCustTable" mode="SingleSelectLeft" selectionChange="onSelectionCustmer">
				<headerToolbar>
					<OverflowToolbar>
						<Title id="MC_id_Title" text="{i18n>manageCustomer}"/>
						<ToolbarSpacer/>
						<Button icon="sap-icon://add-employee" tooltip="{i18n>custAddButToolTip}" press="MC_onAddCustomerDetails" />
						<ToolbarSeparator />
						<Button icon="sap-icon://edit" tooltip="{i18n>custEditButToolTip}" press="MC_onEditCustomerDetails" />
						<ToolbarSeparator />
						<Button icon="sap-icon://delete" tooltip="{i18n>custDeleteToolTip}" press="MC_onDeleteAddCustomer" />
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column>
						<Text text="{i18n>CompanyName}" />
					</Column>
					<Column>
						<Text text="{i18n>Name}" />
					</Column>
					<Column>
						<Text text="{i18n>GST}" />
					</Column>
					<Column>
						<Text text="{i18n>Type}" />
					</Column>
					<Column>
						<Text text="{i18n>Value}" />
					</Column>
					<Column>
						<Text text="{i18n>MailID}" />
					</Column>
					<Column>
						<Text text="{i18n>MobileNo}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem>
						<cells>
							<Text text="{CompanyName}" />
							<Text text="{Name}" />
							<Text text="{GST}" />
							<Text text="{Type}" />
							<Text text="{Value}" />
							<Text text="{MailID}" />
							<Text text="{MobileNo}" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar>
				<contentLeft>
					<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
				</contentLeft>
				<contentRight></contentRight>
			</Bar>
		</footer>
	</Page>
</mvc:View>