<mvc:View controllerName="sap.kt.com.minihrsolution.controller.CompanyInvoice"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:fb="sap.ui.comp.filterbar"
	xmlns:core="sap.ui.core">
	<Page id="CI_id_CompanyInvoice">
		<headerContent>
			<Button press="CI_onPressback" icon="sap-icon://home"/>
			<Text text="{i18n>invoiceApplication}" class="boldBlackText"/>
			<ToolbarSpacer/>
			<Button press="CI_onSignout" icon="sap-icon://log"/>
		</headerContent>
		<content>
			<fb:FilterBar id="CI_id_InvoiceFilterBar" showFilterConfiguration="false" useToolbar="false" showClearOnFB="true" search="onSearch" >
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="InvNo" label="{i18n>invoiceNo}" groupName="ConsultantInvoice" visibleInFilterBar="true">
						<fb:control>
							<ComboBox id="CI_id_InvNo"
                    items="{path:'oInvoiceModel>/InvoiceNoList', length:1000}"
                    showSecondaryValues="true" showClearIcon="true">
								<core:ListItem key="{oInvoiceModel>InvoiceNoID}" text="{oInvoiceModel>InvoiceNo}" additionalText="{oInvoiceModel>InvoiceDate}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="InvoiceDate" label="{i18n>invoiceDate}" groupName="ConsultantInvoice" visibleInFilterBar="true">
						<fb:control>
							<DateRangeSelection id="CI_id_InvoiceDatePicker" valueFormat="dd/MM/yyyy" displayFormat="dd/MM/yyyy" change="onDateRangeChange" />
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="CustomerName" label="{i18n>customerName}" groupName="ConsultantInvoice" visibleInFilterBar="true">
						<fb:control>
							<ComboBox id="CI_id_CustomerNameComboBox" showClearIcon="true"/>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="Status" label="{i18n>status}" groupName="ConsultantInvoice" visibleInFilterBar="true">
						<fb:control>
							<ComboBox id="CI_id_StatusComboBox" showClearIcon="true" />
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table id="CI_id_InvoiceTable" items="{pavan>/}" mode="SingleSelect" selectionChange="onSelectionChange">
				<headerToolbar>
					<Toolbar>
						<Title id="CI_id_Title" text="{i18n>invoiceapp}"/>
						<ToolbarSpacer />
						<ToolbarSeparator />
						<Button icon="sap-icon://add-employee" tooltip="{i18n>addInvoice}" press="CI_onPressAddInvoice" />
						<ToolbarSeparator />
						<Button text="{i18n>msasow}" tooltip="{i18n>addInvoice}" press="CI_onPressMSASOW"/>
					</Toolbar>
				</headerToolbar>
				<columns>
					<Column>
						<Text text="{i18n>invoiceNo}" />
					</Column>
					<Column>
						<Text text="{i18n>invoiceDate}" />
					</Column>
					<Column>
						<Text text="{i18n>PayByDate}" />
					</Column>
					<Column>
						<Text text="{i18n>invoiceDescription}" />
					</Column>
					<Column>
						<Text text="{i18n>customerName}" />
					</Column>
					<Column>
						<Text text="{i18n>totalAmount}" />
					</Column>
					<Column>
						<Text text="{i18n>currency}" />
					</Column>
					<Column>
						<Text text="{i18n>status}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="CI_onPressInvoiceRow">
						<cells>
							<Text text="{InvNo}" />
							<Text text="{InvoiceDate}" />
							<Text text="{PayByDate}" />
							<Text text="{InvoiceDescription}" />
							<Text text="{CustomerName}" />
							<Text text="{path: 'TotalAmount', formatter: '.Formatter.numberFormatter'}" textAlign="End" />
							<Text text="{Currency}" textAlign="End" />
							<ObjectStatus text="{Status}" inverted="true" state="{path: 'Status', formatter: '.Formatter.statusStateFormatter'}" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
	</Page>
</mvc:View>