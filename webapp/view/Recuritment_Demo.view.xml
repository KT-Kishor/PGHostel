<mvc:View
	controllerName="sap.kt.com.minihrsolution.controller.Recuritment_Demo"
	xmlns:mvc="sap.ui.core.mvc"
  xmlns:m="sap.m"
    xmlns="sap.m"
   xmlns:core="sap.ui.core"
	displayBlock="true"
       xmlns:g="sap.f"
           xmlns:f="sap.ui.layout.form"
             xmlns:l="sap.ui.layout"
	height="100%"
	busyIndicatorDelay="0"
>
	<Page >
    	<headerContent>
			<Avatar src="./image/logo.jpg" displaySize="XS" press="onAvatarPressed" tooltip="Company Logo"/>
			<Title level="H1" text="{i18n>companynameKT}" class="custom-text" wrapping="false"/>
			<ToolbarSpacer/>
			<Button icon="sap-icon://home" press="onpresshome" class="sapUiTinyMarginEnd" tooltip="{i18n>toolHome}"/>
		</headerContent>

			<Title level="H1" text="{i18n>Recruitment}" class="HeadDemoSection" wrapping="false"/>
			
    <!-- Generate salary -->
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiSmallMarginTop">
            <m:Title text="{i18n>JobPosting}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>JobPosting_Par}" class="jioParagraph" />
        </m:VBox>

        <!-- Right Column -->
        <m:VBox id="videoBox-1" alignItems="Center" justifyContent="Center" class="sapUiTinyMarginTop">
         <core:HTML id="videoFrameHtml-1"
        content="&lt;video width='560' height='315' controls autoplay muted playsinline 
                     style='border:none;border-radius:15px;overflow:hidden;background:#f3f3f3'&gt;
                    &lt;source src='../Videos/Job Posting.mp4' type='video/mp4'&gt;
                    Your browser does not support the video tag.
                 &lt;/video&gt;" />
</m:VBox>
<!-- Header PaySlip -->
    </g:GridContainer>
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Right Column -->
    <m:VBox alignItems="Center" id="videoBox-2" justifyContent="Center" class="sapUiMediumMarginTop">
     <core:HTML id="videoFrameHtml-2"
        content="&lt;video width='560' height='315' controls 
                     style='border:none;border-radius:15px;overflow:hidden;background:#f3f3f3'&gt;
                    &lt;source src='../Videos/Apply Job.mp4' type='video/mp4'&gt;
                    Your browser does not support the video tag.
                 &lt;/video&gt;" />
</m:VBox>



        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiMediumMarginTop">
            <m:Title text="{i18n>Applyjob}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>Applyjob_Par}" class="jioParagraph" />
        </m:VBox>
    </g:GridContainer>
    <!-- offer Letter -->
  
    <!-- Employee Details -->
     <!-- <m:Button
            text="Request Demo"
            press="onOpenDemoForm"
            class="demoBtn"
        /> -->
         <Image
        src="../image/Demo.png"
        class="floatingButton"
        press="onOpenDemoForm"
      />
 </Page>
 
   <!-- <l:Grid defaultSpan="L12 M12 S12"  vSpacing="2" hSpacing="2" class="sapUiTinyMargin">
        <l:content>
            <m:Carousel id="videoCarousel" showPageIndicator="false" loop="true" class="allvideo"/>
         </l:content>
     </l:Grid> -->
   
       
</mvc:View>
