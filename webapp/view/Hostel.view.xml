<mvc:View
    controllerName="sap.ui.com.project1.controller.Hostel"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:tnt="sap.tnt"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:svm="sap.ui.comp.smartvariants"
    height="100%"
    busyIndicatorDelay="0"
>
    <tnt:ToolPage>
        <tnt:header>
            <tnt:ToolHeader>
                <Image
                    src="./image/LOGO.png"
                    height="250px"
                    width="250px"
                    class="sapUiTinyMarginTop weblogo"
                    tooltip="{i18n>companyLogo}"
                />
                <!-- <Title level="H1" text="SHAH HOSTEL" class="custom-text"/> -->
                <ToolbarSpacer />
                <Button
                    text="{i18n>sIGNINUP}"
                    id="loginButton"
                    tooltip="{i18n>signInorSignUp}"
                    class=" sapUiSmallMarginTop loginButton"
                    press="onpressLogin"
                    visible="{= !${UIModel>/isLoggedIn} }"
                >
                    <layoutData>
                        <OverflowToolbarLayoutData priority="NeverOverflow" />
                    </layoutData>
                </Button>
                <Avatar
                    visible="{UIModel>/isLoggedIn}"
                    id="ProfileAvatar"
                    src="{LoginModel>/Photo}"
                    initials="{= ${LoginModel>/EmployeeName} ? ${LoginModel>/EmployeeName}.charAt(0).toUpperCase() : '' }"
                    displaySize="XS"
                    tooltip="{= ${LoginModel>/UserName} || ${i18n>profilePic} }"
                    press="onPressAvatar"
                    class="sapUiTinyMarginTop profileAvatar"
                />
            </tnt:ToolHeader>
        </tnt:header>
        <tnt:subHeader>
            <tnt:ToolHeader>
                <!-- <ToolbarSpacer /> -->
                <IconTabHeader
                    id="mainTabHeader"
                    select="onTabSelect"
                >
                    <items>
                        <IconTabFilter
                            key="idHome"
                            tooltip="{i18n>home}"
                            text="{i18n>home}"
                        />
                        <IconTabFilter
                            key="idRooms"
                            tooltip="{i18n>rooms}"
                            text="{i18n>rooms}"
                        />
                        <!-- <IconTabFilter key="idFacilities" text="Facilities" /> -->
                        <IconTabFilter
                            key="idContact"
                            tooltip="{i18n>contact}"
                            text="{i18n>contact}"
                        />
                        <!-- <IconTabFilter key="idAdddata" text="Add Data"/> -->
                    </items>
                </IconTabHeader>
            </tnt:ToolHeader>
        </tnt:subHeader>
        <tnt:mainContents>
            <VBox
                height="100%"
                renderType="Bare"
                justifyContent="Start"
                class="  "
            >
                <items>
                    <NavContainer
                        id="pageContainer"
                        height="auto"
                    >
                        <!-- <layoutData>
	<FlexItemData growFactor="1" baseSize="0" />
</layoutData> -->
                        <layoutData>
                            <FlexItemData growFactor="1" />
                        </layoutData>
                        <pages>
                            <ScrollContainer
                                id="idHome"
                                horizontal="false"
                                vertical="true"
                                height="100%"
                                class="sapUiContentPadding Homepage sapUiTinyMargin"
                            >
                                <l:Grid
                                    defaultSpan="XL12 L12 M12 S12"
                                    width="100%"
                                    class="position-welcome fullHeightGrid"
                                >
                                    <VBox class="heroTextBox">
                                        <Text
                                            class="custom-welcome"
                                            text="{i18n>welcomeTo}"
                                        />
                                        <Text
                                            class="custom-welcome"
                                            text="{i18n>companynameKT}"
                                        />
                                        <Text
                                            class="custom-tagline"
                                            text="{i18n>yourNewHomeAwayFromHome}"
                                        />
                                    </VBox>

                                    <!-- <Button text="Explore Now" tooltip="Book Room" class="exploreBtn  sapUiLargeMarginBegin " press="onpressBookrooms" /> -->
                                    <HBox
                                        id="exploreWrapper"
                                        width="100%"
                                        class="exploreBtnWrapper explore-enter"
                                    >
                                        <Button
                                            text="{i18n>exploreNow}"
                                            class="exploreBtn"
                                            press="onpressBookrooms"
                                        />
                                    </HBox>
                                </l:Grid>
                            </ScrollContainer>
                            <Page
                                id="idRooms"
                                showHeader="false"
                                enableScrolling="true"
                            >
                                <VBox
                                    height="100%"
                                    renderType="Bare"
                                >
                                    <ScrollContainer
                                        id="idRoomsScroll"
                                        height="100%"
                                        vertical="true"
                                        horizontal="false"
                                        class="stickyPageContent"
                                    >
                                        <layoutData>
                                            <FlexItemData
                                                growFactor="1"
                                                baseSize="0%"
                                            />
                                        </layoutData>
                                        <content>
                                            <VBox
                                                class="minHeight100 flexGrow1"
                                                justifyContent="SpaceBetween"
                                            >
                                                <VBox width="100%">
                                                    <!-- <HBox justifyContent="End"><Button text="Filter" icon="sap-icon://map" press="onpressFilter" width="200px" class="sapUiTinyMargin"/></HBox> -->
                                                    <VBox
                                                        height="350px"
                                                        class="sapUiContentPadding HostelRooms sapUiTinyMargin"
                                                    >
                                                        <l:Grid
                                                            defaultSpan="XL12 L12 M12 S12"
                                                            width="100%"
                                                            class="position-welcome"
                                                        >
                                                            <VBox
                                                                class=" sapUiLargeMarginTop heroTextBox"
                                                            >
                                                                <Text
                                                                    class="custom-welcome sapUiTinyMarginTopBottom"
                                                                    text="{i18n>bookYourRoom} "
                                                                />
                                                                <!-- <Text class="custom-welcome  sapUiTinyMarginTopBottom " text="{i18n>companynameKT}" /> -->
                                                                <Text
                                                                    text="{i18n>yourNewHomeAwayFromHome}"
                                                                    class="custom-tagline s apUiTinyMarginTop "
                                                                />
                                                            </VBox>
                                                            <HBox
                                                                width="100%"
                                                                justifyContent="End"
                                                                alignItems="Center"
                                                            />
                                                        </l:Grid>
                                                    </VBox>

                                                    <fb:FilterBar
                                                        id="filterbar"
                                                        persistencyKey="myPersKey"
                                                        useToolbar="false"
                                                        clear="FC_onPressClear"
                                                        showClearOnFB="true"
                                                        search="onSearchRooms"
                                                        filterChange="IA_.onFilterChange"
                                                        afterVariantLoad="IA_.onAfterVariantLoad"
                                                        showFilterConfiguration="false"
                                                        filterContainerWidth="auto"
                                                        class="sapUiContentPadding HostelRooms sapUiTinyMargin"
                                                        busyIndicatorDelay="0"
                                                    >
                                                        <fb:filterGroupItems>
                                                            <!--  Branch Name -->
                                                            <fb:FilterGroupItem
                                                                name="Branch"
                                                                label="{i18n>city}"
                                                                groupName="Group1"
                                                                visibleInFilterBar="true"
                                                                mandatory="true"
                                                            >
                                                                <fb:control>
                                                                    <ComboBox
                                                                        id="id_Branch"
                                                                        placeholder="{i18n>cityValueText}"
                                                                        valueStateText="{i18n>pleaseSelectCity}"
                                                                        showClearIcon="true"
                                                                        busyIndicatorDelay="0"
                                                                        enabled="true"
                                                                        items="{path:'sBRModel>/'}"
                                                                        selectionChange=".onBranchSelectionChange"
                                                                    >
                                                                        <core:ListItem
                                                                            key="{sBRModel>city}"
                                                                            text="{sBRModel>city}"
                                                                        />
                                                                    </ComboBox>
                                                                </fb:control>
                                                            </fb:FilterGroupItem>
                                                            <fb:FilterGroupItem
                                                                name="Hostel Name"
                                                                label="Hostel Name"
                                                                groupName="Group1"
                                                                visibleInFilterBar="true"
                                                            >
                                                                <fb:control>
                                                                    <ComboBox
                                                                        id="id_Roomtype"
                                                                        placeholder="Select branch name"
                                                                        showClearIcon="true"
                                                                        busyIndicatorDelay="0"
                                                                        items="{AreaModel>/}"
                                                                    >
                                                                        <core:ListItem
                                                                            key="{AreaModel>Name}"
                                                                            text="{AreaModel>Name}"
                                                                        />
                                                                    </ComboBox>
                                                                </fb:control>
                                                            </fb:FilterGroupItem>
                                                            <!-- Area -->
                                                            <fb:FilterGroupItem
                                                                name="Area"
                                                                label="{i18n>locality}"
                                                                groupName="Group1"
                                                                visibleInFilterBar="true"
                                                            >
                                                                <fb:control>
                                                                    <ComboBox
                                                                        id="id_Area"
                                                                        placeholder="{i18n>selectLocality}"
                                                                        showClearIcon="true"
                                                                        enabled="false"
                                                                        valueStateText="{i18n>selectArea}"
                                                                        items="{AreaModel>/}"
                                                                        selectionChange=".onAreaSelectionChange"
                                                                        busyIndicatorDelay="0"
                                                                    >
                                                                        <core:ListItem
                                                                            key="{AreaModel>LandMark}"
                                                                            text="{AreaModel>LandMark}"
                                                                        />
                                                                    </ComboBox>
                                                                </fb:control>
                                                            </fb:FilterGroupItem>
                                                            <!--  Room Type -->
                                                        </fb:filterGroupItems>
                                                    </fb:FilterBar>

                                                    <VBox
                                                        height="100%"
                                                        justifyContent="Start"
                                                    >
                                                        <l:Grid
                                                            id="idBedTypeFlex"
                                                            defaultSpan="XL3 L4 M6 S12"
                                                            containerQuery="true"
                                                            hSpacing="2"
                                                            vSpacing="2"
                                                            content="{path: 'VisibilityModel>/Branches'}"
                                                        >
                                                            <VBox
                                                                class="bedCard"
                                                            >
                                                                <!-- ===== IMAGE CAROUSEL ===== -->
                                                                <Carousel
                                                                    height="200px"
                                                                    width="100%"
                                                                    loop="true"
                                                                    showPageIndicator="false"
                                                                    backgroundDesign="Transparent"
                                                                >
                                                                    <pages>
                                                                        <VBox
                                                                            class="imageWrapper"
                                                                        >
                                                                            <!-- Image -->
                                                                            <Image
                                                                                src="{VisibilityModel>Image}"
                                                                                width="100%"
                                                                                height="200px"
                                                                                class="bedCardImage"
                                                                                decorative="false"
                                                                            />
                                                                            <CustomListItem
                                                                                type="Active"
                                                                                press=".onRatingPress"
                                                                                visible="{= ${VisibilityModel>TotalFeedbacks} > 0 }"
                                                                                tooltip="Tap to See Reviews"
                                                                            >
                                                                                <HBox
                                                                                    class="ratingOverlay"
                                                                                    alignItems="Center"
                                                                                >
                                                                                    <RatingIndicator
                                                                                        value="{VisibilityModel>AverageRating}"
                                                                                        maxValue="5"
                                                                                        enabled="false"
                                                                                        iconSize="0.8rem"
                                                                                    />
                                                                                    <Text
                                                                                        text="({VisibilityModel>TotalFeedbacks})"
                                                                                        class="ratingCountText"
                                                                                    />
                                                                                </HBox>
                                                                            </CustomListItem>
                                                                        </VBox>
                                                                    </pages>
                                                                </Carousel>

                                                                <!-- ===== CARD CONTENT ===== -->
                                                                <VBox
                                                                    class="bedCardContent"
                                                                >
                                                                    <Text
                                                                        text="{= ${VisibilityModel>Name} + ' - ' + ${VisibilityModel>City}}"
                                                                        class="bedCardTitle"
                                                                    />

                                                                    <HBox
                                                                        justifyContent="Center"
                                                                        alignItems="Center"
                                                                        class="sapUiTinyMarginTop"
                                                                    >
                                                                        <Link
                                                                            text="View Rooms"
                                                                            tooltip="View Rooms"
                                                                            press="viewRooms"
                                                                            class="btnViewDetails"
                                                                        />
                                                                    </HBox>
                                                                </VBox>
                                                            </VBox>
                                                        </l:Grid>

                                                        <VBox
                                                            height="400px"
                                                            justifyContent="Center"
                                                            alignItems="Center"
                                                            visible="{VisibilityModel>/NoData}"
                                                        >
                                                            <Text
                                                                text="{i18n>noRoomsFound}"
                                                                class="cssNoDataMessage"
                                                            />
                                                            <Text
                                                                text="{i18n>pleaseselectanotherCity}"
                                                                class="cssNoDataSubMessage"
                                                            />
                                                        </VBox>
                                                    </VBox>

                                                    <VBox
                                                        alignItems="Center"
                                                        class="sapUiTinyMarginTop sapUiTinyMarginBottom"
                                                        visible="{VisibilityModel>/ShowViewMore}"
                                                    >
                                                        <Link
                                                            id="idViewMoreBusy"
                                                            text="{i18n>viewmorerooms}"
                                                            press="onViewMoreRooms"
                                                            class="btnViewDetails"
                                                        />

                                                        <VBox height="2rem" />
                                                    </VBox>
                                                </VBox>
                                                <VBox
                                                    visible="{FooterModel>/showRoomsFooter}"
                                                >
                                                    <core:Fragment
                                                        id="roomsFooter"
                                                        fragmentName="sap.ui.com.project1.fragment.Footer"
                                                        type="XML"
                                                    />
                                                </VBox>
                                            </VBox>
                                        </content>
                                    </ScrollContainer>
                                </VBox>
                            </Page>
                            <!-- <ScrollContainer id="idFacilities" horizontal="false" vertical="true" height="100%" class="Products_list sapUiTinyMargin">
                        <core:Fragment fragmentName="sap.ui.com.project1.fragment.HomePage" type="XML" />
                    </ScrollContainer> -->
                            <ScrollContainer
                                id="idContact"
                                horizontal="false"
                                vertical="true"
                                height="100%"
                                class="sapUiContentPadding contactScrollWrapper"
                            >
                                <core:Fragment
                                    fragmentName="sap.ui.com.project1.fragment.ContactPage"
                                    type="XML"
                                />
                                <!-- <VBox height="1rem" /> -->
                            </ScrollContainer>
                            <ScrollContainer
                                id="idAdddata"
                                horizontal="false"
                                vertical="true"
                                height="100%"
                                class="sapUiContentPadding career-background sapUiTinyMargin"
                            />
                        </pages>
                    </NavContainer>
                    <VBox visible="{FooterModel>/showGlobalFooter}">
                        <core:Fragment
                            id="globalFooter"
                            fragmentName="sap.ui.com.project1.fragment.Footer"
                            type="XML"
                        />
                    </VBox>
                </items>
            </VBox>
        </tnt:mainContents>
    </tnt:ToolPage>
</mvc:View>
