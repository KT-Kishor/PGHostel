<mvc:View controllerName="sap.ui.com.project1.controller.ComplainDashboard" 
	xmlns:mvc="sap.ui.core.mvc" 
	xmlns="sap.m" 
	xmlns:core="sap.ui.core" 
	xmlns:fb="sap.ui.comp.filterbar" 
	xmlns:layout="sap.ui.layout" 
	xmlns:viz="sap.viz.ui5.controls" 
	xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds" 
	xmlns:vizData="sap.viz.ui5.data" 
	xmlns:f="sap.f" 
	xmlns:com="sap.suite.ui.commons" displayBlock="true" height="100%" busyIndicatorDelay="0">
	<Page id="ComplaintDashboardPage" showHeader="true">
		<headerContent>
			<core:Fragment fragmentName="sap.ui.com.project1.fragment.Header" type="XML" />
		</headerContent>
		<content>
			<!-- <VBox class="sapUiSmallMargin"> -->
			<VBox class="sapUiSmallMargin paymentDashboardTheme">
				<!-- Filter Bar -->
				<fb:FilterBar id="CD_FilterBar" useToolbar="false" clear="onClearFilters" showClearOnFB="true" search="onFilterChange"   showFilterConfiguration="false">
					<fb:filterGroupItems>
						<fb:FilterGroupItem name="Branch" label="Branch" groupName="Group1" visibleInFilterBar="true">
							<fb:control>
								<MultiComboBox id="CD_branchFilter" width="400px" placeholder="Select Branch" items="{path: 'Branchmodel>/'}" selectionChange="onBranchChange">
									<items>
										<core:Item key="{Branchmodel>BranchID}" text="{Branchmodel>Name}" />
									</items>
								</MultiComboBox>
							</fb:control>
						</fb:FilterGroupItem>
						<fb:FilterGroupItem name="ComplainDate" label="Date Range" groupName="Group1" visibleInFilterBar="true">
							<fb:control>
								<DateRangeSelection id="CD_complain_Date" valueFormat="dd/MM/yyyy" displayFormat="dd/MM/yyyy" change="onFilterChange" />
							</fb:control>
						</fb:FilterGroupItem>
						<fb:FilterGroupItem name="Year" label="Assigned Staff" groupName="Group1" visibleInFilterBar="true">
							<fb:control>
							<ComboBox id="CD_assignedStaffFilter" width="400px" placeholder="Select Assigned Staff"  items="{path: 'AssignedStaffModel>/'}">
									<items>
										<core:Item key="{AssignedStaffModel>AssignedBy}" text="{AssignedStaffModel>AssignedBy}" />
									</items>
								</ComboBox>
							</fb:control>
						</fb:FilterGroupItem>
						<fb:FilterGroupItem name="Status" label="Status" groupName="Group1" visibleInFilterBar="true">
							<fb:control>
								<ComboBox id="CD_statusFilter" width="400px" placeholder="Select Status" >
									<items>
										<core:Item key="Pending" text="Pending" />
										<core:Item key="In Progress" text="In Progress" />
										<core:Item key="Resolved" text="Resolved" />
									</items>
								</ComboBox>
							</fb:control>
						</fb:FilterGroupItem>
					</fb:filterGroupItems>
				</fb:FilterBar>
				<!-- Grid for Charts -->
				<layout:Grid defaultSpan="XL6 L6 M12 S12" class="sapUiResponsiveMargin">
					<layout:content>
						<!-- 1. Status Distribution Chart -->
						<f:Card class="sapUiTinyMargin">
							<f:header>
								<Toolbar class="customdashboard">
                                <Title text="Complain Status Distribution" level="H5" wrapping="false" class="Dashboardtitle automatedEllipsis"/>
									<ToolbarSpacer />
									<Button icon="sap-icon://pie-chart" press="IN_onPressStatusPie" tooltip="Pie Chart" />
									<!-- <Button icon="sap-icon://bar-chart" press="	" tooltip="Bar Chart" /> -->
									<Button icon="sap-icon://donut-chart" press="IN_onPressStatusDonut" tooltip="Donut Chart" />
								</Toolbar>
							</f:header>
							<f:content>
								<com:ChartContainer showFullScreen="true" showPersonalization="false" autoAdjustHeight="false">
									<com:content>
										<com:ChartContainerContent>
											<com:content>
												<viz:VizFrame id="CD_donutChartStatus" vizType="{ComplaintChartModel>/statusType}" width="100%" vizProperties="{
    title: { visible: false },
    legend: { label: { color: '#ffffff' } },
    plotArea: {
        dataLabel: { visible: false },
        colorPalette: ['#ec3b14', '#e2f026', '#0b8400']
    }
    
}" selectData="onStatusChartSelect">
    <viz:dataset>
        <vizData:FlattenedDataset data="{chartData>/statusDistribution}">
            <vizData:dimensions>
                <vizData:DimensionDefinition name="Status" value="{chartData>Status}" />
            </vizData:dimensions>
            <vizData:measures>
                <vizData:MeasureDefinition name="Count" value="{chartData>Count}" />
            </vizData:measures>
        </vizData:FlattenedDataset>
    </viz:dataset>
    <viz:feeds>
        <vizFeeds:FeedItem uid="size" type="Measure" values="Count" />
        <vizFeeds:FeedItem uid="color" type="Dimension" values="Status" />
    </viz:feeds>
</viz:VizFrame>
											</com:content>
										</com:ChartContainerContent>
									</com:content>
								</com:ChartContainer>
							</f:content>
						</f:Card>
						<!-- 2. Daily Trend Chart -->
						<f:Card class="sapUiTinyMargin">
							<f:header>
								<Toolbar class="customdashboard">
									<Title text="Daily Complain Trend" level="H5" wrapping="false" class="Dashboardtitle automatedEllipsis" />
									<ToolbarSpacer />
									<!-- <Button icon="sap-icon://vertical-bar-chart" press="IN_onPressDailyPie" tooltip="Vertical Chart" /> -->
									<Button icon="sap-icon://bar-chart" press="IN_onPressDailyBar" tooltip="Bar Chart" />
									<Button icon="sap-icon://line-chart" press="IN_onPressDailyLine" tooltip="Line Chart" />
								</Toolbar>
							</f:header>
							<f:content>
								<com:ChartContainer showFullScreen="true" showPersonalization="false" autoAdjustHeight="false" class="monthly-trend-chart">
									<com:content>
										<com:ChartContainerContent>
											<com:content>
												<viz:VizFrame id="DailyChartMonthly" vizType="{ComplaintChartModel>/DailyType}" width="100%" vizProperties="{                                                                                                               title: { visible: false },                                                                                                               plotArea: {                                                                                                                   colorPalette: ['#ec3b14','#0b8400','#e2f026'],                                                                                                                   dataLabel: {                                                                                                                       visible: false,                                                                                                                        formatString: '#'                                                                                                                    }                                                                                                                },                                                                                                                interaction: {                                                                                                                    selectability: { mode: 'SINGLE' }                                                                                                               }                                                                                                            }" selectData="onDailyComplainSelect">
													<viz:dataset>
														<vizData:FlattenedDataset data="{chartData>/dailyValue}">
															<vizData:dimensions>
																<vizData:DimensionDefinition name="Day" value="{chartData>date}" />
															</vizData:dimensions>
															<vizData:measures>
																  <vizData:MeasureDefinition name="Pending" value="{chartData>Pending}" />
        <vizData:MeasureDefinition name="Resolved" value="{chartData>Resolved}" />
        <vizData:MeasureDefinition name="In Progress" value="{chartData>In Progress}" />
															</vizData:measures>
														</vizData:FlattenedDataset>
													</viz:dataset>
													<viz:feeds>
														<vizFeeds:FeedItem uid="valueAxis" type="Measure" values="Pending,Resolved,In Progress" />
<vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="Day" />
<vizFeeds:FeedItem uid="color" type="Measure" values="Pending,Resolved,In Progress" />
													</viz:feeds>
												</viz:VizFrame>
											</com:content>
										</com:ChartContainerContent>
									</com:content>
								</com:ChartContainer>
							</f:content>
						</f:Card>
						<!-- 3.Monthly  Chart -->
						<f:Card class="sapUiTinyMargin">
							<f:header>
								<Toolbar class="customdashboard">
									<Title text="Monthly Complain Trend" level="H5"
									
                                  wrapping="false" class="Dashboardtitle automatedEllipsis" />
									<ToolbarSpacer />
									<Button icon="sap-icon://vertical-bar-chart" press="IN_onPressMonthlyPie" tooltip="Vertical Chart" />
									<Button icon="sap-icon://bar-chart" press="IN_onPressMonthlyBar" tooltip="Bar Chart" />
								</Toolbar>
							</f:header>
							<f:content>
								<com:ChartContainer showFullScreen="true" showPersonalization="false" autoAdjustHeight="false">
									<com:content>
										<com:ChartContainerContent>
											<com:content>
												<viz:VizFrame id="CD_Monthlyid" vizType="{ComplaintChartModel>/monthlyType}" width="100%" vizProperties="{                                                            title: { visible: false },                                                            plotArea: {                                                                colorPalette: ['#e2f026','#0b8400','#ec3b14'],                                                               dataLabel: {                                                                    visible: false,                                                                    formatString: '#'                                                               }                                                           },                                                            interaction: {                                                                selectability: { mode: 'SINGLE' }                                                            }                                                        }" selectData="onTotalInvoiceValueSelect">
													<viz:dataset>
														<vizData:FlattenedDataset data="{chartData>/monthlyValue}">
															<vizData:dimensions>
																<vizData:DimensionDefinition name="Month" value="{chartData>Month}" />
															</vizData:dimensions>
															<vizData:measures>
																 <vizData:MeasureDefinition name="In Progress" value="{chartData>In Progress}" />
        <vizData:MeasureDefinition name="Resolved" value="{chartData>Resolved}" />
        <vizData:MeasureDefinition name="Pending" value="{chartData>Pending}" />
															</vizData:measures>
														</vizData:FlattenedDataset>
													</viz:dataset>
													<viz:feeds>
														 <vizFeeds:FeedItem
        uid="valueAxis"
        type="Measure"
        values="In Progress,Resolved,Pending" />

    <vizFeeds:FeedItem
        uid="categoryAxis"
        type="Dimension"
        values="Month" />

    <vizFeeds:FeedItem
        uid="color"
        type="Measure"
        values="In Progress,Resolved,Pending" />
													</viz:feeds>
												</viz:VizFrame>
											</com:content>
										</com:ChartContainerContent>
									</com:content>
								</com:ChartContainer>
							</f:content>
						</f:Card>
						<!-- 4. Yearly Trend Chart -->
						<f:Card class="sapUiTinyMargin">
							<f:header>
								<Toolbar class="customdashboard">
									<Title text="Total Complain Trend" 
									level="H5" wrapping="false" class="Dashboardtitle automatedEllipsis" />
									<ToolbarSpacer />
									<Button icon="sap-icon://bar-chart" press="IN_onPressYearlyBar" tooltip="Bar Chart" />
									<Button icon="sap-icon://line-chart" press="IN_onPressYearlyLine" tooltip="Line Chart" />
								</Toolbar>
							</f:header>
							<f:content>
								<com:ChartContainer showFullScreen="true" showPersonalization="false" autoAdjustHeight="false">
									<com:content>
										<com:ChartContainerContent>
											<com:content>
												<viz:VizFrame id="CD_lineChartYearly" vizType="{ComplaintChartModel>/yearlyType}" width="100%" vizProperties="{                                                                title: { visible: false },                                                                plotArea: {                                                                    colorPalette: ['#e2f026','#0b8400','#ec3b14'],                                                                  dataLabel: {                                                                        visible: false,                                                                        formatString: '#'                                                                    }                                                                },                                                                interaction: {                                                                   selectability: { mode: 'SINGLE' }                                                                }                                                                                                                    }" selectData="onYearlyInvoiceSelect">
													<viz:dataset>
														<vizData:FlattenedDataset data="{chartData>/yearlyValue}">
															<vizData:dimensions>
																<vizData:DimensionDefinition name="Total" value="{chartData>Total}" />
															</vizData:dimensions>
															<vizData:measures>
															 <vizData:MeasureDefinition name="In Progress" value="{chartData>In Progress}" />
        <vizData:MeasureDefinition name="Resolved" value="{chartData>Resolved}" />
        <vizData:MeasureDefinition name="Pending" value="{chartData>Pending}" />
															</vizData:measures>
														</vizData:FlattenedDataset>
													</viz:dataset>
													<viz:feeds>
    <vizFeeds:FeedItem
        uid="valueAxis"
        type="Measure"
        values="In Progress,Resolved,Pending" />

    <vizFeeds:FeedItem
        uid="categoryAxis"
        type="Dimension"
        values="Total" />

    <vizFeeds:FeedItem
        uid="color"
        type="Measure"
        values="In Progress,Resolved,Pending" />
</viz:feeds>
												</viz:VizFrame>
											</com:content>
										</com:ChartContainerContent>
									</com:content>
								</com:ChartContainer>
							</f:content>
						</f:Card>
					</layout:content>
				</layout:Grid>
				<!-- Grid for Full Width Charts -->
				<!-- <layout:Grid defaultSpan="XL12 L12 M12 S12" class="sapUiResponsiveMargin">
					<layout:content>
						
