<mvc:View controllerName="sap.kt.com.minihrsolution.controller.TraineeDetails"
	xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core">
	<Page id="TD_id_PageCreate" title="{i18n>headerTrainee}" navButtonPress="TD_onPressback" showNavButton="true">
		<content>
			<Wizard id="TD_id_Wizard" complete="TD_onWizardComplete"	showNextButton="true" finishButtonText="{i18n>submit}">
				<WizardStep id="TD_id_StepOne" title="{i18n>traineeDetails}" validated="true">
					<f:SimpleForm 
            layout="ResponsiveGridLayout"
			labelSpanXL="3"
			labelSpanL="3"
			labelSpanM="3"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="4"
			emptySpanL="4"
			emptySpanM="4"
			emptySpanS="0"
			columnsXL="1"
			columnsL="1"
			columnsM="1"
			singleContainerFullSize="false">
						<f:content >
							<Label text="{i18n>traineeName}" required="true" />
							<HBox width="100%" justifyContent="Start" alignItems="Center">
								<VBox width="20%">
									<Select
                                               id="TD_id_NameSalutation"
                                               selectedKey="{oTraineeDetails>/NameSalutation}"
                                               items="{Salutation>/salutation}"
                                               width="100%">
										<core:Item key="{Salutation>text}" text="{Salutation>text}"/>
									</Select>
								</VBox>
								<VBox width="78%">
									<Input value="{oTraineeDetails>/TraineeName}" maxLength="50" placeholder="{i18n>placeTraineeName}" id="TD_id_Name" liveChange="TD_validateName" class="sapUiTinyMarginBegin" valueStateText="{i18n>nameEmployeeValueState}"/>
								</VBox>
							</HBox>
							<Label text="{i18n>reportingManager}" required="true" />
							<HBox width="100%" justifyContent="Start" alignItems="Center">
								<VBox width="20%">
									<Select
                                               id="TD_id_ManagerSalutation"
                                               selectedKey="{oTraineeDetails>/ReportingManagerSalutation}"
                                               items="{Salutation>/salutation}"
                                               width="100%"
											   valueStateText="{i18n>nameEmployeeValueState}">
										<core:Item key="{Salutation>text}" text="{Salutation>text}"/>
									</Select>
								</VBox>
								<VBox width="78%">
									<ComboBox showSecondaryValues="true"  change="TD_validateName"  selectionChange="onManagerSelectionChange"  selectedKey="1" value="{oTraineeDetails>/ReportingManager}" items="{idModel>/results}" id="TD_id_ReportingManager" width="100%"  class="sapUiTinyMarginBegin">
										<core:ListItem key="{idModel>ID}" text="{idModel>EmployeeName}" additionalText="{idModel>ID}" />
									</ComboBox>
								</VBox>
							</HBox>
							<Label text="{i18n>emailId}" required="true" />
							<Input value="{oTraineeDetails>/TraineeEmail}" maxLength="50" id="TD_id_EmailID" placeholder="{i18n>placeEmailId}" liveChange="TD_validateEmail" valueStateText="{i18n>emailValueState}"/>
							<Label text="{i18n>stipend}" required="true" />
							<Input value="{oTraineeDetails>/Stipend}" maxLength="15" placeholder="{i18n>placeStipend}" id="TD_id_Stipend" liveChange="TD_validateAmount" valueStateText="{i18n>ammountValuState}"/>
								<Select items="{CurrencyModel>/}"  selectedKey="{oTraineeDetails>/Currency}" id="TD_id_Currency" width="100%" class="marginLeft">
												<core:Item key="{CurrencyModel>currency}" text="{CurrencyModel>currency}" />
											</Select>
							<Label text="{i18n>joiningDate}"   required="true" />
							<DatePicker width="50%" value="{oTraineeDetails>/JoiningDate}" id="TD_id_JoiningDate"  change="TD_validateDate"  displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy" valueStateText="{i18n>dateValueState}"/>
						</f:content>
					</f:SimpleForm>
				</WizardStep>
				<WizardStep 
							complete="TD_onSubmitData"
                            title="{i18n>review}"
                            validated="true">
					<f:SimpleForm                    
             editable="true"
			layout="ResponsiveGridLayout"
			labelSpanXL="4"
			labelSpanL="3"
			labelSpanM="4"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="0"
			emptySpanL="4"
			emptySpanM="0"
			emptySpanS="0"
			columnsXL="2"
			columnsL="1"
			columnsM="1">
						<f:content>
							<Label text="{i18n>traineeName}"/>
							<Text text="{= ${oTraineeDetails>/NameSalutation} + ' ' + ${oTraineeDetails>/TraineeName}}"/>
							<Label text="{i18n>reportingManager}" />
							<Text text="{= ${oTraineeDetails>/ReportingManagerSalutation} + ' ' + ${oTraineeDetails>/ReportingManager}}"/>
							<Label text="{i18n>emailId}" />
							<Text  text="{oTraineeDetails>/TraineeEmail}"/>
							<Label text="{i18n>stipend}" />
							<Text text="{oTraineeDetails>/Stipend} "/>
							<Label text="{i18n>currency}" />
							<Text text="{oTraineeDetails>/Currency}"/>
							<Label text="{i18n>joiningDate}" />
							<Text text="{oTraineeDetails>/JoiningDate}"/>
						</f:content>
					</f:SimpleForm>
				</WizardStep>
			</Wizard>
		</content>
				<footer>
			<Bar>
					    <contentLeft>
                    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
                </contentLeft>
			</Bar>
		</footer>
	</Page>
	<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.TraineeUpdate" type="XML" />

</mvc:View>