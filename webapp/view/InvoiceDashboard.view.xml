<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
    controllerName="sap.kt.com.minihrsolution.controller.InvoiceDashboard"
	xmlns:fb="sap.ui.comp.filterbar"
    displayBlock="true"
	xmlns:f="sap.f"
	xmlns:layout="sap.ui.layout"
	xmlns:viz="sap.viz.ui5.controls"
	xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds"
	xmlns:vizData="sap.viz.ui5.data">
	<Page>
		<headerContent>
			<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
		</headerContent>
		<content>
			<fb:FilterBar showFilterConfiguration="false" class="sapUiTinyMargin" id="T_id_Filterbar" persistencyKey="myPersKey" useToolbar="false" clear="T_onPressClear" showClearOnFB="true" search="T_onSearch" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad" >
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="Company" label="{i18n>companyName}" groupName="Group1" visibleInFilterBar="true" >
						<fb:control>
							<MultiComboBox
                        id="companyFilter"
                        width="300px"
                        items="{path: 'companies>/'}"
                        selectionChange="onFilterChange">
						<items>
							<core:Item key="{companies>key}" text="{companies>key}"/>
						</items>
					</MultiComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="Date" label="{i18n>date}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<DateRangeSelection id="IDA_id_Date"  valueFormat="MM/dd/yyyy"  displayFormat="MM/dd/yyyy" change="onDateChange" />
						</fb:control>
					</fb:FilterGroupItem>
					   <fb:FilterGroupItem name="Year" label="{i18n>year}" groupName="Group1" visibleInFilterBar="true">
                       <fb:control>
                   <DatePicker id="IDA_id_Year" displayFormat="yyyy" valueFormat="yyyy" placeholder="{i18n>year}" />
                       </fb:control>
                   </fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
								<Toolbar>

				
				<Label text="Period:" class="sapUiSmallMarginEnd"/>
					<SegmentedButton id="timePeriodFilter" selectedKey="Yearly" selectionChange="onFilterChange">
						<items>
							<SegmentedButtonItem text="Quarterly" key="Quarterly" />
							<SegmentedButtonItem text="Half-Yearly" key="HalfYearly" />
							<SegmentedButtonItem text="Yearly" key="Yearly" />
						</items>
					</SegmentedButton>
									</Toolbar>

			<layout:Grid defaultSpan="XL6 L6 M12 S12" class="sapUiSmallMarginTop">
				<layout:content>
					<!-- Bar Chart: Invoice Count by Period -->
					<viz:VizFrame
                        id="barChartCount"
                        vizType="column"
                        width="100%"
                        height="400px"
                        vizProperties="{ title: { text: 'Invoice Count by Period' } }">
						<viz:dataset>
							<!-- Using corrected 'vizData' prefix -->
							<vizData:FlattenedDataset data="{chartData>/invoiceCounts}">
								<vizData:dimensions>
									<vizData:DimensionDefinition name="Period" value="{chartData>periodLabel}" />
								</vizData:dimensions>
								<vizData:measures>
									<vizData:MeasureDefinition name="Invoice Count" value="{chartData>count}" />
								</vizData:measures>
							</vizData:FlattenedDataset>
						</viz:dataset>
						<viz:feeds>
							<!-- Using corrected 'vizFeeds' prefix -->
							<vizFeeds:FeedItem uid="valueAxis" type="Measure" values="Invoice Count" />
							<vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="Period" />
						</viz:feeds>
					</viz:VizFrame>
					<!-- Pie Chart: Invoice Total Amount by Company -->
					<viz:VizFrame
                        id="pieChartTotal"
                        vizType="pie"
                        width="100%"
                        height="400px"
                        vizProperties="{ title: { text: 'Invoice Value by Company' } }">
						<viz:dataset>
							<!-- Using corrected 'vizData' prefix -->
							<vizData:FlattenedDataset data="{chartData>/companyTotals}">
								<vizData:dimensions>
									<vizData:DimensionDefinition name="Company" value="{chartData>companyName}" />
								</vizData:dimensions>
								<vizData:measures>
									<vizData:MeasureDefinition name="Total Amount" value="{chartData>totalAmount}" />
								</vizData:measures>
							</vizData:FlattenedDataset>
						</viz:dataset>
						<viz:feeds>
							<!-- Using corrected 'vizFeeds' prefix -->
							<vizFeeds:FeedItem uid="size" type="Measure" values="Total Amount" />
							<vizFeeds:FeedItem uid="color" type="Dimension" values="Company" />
						</viz:feeds>
					</viz:VizFrame>
				</layout:content>
			</layout:Grid>
		</content>
		<footer>
			<Bar>
				<contentLeft>
					<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
				</contentLeft>
			</Bar>
		</footer>
	</Page>
</mvc:View>