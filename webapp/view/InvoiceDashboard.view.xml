<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    controllerName="sap.kt.com.minihrsolution.controller.InvoiceDashboard"
    xmlns:fb="sap.ui.comp.filterbar"
    displayBlock="true"
    xmlns:layout="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds"
    xmlns:vizData="sap.viz.ui5.data"
    xmlns:f="sap.f"
    xmlns:com="sap.suite.ui.commons">
    <Page id="invoiceDashboardPage" >
        <headerContent>
            <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
        </headerContent>
        <content>
            <VBox class="sapUiSmallMargin">
                <!-- Filter Bar -->
                <fb:FilterBar id="dashboardFilterBar"  useToolbar="false" clear="onClearFilters" showClearOnFB="true" search="onFilterChange" >
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem name="Company" label="Company" groupName="Group1" visibleInFilterBar="true">
                            <fb:control>
                                <MultiComboBox id="companyFilter" width="400px" placeholder="{i18n>companyName}" items="{path: 'companies>/'}" >
                                    <items><core:Item key="{companies>key}" text="{companies>text}"/></items>
                                </MultiComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="InvoiceDate" label="{i18n>invoiceDate}" groupName="Group1" visibleInFilterBar="true">
                            <fb:control>
                                <DateRangeSelection id="DashI_id_Date" valueFormat="MM/dd/yyyy" displayFormat="MM/dd/yyyy" change="onDateRangeselection" />
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="Year" label="{i18n>financialyear}" groupName="Group1" visibleInFilterBar="true">
                            <fb:control>
                                <DatePicker id="yearFilter" displayFormat="yyyy" valueFormat="yyyy" placeholder="{i18n>currentYear}" change="onchangeFY"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                </fb:FilterBar>

                <!-- Grid for Charts -->
                <layout:Grid defaultSpan="XL6 L6 M12 S12" class="sapUiResponsiveMargin">
                    <layout:content>
                        <!-- 1. Status Distribution Chart -->
                        <f:Card class="sapUiTinyMargin">
                            <f:header>
                                <Toolbar class="customdashboard">
                                    <Title text="{i18n>invoiceStatusDash}" level="H5" wrapping="true"/>
                                    <ToolbarSpacer/>
                                    <Button icon="sap-icon://pie-chart" press="IN_onPressStatusPie" tooltip="{i18n>pieChartTooltip}"/>
                                    <Button icon="sap-icon://bar-chart" press="IN_onPressStatusBar" tooltip="{i18n>barChartTooltip}"/>
                                    <Button icon="sap-icon://donut-chart" press="IN_onPressStatusDonut" tooltip="{i18n>donutChartTooltip}"/>
                                </Toolbar>
                            </f:header>
                            <f:content>
                                <com:ChartContainer showFullScreen="true" showPersonalization="false" autoAdjustHeight="false">
									<com:content>
										<com:ChartContainerContent>
											<com:content>
                                                <viz:VizFrame id="donutChartStatus" vizType="{invoiceChartTypeModel>/statusType}" width="100%"  vizProperties="{ title: { visible: false }, plotArea: { dataLabel: { visible: false, type: 'value' } }, interaction: { selectability: { mode: 'SINGLE' } } }" selectData="onStatusChartSelect">
                                                    <viz:dataset>
                                                        <vizData:FlattenedDataset data="{chartData>/statusDistribution}">
                                                            <vizData:dimensions> <vizData:DimensionDefinition name="Status" value="{chartData>status}" /> </vizData:dimensions>
                                                            <vizData:measures> <vizData:MeasureDefinition name="Count" value="{chartData>count}" /> </vizData:measures>
                                                        </vizData:FlattenedDataset>
                                                    </viz:dataset>
                                                    <viz:feeds>
                                                        <vizFeeds:FeedItem uid="size" type="Measure" values="Count" />
                                                        <vizFeeds:FeedItem uid="color" type="Dimension" values="Status" />
                                                    </viz:feeds>
                                                </viz:VizFrame>
                                	        </com:content>
										</com:ChartContainerContent>
									</com:content>
								</com:ChartContainer>
                            </f:content>
                        </f:Card>

                        <!-- 2. Monthly Trend Chart -->
                        <f:Card class="sapUiTinyMargin">
                            <f:header>
                                <Toolbar class="customdashboard">
                                    <Title text="{i18n>invoiceMonthly}" level="H5" wrapping="true"/>
                                    <ToolbarSpacer/>
                                    <Button icon="sap-icon://vertical-bar-chart" press="IN_onPressMonthlyPie" tooltip="{i18n>verticalchartTooltip}"/>
                                    <Button icon="sap-icon://bar-chart" press="IN_onPressMonthlyBar" tooltip="{i18n>barChartTooltip}"/>
                                    <Button icon="sap-icon://line-chart" press="IN_onPressMonthlyLine" tooltip="{i18n>lineChartTooltip}"/>
                                </Toolbar>
                            </f:header>
                            <f:content>
                            	<com:ChartContainer showFullScreen="true" showPersonalization="false" autoAdjustHeight="false">
									<com:content>
										<com:ChartContainerContent>
											<com:content>
                                                    <viz:VizFrame id="lineChartMonthly"
                                                        vizType="{invoiceChartTypeModel>/monthlyType}"
                                                        width="100%"
                                                        vizProperties="{
                                                            title: { visible: false },
                                                            plotArea: { dataLabel: { visible: false, formatString: '#' } },
                                                            interaction: { selectability: { mode: 'SINGLE' } }
                                                        }"
                                                        selectData="onMonthlyInvoiceSelect">
                                                    <viz:dataset>
                                                        <vizData:FlattenedDataset data="{chartData>/monthlyValue}">
                                                            <vizData:dimensions> <vizData:DimensionDefinition name="Month" value="{chartData>month}" /> </vizData:dimensions>
                                                            <vizData:measures> <vizData:MeasureDefinition name="Total Value (INR)" value="{chartData>totalAmountInINR}" /> </vizData:measures>
                                                        </vizData:FlattenedDataset>
                                                    </viz:dataset>
                                                    <viz:feeds>
                                                        <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="Total Value (INR)" />
                                                        <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="Month" />
                                                    </viz:feeds>
                                                </viz:VizFrame>
                                	        </com:content>
										</com:ChartContainerContent>
									</com:content>
								</com:ChartContainer>
                            </f:content>
                        </f:Card>
                        
                        <!-- 3. Value by Company Chart -->
                            <f:Card class="sapUiTinyMargin">
        <f:header>
            <Toolbar class="customdashboard">
                <Title text="{i18n>companytotalinvoice}" level="H5" wrapping="true"/>
                <ToolbarSpacer/>
                <Button icon="sap-icon://vertical-bar-chart" press="IN_onPressCompanyPie" tooltip="{i18n>verticalchartTooltip}"/>
                <Button icon="sap-icon://bar-chart" press="IN_onPressCompanyBar" tooltip="{i18n>barChartTooltip}"/>
            </Toolbar>
        </f:header>
        <f:content>
            <com:ChartContainer showFullScreen="true" showPersonalization="false" autoAdjustHeight="false">
                <com:content>
                    <com:ChartContainerContent>
                        <com:content>
                        
                                <viz:VizFrame
                                    id="barChartCompany"
                                    vizType="{invoiceChartTypeModel>/companyType}"
                                    width="100%" vizProperties="{
                                                                title: { visible: false },
                                                                plotArea: { dataLabel: { visible: false, formatString: '#' } },
                                                                interaction: { selectability: { mode: 'SINGLE' } }
                                                            }"
                                                            selectData="onTotalInvoiceValueSelect">
                                    <viz:dataset>
                                        <vizData:FlattenedDataset data="{chartData>/companyTotals}">
                                            <vizData:dimensions>
                                                <vizData:DimensionDefinition name="Company" value="{chartData>companyName}" />
                                            </vizData:dimensions>
                                            <vizData:measures>
                                                <vizData:MeasureDefinition name="Total Value (INR)" value="{chartData>totalAmountInINR}" />
                                            </vizData:measures>
                                        </vizData:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="Total Value (INR)" />
                                        <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="Company" />
                                    </viz:feeds>
                                </viz:VizFrame>
                        </com:content>
                    </com:ChartContainerContent>
                </com:content>
            </com:ChartContainer>
        </f:content>
    </f:Card>

                        <!-- 4. Yearly Trend Chart (No Scroll Container Needed) -->
                        <f:Card class="sapUiTinyMargin">
                            <f:header>
                                <Toolbar class="customdashboard">
                                    <Title text="{i18n>yearlyInvoiceTrend}" level="H5" wrapping="true"/>
                                    <ToolbarSpacer/>
                                    <Button icon="sap-icon://bar-chart" press="IN_onPressYearlyBar" tooltip="{i18n>barChartTooltip}"/>
                                    <Button icon="sap-icon://line-chart" press="IN_onPressYearlyLine" tooltip="{i18n>lineChartTooltip}"/>
                                </Toolbar>
                            </f:header>
                            <f:content>
                                <com:ChartContainer showFullScreen="true" showPersonalization="false" autoAdjustHeight="false">
									<com:content>
										<com:ChartContainerContent>
											<com:content>
                                                <viz:VizFrame id="lineChartYearly" vizType="{invoiceChartTypeModel>/yearlyType}" width="100%"  vizProperties="{
                                                            title: { visible: false },
                                                            plotArea: { dataLabel: { visible: false, formatString: '#' } },
                                                            interaction: { selectability: { mode: 'SINGLE' } }
                                                        }"
                                                        selectData="onYearlyInvoiceSelect">
                                                    <viz:dataset>
                                                        <vizData:FlattenedDataset data="{chartData>/yearlyTrend}">
                                                            <vizData:dimensions> <vizData:DimensionDefinition name="Year" value="{chartData>year}" /> </vizData:dimensions>
                                                            <vizData:measures>
                                                                <vizData:MeasureDefinition name="Total Value (INR)" value="{chartData>totalAmountInINR}" />
                                                                <vizData:MeasureDefinition name="Invoice Count" value="{chartData>count}" />
                                                            </vizData:measures>
                                                        </vizData:FlattenedDataset>
                                                    </viz:dataset>
                                                    <viz:feeds>
                                                        <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="Total Value (INR)" />
                                                        <vizFeeds:FeedItem uid="valueAxis2" type="Measure" values="Invoice Count" />
                                                        <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="Year" />
                                                    </viz:feeds>
                                                </viz:VizFrame>
                                            </com:content>
										</com:ChartContainerContent>
									</com:content>
								</com:ChartContainer>
                            </f:content>
                        </f:Card>
                        <VBox fitContainer="true" class="parentContainer" >
                        <!-- 5. Payment Breakdown (Stacked Bar Chart) (WITH SCROLL CONTAINER) -->
                        <f:Card class="sapUiTinyMargin">
                            <f:header>
                                <Toolbar class="customdashboard">
                                    <Title text="{i18n>paymentBreakdown}" level="H5" wrapping="true"/>
                                    <ToolbarSpacer/>
                                    <Button icon="sap-icon://vertical-stacked-chart" press="onPressPaymentStackedColumn" tooltip="{i18n>stackedHorizontalTooltip}"/>
                                    <Button icon="sap-icon://horizontal-stacked-chart" press="onPressPaymentStackedBar" tooltip="{i18n>groupedHorizontalTooltip}"/>
                                    <Button icon="sap-icon://bar-chart" press="onPressPaymentGroupedBar" tooltip="{i18n>barChartTooltip}"/>
                                </Toolbar>
                            </f:header>
                            <f:content>
                                <com:ChartContainer showFullScreen="true" showPersonalization="false" autoAdjustHeight="false">
									<com:content>
										<com:ChartContainerContent>
											<com:content>
                                               
                                                    <viz:VizFrame id="stackedChartPayment"
                                                        vizType="{invoiceChartTypeModel>/paymentBreakdownType}"
                                                        width="100%"
                                                        vizProperties="{
                                                            title: { visible: false },
                                                            plotArea: { dataLabel: { visible: false, formatString: '#' } },
                                                            interaction: { selectability: { mode: 'SINGLE' } }
                                                        }"
                                                        selectData="onPaymentBreakdownSelect">
                                                        <viz:dataset>
                                                            <vizData:FlattenedDataset data="{chartData>/paymentBreakdown}">
                                                                <vizData:dimensions> <vizData:DimensionDefinition name="Company" value="{chartData>companyName}" /> </vizData:dimensions>
                                                              <vizData:measures>
    <vizData:MeasureDefinition name="Taxable Amount" value="{chartData>taxableAmount}" />
    <vizData:MeasureDefinition name="GST Amount" value="{chartData>gstAmount}" />
    <!-- <vizData:MeasureDefinition name="TDS Amount" value="{chartData>tdsAmount}" /> -->
    <!-- <vizData:MeasureDefinition name="Total Amount" value="{chartData>totalAmountInINR}" />  -->
</vizData:measures>

                                                            </vizData:FlattenedDataset>
                                                        </viz:dataset>
                                                        <viz:feeds>
    <vizFeeds:FeedItem uid="valueAxis" type="Measure" 
        values="Taxable Amount,GST Amount" />
    <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="Company" />
</viz:feeds>

                                                    </viz:VizFrame>
                                              
                                            </com:content>
										</com:ChartContainerContent>
									</com:content>
								</com:ChartContainer>
                            </f:content>
                        </f:Card>

                        <!-- 6. Pending Payments by Company (WITH SCROLL CONTAINER) -->
                        <f:Card class="sapUiTinyMargin">
                            <f:header>
                                <Toolbar class="customdashboard">
                                    <Title text="{i18n>pendingPaymentsByCompany}" level="H5" wrapping="true"/>
                                    <ToolbarSpacer/>
                                    <Button icon="sap-icon://vertical-bar-chart" press="onPressPendingColumn" tooltip="{i18n>columnChartTooltip}"/>
                                    <Button icon="sap-icon://horizontal-bar-chart" press="onPressPendingBar" tooltip="{i18n>barChartTooltip}"/>
                                </Toolbar>
                            </f:header>
                            <f:content>
                                <com:ChartContainer showFullScreen="true" showPersonalization="false" autoAdjustHeight="false">
									<com:content>
										<com:ChartContainerContent>
											<com:content>
                                                    <viz:VizFrame id="barChartPending"
                                                        vizType="{invoiceChartTypeModel>/pendingByCompanyType}"
                                                        width="100%"
                                                        vizProperties="{
                                                            title: { visible: false },
                                                            plotArea: { dataLabel: { visible: false, formatString: '#' } },
                                                            interaction: { selectability: { mode: 'SINGLE' } }
                                                        }"
                                                        selectData="onPendingCompanySelect">
                                                        <viz:dataset>
                                                            <vizData:FlattenedDataset data="{chartData>/pendingByCompany}">
                                                                <vizData:dimensions> <vizData:DimensionDefinition name="Company" value="{chartData>companyName}" /> </vizData:dimensions>
                                                                <vizData:measures> <vizData:MeasureDefinition name="Pending Amount (INR)" value="{chartData>pendingAmountInINR}" /> </vizData:measures>
                                                            </vizData:FlattenedDataset>
                                                        </viz:dataset>
                                                        <viz:feeds>
                                                            <vizFeeds:FeedItem uid="valueAxis" type="Measure" values="Pending Amount (INR)" />
                                                            <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="Company" />
                                                        </viz:feeds>
                                                    </viz:VizFrame>
                                              
                                            </com:content>
										</com:ChartContainerContent>
									</com:content>
								</com:ChartContainer>
                            </f:content>
                        </f:Card>
                        </VBox>
                    </layout:content>
                </layout:Grid>
            </VBox>
        </content>
        <footer>
            <Bar>
                <contentLeft><core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" /></contentLeft>
            </Bar>
        </footer>
    </Page>
</mvc:View>