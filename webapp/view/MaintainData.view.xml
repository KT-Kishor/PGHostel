<mvc:View
    controllerName="sap.kt.com.minihrsolution.controller.MaintainData"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Page id="page">
        <headerContent>
            <!-- <Title text="Main"/> -->
            <core:Fragment
                fragmentName="sap.kt.com.minihrsolution.fragment.Header"
                type="XML"
            />
        </headerContent>
        <SplitContainer
            id="SplitContDemo"
            initialDetail="detail"
            initialMaster="master"
        >
            <detailPages>
                <Page
                    id="detail"
                    title="{i18n>masterTableDetails}"
                    backgroundDesign="Solid"
                    showNavButton="{= !${device>/system/desktop} }"
                    navButtonPress=".onPressDetailBack"
                >
                    <headerContent>
                        <ToolbarSpacer />
                        <Button
                            text="{i18n>add}"
                            press="MD_AddButtonPress"
                        />
                        <Button
                            text="{i18n>uploadExcel}"
                            press="MD_UploadButtonPress"
                        />
                        <Button
                            text="{i18n>DownloadTemplate}"
                            press="MD_DownloadButtonPress"
                        />
                    </headerContent>
                    <ScrollContainer
                        id="scrollContainer"
                        horizontal="true"
                        vertical="true"
                        width="100%"
                        height="100%"
                    >
                    <VBox width="100%" height="100%" id="detailContainer" />
                     </ScrollContainer>
                </Page>
            </detailPages>
            <masterPages>
                <Page title="{i18n>TableNames}">
                    
                        <List
                            items="{ path: 'listNameData>/ListData'}"
                            itemPress=".onEntitySelect"
                            mode="SingleSelectMaster"
                        >
                            <StandardListItem
                                title="{listNameData>title}"
                                description="{ProductId}"
                                icon="{ProductPicUrl}"
                                iconDensityAware="false"
                                iconInset="false"
                                type="Active"
                            />
                        </List>
                   
                </Page>
            </masterPages>
        </SplitContainer>
        <footer>
            <Bar>
                <contentLeft>
                    <core:Fragment
                        fragmentName="sap.kt.com.minihrsolution.fragment.Footer"
                        type="XML"
                    />
                </contentLeft>
            </Bar>
        </footer>
    </Page>
</mvc:View>
