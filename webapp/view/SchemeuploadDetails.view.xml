<mvc:View
    controllerName="sap.kt.com.minihrsolution.controller.SchemeuploadDetails"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:u="sap.ui.unified"
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.m"
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
>
    <m:Page id="idQuotationschemeDetails">
        <headerContent>
            <Button
                id="idBack"
                text=""
                press="onhandleBackPress"
                type="Transparent"
                visible="true"
                icon="sap-icon://nav-back"
            />
            <Title
                text="{i18n>schtitle}"
                class="boldBlackText"
            />
            <ToolbarSpacer />
        </headerContent>

        <VBox class="sapUiSmallMargin">
            <f:SimpleForm
                id="idSimpleForm"
                editable="{detailModel>/isEditable}"
                layout="ColumnLayout"
                title=""
                columnsM="2"
                columnsL="3"
                columnsXL="4"
            >
                <f:toolbar>
                    <Toolbar id="TB1">
                        <Title
                            id="Title1"
                            text="{i18n>schTtext}"
                        />
                        <ToolbarSpacer />
                       
                    </Toolbar>
                </f:toolbar>
                <f:content>
                    <Label text="{i18n>company}" />
                    <ComboBox
                        required="true"
                        selectionChange="onFieldLiveChange"
                        id="idCompanyName"
                        name="Company"
                        value="{detailModel>/Company}"
                        items=""
                        editable="{= ${detailModel>/isNew} ? true : false }"
                      
                    >
                        <core:ListItem
                            key=""
                            text=""
                           
                        />
                    </ComboBox>
                    <Label
                        text="{i18n>vehicleModel}"
                        required="{= ${detailModel>/isNew} }"
                    />
                    <Input
                        id="idModel"
                        value="{detailModel>/Model}"
                        editable="{= ${detailModel>/isNew} ? true : false }"
                        liveChange="onFieldLiveChange"
                        maxLength="99"
                    />
                    <Label
                        text="{i18n>vehicleVariant}"
                        required="{= ${detailModel>/isNew} }"
                    />
                    <Input
                        id="idVariant"
                        value="{detailModel>/Variant}"
                        editable="{= ${detailModel>/isNew} ? true : false }"
                        liveChange="onFieldLiveChange"
                        maxLength="99"
                    />
                    <Label
                        text="{i18n>vehicleTransmission}"
                      required="{= ${detailModel>/isNew} }"
                    />
                    <Input
                        id="idTransmission"
                        value="{detailModel>/Transmission}"
                        editable="{= ${detailModel>/isNew} ? true : false }"
                        liveChange="onFieldLiveChange"
                        maxLength="49"
                    />
                    <Label
                        text="{i18n>vehicleColor}"
                      required="{= ${detailModel>/isNew} }"
                    />
                    <Input
                        id="idColor"
                        value="{detailModel>/Color}"
                        editable="{= ${detailModel>/isNew} ? true : false }"
                        liveChange="onFieldLiveChange"
                        maxLength="19"
                    />
                    <Label
                        text="{i18n>vehicleFuel}"
                      required="{= ${detailModel>/isNew} }"
                    />
                    <Input
                        id="idFuel"
                        value="{detailModel>/Fuel}"
                        editable="{= ${detailModel>/isNew} ? true : false }"
                        liveChange="onFieldLiveChange"
                        maxLength="19"
                    />
                    <Label
                        text="{i18n>vehicleBoardPlate}"
                       
                    />
                    <Input  
                        value="{detailModel>/BoardPlate}"
                        editable="{detailModel>/isEditable}"
                        maxLength="29"
                    />  
                    <Label text="{i18n>vehicleMake}" />
                    <Input
                        value="{detailModel>/Make}"
                        editable="{detailModel>/isEditable}"
                        maxLength="49"
                    />
                    <Label text="{i18n>schEmission}" />
                    <Input
                        value="{detailModel>/Emission}"
                        editable="{detailModel>/isEditable}"
                        maxLength="9"
                    />
                    <Label
                        text="{i18n>schexshowroom}"
                        showColon="true"
                    />
                    <Input
                        value="{ path: 'detailModel>/ExShowroom', formatter: '.Formatter.IndiaNumberFormatter' }"
                                            editable="{detailModel>/isEditable}"
                                            change=".onFieldChange"
                                            maxLength="14"
                    />
                    <Label text="{i18n>schconsumer}" />
                    <Input
                        value="{ path: 'detailModel>/ConsumerScheme', formatter: '.Formatter.IndiaNumberFormatter' }"
                        editable="{detailModel>/isEditable}"
                        maxLength="14"
                        change="onFieldChange"
                    />
                    <Label text="{i18n>schexshowroomafter}" />
                    <Input
                        value="{ path: 'detailModel>/ExShowroomAfterScheme', formatter: '.Formatter.IndiaNumberFormatter' }"
                        editable="{detailModel>/isEditable}"
                        maxLength="14"
                        change="onFieldChange"
                    />
                    <Label text="{i18n>vehicleTCS}" />
                    <Input
                        value="{ path: 'detailModel>/TCS1Perc', formatter: '.Formatter.IndiaNumberFormatter' }"
                        change="onFieldChange"
                        editable="{detailModel>/isEditable}"
                        maxLength="14"
                    />
                    <Label text="{i18n>vehicleRoadTax}" />
                    <Input
                        change="onFieldChange"
                        value="{ path: 'detailModel>/ROADTAX', formatter: '.Formatter.IndiaNumberFormatter' }"
                        editable="{detailModel>/isEditable}"
                        maxLength="14"
                    />
                    <Label text="{i18n>schAddoninsurance}" />
                    <Input
                        change="onFieldChange"
                        value="{ path: 'detailModel>/AddOnInsurance', formatter: '.Formatter.IndiaNumberFormatter' }"
                        editable="{detailModel>/isEditable}"
                        maxLength="14"
                    />
                    <Label text="{i18n>regHyp}" />
                    <Input
                        change="onFieldChange"
                        value="{ path: 'detailModel>/RegHypCharge', formatter: '.Formatter.IndiaNumberFormatter' }"
                        editable="{detailModel>/isEditable}"
                        maxLength="14"
                    />
                    <Label text="{i18n>sot}" />
                    <Input
                        change="onFieldChange"
                        value="{ path: 'detailModel>/ShieldOfTrust4YR45K', formatter: '.Formatter.IndiaNumberFormatter' }"
                        editable="{detailModel>/isEditable}"
                        maxLength="14"
                    />
                    <Label text="{i18n>extWarranty}" />
                    <Input
                        change="onFieldChange"
                        value="{ path: 'detailModel>/EXTDWarrantyFOR4YR80K', formatter: '.Formatter.IndiaNumberFormatter' }"
                        editable="{detailModel>/isEditable}"
                        maxLength="14"
                    />
                    <Label text="{i18n>vehicleRSA}" />
                    <Input
                        change="onFieldChange"
                        value="{ path: 'detailModel>/RSA', formatter: '.Formatter.IndiaNumberFormatter' }"
                        editable="{detailModel>/isEditable}"
                        maxLength="14"
                    />
                    <Label text="{i18n>schStdsetting}" />
                    <Input
                        change="onFieldChange"
                        value="{ path: 'detailModel>/STDFittings', formatter: '.Formatter.IndiaNumberFormatter' }"
                        editable="{detailModel>/isEditable}"
                        maxLength="14"
                    />
                    <Label text="{i18n>vehicleFastTag}" />
                    <Input
                        change="onFieldChange"
                        value="{ path: 'detailModel>/FastTag', formatter: '.Formatter.IndiaNumberFormatter' }"
                        editable="{detailModel>/isEditable}"
                        maxLength="14"
                    />
                    <Label text="{i18n>vehicleVAS}" />
                    <Input
                        change="onFieldChange"
                        value="{ path: 'detailModel>/VAS', formatter: '.Formatter.IndiaNumberFormatter' }"
                        editable="{detailModel>/isEditable}"
                        maxLength="14"
                    />
                    <Label text="{i18n>discountOffers}" />
                    <Input
                        change="onFieldChange"
                        value="{ path: 'detailModel>/DiscountOffers', formatter: '.Formatter.IndiaNumberFormatter' }"
                        editable="{detailModel>/isEditable}"
                        maxLength="14"
                    />
                  
                </f:content>
            </f:SimpleForm>
        </VBox>
        <footer>
            <Bar>
                <contentLeft>
          <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />

                </contentLeft>
                <contentRight>
                 <Button
                            id="idEdit"
                            text="{= ${detailModel>/isNew} ? ${i18n>quoSchemeSave} : (${detailModel>/isEditable} ? ${i18n>quoSchemeSave} : ${i18n>btnEdit}) }"
                            icon="{= ${detailModel>/isNew} ? '' : (${detailModel>/isEditable} ? '' : 'sap-icon://edit') }"
                            press="handleEditPress"
    type="{= ${detailModel>/isNew} ? 'Accept' : (${detailModel>/isEditable} ? 'Accept' : 'Neutral') }"
                            visible="true"
                          
                        />
                </contentRight>
            </Bar>
        </footer>
    </m:Page>
</mvc:View>
