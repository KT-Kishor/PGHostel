<mvc:View
    controllerName="sap.ui.com.project1.controller.CustomerReview"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:f="sap.f"
    xmlns:et="sap.m"
    xmlns:card="sap.ui.integration.widgets"
>
    <Page showHeader="true">
        <headerContent>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.Header"
                type="XML"
            />
        </headerContent>
        <content>
            <VBox class="sapUiSmallMargin">
                <Title
                    text="Customer's Review"
                    level="H3"
                    class="sapUiTinyMarginBottom"
                />
                <fb:FilterBar
                    id="CR_id_Filterbar"
                    useToolbar="false"
                    clear="CR_onPressClear"
                    showClearOnFB="true"
                    search="_loadCustomerReviews"
                    showFilterConfiguration="false"
                >
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem
                            name="FeedbackDate"
                            label="Feedback Date"
                            groupName="Group"
                            visibleInFilterBar="true"
                        >
                            <fb:control>
                                <DateRangeSelection
                                    id="CR_id_BranchCode"
                                    valueFormat="yyyy-MM-dd"
                                    displayFormat="dd/MM/yyyy"
                                    change="onDateRangeChange"
                                />
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem
                            name="Rating"
                            label="Rating"
                            groupName="Group"
                            visibleInFilterBar="true"
                        >
                            <fb:control>
                                <ComboBox id="CR_id_Rating">
                                    <core:Item
                                        key="1"
                                        text="1 Star"
                                    />
                                    <core:Item
                                        key="2"
                                        text="2 Stars"
                                    />
                                    <core:Item
                                        key="3"
                                        text="3 Stars"
                                    />
                                    <core:Item
                                        key="4"
                                        text="4 Stars"
                                    />
                                    <core:Item
                                        key="5"
                                        text="5 Stars"
                                    />
                                </ComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem
                            name="sort"
                            label="Sort By"
                            groupName="Group"
                            visibleInFilterBar="true"
                        >
                            <fb:control>
                                <ComboBox id="CR_id_Sort">
                                    <core:Item
                                        key="1"
                                        text="Highest to Lowest Rating"
                                    />
                                    <core:Item
                                        key="2"
                                        text="Lowest to Highest Rating"
                                    />
                                    <core:Item
                                        key="3"
                                        text="Latest Date"
                                    />
                                    <core:Item
                                        key="4"
                                        text="Oldest Date"
                                    />
                                </ComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                </fb:FilterBar>
                <m:ScrollContainer
                    horizontal="false"
                    vertical="true"
                    class="sapUiResponsiveContentPadding"
                >
                    <m:VBox
                        id="CR_id_ReviewContainer"
                        class="reviewGrid"
                    />
                </m:ScrollContainer>
            </VBox>
        </content>
    </Page>
</mvc:View>