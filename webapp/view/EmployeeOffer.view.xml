
<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
    controllerName="sap.kt.com.minihrsolution.controller.EmployeeOffer"
	xmlns:fb="sap.ui.comp.filterbar"	
    displayBlock="true">
	<Page id="EO_id_Page" >
		<headerContent>
			<Button  press="EO_onPressback" icon="sap-icon://home" />
			<Text text="{i18n>headerEmpDetails}" class="boldBlackText"></Text>
			<ToolbarSpacer />
			<Button  press="EO_onSignout" icon="sap-icon://log"></Button>
		</headerContent>
		<content>
			<fb:FilterBar  class="sapUiTinyMargin" id="EO_id_FilterBar" persistencyKey="myPersKey" useToolbar="false" clear="onPressClear" showClearOnFB="true" search=".onSearch" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad" >
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="ConsultantName" label="{i18n>employeeName}" groupName="Group1" visibleInFilterBar="true">
					<fb:control>
						<ComboBox items="{EmployeeOfferModel>/}" selectionChange=".onBranchChange" showClearIcon="true" >
							<core:Item key="{EmployeeOfferModel>ConsultantName}" text="{EmployeeOfferModel>ConsultantName}" />
						</ComboBox>
					</fb:control>
				</fb:FilterGroupItem>
				<fb:FilterGroupItem name="BaseLocation" label="{i18n>baseLocation}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox items="{BaseLocationModel>/}" showClearIcon="true" id="EO_id_DesiFilter">
								<core:Item key="{BaseLocationModel>id}" text="{BaseLocationModel>city}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="JoiningDate" label="{i18n>joiningDate}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
                    <DateRangeSelection id="EO_id_JoiningDate" valueFormat="yyyy-MM-dd"  displayFormat="dd/MM/yyyy" change="onDateChange" />						
					</fb:control>
						</fb:FilterGroupItem>
					<fb:FilterGroupItem name="Status" label="{i18n>status}" groupName="Group1" visibleInFilterBar="true">
					<fb:control>
						<ComboBox name="Status" showClearIcon="true" selectionChange=".onSelectionChange" items="{EmployeeOffer>/Status}">
							<core:Item key="{EmployeeOffer>ID}" text="{EmployeeOffer>Status}"/>
						</ComboBox>
					</fb:control>
				</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table mode="SingleSelectLeft" selectionChange="EO_onSelectionRadRowE" class="sapUiTinyMargin" items="{path: 'EmployeeOfferModel>/',sorter: {path: '',descending: false,group: false}}" growingScrollToLoad="true" width="auto" id="EO_id_" growing="true"  growingThreshold="50"  alternateRowColors="true">
			 <headerToolbar>
                <OverflowToolbar >
                    <Title text="{i18n>headerEmpDetails}"/>
                    <ToolbarSpacer/>
                    <Button tooltip="{i18n>onboardEmp}" id="EO_id_OnboardBtn" text="Onboard" type="Neutral" press="EO_onOnboardPress"  icon="sap-icon://manager"/>
                    <Button tooltip="{i18n>rejectEmp}" id="EO_id_RejectBtn" type="Reject" text="Reject" press="EO_onRejectPress" icon="sap-icon://employee-rejections" />
                    <Button text="{i18n>generateOffer}" press="EO_onPressAddEmployee" type="Accept"  icon="sap-icon://employee-approvals"/>
                </OverflowToolbar>
            </headerToolbar>
				<columns>
					<Column demandPopin="true">
						<Text text="{i18n>employeeName}"/>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>designation}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>baseLocation}" />
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>ctc}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>joiningDate}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>status}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="EO_onPressRowE">
						<cells>
							<Text text="{EmployeeOfferModel>Salutation} {EmployeeOfferModel>ConsultantName}"/>
							<Text text="{EmployeeOfferModel>Designation}"/>
							<Text text="{EmployeeOfferModel>BaseLocation}"/>
							<Text text="{EmployeeOfferModel>JoiningDate}"/>
							<Text text="{EmployeeOfferModel>CTC}"/>
							<Text text="{EmployeeOfferModel>Status}"/>
							<!-- <Text text="INR {path:'EmployeeOfferModel>CTC',formatter: '.Formatter.IndiaNumberFormatter'}"/> -->
							<!-- <ObjectStatus text="{EmployeeOfferModel>Status}" inverted="true" class="centerText" /> -->
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar>
				<contentLeft>
				  <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
				</contentLeft>
			</Bar>
		</footer>
	</Page>
</mvc:View>
