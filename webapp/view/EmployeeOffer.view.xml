
<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
    controllerName="sap.kt.com.minihrsolution.controller.EmployeeOffer"
	xmlns:fb="sap.ui.comp.filterbar"	
    displayBlock="true">
	<Page id="Ov_id_Page" >
		<headerContent>
			<Button  press="Ov_onPressback" icon="sap-icon://home" />
			<Text text="{i18n>headerEmpDetails}" class="boldBlackText"></Text>
			<ToolbarSpacer />
			<Button  press="Ov_onSignout" icon="sap-icon://log"></Button>
		</headerContent>
		<content>
			<fb:FilterBar  class="sapUiTinyMargin" id="Ov_id_FilterBar" persistencyKey="myPersKey" useToolbar="false" clear="onPressClear" showClearOnFB="true" search=".onSearch" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad" >
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="Employee Name" label="Employee Name" groupName="Group1" visibleInFilterBar="true">
					<fb:control>
						<ComboBox name="Employee Name" selectionChange=".onBranchChange" showClearIcon="true" items="" >
							<core:Item key="{BaseLocation>ID}" text="{BaseLocation>City}"/>
						</ComboBox>
					</fb:control>
				</fb:FilterGroupItem>
				<fb:FilterGroupItem name="Base Location" label="Base Location" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox name="Base Location"  items="" showClearIcon="true" id="Ov_id_DesiFilter">
								<core:Item key="{DropDownModel>ConsultantName}" text="{DropDownModel>ConsultantName}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="Joining Date" label="Joining Date" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
                    <DateRangeSelection id="Ov_id_JoiningDate" valueFormat="yyyy-MM-dd"  displayFormat="dd/MM/yyyy" change="onDateChange" />						
					</fb:control>
						</fb:FilterGroupItem>
					<fb:FilterGroupItem name="Status" label="{i18n>status}" groupName="Group1" visibleInFilterBar="true">
					<fb:control>
						<ComboBox name="Status" showClearIcon="true" selectionChange=".onSelectionChange" items="{EmployeeOffer>/Status}">
							<core:Item key="{EmployeeOffer>ID}" text="{EmployeeOffer>Status}"/>
						</ComboBox>
					</fb:control>
				</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table class="sapUiTinyMargin" growingScrollToLoad="true" width="auto" id="Ov_idSalary" items="" growing="true"  growingThreshold="50"  alternateRowColors="true">
			 <headerToolbar>
                <OverflowToolbar >
                    <Title id="" text="{i18n>headerEmpDetails}"/>
                    <!-- <ToolbarSeparator/> -->
                    <ToolbarSpacer/>
                    <Button tooltip="{i18n>onboardEmp}" id="Ov_id_OnboardBtn" text="Onboard" type="Neutral" press="O_onOnboardPress"  icon="sap-icon://manager"/>
                    <Button tooltip="{i18n>rejectEmp}" id="Ov_id_RejectBtn" type="Reject" text="Reject" press="O_onRejectPress" icon="sap-icon://employee-rejections" />
                    <Button text="{i18n>generateOffer}" press="Ov_onPressAddEmployee" type="Accept"  icon="sap-icon://employee-approvals"/>
                </OverflowToolbar>
            </headerToolbar>
				<columns>
					<Column demandPopin="true">
						<Text text="{i18n>employeeName}"/>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>designation}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>baseLocation}" />
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>ctc}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>joiningDate}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>status}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem>
						<cells>
							<Text text="{EmployeeOfferModel>Salutation} {EmployeeOfferModel>ConsultantName}"/>
							<Text text="{EmployeeOfferModel>Designation}"/>
							<Text text="{EmployeeOfferModel>JoiningDate}"/>
							<Text text="INR {path:'EmployeeOfferModel>CTC',formatter: '.Formatter.IndiaNumberFormatter'}"/>
							<!-- <Text text=""/> -->
							<ObjectStatus text="{EmployeeOfferModel>Status}" inverted="true" class="centerText" state="{path: 'EmployeeOfferModel>Status', formatter: '.Formatter.statusStateFormatter'}" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar>
				<contentLeft>
					   <HBox class="sapUiTinyMarginTop">
    <Image src="../image/logo.jpg" width="30px" height="30px" class="companylogo" />
    <Link
        class="footer-CoName sapUiTinyMarginBegin"
        text="Developed by Kalpavriksha Technologies"
        href="https://www.kalpavrikshatechnologies.com/" 
        target="_blank"  
    />
</HBox>
				</contentLeft>
			</Bar>
		</footer>
	</Page>
</mvc:View>
