<mvc:View
    controllerName="sap.ui.com.project1.controller.HostelFeatures"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:m="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%"
    busyIndicatorDelay="0"
>
    <Page showHeader="true">
        <headerContent>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.Header"
                type="XML"
            />
        </headerContent>
        <content>
            <fb:FilterBar
                id="HF_id_FilterbarEmployee"
                persistencyKey="myPersKey"
                useToolbar="false"
                clear="FC_onPressClear"
                showClearOnFB="true"
                search="Onsearch"
                filterChange="IA_.onFilterChange"
                afterVariantLoad="IA_.onAfterVariantLoad"
                showFilterConfiguration="false"
                filterContainerWidth="auto"
            >
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="FacilityName"
                        label="Facility Name"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="HF_id_FacilityName"
                                items="{HostelFeatures>/}"
                                showClearIcon="true"
                            >
                                <core:Item
                                    key="{HostelFeatures>FacilityName}"
                                    text="{HostelFeatures>FacilityName}"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>
            <Table
                id="HF_HostelFeatureTable"
                sticky="ColumnHeaders,HeaderToolbar"
                mode="MultiSelect"
                width="auto"
                busyIndicatorDelay="0"
                class="sapUiResponsiveMargin"
                items="{path:'HostelFeatures>/', sorter: {path: 'BranchCode',descending: false,group: true}}"
            >
                <headerToolbar>
                    <OverflowToolbar>
                        <Title
                            text="Hostel Features ({=${HostelFeatures>/}.length})"
                        />
                        <ToolbarSpacer />
                        <Button
                            text="Add Hostel Features"
							tooltip="Add Hostel Features"
                            press="HM_AddHostelFeature"
                            class="myUnifiedBtn"
                        />
                        <Button
                            text="Edit"
							tooltip="Edit Hostel Feature"
                            press="HM_EditHostelFeature"
                            class="myUnifiedBtn"
                        />
                        <Button
                            text="Delete"
							tooltip="Delete Hostel Feature"
                            press="HM_DeleteHostelFeature"
                            class="myUnifiedBtn"
                        />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column demandPopin="true">
                        <Text text="Facility Name" tooltip="Facility Name"/>
                    </Column>
                    <Column demandPopin="true">
                        <Text text="Description" tooltip="Description"/>
                    </Column>
                    <Column demandPopin="true">
                        <Text text="Image" tooltip="Image"/>
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{HostelFeatures>FacilityName}" />
                            <ExpandableText
                                text="{HostelFeatures>Description}"
                                maxCharacters="20"
                            />
                            <Button
                                text="View"
                                press="HF_viewroom"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>