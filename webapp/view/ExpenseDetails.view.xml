<mvc:View
	controllerName="sap.kt.com.minihrsolution.controller.ExpenseDetails"
	xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
	xmlns:f="sap.ui.layout.form"
	xmlns="sap.uxap"
	xmlns:core="sap.ui.core"
	xmlns:m="sap.m"
	height="100%"
	busyIndicatorDelay="0"
>

<m:Page id="id_Expense_Details" title="{i18n>expDetails}" navButtonPress="onPressBackBtn" showNavButton="true">
	<ObjectPageLayout 
            enableLazyLoading="true"
            beforeNavigate="onBeforeNavigate"
            useIconTabBar="true"
            showTitleInHeaderContent="true"
            upperCaseAnchorBar="false"
            headerContentPinnable="false"
            sectionChange="onSectionChange"
			id="objectPageLayoutExpence"
            class="sapUiSmallmarginResponsive">
			<headerTitle>
				<ObjectPageDynamicHeaderTitle>
					<expandedHeading>
						<m:Title text="{FilteredExpenseModel>/EmployeeName}" wrapping="true" width="100%" />
					</expandedHeading>
					<expandedContent>
						<m:Label text="{FilteredExpenseModel>/EmployeeID}" wrapping="true" width="100%" />
					</expandedContent>
				</ObjectPageDynamicHeaderTitle>
			</headerTitle>
			<sections>
				<ObjectPageSection titleUppercase="false" id="idObjectPageSection" >
					<subSections>
						<ObjectPageSubSection titleUppercase="false" title="{i18n>expBasicInformation}">
							<blocks>
								<f:SimpleForm 
                                            editable="true" layout="ColumnLayout"
              labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
              adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"
              emptySpanM="0" emptySpanS="0" columnsXL="2" columnsL="2" columnsM="1">
											<f:toolbar>
											<m:Toolbar>												
												<m:ToolbarSpacer />
												<m:Button  text="Edit" 
                    press="onEditOrSavePress" />
											</m:Toolbar>
										</f:toolbar>
									<!-- <f:content> -->
										<!-- Employee ID -->
										<m:Label text="{i18n>employeeID}" required="true" />
										<m:Input  value="{FilteredExpenseModel>/EmployeeID}" editable="false" maxLength="20" />
										<!-- Employee Name -->
										<m:Label text="{i18n>expExpenseName}" required="true" />
										<m:Input  value="{FilteredExpenseModel>/EmployeeName}" editable="false" maxLength="50" />
										<!-- Total Amount -->
										<m:Label text="{i18n>totalAmount}" required="true"/>
										<m:Input  value="{path:'FilteredExpenseModel>/TotalAmount',formatter:'.Formatter.numberFormater'}" editable="false" />
										<!-- Reimbursement Amount -->
										<m:Label text="{i18n>expReimbursementAmount}" required="true"/>
										<m:Input  value="{path:'FilteredExpenseModel>/ReimbursementAmount',formatter: '.Formatter.numberFormater'}" editable="false" />
										<!-- Status -->
										<m:Label text="{i18n>expStatus}" required="true"/>
										<m:Input  value="{FilteredExpenseModel>/Status}"  editable="false" />
										<!-- Trip Type -->
										<m:Label text="{i18n>expExpenseType}" required="true"/>
										<m:Select items="{tripTypeModel>/results}" change="onChangeExpenseType" editable="false" selectedKey="{FilteredExpenseModel>/TripType}">
											<core:Item key="{tripTypeModel>Name}" text="{tripTypeModel>Name}"/>
										</m:Select>
										<!-- Travel Allowance -->
										<m:Label text="{i18n>expTravelAllowance}" required="true" />
										<m:Select  selectedKey="{FilteredExpenseModel>/TravelAllowance}"  editable="false">
											<core:Item key="{i18n>no}" text="{i18n>no}" />
											<core:Item key="{i18n>yes}" text="{i18n>yes}" />
										</m:Select>
										<!-- Expense Name -->
										<m:Label text="{i18n>expExpenseName}" required="true"/>
										<m:Input id="idEditExpName" valueState="None"  liveChange="onLiveAllValidation" value="{FilteredExpenseModel>/ExpenseName}" maxLength="200"  editable="false" />
										<!-- Start Date -->
										<m:Label text="{i18n>startDate}" required="true" />
										<m:DatePicker  displayFormat="dd/MM/yyyy"  value="{FilteredExpenseModel>/ExpStartDate}" id="idExpStart" editable="false"  />
										<!-- EndDate -->
										<m:Label text="{i18n>endDate}" required="true" />
										<m:DatePicker  displayFormat="dd/MM/yyyy" value="{FilteredExpenseModel>/ExpEndDate}" id="isExpEnd" editable="false" />										
										<!-- Source -->
										<m:Label text="{i18n>expSource}" required="true"/>
										<m:ComboBox id="idEditSource" valueState="None"  change="onLiveAllValidation" items="{CityJsonModel>/results}"  value="{FilteredExpenseModel>/Source}" editable="{simpleForm>/editable}">
											<core:Item key="{CityJsonModel>ID}" text="{CityJsonModel>LocationName}" />
										</m:ComboBox>
										<!-- Destination -->
										<m:Label text="{i18n>expDestination}" required="{ExpenseType>/required}"/>
										<m:ComboBox  id="idEditDestination" valueState="None"  change="onLiveAllValidation" items="{CityJsonModel>/results}" editable="{simpleForm>/editable}" value="{FilteredExpenseModel>/Destination}">
											<core:Item key="{CityJsonModel>ID}" text="{CityJsonModel>LocationName}" />
										</m:ComboBox>
										<!-- CostCenter -->
										<m:Label text="{i18n>expCostCenter}" required="true"/>
										<m:Select items="{costCenterModel>/results}" 												             
												selectedKey="{FilteredExpenseModel>/CostCenter}"  editable="{simpleForm>/editable}">
											<core:Item key="{costCenterModel>Value}" text="{costCenterModel>Value}"/>
										</m:Select>																														
										<!-- Country -->
										<m:Label text="{i18n>expCountry}" required="true"/>
										<m:ComboBox id="idEditCountry" valueState="None"  change="onLiveAllValidation" items="{countryModel>/results}" value="{FilteredExpenseModel>/Country}" editable="{simpleForm>/editable}">
											<core:Item key="{countryModel>CountryName}" text="{countryModel>CountryName}"/>
										</m:ComboBox>

										<m:Label text="{i18n>managerRemarksLeave}" />
										<m:Text text="{= ${FilteredExpenseModel>/ManagerRemark}.length > 80 ? ${FilteredExpenseModel>/ManagerRemark}.substring(0, 80) + '...' : ${FilteredExpenseModel>/ManagerRemark}}" wrapping="false" />
										<m:Link text="{i18n>showMore}" press="onPressManagerRemarks" visible="{= ${FilteredExpenseModel>/ManagerRemark}.length > 80}" />

										<m:Label text="{i18n>expAccountantRemark}" />
										<m:Text id="textRemark" text="{= ${FilteredExpenseModel>/AccountingRemark}.length > 80 ? ${FilteredExpenseModel>/AccountingRemark}.substring(0, 80) + '...' : ${FilteredExpenseModel>/AccountingRemark}}" wrapping="false" />
										<m:Link text="{i18n>showMore}" press="onPressAccountantRemark" visible="{= ${FilteredExpenseModel>/AccountingRemark}.length > 80}" />

										<m:Label text="{i18n>expEmployeeRemark}" required="true"/>
										<m:TextArea id="idEditComments" valueState="None" liveChange="onLiveAllValidation" rows="4" value="{FilteredExpenseModel>/Comments}"  editable="{simpleForm>/editable}" maxLength="1000"/>
									<!-- </f:content> -->
								</f:SimpleForm>
							</blocks>
						</ObjectPageSubSection>
						<ObjectPageSubSection title="" titleUppercase="false">
							<blocks>
								<m:Table id="exp_Id_ExpenseTable" items="{ExpenseModel>/expenses}" class="sapUiResponsiveMargin" growing="true" growingThreshold="50"  alternateRowColors="true" growingScrollToLoad="true" width="auto" >
									<m:headerToolbar>
										<m:OverflowToolbar>
											<m:ToolbarSpacer />
											<m:ToolbarSeparator />
											<m:Button icon="sap-icon://add" tooltip="{i18n>expenseAddTooltip}" press="onPressAddExpenseItem" visible="{VisibleModel>/status}" id="idAddExpBtn" enabled="{VisibleModel>/enable}" />											
											<m:Button icon="sap-icon://edit" tooltip="{i18n>expenseEditTooltip}" press="onPressExpenseItemEdit" id="idExpenseItemEdit"  visible="{VisibleModel>/status}" enabled="{VisibleModel>/enableDelete}" />											
											<m:Button icon="sap-icon://delete" tooltip="{i18n>expenseDeleteTooltip}" press="onPressExpenseItemDelete" visible="{VisibleModel>/status}"  id="idExpDeleteBtn" enabled="{VisibleModel>/enable}" />											
											<m:Button icon="sap-icon://attachment" press="onPressOpenFolder" visible="{= ${FilteredExpenseModel>/FolderID} === ''?false:true}"  />										
											<m:Button icon="sap-icon://add-folder" press="onPressNewFolder" visible="{= ${FilteredExpenseModel>/FolderID} === ''?true:false}"  />											
											<m:Button icon="sap-icon://download" press="onPressExpenseDownload" visible="{VisibleModel>/status}" />
										</m:OverflowToolbar>
									</m:headerToolbar>
										<m:columns>
											<m:Column>
												<m:Label text="{i18n>itemID}" />
											</m:Column>
											<m:Column>
												<m:Label text="{i18n>expDetItemType}" />
											</m:Column>
											<m:Column>
												<m:Label text="{i18n>expDetForeignAmount}" />
											</m:Column>
											<m:Column>
												<m:Label text="{i18n>expDetExpenseDate}" />
											</m:Column>
											<m:Column>
												<m:Label text="{i18n>expDetExpenseAmount}" />
											</m:Column>
											<m:Column>
												<m:Label text="{i18n>expModeOfPayment}" />
											</m:Column>
											<m:Column>
												<m:Label text="{i18n>comments}" />
											</m:Column>
										</m:columns>
										<m:items>
											<m:ColumnListItem type="Navigation" press="onCheckExpenseDetails">
												<m:cells>
													<m:Text text="{ExpenseModel>employeeName}" />
													<m:Text text="{ExpenseModel>expenseName}" />
													<m:Text text="{ExpenseModel>startDate}" />
													<m:Text text="{ExpenseModel>endDate}" />
													<m:Text text="{ExpenseModel>destination}" />
													<m:Text text="{ExpenseModel>totalAmount}" />
													<m:Text text="{ExpenseModel>reimbursementAmount}" />
													<m:Text text="{ExpenseModel>status}" />
													<m:Button icon="sap-icon://delete" press="onPressEditExpense" />
												</m:cells>
											</m:ColumnListItem>
										</m:items>
									</m:Table>
							</blocks>
						</ObjectPageSubSection>
					</subSections>
				</ObjectPageSection>
			</sections>
		</ObjectPageLayout>
		<m:footer>
			<m:Bar>
				<m:contentRight>					
					<m:Button text="{i18n>submit}" type="Emphasized" press="onPressSubmitExpenseItems" visible="{VisibleModel>/status}" id="idExpenseSubmit" enabled="{VisibleModel>/enable}" />
				</m:contentRight>
			</m:Bar>
		</m:footer>
</m:Page>
</mvc:View>