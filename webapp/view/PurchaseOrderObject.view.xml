<mvc:View
    controllerName="sap.kt.com.minihrsolution.controller.PurchaseOrderObject"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns:suite="sap.suite.ui.commons"
    xmlns="sap.uxap"
    xmlns:uxap="sap.uxap"
    xmlns:richtexteditor="sap.ui.richtexteditor"
    xmlns:layout="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:c="sap.ui.core"
    displayBlock="true"
    height="100%"
    busyIndicatorDelay="0"
>
    <m:Page
        navButtonPress="PO_onButtonPress"
        showNavButton="true"
    >
        <ObjectPageLayout id="ObjectPageLayout">
            <!-- <headerTitle>
