                </m:FlexBox>
            </headerContent> -->
            <sections>
                <ObjectPageSection
                    titleUppercase="false"
                    id="purchaseOrderHeaderSection1"
                    title="Company Details"
                >
                    <subSections>
                        <ObjectPageSubSection id="dsd1">
                            <blocks>
                                <f:SimpleForm
                                    id="idsimpleCompanyDetails"
                                    busyIndicatorDelay="0"
                                    editable="true"
                                    layout="ColumnLayout"
                                    labelSpanXL="2"
                                    labelSpanL="3"
                                    labelSpanM="2"
                                    labelSpanS="12"
                                    adjustLabelSpan="false"
                                    emptySpanXL="0"
                                    emptySpanL="0"
                                    emptySpanM="0"
                                    emptySpanS="0"
                                    columnsXL="3"
                                    columnsL="2"
                                    columnsM="2"
                                    singleContainerFullSize="false"
                                >
                                    <f:content>
                                        <m:Label
                                            text="Branch Code"
                                            class="oSowFragLabel"
                                            required="true"
                                        />
                                        <m:ComboBox
                                            id="FPO_id_BranchCode"
                                            change="PO_onComboBoxBranchChange"
                                            placeholder="Select Branch Code"
                                            valueStateText="Please Select a Branch"
                                            selectedKey="{PurchaseOrderModel>/BranchCode}"
                                            filterSecondaryValues="true"
                                            showSecondaryValues="true"
                                            items="{CompanyCodeDetailsModel>/}"
                                        >
                                            <c:ListItem
                                                key="{CompanyCodeDetailsModel>branchCode}"
                                                text="{CompanyCodeDetailsModel>branchCode}"
                                                additionalText="{CompanyCodeDetailsModel>branch}"
                                            />
                                        </m:ComboBox>
                                        <m:Label
                                            text="Company Name"
                                            class="oSowFragLabel"
                                        />
                                        <m:Input
                                            value="{PurchaseOrderModel>/CompanyName}"
                                            id="FPO_id_Companyname"
                                            editable="false"
                                        />
                                        <m:Label
                                            text="Address"
                                            class="oSowFragLabel"
                                        />
                                        <m:Input
                                            value="{PurchaseOrderModel>/CompanyAddress}"
                                            id="FPO_id_CompanyAddress"
                                            editable="false"
                                        />
                                        <m:Label
                                            text="Email"
                                            class="oSowFragLabel"
                                        />
                                        <m:Input
                                            value="{PurchaseOrderModel>/CompanyEmail}"
                                            id="FPO_id_CCompanyEmail"
                                            editable="false"
                                        />
                                        <m:Label
                                            text="GSTIN"
                                            class="oSowFragLabel"
                                        />
                                        <m:Input
                                            value="{PurchaseOrderModel>/CompanyGSTNo}"
                                            id="FPO_id_CompanyGSTNo"
                                            editable="false"
                                        />
                                        <m:Label
                                            text="PAN"
                                            class="oSowFragLabel"
                                        />
                                        <m:Input
                                            id="FPO_id_CompanyPANNo"
                                            value="{PurchaseOrderModel>/CompanyPANNo}"
                                            editable="false"
                                        />
                                    </f:content>
                                </f:SimpleForm>
                            </blocks>
                        </ObjectPageSubSection>
                    </subSections>
                </ObjectPageSection>

                <ObjectPageSection
                    titleUppercase="false"
                    id="purchaseOrderHeaderSection"
                    title="Purchase Order Header"
                >
                    <subSections>
                        <ObjectPageSubSection id="dsd">
                            <blocks>
                                <f:SimpleForm
                                    id="idsimplePO"
                                    busyIndicatorDelay="0"
                                    editable="true"
                                    layout="ColumnLayout"
                                    labelSpanXL="2"
                                    labelSpanL="3"
                                    labelSpanM="2"
                                    labelSpanS="12"
                                    adjustLabelSpan="false"
                                    emptySpanXL="0"
                                    emptySpanL="0"
                                    emptySpanM="0"
                                    emptySpanS="0"
                                    columnsXL="3"
                                    columnsL="2"
                                    columnsM="2"
                                    singleContainerFullSize="false"
                                >
                                    <f:content>
                                        <m:Label
                                            text="Company Name"
                                            class="oSowFragLabel"
                                            required="true"
                                        />
                                        <m:ComboBox
                                            id="FPO_id_CustomerName"
                                            change="PO_onComboBoxChange"
                                            placeholder="Select Company Name"
                                            valueStateText="Please Enter a Valid Company Name"
                                            selectedKey="{PurchaseOrderModel>/CustomerName}"
                                            filterSecondaryValues="true"
                                            showSecondaryValues="true"
                                            items="{ManageCustomerModel>/}"
                                        >
                                            <c:ListItem
                                                key="{ManageCustomerModel>companyName}"
                                                text="{ManageCustomerModel>companyName}"
                                                additionalText="{ManageCustomerModel>name}"
                                            />
                                        </m:ComboBox>
                                        <m:Label
                                            text="Mobile No"
                                            class="oSowFragLabel"
                                        />
                                        <m:Select
                                            id="FPO_idSTD"
                                            editable="false"
                                        >
                                            <c:Item
                                                key="{PurchaseOrderModel>/STDCode}"
                                                text="{PurchaseOrderModel>/STDCode}"
                                            />
                                        </m:Select>

                                        <m:Input
                                            id="FPO_id_MobileNo"
                                            value="{PurchaseOrderModel>/mobileNo}"
                                            maxLength="10"
                                            editable="false"
                                            placeholder="Phone Number"
                                        />
                                        <m:Label
                                            text="Email"
                                            class="oSowFragLabel"
                                        />
                                        <m:Input
                                            id="FPO_id_Email"
                                            value="{PurchaseOrderModel>/customerEmail}"
                                            editable="false"
                                        />
                                        <m:Label
                                            text="GSTIN"
                                            class="oSowFragLabel"
                                        />
                                        <m:Input
                                            id="FPO_id_GSTIN"
                                            value="{PurchaseOrderModel>/GSTIN}"
                                            maxLength="150"
                                            editable="false"
                                        />
                                        <m:Label
                                            text="Tax Percentage"
                                            class="oSowFragLabel"
                                        />
                                        <m:Input
                                            id="FPO_id_type"
                                            value="{PurchaseOrderModel>/GSTType}"
                                            editable="false"
                                        />
                                        <m:Input
                                            id="FPO_id_tax"
                                            value="{PurchaseOrderModel>/Tax}"
                                            editable="false"
                                        />
                                        <m:Label
                                            text="Address"
                                            class="oSowFragLabel"
                                        />
                                        <m:TextArea
                                            id="FPO_id_Address"
                                            value="{PurchaseOrderModel>/Address}"
                                            maxLength="250"
                                            editable="false"
                                        />
                                        <m:Label
                                            text="PAN No"
                                            class="oSowFragLabel"
                                        />
                                        <m:Input
                                            value="{PurchaseOrderModel>/PAN}"
                                            id="FPO_id_PanNo"
                                            maxLength="15"
                                            editable="false"
                                        />
                                        <m:Label
                                            text="LUT"
                                            class="oSowFragLabel"
                                        />
                                        <m:Input
                                            value="{PurchaseOrderModel>/LUT}"
                                            id="FPO_id_LUT"
                                            editable="false"
                                        />
                                        <m:Label
                                            text="Type"
                                            class="oSowFragLabel"
                                            required="true"
                                        />
                                        <m:Select
                                            id="PO_id_Type"
                                            selectedKey="{PurchaseOrderModel>/Type}"
                                        >
                                            <c:Item
                                                key="Internal"
                                                text="Internal"
                                            />
                                            <c:Item
                                                key="Fixed"
                                                text="Fixed"
                                            />
                                            <c:Item
                                                key="Service"
                                                text="Service"
                                            />
                                        </m:Select>
                                        <m:Label
                                            text="Start Date"
                                            class="oSowFragLabel"
                                            required="true"
                                        />
                                        <m:DatePicker
                                            id="FPO_id_StartDate"
                                            change="FPO_onDateChange"
                                            valueStateText="Select Start Date"
                                            value="{PurchaseOrderModel>/StartDate}"
                                            valueFormat="dd/MM/yyyy"
                                            displayFormat="dd/MM/yyyy"
                                        />
                                        <m:Label
                                            text="End Date"
                                            class="oSowFragLabel"
                                            required="true"
                                        />
                                        <m:DatePicker
                                            id="FPO_id_EndDate"
                                            change="FPO_onDateChange"
                                            valueStateText="Select End Date"
                                            value="{PurchaseOrderModel>/EndDate}"
                                            valueFormat="dd/MM/yyyy"
                                            displayFormat="dd/MM/yyyy"
                                        />
                                        <m:Label
                                            text="Creation Date"
                                            class="oSowFragLabel"
                                            required="true"
                                        />
                                        <m:DatePicker
                                            id="FPO_id_Date"
                                            change="FPO_onDateChange"
                                            valueStateText="Select Creation Date"
                                            value="{PurchaseOrderModel>/CurrentDate}"
                                            valueFormat="dd/MM/yyyy"
                                            displayFormat="dd/MM/yyyy"
                                        />
                                        <m:Label
                                            text="Currency"
                                            class="oSowFragLabel"
                                            required="true"
                                        />
                                        <m:Select
                                            selectedKey="{PurchaseOrderModel>/Currency}"
                                            width="100%"
                                            editable="{PurchaseOrderModel>/Editable}"
                                            items="{CurrencyModel>/}"
                                        >
                                            <c:Item
                                                key="{CurrencyModel>currency}"
                                                text="{CurrencyModel>currency}"
                                            />
                                        </m:Select>
                                    </f:content>
                                </f:SimpleForm>
                            </blocks>
                        </ObjectPageSubSection>
                    </subSections>
                </ObjectPageSection>

                <ObjectPageSection
                    titleUppercase="false"
                    id="purchaseOrderSection"
                    title="Purchase Order Items"
                >
                    <subSections>
                        <ObjectPageSubSection id="POO_Purchaseordersection">
                            <blocks>
                                <m:VBox class="sapUiSmallMargin">
                                    <m:Table
                                        id="idTable"
                                        items="{PurchaseOrderModel>/PurchaseOrders}"
                                        mode="{= ${PurchaseOrderModel>/Editable} === true ? 'Delete' : 'None'}"
                                        delete="POO_onPOTableDelete"
                                    >
                                        <m:headerToolbar>
                                            <m:Toolbar>
                                                <m:ToolbarSpacer />
                                                <m:Button
                                                    id="POO_idAddItemButton"
                                                    text="Add Item"
                                                    press="onAddItemButtonPress"
                                                />
                                            </m:Toolbar>
                                        </m:headerToolbar>
                                        <m:columns>
                                            <m:Column width="100px">
                                                <m:Text text="Sl No" />
                                            </m:Column>
                                            <m:Column>
                                                <m:Text
                                                    text="Consultant Name"
                                                />
                                            </m:Column>
                                            <m:Column>
                                                <m:Text text="Description" />
                                            </m:Column>
                                            <m:Column>
                                                <m:Text text="Unit" />
                                            </m:Column>
                                            <m:Column>
                                                <m:Text text="Amount" />
                                            </m:Column>
                                            <m:Column width="130px" />
                                            <m:Column>
                                                <m:Text text="Total Amount" />
                                            </m:Column>
                                        </m:columns>
                                        <m:items>
                                            <m:ColumnListItem>
                                                <m:cells>
                                                    <m:Input
                                                        editable="{PurchaseOrderModel>/Editable}"
                                                        value="{PurchaseOrderModel>SerialNo}"
                                                        maxLength="10"
                                                        width="100%"
                                                    />

                                                    <m:Input
                                                        id="PO_id_Consultantname"
                                                        value="{PurchaseOrderModel>ConsultantName}"
                                                        liveChange="PO_onConsultantnameLiveChange"
                                                        valueStateText="Please Enter a Valid Name"
                                                        maxLength="30"
                                                        width="100%"
                                                        editable="{PurchaseOrderModel>/Editable}"
                                                    />
                                                    <m:Input
                                                        id="PO_id_Description"
                                                        value="{PurchaseOrderModel>Description}"
                                                        liveChange="onDescriptionInputLiveChange"
                                                        valueStateText="Please enter a valid description"
                                                        maxLength="250"
                                                        editable="{PurchaseOrderModel>/Editable}"
                                                    />
                                                    <m:Input
                                                        id="PO_id_Unit"
                                                        liveChange="PO_onAmountInputChange"
                                                        valueStateText="Please enter a valid unit"
                                                        value="{PurchaseOrderModel>Unit}"
                                                        maxLength="10"
                                                        width="100%"
                                                        editable="{PurchaseOrderModel>/Editable}"
                                                    />
                                                    <m:Input
                                                        id="PO_id_AmountInput"
                                                        liveChange="PO_onAmountInputChange"
                                                        valueStateText="Please enter a valid amount"
                                                        value="{PurchaseOrderModel>Amount}"
                                                        maxLength="10"
                                                        width="100%"
                                                        editable="{PurchaseOrderModel>/Editable}"
                                                    />
                                                    <m:Select
                                                        id="PO_id_day"
                                                        selectedKey="{PurchaseOrderModel>Period}"
                                                        editable="{PurchaseOrderModel>/Editable}"
                                                        items="{RateType>/}"
                                                    >
                                                        <c:Item
                                                            key="{RateType>RateType}"
                                                            text="{RateType>RateType}"
                                                        />
                                                    </m:Select>
                                                    <m:Input
                                                        id="PO_id_TotalAmount"
                                                        value="{PurchaseOrderModel>/TotalAmount}"
                                                        width="100%"
                                                        editable="false"
                                                    />
                                                </m:cells>
                                            </m:ColumnListItem>
                                        </m:items>
                                    </m:Table>
                                    <m:VBox class="sapUiSmallMarginTop">
                                        <m:HBox
                                            justifyContent="End"
                                            alignItems="Center"
                                        >
                                            <m:Label
                                                text="Sub Total :"
                                                class="boldBlackText sapUiLargeMarginEnd"
                                                wrapping="false"
                                            />
                                            <m:Text
                                                text="{PurchaseOrderModel>/SubTotal}"
                                                class="sapUiSmallMarginBegin "
                                                wrapping="false"
                                            />
                                        </m:HBox>
                                        <m:HBox
                                            justifyContent="End"
                                            alignItems="Center"

                                        >
                                            <m:Label
                                                visible="{= ${PurchaseOrderModel>/GSTType} === 'IGST' }"
                                                text="IGST ({PurchaseOrderModel>/Tax}%) :"
                                                class="boldBlackText sapUiLargeMarginEnd"
                                                wrapping="false"
                                                
                                            />
                                            <m:Text
                                                id="POO_idIGSTText"
                                             
                                               text="{PurchaseOrderModel>/IGST}"
                                                class="sapUiSmallMarginBegin"
                                                wrapping="false"
                                                visible="{= ${PurchaseOrderModel>/GSTType} === 'IGST' }"  
                                                                                        
                                          />
                                        </m:HBox>
                                      <m:HBox
                                            justifyContent="End"
                                            alignItems="Center"

                                        >
                                            <m:Label
                                                visible="{= ${PurchaseOrderModel>/GSTType} === 'CGST/SGST' }"  

                                                text="CGST ({PurchaseOrderModel>/Tax}%) :"
                                                class="boldBlackText sapUiLargeMarginEnd"
                                                wrapping="false"
                                            />
                                            <m:Text
                                                visible="{= ${PurchaseOrderModel>/GSTType} === 'CGST/SGST' }"  

                                                text="{PurchaseOrderModel>/CGST}"
                                                class="sapUiSmallMarginBegin"
                                                wrapping="false"
                                            />
                                        </m:HBox>
                                          <m:HBox
                                            justifyContent="End"
                                            alignItems="Center"

                                        >
                                            <m:Label
                                                visible="{= ${PurchaseOrderModel>/GSTType} === 'CGST/SGST' }"  

                                                text="SGST ({PurchaseOrderModel>/Tax}%) :"
                                                class="boldBlackText sapUiLargeMarginEnd"
                                                wrapping="false"
                                            />
                                            <m:Text
                                                visible="{= ${PurchaseOrderModel>/GSTType} === 'CGST/SGST' }"  

                                                text="{PurchaseOrderModel>/SGST}"
                                                class="sapUiSmallMarginBegin"
                                                wrapping="false"
                                            />
                                        </m:HBox>
                                         <m:HBox
                                            justifyContent="End"
                                            alignItems="Center"

                                        >
                                            <m:Label
                                                text="Total :"
                                                class="boldBlackText sapUiLargeMarginEnd"
                                                wrapping="false"
                                            />
                                            <m:Text
                                                text="{PurchaseOrderModel>/GrantTotal}"
                                                class="sapUiSmallMarginBegin"
                                                wrapping="false"
                                            />
                                        </m:HBox>
                                    </m:VBox>
                                </m:VBox>
                            </blocks>
                        </ObjectPageSubSection>
                    </subSections>
                </ObjectPageSection>

                <ObjectPageSection
                    titleUppercase="false"
                    id="POO_idSectionNotes"
                    title="Notes"
                    tooltip="Notes"
                >
                    <subSections>
                        <ObjectPageSubSection titleUppercase="false">
                            <blocks>
                                <m:VBox>
                                    <m:Toolbar>
                                        <m:ToolbarSpacer />
                                        <m:Button
                                            id="POO_idClearButton"
                                            text="Clear"
                                            press="onClearNotesPress"
                                        />
                                    </m:Toolbar>
                                    <richtexteditor:RichTextEditor
                                        id="FPO_idRichTextEditor"
                                        value="{PurchaseOrderModel>/Notes}"
                                        width="100%"
                                        height="300px"
                                    />
                                </m:VBox>
                            </blocks>
                        </ObjectPageSubSection>
                    </subSections>
                </ObjectPageSection>
            </sections>
        </ObjectPageLayout>
        <m:footer>
            <m:Bar id="IA_id_FooterBar">
                <m:contentRight>
                    <m:Button
                        id="POO_idSubmitButton"
                        text="Submit"
                        type="Emphasized"
                        press="POO_onSubmitButtonPress"
                    />
                    <m:Button
                        id="POO_idmailButton"
                        text="Send Mail"
                        type="Ghost"
                        press="POO_onmailButtonPress"
                    />
                    <m:Button
                        id="POO_ideditButton"
                        visible="{=${PurchaseOrderModel>/Editable}===false}"
                        text="Edit"
                        type="Emphasized"
                        press="POO_onEditButtonPress"
                    />
                    <m:Button
                        id="POO_idSaveButton"
                        text="Save"
                        type="Accept"
                        press="POO_onSaveButtonPress"
                    />
                    <m:Button
                        id="POO_idPDFButton"
                        text="Genarate PDF"
                        type="Attention"
                        press="POO_onPDFButtonPress"
                    />
                </m:contentRight>
            </m:Bar>
        </m:footer>
    </m:Page>
</mvc:View>
