<mvc:View controllerName="sap.ui.com.project1.controller.View_Rooms"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
	xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core"
	xmlns:uxap="sap.uxap"
	xmlns:fb="sap.ui.comp.filterbar"
	displayBlock="true"
	height="100%"
	class="hideVendorReg"
	busyIndicatorDelay="0">
	<VBox height="100%">
		<Page
			showHeader="true"
			enableScrolling="true"
			class="RoomsPage roomsBgPage">
<layoutData>
    <FlexItemData growFactor="1" />
</layoutData>

			<headerContent >
				<core:Fragment
					fragmentName="sap.ui.com.project1.fragment.BookingHeader"
					type="XML" />
			</headerContent>
			<content>
				<uxap:ObjectPageLayout
					id="VR_id_ObjectPageLayout"
					useIconTabBar="false"
					showTitleInHeaderContent="true"
					class="vrObjectPageLayout roomsBgLayout">

					<uxap:headerTitle>
						<uxap:ObjectPageDynamicHeaderTitle visible="false">
							<uxap:expandedHeading>
								<HBox />
							</uxap:expandedHeading>
							<uxap:snappedHeading>
								<FlexBox
									fitContainer="true"
									alignItems="Center"
									class="vrSnappedHeader">
									<Avatar
										src="{= 'data:image/jpeg;base64,' + ${BranchModel>/Photo1} }"
										displaySize="L"
										displayShape="Square"
										visible="{= !!${BranchModel>/Photo1} }"
										class="vrSquareAvatarSmall vrSnappedAvatar sapUiAvatarImageContain" />
									<VBox class="vrSnappedTitleBlock">
										<Title
											text="{BranchModel>/Name}"
											wrapping="true"
											class="vrHeaderTitle vrSnappedTitle" />
										<Text
											text="{BranchModel>/PropertyType}"
											class="vrHeaderSubtitle vrSnappedSubtitle" />
									</VBox>
								</FlexBox>
							</uxap:snappedHeading>
						</uxap:ObjectPageDynamicHeaderTitle>
					</uxap:headerTitle>

					<uxap:headerContent>
						<FlexBox
							wrap="Wrap"
							fitContainer="true"
							alignItems="Start"
							justifyContent="Start"
							class="sapUiTinyMarginTop vrHeaderRow">
							<HBox class="vrIdentityRow sapUiMediumMarginEnd sapUiSmallMarginBottom" alignItems="Start">
								<Avatar
									src="{= 'data:image/jpeg;base64,' + ${BranchModel>/Photo1} }"
									displaySize="XL"
									displayShape="Square"
									visible="{= !!${BranchModel>/Photo1} }"
									class="vrSquareAvatarLarge sapUiMediumMarginEnd sapUiAvatarImageContain vrHeaderAvatar" />
								<VBox class="vrTitleBlock">
									<Title
										text="{BranchModel>/Name}"
										wrapping="true"
										class="vrHeaderTitle" />
									<Text
										text="{BranchModel>/PropertyType}"
										class="vrHeaderSubtitle sapUiTinyMarginTop" />
								</VBox>
							</HBox>
<VBox
    class="sapUiMediumMarginEnd sapUiSmallMarginBottom vrHeaderSection vrHeaderSectionPrimary"
>
    <HBox
        alignItems="Center"
        class="sapUiTinyMarginBottom vrHeaderFieldRow"
    >
        <Label
            text="Email:"
            design="Bold"
            class="vrHeaderLabel"
        />
        <Link
            text="{BranchModel>/EmailID}"
            href="{= 'mailto:' + ${BranchModel>/EmailID} }"
            wrapping="true"
            class="vrHeaderValueLink"
        />
    </HBox>
    <HBox
        alignItems="Center"
        class="sapUiTinyMarginBottom vrHeaderFieldRow"
    >
        <Label
            text="Contact:"
            design="Bold"
            class="vrHeaderLabel"
        />
        <Link
            text="{BranchModel>/STD} {BranchModel>/Contact}"
            href="{= 'tel:' + ${BranchModel>/Contact} }"
            wrapping="true"
            class="vrHeaderValueLink"
        />
    </HBox>
    <HBox
        alignItems="Center"
        class="sapUiTinyMarginBottom vrHeaderFieldRow"
        visible="{= !!${BranchModel>/GSTIN} }"
    >
        <Label
            text="GSTIN:"
            design="Bold"
            class="vrHeaderLabel"
        />
        <Text
            text="{BranchModel>/GSTIN}"
            class="vrHeaderValueText"
        />
    </HBox>
</VBox>

							<VBox class="sapUiSmallMarginBottom vrHeaderSection vrHeaderSectionSecondary">
								<HBox alignItems="Center" class="sapUiTinyMarginBottom vrHeaderFieldRow">
									<Label text="Address:" design="Bold" class="vrHeaderLabel" />
									<Link
										text="{BranchModel>/Address}"
										href="{BranchModel>/GeoLocation}"
										target="_blank"
										wrapping="true"
										class="vrHeaderValueLink" />
								</HBox>
								<HBox alignItems="Center" class="sapUiTinyMarginBottom vrHeaderFieldRow vrRatingRow">
									<Label text="User Rating:" design="Bold" class="vrHeaderLabel" />
									<HBox id="VR_id_RatingClickable" alignItems="Center" class="vrHeaderValueBox vrRatingClickable">
										<RatingIndicator
											value="{= Number(${VisibilityModel>/AverageRating}) || 0 }"
											maxValue="5"
											enabled="false"
											iconSize="1.1rem"
											class="vrRatingStars sapUiTinyMarginEnd" />
										<Text
											text="{= '(' + (${VisibilityModel>/TotalFeedbacks} || 0) + ')' }"
											class="vrRatingCount" />
									</HBox>
								</HBox>
							</VBox>
						</FlexBox>
					</uxap:headerContent>

					<uxap:sections>
						<!-- AC Rooms Tab Section -->
						<uxap:ObjectPageSection
							visible="{= ${VisibilityModel>/isDataLoaded} &amp;&amp; ${VisibilityModel>/ACRooms}.length > 0 }"
							id="VR_id_ACSection"
							title="AC Rooms"
							titleUppercase="false">
							<uxap:subSections>
								<uxap:ObjectPageSubSection
									id="VR_id_ACSubSection"
									visible="{= ${VisibilityModel>/isDataLoaded} &amp;&amp; ${VisibilityModel>/ACRooms}.length > 0}">
									<uxap:blocks>
										<VBox>
											<VBox class="">
												<l:Grid
													id="idBedTypeFlex2"
													defaultSpan="XL3 L3 M6 S12"
													containerQuery="true"
													hSpacing="0"
													vSpacing="0"
													content="{path: 'VisibilityModel>/ACRooms'}">
													<VBox class="bedCard sapUiTinyMargin">
														<Carousel
															height="300px"
															width="100%"
															loop="true"
															showPageIndicator="false"
															backgroundDesign="Transparent"
															class="roomCardCarousel"
															pages="{path: 'VisibilityModel>Images', templateShareable: false}">
															<pages>
																<VBox class="imageWrapper">
																	<HBox class="areaTagBox">
																		<core:Icon
																			src="sap-icon://building"
																			size="0.9rem"
																			color="black"
																			class="sapUiTinyMarginEnd" />
																		<Text text="{VisibilityModel>Area}" />
																	</HBox>
																	<Image
																		src="{VisibilityModel>src}"
																		width="100%"
																		height="300px"
																		class="bedCardImage"
																		decorative="false" />
																</VBox>
															</pages>
														</Carousel>
														<VBox class="bedCardContent">
															<Text
																text="{= ${VisibilityModel>Name} + ' (' + ${VisibilityModel>ACType} + ')' }"
																class="bedCardTitle" />
															<Text
																text="{VisibilityModel>Description}"
																class="bedCardDesc"
																maxLines="4"
																wrapping="true" />
															<Text
																text="{
																	parts: ['VisibilityModel>Currency','VisibilityModel>BasicPrice'],
																	formatter: '.Formatter.formatStartingPrice'
																}"
																class="bedCardPrice" />
															<HBox
																justifyContent="Center"
																alignItems="Center"
																class="sapUiTinyMarginTop">
																<Link
																	text="Book Room"
																	press="onViewDetailsPress"
																	class="pillActionBtn pillLeft" />
																<Link
																	text="Enquiry"
																	press="onEnquiryPress"
																	class="pillActionBtn pillRight" />
															</HBox>
														</VBox>
													</VBox>
												</l:Grid>
												<VBox
													alignItems="Center"
													class="sapUiTinyMarginTop sapUiTinyMarginBottom"
													visible="{VisibilityModel>/ShowViewMore}">
													<VBox height="2rem" />
												</VBox>
											</VBox>
										</VBox>
									</uxap:blocks>
								</uxap:ObjectPageSubSection>
							</uxap:subSections>
						</uxap:ObjectPageSection>

						<!-- Non-AC Rooms Tab Section -->
						<uxap:ObjectPageSection
							id="VR_id_NonACSection"
							title="Non-AC Rooms"
							titleUppercase="false"
							visible="{= ${VisibilityModel>/isDataLoaded} &amp;&amp; ${VisibilityModel>/NonACRooms}.length > 0 }">
							<uxap:subSections>
								<uxap:ObjectPageSubSection
									id="VR_id_NonACSubSection"
									title="Non-AC Rooms"
									visible="{= ${VisibilityModel>/isDataLoaded} &amp;&amp; ${VisibilityModel>/NonACRooms}.length > 0}">
									<uxap:blocks>
										<VBox>
											<VBox class="">
												<l:Grid
													id="idBedTypeFlex1"
													defaultSpan="XL3 L3 M6 S12"
													containerQuery="true"
													hSpacing="0"
													vSpacing="0"
													content="{path: 'VisibilityModel>/NonACRooms'}">
													<VBox class="bedCard sapUiTinyMargin">
														<Carousel
															height="300px"
															width="100%"
															loop="true"
															showPageIndicator="false"
															backgroundDesign="Transparent"
															class="roomCardCarousel"
															pages="{path: 'VisibilityModel>Images', templateShareable: false}">
															<pages>
																<VBox class="imageWrapper">
																	<HBox class="areaTagBox">
																		<core:Icon
																			src="sap-icon://building"
																			size="0.9rem"
																			color="black"
																			class="sapUiTinyMarginEnd" />
																		<Text text="{VisibilityModel>Area}" />
																	</HBox>
																	<Image
																		src="{VisibilityModel>src}"
																		width="100%"
																		height="300px"
																		class="bedCardImage"
																		decorative="false" />
																</VBox>
															</pages>
														</Carousel>
														<VBox class="bedCardContent">
															<Text
																text="{= ${VisibilityModel>Name} + ' (' + ${VisibilityModel>ACType} + ')' }"
																class="bedCardTitle" />
															<Text
																text="{VisibilityModel>Description}"
																class="bedCardDesc"
																maxLines="4"
																wrapping="true" />
															<Text
																text="{
																	parts: ['VisibilityModel>Currency','VisibilityModel>BasicPrice'],
																	formatter: '.Formatter.formatStartingPrice'
																}"
																class="bedCardPrice" />
															<HBox
																justifyContent="Center"
																alignItems="Center"
																class="sapUiTinyMarginTop">
																<Link
																	text="Book Room"
																	press="onViewDetailsPress"
																	class="pillActionBtn pillLeft" />
																<Link
																	text="Enquiry"
																	press="onEnquiryPress"
																	class="pillActionBtn pillRight" />
															</HBox>
														</VBox>
													</VBox>
												</l:Grid>
												<VBox
													alignItems="Center"
													class="sapUiTinyMarginTop sapUiTinyMarginBottom"
													visible="{VisibilityModel>/ShowViewMore}">
													<VBox height="2rem" />
												</VBox>
											</VBox>
										</VBox>
									</uxap:blocks>
								</uxap:ObjectPageSubSection>
							</uxap:subSections>
						</uxap:ObjectPageSection>

						<uxap:ObjectPageSection
							id="VR_id_NoDataSection"
							title=""
							titleUppercase="false"
							visible="{= ${VisibilityModel>/isDataLoaded} &amp;&amp; ${VisibilityModel>/NonACRooms}.length === 0 &amp;&amp; ${VisibilityModel>/ACRooms}.length === 0 }">
							<uxap:subSections>
								<uxap:ObjectPageSubSection id="VR_id_NoDataSubSection">
									<uxap:blocks>
										<VBox
											height="300px"
											justifyContent="Center"
											alignItems="Center">
											<Text
												text="{i18n>noRoomsFound}"
												class="cssNoDataMessage" />
											<Text
												text="{i18n>pleaseselectanotherCity}"
												class="cssNoDataSubMessage" />
										</VBox>
									</uxap:blocks>
								</uxap:ObjectPageSubSection>
							</uxap:subSections>
						</uxap:ObjectPageSection>
					</uxap:sections>
				</uxap:ObjectPageLayout>
			</content>
		</Page>
		<VBox visible="{FooterModel>/showGlobalFooter}" class="footer-shell">
			<core:Fragment
				fragmentName="sap.ui.com.project1.fragment.Footer"
				type="XML" />
		</VBox>
	</VBox>
</mvc:View>
