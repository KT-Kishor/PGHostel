<mvc:View controllerName="sap.ui.com.project1.controller.View_Rooms"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
	xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core"
	xmlns:uxap="sap.uxap"
	xmlns:f="sap.ui.layout.form"
	xmlns:fb="sap.ui.comp.filterbar"
	displayBlock="true"
	height="100%"
	busyIndicatorDelay="0">
	<Page
		showHeader="true"
		enableScrolling="true"
		class="RoomsPage">
		<headerContent>
			<core:Fragment
				fragmentName="sap.ui.com.project1.fragment.BookingHeader"
				type="XML" />
		</headerContent>
		<content>
         <FlexBox
            direction="Row"
            justifyContent="Center"
            alignItems="Center"
            class="sapUiMediumMargin profileFlex"
        >
            <VBox class="avatarContainer sapUiSmallMarginEnd">
                <Avatar
                    src="{= 'data:image/jpeg;base64,' + ${BranchModel>/Photo1} }"
                    initials="{profileData>/initials}"
                    displayShape="Square"
                    displaySize="XL"
                    class="customLargeAvatar "
                />
                
            </VBox>

            <!-- Profile Forms -->
            <VBox>
                <!-- DISPLAY MODE -->
                <f:SimpleForm
                    layout="ColumnLayout"
                    columnsM="2"
                    columnsL="2"
                    class="sapUiTinyMarginTop RoomSimpleform"
                   
                >
                    <f:content>
                        <Label text="{i18n>Name}"  />
                        <Text
                            text="{BranchModel>/Name} ({BranchModel>/PropertyType})"
                        />
                        <!-- <Label text="{i18n>Property Type}"  />
                        <Text
                            text="{BranchModel>/PropertyType}"
                        /> -->
                        
                        <Label text="{i18n>email}"   />
                        <Text text="{BranchModel>/EmailID}" />

                        <Label text="{i18n>MSmobileNo}"   />
                        <Text text="{BranchModel>/STD} {BranchModel>/Contact}" />
                        <Label
                                    text="GSTIN"
                                   visible="{= !!${BranchModel>/GSTIN} }"
                                />
                                <Text text="{BranchModel>/GSTIN}" visible="{= !!${BranchModel>/GSTIN} }" />


                        <Label text="{i18n>address}"   />
                        <Text
                            text="{BranchModel>/Address}"
                            wrapping="true"
                        />
                        <Label
                                    text="Location"
                                   
                                />
                                <Link
                                    text="View on Map"
                                    href="{BranchModel>/GeoLocation}"
                                    target="_blank"
                                />
                    </f:content>
                </f:SimpleForm>

             
            </VBox>
        </FlexBox>
