<mvc:View
    controllerName="sap.ui.com.project1.controller.View_Rooms"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%"
    busyIndicatorDelay="0"
>
    <Page
        showHeader="true"
        enableScrolling="true"
    >
        <headerContent>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.BookingHeader"
                type="XML"
            />
        </headerContent>

        <content>
            <VBox
                height="600px"
                justifyContent="Center"
                alignItems="Center"
                visible="{VisibilityModel>/ShowGlobalNoData}"
            >
                <Text
                    text="{i18n>noRoomsFound}"
                    class="cssNoDataMessage"
                />
                <Text
                    text="{i18n>pleaseselectanotherCity}"
                    class="cssNoDataSubMessage"
                />
            </VBox>

            <Title
                text="AC Rooms"
                level="H2"
                class="roomHeaderTitle sapUiMediumMarginBeginEnd"
                visible="{= ${VisibilityModel>/ACRooms}.length > 0}"
            />

            <VBox class="sapUiTinyMarginTop">
                <l:Grid
                    id="idBedTypeFlex2"
                    defaultSpan="XL3 L4 M6 S12"
                    containerQuery="true"
                    hSpacing="2"
                    vSpacing="2"
                    content="{path: 'VisibilityModel>/ACRooms'}"
                >
                    <VBox class="bedCard">
                        <Carousel
                            height="300px"
                            width="100%"
                            loop="true"
                            showPageIndicator="false"
                            backgroundDesign="Transparent"
                            pages="{path: 'VisibilityModel>Images', templateShareable: false}"
                        >
                            <pages>
                                <VBox class="imageWrapper">
                                    <HBox class="areaTagBox">
                                        <core:Icon
                                            src="sap-icon://building"
                                            size="0.9rem"
                                            color="black"
                                            class="sapUiTinyMarginEnd"
                                        />
                                        <Text text="{VisibilityModel>Area}" />
                                    </HBox>

                                    <Image
                                        src="{VisibilityModel>src}"
                                        width="100%"
                                        height="300px"
                                        class="bedCardImage"
                                        decorative="false"
                                    />

                                    <CustomListItem
                                        type="Active"
                                        press=".onRatingPress"
                                        visible="{= ${VisibilityModel>TotalFeedbacks} > 0 }"
                                        tooltip="Tap to See Reviews"
                                    >
                                        <HBox
                                            class="ratingOverlay"
                                            alignItems="Center"
                                        >
                                            <RatingIndicator
                                                value="{VisibilityModel>AverageRating}"
                                                maxValue="5"
                                                enabled="false"
                                                iconSize="0.8rem"
                                            />
                                            <Text
                                                text="({VisibilityModel>TotalFeedbacks})"
                                                class="ratingCountText"
                                            />
                                        </HBox>
                                    </CustomListItem>
                                </VBox>
                            </pages>
                        </Carousel>

                        <VBox class="bedCardContent">
                            <Text
                                text="{= ${VisibilityModel>Name} + ' (' + ${VisibilityModel>ACType} + ')' }"
                                class="bedCardTitle"
                            />

                            <Text
                                text="{VisibilityModel>Description}"
                                class="bedCardDesc"
                                maxLines="4"
                                wrapping="true"
                            />

                            <Text
                                text="{
                                    parts: ['VisibilityModel>Currency','VisibilityModel>BasicPrice'],
                                    formatter: '.Formatter.formatStartingPrice'
                                }"
                                class="bedCardPrice"
                            />

                            <HBox
                                justifyContent="Center"
                                alignItems="Center"
                                class="sapUiTinyMarginTop"
                            >
                                <Toolbar
                                    class="pillActionBar sapUiTinyMarginTop"
                                    design="Transparent"
                                >
                                    <Button
                                        text="View Details"
                                        type="Transparent"
                                        press="onViewDetailsPress"
                                        class="pillActionBtn pillLeft"
                                    />

                                    <ToolbarSpacer width="1px" />

                                    <Button
                                        text="Enquiry"
                                        type="Transparent"
                                        press="onEnquiryPress"
                                        class="pillActionBtn pillRight"
                                    />
                                </Toolbar>
                            </HBox>
                        </VBox>
                    </VBox>
                </l:Grid>
                <VBox
                    alignItems="Center"
                    class="sapUiTinyMarginTop sapUiTinyMarginBottom"
                    visible="{VisibilityModel>/ShowViewMore}"
                >
                    <Link
                        id="idViewMoreBusy2"
                        text="{i18n>viewmorerooms}"
                        press="onViewMoreRooms"
                        class="btnViewDetails"
                    />
                    <VBox height="2rem" />
                </VBox>
            </VBox>

            <Title
                text="Non-AC Rooms"
                level="H2"
                class="roomHeaderTitle sapUiMediumMarginBegin sapUiTinyMarginTop"
                visible="{= ${VisibilityModel>/NonACRooms}.length > 0}"
            />

            <VBox class="sapUiTinyMarginTop">
                <l:Grid
                    id="idBedTypeFlex1"
                    defaultSpan="XL3 L4 M6 S12"
                    containerQuery="true"
                    hSpacing="2"
                    vSpacing="2"
                    content="{path: 'VisibilityModel>/NonACRooms'}"
                >
                    <VBox class="bedCard">
                        <Carousel
                            height="300px"
                            width="100%"
                            loop="true"
                            showPageIndicator="false"
                            backgroundDesign="Transparent"
                            pages="{path: 'VisibilityModel>Images', templateShareable: false}"
                        >
                            <pages>
                                <VBox class="imageWrapper">
                                    <HBox class="areaTagBox">
                                        <core:Icon
                                            src="sap-icon://building"
                                            size="0.9rem"
                                            color="black"
                                            class="sapUiTinyMarginEnd"
                                        />
                                        <Text text="{VisibilityModel>Area}" />
                                    </HBox>

                                    <Image
                                        src="{VisibilityModel>src}"
                                        width="100%"
                                        height="300px"
                                        class="bedCardImage"
                                        decorative="false"
                                    />

                                    <CustomListItem
                                        type="Active"
                                        press=".onRatingPress"
                                        visible="{= ${VisibilityModel>TotalFeedbacks} > 0 }"
                                        tooltip="Tap to See Reviews"
                                    >
                                        <HBox
                                            class="ratingOverlay"
                                            alignItems="Center"
                                        >
                                            <RatingIndicator
                                                value="{VisibilityModel>AverageRating}"
                                                maxValue="5"
                                                enabled="false"
                                                iconSize="0.8rem"
                                            />
                                            <Text
                                                text="({VisibilityModel>TotalFeedbacks})"
                                                class="ratingCountText"
                                            />
                                        </HBox>
                                    </CustomListItem>
                                </VBox>
                            </pages>
                        </Carousel>

                        <VBox class="bedCardContent">
                            <Text
                                text="{= ${VisibilityModel>Name} + ' (' + ${VisibilityModel>ACType} + ')' }"
                                class="bedCardTitle"
                            />

                            <Text
                                text="{VisibilityModel>Description}"
                                class="bedCardDesc"
                                maxLines="4"
                                wrapping="true"
                            />

                            <Text
                                text="{
                                    parts: ['VisibilityModel>Currency','VisibilityModel>BasicPrice'],
                                    formatter: '.Formatter.formatStartingPrice'
                                }"
                                class="bedCardPrice"
                            />

                            <HBox
                                justifyContent="Center"
                                alignItems="Center"
                                class="sapUiTinyMarginTop"
                            >
                                <Toolbar
                                    class="pillActionBar sapUiTinyMarginTop"
                                    design="Transparent"
                                >
                                    <Button
                                        text="View Details"
                                        type="Transparent"
                                        press="onViewDetailsPress"
                                        class="pillActionBtn pillLeft"
                                    />

                                    <ToolbarSpacer width="1px" />

                                    <Button
                                        text="Enquiry"
                                        type="Transparent"
                                        press="onEnquiryPress"
                                        class="pillActionBtn pillRight"
                                    />
                                </Toolbar>
                            </HBox>
                        </VBox>
                    </VBox>
                </l:Grid>

                <VBox
                    alignItems="Center"
                    class="sapUiTinyMarginTop sapUiTinyMarginBottom"
                    visible="{VisibilityModel>/ShowViewMore}"
                >
                    <Link
                        id="idViewMoreBusy1"
                        text="{i18n>viewmorerooms}"
                        press="onViewMoreRooms"
                        class="btnViewDetails"
                    />
                    <VBox height="2rem" />
                </VBox>
            </VBox>
        </content>
    </Page>
</mvc:View>
