<mvc:View controllerName="sap.ui.com.project1.controller.View_Rooms"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
	xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core"
	xmlns:uxap="sap.uxap"
	xmlns:f="sap.ui.layout.form"
	xmlns:fb="sap.ui.comp.filterbar"
	displayBlock="true"
	height="100%"
	busyIndicatorDelay="0">
	<Page
		showHeader="true"
		enableScrolling="true"
		class="RoomsPage roomsBgPage">
		<headerContent >
			<core:Fragment
				fragmentName="sap.ui.com.project1.fragment.BookingHeader"
				type="XML" />
		</headerContent>
		<content>
			<uxap:ObjectPageLayout
				id="VR_id_ObjectPageLayout"
				useIconTabBar="false"
				showTitleInHeaderContent="true"
				class="vrObjectPageLayout roomsBgLayout"
				
					>

				<uxap:headerTitle>
					<uxap:ObjectPageDynamicHeaderTitle>
						<uxap:expandedHeading>
							<HBox>
								<Title
									text="{BranchModel>/Name}"
									wrapping="true" />
							</HBox>
						</uxap:expandedHeading>
						<uxap:snappedHeading>
							<FlexBox
								fitContainer="true"
								alignItems="Center">
								<Avatar
									src="{= 'data:image/jpeg;base64,' + ${BranchModel>/Photo1} }"
									displaySize="L"
									displayShape="Square"
									class="vrSquareAvatarSmall sapUiTinyMarginEnd sapUiAvatarImageContain" />
								<Title
									text="{BranchModel>/Name}"
									wrapping="true" />
							</FlexBox>
						</uxap:snappedHeading>
						<uxap:expandedContent>
							<Text text="{BranchModel>/PropertyType}" />
						</uxap:expandedContent>
						<uxap:snappedContent>
							<Text text="{BranchModel>/PropertyType}" />
						</uxap:snappedContent>
					</uxap:ObjectPageDynamicHeaderTitle>
				</uxap:headerTitle>
	
		<uxap:headerContent>
    <FlexBox
        wrap="Wrap"
        fitContainer="true"
        alignItems="Start"
        class="sapUiTinyMarginTop"
    >
        <Avatar
            src="{= 'data:image/jpeg;base64,' + ${BranchModel>/Photo1} }"
            displaySize="XL"
            displayShape="Square"
            class="vrSquareAvatarLarge sapUiMediumMarginEnd sapUiSmallMarginBottom sapUiAvatarImageContain"
        />

        <VBox
            class="sapUiLargeMarginEnd sapUiSmallMarginBottom"
            width="350px"
        >
            <HBox
                alignItems="Center"
                class="sapUiTinyMarginBottom"
            >
                <Label
                    text="Email Address:"
                    design="Bold"
                    width="120px"
                />
                <Link
                    text="{BranchModel>/EmailID}"
                    href="{= 'mailto:' + ${BranchModel>/EmailID} }"
                />
            </HBox>

            <HBox
                alignItems="Center"
                class="sapUiTinyMarginBottom"
            >
                <Label
                    text="Contact Number:"
                    design="Bold"
                    width="120px"
                />
                <Link
                    text="{BranchModel>/STD} {BranchModel>/Contact}"
                    href="{= 'tel:' + ${BranchModel>/Contact} }"
                />
            </HBox>

            <HBox
                alignItems="Center"
                class="sapUiTinyMarginBottom"
            >
                <Label
                    text="User Rating:"
                    design="Bold"
                    width="120px"
                />
                <HBox alignItems="Center">
                    <RatingIndicator
                        value="{= Number(${VisibilityModel>/AverageRating}) || 0 }"
                        maxValue="5"
                        enabled="false"
                        iconSize="1.1rem"
                        class="vrRatingStars sapUiTinyMarginEnd"
                    />
                    <Text
                        text="{= '(' + (${VisibilityModel>/TotalFeedbacks} || 0) + ')' }"
                        class="vrRatingCount"
                    />
                </HBox>
            </HBox>
        </VBox>

        <VBox
            class="sapUiSmallMarginBottom"
            width="450px"
        >
            <HBox
                alignItems="Center"
                class="sapUiTinyMarginBottom"
                visible="{= !!${BranchModel>/GSTIN} }"
            >
                <Label
                    text="GSTIN:"
                    design="Bold"
                    width="80px"
                />
                <Text text="{BranchModel>/GSTIN}" />
            </HBox>

            <HBox alignItems="Start">
                <Label
                    text="Address:"
                    design="Bold"
                    width="80px"
                    class="sapUiTinyMarginTop"
                />
                <Link
                    text="{BranchModel>/Address}"
                    href="{BranchModel>/GeoLocation}"
                    target="_blank"
                    wrapping="true"
                    class="sapUiTinyMarginTop"
                />
            </HBox>
        </VBox>
    </FlexBox>
</uxap:headerContent>
	

				<uxap:sections >
					<!-- AC Rooms Tab Section -->
					<uxap:ObjectPageSection
					visible="{= ${VisibilityModel>/isDataLoaded} &amp;&amp; ${VisibilityModel>/ACRooms}.length > 0 }"				id="VR_id_ACSection"
						title="AC Rooms"
						titleUppercase="false" >
						<uxap:subSections>
							<uxap:ObjectPageSubSection
								id="VR_id_ACSubSection"
							visible="{= ${VisibilityModel>/isDataLoaded} &amp;&amp; ${VisibilityModel>/ACRooms}.length > 0}" 
								class=""
								>
								<uxap:blocks>
									<VBox>
										<!-- <Title
											text="AC Rooms"
											level="H2"
											class="roomHeaderTitle sapUiMediumMarginBeginEnd"
											visible="{= ${VisibilityModel>/isDataLoaded} &amp;&amp; ${VisibilityModel>/ACRooms}.length > 0}" /> -->
										<VBox class="sapUiTinyMarginTop">
											<l:Grid
												id="idBedTypeFlex2"
												defaultSpan="XL4 L4 M6 S12"
												containerQuery="true"
												hSpacing="2"
												vSpacing="2"
												content="{path: 'VisibilityModel>/ACRooms'}">
												<VBox class="bedCard">
													<Carousel
														height="300px"
														width="100%"
														loop="true"
														showPageIndicator="false"
														backgroundDesign="Transparent"
														class="roomCardCarousel"
														pages="{path: 'VisibilityModel>Images', templateShareable: false}">
														<pages>
															<VBox class="imageWrapper">
																<HBox class="areaTagBox">
																	<core:Icon
																		src="sap-icon://building"
																		size="0.9rem"
																		color="black"
																		class="sapUiTinyMarginEnd" />
																	<Text text="{VisibilityModel>Area}" />
																</HBox>
																<Image
																	src="{VisibilityModel>src}"
																	width="100%"
																	height="300px"
																	class="bedCardImage"
																	decorative="false" />
															</VBox>
														</pages>
													</Carousel>
													<VBox class="bedCardContent">
														<Text
															text="{= ${VisibilityModel>Name} + ' (' + ${VisibilityModel>ACType} + ')' }"
															class="bedCardTitle" />
														<Text
															text="{VisibilityModel>Description}"
															class="bedCardDesc"
															maxLines="4"
															wrapping="true" />
														<Text
															text="{
																parts: ['VisibilityModel>Currency','VisibilityModel>BasicPrice'],
																formatter: '.Formatter.formatStartingPrice'
															}"
															class="bedCardPrice" />
														<HBox
															justifyContent="Center"
															alignItems="Center"
															class="sapUiTinyMarginTop">
															<Link
																text="Book Room"
																press="onViewDetailsPress"
																class="pillActionBtn pillLeft" />
															<Link
																text="Enquiry"
																press="onEnquiryPress"
																class="pillActionBtn pillRight" />
														</HBox>
													</VBox>
												</VBox>
											</l:Grid>
											<VBox
												alignItems="Center"
												class="sapUiTinyMarginTop sapUiTinyMarginBottom"
												visible="{VisibilityModel>/ShowViewMore}">
												<VBox height="2rem" />
											</VBox>
										</VBox>
									</VBox>
								</uxap:blocks>
							</uxap:ObjectPageSubSection>
						</uxap:subSections>
					</uxap:ObjectPageSection>

					<!-- Non-AC Rooms Tab Section -->
					<uxap:ObjectPageSection
						id="VR_id_NonACSection"
						title="Non-AC Rooms"
						titleUppercase="false"
						
						visible="{= ${VisibilityModel>/isDataLoaded} &amp;&amp; ${VisibilityModel>/NonACRooms}.length > 0 }">
						<uxap:subSections>
							<uxap:ObjectPageSubSection
								id="VR_id_NonACSubSection"
								title="Non-AC Rooms"
								visible="{= ${VisibilityModel>/isDataLoaded} &amp;&amp; ${VisibilityModel>/NonACRooms}.length > 0}" >
									
								
								<uxap:blocks>
									<VBox>
										<!-- <Title
											text="Non-AC Rooms"
											level="H2"
											class="roomHeaderTitle sapUiMediumMarginBegin sapUiTinyMarginTop"
											visible="{= ${VisibilityModel>/isDataLoaded} &amp;&amp; ${VisibilityModel>/NonACRooms}.length > 0}" /> -->
										<VBox class="sapUiTinyMarginTop">
											<l:Grid
												id="idBedTypeFlex1"
												defaultSpan="XL3 L4 M6 S12"
												containerQuery="true"
												hSpacing="2"
												vSpacing="2"
												content="{path: 'VisibilityModel>/NonACRooms'}">
												<VBox class="bedCard">
													<Carousel
														height="300px"
														width="100%"
														loop="true"
														showPageIndicator="false"
														backgroundDesign="Transparent"
														class="roomCardCarousel"
														pages="{path: 'VisibilityModel>Images', templateShareable: false}">
														<pages>
															<VBox class="imageWrapper">
																<HBox class="areaTagBox">
																	<core:Icon
																		src="sap-icon://building"
																		size="0.9rem"
																		color="black"
																		class="sapUiTinyMarginEnd" />
																	<Text text="{VisibilityModel>Area}" />
																</HBox>
																<Image
																	src="{VisibilityModel>src}"
																	width="100%"
																	height="300px"
																	class="bedCardImage"
																	decorative="false" />
															</VBox>
														</pages>
													</Carousel>
													<VBox class="bedCardContent">
														<Text
															text="{= ${VisibilityModel>Name} + ' (' + ${VisibilityModel>ACType} + ')' }"
															class="bedCardTitle" />
														<Text
															text="{VisibilityModel>Description}"
															class="bedCardDesc"
															maxLines="4"
															wrapping="true" />
														<Text
															text="{
																parts: ['VisibilityModel>Currency','VisibilityModel>BasicPrice'],
																formatter: '.Formatter.formatStartingPrice'
															}"
															class="bedCardPrice" />
														<HBox
															justifyContent="Center"
															alignItems="Center"
															class="sapUiTinyMarginTop">
															<Link
																text="Book Room"
																press="onViewDetailsPress"
																class="pillActionBtn pillLeft" />
															<Link
																text="Enquiry"
																press="onEnquiryPress"
																class="pillActionBtn pillRight" />
														</HBox>
													</VBox>
												</VBox>
											</l:Grid>
											<VBox
												alignItems="Center"
												class="sapUiTinyMarginTop sapUiTinyMarginBottom"
												visible="{VisibilityModel>/ShowViewMore}">
												<VBox height="2rem" />
											</VBox>
										</VBox>
									</VBox>
								</uxap:blocks>
							</uxap:ObjectPageSubSection>
						</uxap:subSections>
					</uxap:ObjectPageSection>

					<uxap:ObjectPageSection
						id="VR_id_NoDataSection"
						title=""
						titleUppercase="false"
						visible="{= ${VisibilityModel>/isDataLoaded} &amp;&amp; ${VisibilityModel>/NonACRooms}.length === 0 &amp;&amp; ${VisibilityModel>/ACRooms}.length === 0 }">
						<uxap:subSections>
							<uxap:ObjectPageSubSection id="VR_id_NoDataSubSection">
								<uxap:blocks>
									<VBox
										height="300px"
										justifyContent="Center"
										alignItems="Center">
										<Text
											text="{i18n>noRoomsFound}"
											class="cssNoDataMessage" />
										<Text
											text="{i18n>pleaseselectanotherCity}"
											class="cssNoDataSubMessage" />
									</VBox>
								</uxap:blocks>
							</uxap:ObjectPageSubSection>
						</uxap:subSections>
					</uxap:ObjectPageSection>
				</uxap:sections>
			</uxap:ObjectPageLayout>
		</content>
	</Page>
</mvc:View>