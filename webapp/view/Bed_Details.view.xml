<mvc:View
    controllerName="sap.ui.com.project1.controller.Bed_Details"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:m="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%"
    busyIndicatorDelay="0"
>
    <Page showHeader="true">
        <headerContent>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.Header"
                type="XML"
            />
        </headerContent>
        <content>
            <fb:FilterBar
                id="BD_id_FilterbarEmployee"
                persistencyKey="myPersKey"
                useToolbar="false"
                clear="PO_onPressClear"
                showClearOnFB="true"
                search="Onsearch"
                filterChange="IA_.onFilterChange"
                afterVariantLoad="IA_.onAfterVariantLoad"
                showFilterConfiguration="false"
                filterContainerWidth="auto"
                class="filterBarTheme"
            >
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="Bed Type"
                        label="{i18n>bedType}"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="PO_id_CustomerName"
                                items="{BedDetails>/}"
                                showClearIcon="true"
                            >
                                <core:Item
                                    key="{BedDetails>Name}"
                                    text="{BedDetails>Name}"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="Room Type"
                        label="{i18n>roomtype}"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="PO_id_CompanyName"
                                showClearIcon="true"
                            >
                                <core:ListItem
                                    key="AC"
                                    text="AC"
                                />
                                <core:ListItem
                                    key="NON-AC"
                                    text="NON-AC"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>
            <Table
                id="id_BedTable"
                sticky="ColumnHeaders,HeaderToolbar"
                mode="MultiSelect"
                width="auto"
                busyIndicatorDelay="0"
                class="sapUiResponsiveMargin"
                items="{path: 'BedDetails>/', sorter: {path: 'BranchName',descending: false,group: true}}"
            >
                <headerToolbar>
                    <OverflowToolbar>
                        <Title
                            text="{i18n>bedList} ({= ${BedDetails>/}.length})"
                        />
                        <ToolbarSpacer />
                        <Button
                            text="{i18n>addBed}"
                            tooltip="{i18n>addBed}"
                            press="HM_RoomDetails"
                            class="myUnifiedBtn"
                              visible="{= ${LoginModel>/Role} !== 'Front Office Employee' }"
                        />
                        <Button
                            text="{i18n>MSdelete}"
                            tooltip="{i18n>deleteSelectedBeds}"
                            press="HM_DeleteDetails"
                            class="myUnifiedBtn"
                           visible="{= ${LoginModel>/Role} !== 'Front Office Employee' }"

                        />
                        <Button
                            text="{i18n>download}"
                            icon="sap-icon://excel-attachment"
                            tooltip="{i18n>downloadBedDetails}"
                            press="BD_onDownload"
                            class="myUnifiedBtn"
                             visible="{= ${LoginModel>/Role} !== 'Front Office Employee' }"

                        />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column demandPopin="true">
                        <Text
                            text="{i18n>bedType}"
                            tooltip="{i18n>bedType}"
                        />
                    </Column>
                    <Column demandPopin="true">
                        <Text
                            text="{i18n>roomtype}"
                            tooltip="{i18n>roomtype}"
                        />
                    </Column>
                    <Column demandPopin="true">
                        <Text
                            text="{i18n>noofRooms}"
                            tooltip="{i18n>noofRooms}"
                        />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text
                            text="{i18n>noofPerson}"
                            tooltip="{i18n>noofPerson}"
                        />
                    </Column>
                        <Column demandPopin="true">
                        <Text
                            text="{i18n>extraBed}"
                            tooltip="{i18n>extraBed}"
                        />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text
                            text="Deposit Amount"
                            tooltip="Deposit Amount"
                        />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text
                            text="{i18n>description}"
                            tooltip="{i18n>description}"
                        />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem
                        type="Navigation"
                        press="onColumnListItemPress"
                    >
                        <cells>
                            <Text text="{BedDetails>Name}" />
                            <Text text="{BedDetails>ACType}" />
                            <Text text="{BedDetails>MaxBeds}" />
                            <Text text="{BedDetails>NoOfPerson}" />
                            <Text text="{BedDetails>ExtraBed}" />

                             <Text
                                text="{parts: ['BedDetails>Deposit','BedDetails>DepositCurrency'],
									formatter: '.Formatter.formatPrice'}"
                            />
                            <ExpandableText
                                text="{BedDetails>Description}"
                                maxCharacters="20"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <footer>
         <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.AppFooter"
                type="XML"
            />
        </footer>
    </Page>
</mvc:View>
