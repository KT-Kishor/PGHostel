<mvc:View
    controllerName="sap.ui.com.project1.controller.NotFound"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
    displayBlock="true">
	<Page
        title="Page Not Found"
        showNavButton="true"
        navButtonPress="onNavBack">
		<content>
			<IllustratedMessage
                illustrationType="sapIllus-ErrorScreen"
                title="Page Not Found"
                description="The link you followed is invalid or expired." />
		</content>
        <footer>
			<core:Fragment
                fragmentName="sap.ui.com.project1.fragment.AppFooter"
                type="XML"
            />
		</footer>
	</Page>
</mvc:View>
