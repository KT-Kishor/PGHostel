<mvc:View controllerName="sap.ui.com.project1.controller.Facilitis"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:m="sap.m"
	xmlns:c="sap.ui.core"
	xmlns:fb="sap.ui.comp.filterbar"
	xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%"
    busyIndicatorDelay="0">
	<Page showHeader="true">
		<headerContent>
			<core:Fragment fragmentName="sap.ui.com.project1.fragment.Header" type="XML"/>
		</headerContent>
		<content>
			<fb:FilterBar id="FO_id_FilterbarEmployee" persistencyKey="myPersKey" useToolbar="false"
                clear="FC_onPressClear" showClearOnFB="true" search="FC_onSearch" filterChange="IA_.onFilterChange"
                afterVariantLoad="IA_.onAfterVariantLoad" showFilterConfiguration="false"
                filterContainerWidth="auto" class="filterBarTheme">
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="FacilityName" label="{i18n>facilityname}" groupName="Group"
                        visibleInFilterBar="true">
						<fb:control>
							<ComboBox id="FN_id_FacilityName" items="{facilitiesDataModelInitial>/}"
                            showClearIcon="true" busyIndicatorDelay="0">
								<core:Item key="{facilitiesDataModelInitial>FacilityName}"
                                    text="{facilitiesDataModelInitial>FacilityName}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="BranchCode" label="{i18n>MSbranchCode}" groupName="Group"
                        visibleInFilterBar="true">
						<fb:control>
							<ComboBox id="FN_id_BranchCode" items="{BranchModel>/}"
                            showClearIcon="true"  showSecondaryValues="true"  busyIndicatorDelay="0">
								<core:ListItem key="{BranchModel>BranchID}" text="{BranchModel>BranchID} - {BranchModel>Name}"
                                    additionalText="{BranchModel>City}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table id="id_facilityTable" sticky="ColumnHeaders,HeaderToolbar" mode="MultiSelect"
            width="auto" busyIndicatorDelay="0" items="{path: 'Facilities>/', sorter: {path: 'BranchName',descending: false,group: true},groupHeaderFactory: '.getGroupHeader'}">
				<headerToolbar>
					<OverflowToolbar>
						<Title text="{i18n>facilities} ({= ${Facilities>/}.length})"/>
						<ToolbarSpacer />
						<Button text="{i18n>addFacility}" tooltip="{i18n>addFacility}" press="FD_RoomDetails"
                        class="myUnifiedBtn" visible="{= ${LoginModel>/Role} !== 'Front Office Employee' }"/>
						<Button text="{i18n>MSdelete}" tooltip="{i18n>MSdelete}" press="HM_DeleteDetails"
                        class="myUnifiedBtn" visible="{= ${LoginModel>/Role} !== 'Front Office Employee' }"/>
						<Button text="{i18n>download}" icon="sap-icon://excel-attachment" tooltip="{i18n>download}"
                        press="MD_onDownload" class="myUnifiedBtn" visible="{= ${LoginModel>/Role} !== 'Front Office Employee'}"/>
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column demandPopin="true">
						<Text text="{i18n>facilityname}" tooltip="{i18n>facilityname}"/>
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>type}" tooltip="{i18n>type}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet">
						<Text text="{i18n>hourlyPrice}" tooltip="{i18n>hourlyPrice}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet">
						<Text text="{i18n>dailyPrice}" tooltip="{i18n>dailyPrice}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet">
						<Text text="{i18n>monthlyPrice}" tooltip="{i18n>monthlyPrice}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet">
						<Text text="{i18n>yearlyPrice}" tooltip="{i18n>yearlyPrice}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet">
						<Text text="{i18n>selectionMode}" tooltip="{i18n>selectionMode}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet">
						<Text text="{i18n>unitPrice}" tooltip="{i18n>unitPrice}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet">
    <Text
        text="{i18n>facilityDetails}"
        tooltip="{i18n>facilityDetails}" />
</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="FD_onFacilityRowPress">
						<cells>
							<Text text="{Facilities>FacilityName}" />
							<Text text="{Facilities>Type}" />
							<Text text="{parts: ['Facilities>PerHourPrice','Facilities>Currency'], formatter: '.Formatter.formatPrice'}"/>
							<Text text="{parts: ['Facilities>PerDayPrice','Facilities>Currency'], formatter: '.Formatter.formatPrice'}"/>
							<Text text="{parts: ['Facilities>PerMonthPrice','Facilities>Currency'], formatter: '.Formatter.formatPrice'}"/>
							<Text text="{parts: ['Facilities>PerYearPrice','Facilities>Currency'], formatter: '.Formatter.formatPrice'}"/>
							<Text text="{path:'Facilities>SelectionMode', formatter: '.Formatter.formatSelectionMode'}" />
							<Text text="{parts: ['Facilities>UnitPrice','Facilities>Currency'], formatter: '.Formatter.formatPrice'}"/>
							<Text
    text="{
        parts: [
            'Facilities>MinimumQty',
            'Facilities>MinimumPrice',
            'Facilities>Currency',
            'Facilities>FacilityChargeType'
        ],
        formatter: '.Formatter.formatFacilityDetails'
    }"
/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<core:Fragment fragmentName="sap.ui.com.project1.fragment.AppFooter" type="XML"/>
		</footer>
	</Page>
</mvc:View>