<mvc:View controllerName="sap.ui.com.project1.controller.VendorDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns:suite="sap.suite.ui.commons"
    xmlns="sap.uxap"
    xmlns:uxap="sap.uxap"
    xmlns:richtexteditor="sap.ui.richtexteditor"
    xmlns:layout="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:c="sap.ui.core"
    displayBlock="true"
    height="100%"
    xmlns:core="sap.ui.core"
    busyIndicatorDelay="0"
    xmlns:u="sap.ui.unified">
    <m:Page navButtonPress="BI_onButtonPress" showNavButton="true" title="{i18n>MVDtitle}">
        <ObjectPageLayout id="V_id_ObjectPageLayout">
            <sections>
                <ObjectPageSection
                    titleUppercase="false"
                    id="V_id_OrderHeaderSection1"
                    title="{i18n>MVDpersonalDetails}"
                >
                    <subSections>
                    <ObjectPageSubSection>
                        <blocks>
                            <m:VBox class="sapUiSmallMarginBegin sapUiSmallMarginTop">
                            <m:Label text="Reason for Review Return" class="boldBlackText" />
                            <m:MessageStrip
                            text="{AdminSignupModel>/AdminComment}"
                            type="Warning"
                            showIcon="true" />
                            </m:VBox>
                        </blocks>
                    </ObjectPageSubSection>
                        <ObjectPageSubSection id="V_id_dsd1">
                            <blocks>
                                <f:SimpleForm
                                    id="V_id_DimpleForm"
                                    editable="true"
                                    layout="ColumnLayout"
                                    labelSpanXL="4"
                                    labelSpanL="3"
                                    labelSpanM="4"
                                    labelSpanS="12"
                                    adjustLabelSpan="false"
                                    emptySpanXL="0"
                                    emptySpanL="0"
                                    emptySpanM="0"
                                    emptySpanS="0"
                                    columnsXL="2"
                                    columnsL="2"
                                    columnsM="1"
                                >
                                    <f:toolbar>
                                        <m:Toolbar>
                                            <m:Title text="{i18n>MVDtitle}" />
                                            <m:ToolbarSpacer />
                                            <m:Button
                                                class="myUnifiedBtn"
                                                text="{= ${editable>/Edit} ? 'Submit' : 'Edit' }"
                                                press="onEditOrSavePress"
                                                enabled="{= ${AdminSignupModel>/Status} !== 'Submitted' }"
                                            />
                                        </m:Toolbar>
                                    </f:toolbar>
                                    <f:content>
                                        <m:Label
                                            text="{i18n>MVDname}"
                                            required="true"
                                        />
                                        <m:ComboBox
                                            id="V_id_adminSalutation"
                                            selectedKey="{AdminSignupModel>/Salutation}"
                                            editable="{editable>/Edit}"
                                            change="onAdminChangeSalutation"
                                            placeholder="Mr."
                                            valueStateText="{i18n>MVDsalutation}"
                                        >
                                            <core:ListItem
                                                key="Mr."
                                                text="Mr."
                                            />
                                            <core:ListItem
                                                key="Ms."
                                                text="Ms."
                                            />
                                            <core:ListItem
                                                key="Mrs."
                                                text="Mrs."
                                            />
                                            <core:ListItem
                                                key="Dr."
                                                text="Dr."
                                            />
                                        </m:ComboBox>
                                        <m:Input
                                            value="{AdminSignupModel>/VendorName}"
                                            liveChange="onAdminLiveValidate"
                                            editable="{editable>/Edit}"
                                            id="V_id_VendorName"
                                            valueStateText="{i18n>enterMVDname}"
                                            maxLength="50"
                                        />
                                        <m:Label
                                            text="{i18n>MVDDOB}"
                                            required="true"
                                        />
                                        <m:DatePicker
                                            value="{AdminSignupModel>/DateOfBirth}"
                                            valueStateText="{i18n>MVDdob}"
                                            displayFormat="dd/MM/yyyy"
                                            valueFormat="dd/MM/yyyy"
                                            change="onChangeDOB"
                                            editable="{editable>/Edit}"
                                            id="V_id_VendorDOB"
                                            initialFocusedDateValue="{controller>/focusedDate}"
                                            minDate="{controller>/minDate}"
                                        />
                                        <m:Label
                                            text="{i18n>MVgender}"
                                            required="true"
                                        />
                                        <m:Select
                                            selectedKey="{AdminSignupModel>/Gender}"
                                            change="ADMIN_onChangeGender"
                                            editable="{editable>/Edit}"
                                            id="V_id_Gender"
                                            valueStateText="{i18n>MVgender}"
                                        >
                                            <core:Item
                                                key="Male"
                                                text="Male"
                                            />
                                            <core:Item
                                                key="Female"
                                                text="Female"
                                            />
                                            <core:Item
                                                key="Other"
                                                text="Other"
                                            />
                                        </m:Select>
                                        <m:Label
                                            text="{i18n>emailId}"
                                            required="true"
                                        />
                                        <m:Input
                                            value="{AdminSignupModel>/Email}"
                                            type="Email"
                                            maxLength="50"
                                            placeholder="{i18n>enterEmailId}"
                                            liveChange="onAdminLiveValidate"
                                            editable="false"
                                            id="V_id_Email"
                                            valueStateText="{i18n>MSenterValidEmail}"
                                        />
                                        <m:Label
                                            text="{i18n>MVDcountry}"
                                            required="true"
                                        />
                                        <m:ComboBox
                                            selectedKey="{AdminSignupModel>/Country}"
                                            change="ADMIN_onChangeCountry"
                                            id="V_id_Country"
                                            selectionChange="ADMIN_onChangeCountry"
                                            placeholder="{i18n>selectCountry}"
                                            valueStateText="{i18n>MVDselectcountry}"
                                            items="{path:'CountryModel>/', length:1000}"
                                            showSecondaryValues="true"
                                            editable="{editable>/Edit}"
                                        >
                                            <core:ListItem
                                                key="{CountryModel>countryName}"
                                                text="{CountryModel>countryName}"
                                                additionalText="{CountryModel>code}"
                                            />
                                        </m:ComboBox>
                                        <m:Label
                                            text="{i18n>MVDstate}"
                                            required="true"
                                        />
                                        <m:ComboBox
                                            selectedKey="{AdminSignupModel>/State}"
                                            change="ADMIN_onChangeState"
                                            items="{StateModel>/}"
                                            editable="{editable>/Edit}"
                                            placeholder="{i18n>selectState}"
                                            valueStateText="{i18n>MSselectState}"
                                            showSecondaryValues="true"
                                            id="V_id_State"
                                        >
                                            <core:ListItem
                                                key="{StateModel>stateName}"
                                                text="{StateModel>stateName}"
                                            />
                                        </m:ComboBox>
                                        <m:Label
                                            text="{i18n>city}"
                                            required="true"
                                        />
                                        <m:ComboBox
                                            selectedKey="{AdminSignupModel>/City}"
                                            change="ADMIN_onChangeCity"
                                            selectionChange="ADMIN_onChangeCity"
                                            placeholder="{i18n>cityValueText}"
                                            valueStateText="{i18n>MSselectCity}"
                                            id="V_id_City"
                                            items="{path:'CityModel>/', length:1000}"
                                            showSecondaryValues="true"
                                            editable="{editable>/Edit}"
                                        >
                                            <core:ListItem
                                                key="{CityModel>cityName}"
                                                text="{CityModel>cityName}"
                                                additionalText="{CityModel>branchCode}"
                                            />
                                        </m:ComboBox>
                                        <m:Label
                                            text="{i18n>MSmobileNo}"
                                            required="true"
                                        />
                                        <m:ComboBox
                                            selectedKey="{AdminSignupModel>/STDCode}"
                                            change="ADMIN_onChangeSTD"
                                            placeholder="ISD"
                                            showSecondaryValues="true"
                                            valueStateText="{i18n>MSselectCode}"
                                            width="100%"
                                            items="{path:'CountryModel>/', length:1000}"
                                            filterSecondaryValues="true"
                                            editable="{editable>/Edit}"
                                            id="V_id_StdCode"
                                        >
                                            <core:ListItem
                                                key="{CountryModel>stdCode}"
                                                text="{CountryModel>stdCode}"
                                                additionalText="{CountryModel>code}"
                                            />
                                        </m:ComboBox>
                                        <m:Input
                                            value="{AdminSignupModel>/Mobile}"
                                            maxLength="18"
                                            liveChange="ADMIN_onMobileLiveChange"
                                            editable="{editable>/Edit}"
                                            id="V_id_MobileNo"
                                            valueStateText="{i18n>mobileNoValueState}"
                                        />
                                        <m:Label
                                            text="{i18n>address}"
                                            required="true"
                                        />
                                        <m:TextArea
                                            value="{AdminSignupModel>/Address}"
                                            maxLength="120"
                                            rows="3"
                                            liveChange="onAdminLiveValidate"
                                            editable="{editable>/Edit}"
                                            id="V_id_Address"
                                            valueStateText="{i18n>enterMVDAddress}"
                                        />
                                    </f:content>
                                </f:SimpleForm>
                            </blocks>
                        </ObjectPageSubSection>
                    </subSections>
                </ObjectPageSection>
                <ObjectPageSection
                    titleUppercase="false"
                    id="connections"
                    title="{i18n>MVDattachments}"
                >
                    <subSections>
                        <ObjectPageSubSection
                            id="connectionsSS"
                            titleUppercase="false"
                        >
                            <blocks>
                                <m:VBox>
                                    <m:VBox
                                        class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop"
                                    >
                                        <m:MessageStrip
                                            text="{i18n>messageStrip}"
                                            showIcon="true"
                                            type="Warning"
                                            class="sapUiTinyMarginBottom"
                                        />
                                    </m:VBox>
                                    <m:Table
                                        id="V_id_adminAttachmentTable"
                                        items="{AdminSignupModel>/Documents}"
                                        mode="SingleSelectLeft"
                                        sticky="ColumnHeaders,HeaderToolbar"
                                        selectionChange="onAdminSelectionChange"
                                    >
                                        <m:headerToolbar>
                                            <m:OverflowToolbar>
                                                <m:Title
                                                    text="{i18n>MVDdocument}"
                                                />
                                                <m:Text
                                                    text="*"
                                                    class="requiredStar"
                                                />
                                                <m:ToolbarSpacer />
                                                <m:ComboBox
                                                    id="V_id_adminDocType"
                                                    selectedKey="{AdminSignupModel>/CurrentDocType}"
                                                    placeholder="{i18n>selectDocument}"
                                                    width="auto"
                                                    change="onDocumentTypeChange"
                                                    valueStateText="{i18n>MVDdoc}"
                                                >
                                                    <core:ListItem
                                                        key="Aadhar Card"
                                                        text="Aadhar Card"
                                                    />
                                                    <core:ListItem
                                                        key="PAN Card"
                                                        text="PAN Card"
                                                    />
                                                    <core:ListItem
                                                        key="Driving License"
                                                        text="Driving License"
                                                    />
                                                    <core:ListItem
                                                        key="Bank Account Proof"
                                                        text="Bank Account Proof"
                                                    />
                                                    <core:ListItem
                                                        key="Other"
                                                        text="Other"
                                                    />
                                                </m:ComboBox>
                                                <!-- Upload button -->
                                                <m:VBox
                                                    id="V_id_adminUploaderWrapper"
                                                >
                                                    <u:FileUploader
                                                        id="V_id_adminFileUploader"
                                                        buttonOnly="true"
                                                        buttonText="{i18n>MVDupload}"
                                                        tooltip="{i18n>MVDupload}"
                                                        uploadOnChange="false"
                                                        change="onAdminFileSelect"
                                                        fileType="jpg,jpeg,png,pdf,doc,docx"
                                                        fileSizeExceed="onFileSizeExceeds"
                                                        maximumFileSize="2MB"
                                                        typeMissmatch="onFileTypeMissmatch"
                                                        sameFilenameAllowed="true"
                                                        iconFirst="true"
                                                        enabled="{editable>/Edit}"
                                                    />
                                                </m:VBox>
                                                <m:Button
                                                    id="V_id_AdminDeleteButton"
                                                    text="{i18n>MSdelete}"
                                                    class="myUnifiedBtn"
                                                    tooltip="{i18n>MSdelete}"
                                                    press="onAdminDeleteFiles"
                                                    enabled="false"
                                                />
                                                <m:Button
                                                    id="V_id_AdminDownloadButton"
                                                    text="{i18n>download}"
                                                    class="myUnifiedBtn"
                                                    tooltip="{i18n>download}"
                                                    press="onAdminDownloadFiles"
                                                    enabled="false"
                                                />
                                            </m:OverflowToolbar>
                                        </m:headerToolbar>
                                         <m:columns>
                                            <m:Column demandPopin="true" minScreenWidth="Tablet" width="auto">
                                                <m:Text
                                                    text="{i18n>filename}"
                                                    tooltip="{i18n>filename}"
                                                    wrapping="true"
                                                />
                                            </m:Column>
                                            <m:Column demandPopin="true">
                                                <m:Text
                                                    text="{i18n>MVDdocumenttype}"
                                                    tooltip="{i18n>MVDdocumenttype}" wrapping="true"
                                                />
                                            </m:Column>
                                            <m:Column demandPopin="true">
                                                <m:Text
                                                    text="{i18n>fileSize}"
                                                    tooltip="{i18n>fileSize}"
                                                />
                                            </m:Column>
                                        </m:columns>
                                        <m:items>
                                            <m:ColumnListItem>
                                                <m:cells>
                                                    <m:VBox width="100%">
                                                        <m:Link
                                                            text="{AdminSignupModel>FileName}"
                                                            press="onAdminPreviewDoc"
                                                            width="100%"
                                                            wrapping="true"
                                                        />
                                                    </m:VBox>
                                                    <m:Text
                                                        text="{AdminSignupModel>DocumentType}"
                                                    />
                                                   <m:Text
                                                        text="{
                                                            path: 'AdminSignupModel>size',
                                                            formatter: '.Formatter.formatFileSize'
                                                        }"
                                                    />
                                                </m:cells>
                                            </m:ColumnListItem>
                                        </m:items>
                                    </m:Table>
                                </m:VBox>
                            </blocks>
                        </ObjectPageSubSection>
                    </subSections>
                </ObjectPageSection>
            </sections>
        </ObjectPageLayout>
    </m:Page>
</mvc:View>