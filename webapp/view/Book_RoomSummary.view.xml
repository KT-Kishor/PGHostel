                <Text
                    text="{i18n>securitydeposit}"
                    tooltip="{i18n>securitydeposit}"
                />
            </Column> -->
            <Column  minScreenWidth="Desktop"
                        demandPopin="true">
                <Text
                    text="{i18n>totalcost}"
                    tooltip="{i18n>totalcost}"
                />
            </Column>
        </columns>

        <items>
            <ColumnListItem>
                <cells>
                    <Text text="{HostelModel>FullName}" />
                    <!-- <Text
                        text="{parts: [
        'HostelModel>TotalFacilityPrice',
        'HostelModel>/Currency'
    ],formatter: '.Formatter.formatCurrency'}"
                    /> -->
                    <!-- <Text
                        text="{parts: [
        'HostelModel>RoomRentPerPerson',
        'HostelModel>/Currency'
    ],formatter: '.Formatter.formatCurrency'}"
                    /> -->
                    <!-- <Text text="{parts: [
        'HostelModel>Deposit'
    ],formatter: '.Formatter.formatCurrency'}"/> -->
                    <Text
                        class="totalColumnBold"
                        text="{ parts: [
        'HostelModel>FinalTotalCost',
        'HostelModel>/Currency'
    ],formatter: '.Formatter.formatCurrency'}"
                    />
                </cells>
            </ColumnListItem>
        </items>
    </Table>

    <FlexBox
        class="custom-flexbox"
        direction="Column"
    >
        <!-- Totals for THIS person (NOTE: all RELATIVE, no leading "/") -->
        <VBox class="sapUiSmallMarginTop custom-vbox">
            <HBox
                id="SummaryCouponid"
                width="100%"
                justifyContent="End"
                alignItems="Center"
                class="sapUiSmallMarginBottom couponContainer"
                visible="{= (${LoginModel>/UserID} ? true : false)
        || (${LoginModel>/EmployeeID} ? true : false) }"
            >
                <!-- Coupon Label -->
                <Label
                    text="{i18n>couponCode}"
                    class="totalColumnBold1 sapUiTinyMarginEnd"
                    width="120px"
                />

                <!-- Coupon Input -->
                <Input
                    value="{HostelModel>/CouponCode}"
                    placeholder="{i18n>enterCoupon}"
                    width="150px"
                    class="sapUiTinyMarginEnd couponInput"
                    id="BookingcouponInput"
                    showValueHelp="true"
                    valueHelpIconSrc="sap-icon://decline"
                    tooltip="{i18n>cancelCoupon}"
                    valueHelpRequest="oncancelCoupon"
                    change="onCouponLiveChange"
                />

                <!-- Apply Now Button -->
                <Button
                    text="{i18n>applyNow}"
                    type="Emphasized"
                    tooltip="{i18n>applyCoupon}"
                    press="onChangeCouponCode"
                    class="sapUiTinyMarginEnd"
                    id="couponApplyBtn"
                    visible="{HostelModel>/CouponButtonVisible}"
                />
            </HBox>
