<mvc:View
    controllerName="sap.ui.com.project1.controller.Book_RoomSummary"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:object="sap.uxap"
>
    <VBox class="sapUiMediumMarginBottom">
        <core:Fragment
            fragmentName="sap.ui.com.project1.fragment.GeneralInfoDisplay"
            type="XML"
        />
    </VBox>

    <!-- Personal Info Section -->
    <List
        id="idPersonalSummaryList"
        items="{
            path: 'HostelModel>/Persons'
        }"
        inset="false"
    >
        <CustomListItem>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.PersonalInfoDisplay"
                type="XML"
                binding="{HostelModel>}"
            />
        </CustomListItem>
    </List>
    <Table
        id="idGrandTotalSummaryTable"
        visible="{HostelModel>/ShowSummary}"
        items="{
        path: 'HostelModel>/Persons'
    }"
    >
        <headerToolbar>
            <Toolbar>
                <Title
                    text="{i18n>grandTotalSummary}"
                    tooltip="{i18n>grandTotalSummary}"
                />
            </Toolbar>
        </headerToolbar>

        <columns>
            <Column demandPopin="true">
                <Text
                    text="{i18n>personName}"
                    tooltip="{i18n>personName}"
                />
            </Column>
           <Column demandPopin="true">
                <Text
                    text="{i18n>roomplan}"
                    tooltip="{i18n>roomplan}"
                />
            </Column>
           <Column demandPopin="true">
                <Text
                    text="{= ${HostelModel>/SelectedPriceType} === 'Per Month' ?  'First Payment' : 'Full Payment'}"
                    tooltip="{i18n>roomplan}"
                />
            </Column>
             <Column demandPopin="true" 
            visible="{=
    (
        ${HostelModel>/SelectedPriceType} === 'Per Month' ||
        ${HostelModel>/SelectedPriceType} === 'Per Year'
    )
   &amp;&amp; ${HostelModel>/SelectedMonths} > 1
}">
                <Text
                    text="{i18n>nextpayment}"
                    tooltip="{i18n>nextpayment}"
                />
            </Column>
            
            <Column  minScreenWidth="Desktop"
                        demandPopin="true">
                <Text
                    text="{i18n>totalcost}"
                    tooltip="{i18n>totalcost}"
                />
            </Column>
        </columns>

        <items>
            <ColumnListItem>
                <cells>
                 <!-- <ObjectIdentifier
                            title="{HostelModel>FullName}"
                            text="{
                   parts: [
        'HostelModel>TotalFacilityPrice',
        'HostelModel>/Currency'
    ], formatter: '.Formatter.formatCurrency'
                }"/> -->
                <Text  text="{HostelModel>FullName}"/>
                  
                    <Text
                         text="{
        parts: [                                                                          
            { path: 'HostelModel>/SelectedPriceType' },
            { path: 'HostelModel>/SelectedMonths' },
             { path: 'HostelModel>/TotalDays' }
        ],
        formatter: '.Formatter.formatDurationText'
    }"
                    />
                    <Text
                        text="{
            parts: ['HostelModel>MonthlyCostPerPerson','HostelModel>/Currency'],
            formatter: '.Formatter.formatCurrency'
        }"
                    />
                    
                    <Text
                        text="{
            parts: ['HostelModel>MonthlyCostPerson','HostelModel>/Currency'],
            formatter: '.Formatter.formatCurrency'
        }"
                    />
                   
                    <Text
                        class="totalColumnBold"
                        text="{ parts: [
        'HostelModel>FinalTotalCost',
        'HostelModel>/Currency'
    ],formatter: '.Formatter.formatCurrency'}"
                    />
                </cells>
            </ColumnListItem>
        </items>
    </Table>

    <FlexBox
        class="custom-flexbox"
        direction="Column"
    >
        <!-- Totals for THIS person (NOTE: all RELATIVE, no leading "/") -->
        <VBox class="sapUiSmallMarginTop custom-vbox">
           
                <!-- Coupon Label -->
                <!-- <Label
                    text="{i18n>couponCode}"
                    class="totalColumnBold1 sapUiTinyMarginEnd"
                    width="120px"
                />

              
                <Input
                    value="{HostelModel>/CouponCode}"
                    placeholder="{i18n>enterCoupon}"
                    width="150px"
                    class="sapUiTinyMarginEnd couponInput"
                    id="BookingcouponInput"
                    showValueHelp="true"
                    valueHelpIconSrc="sap-icon://decline"
                    valueHelpRequest="oncancelCoupon"
                    change="onCouponLiveChange"
                /> -->

                <!-- Apply Now Button -->
                <!-- <Button
                    text="{i18n>applyNow}"
                    type="Emphasized"
                    tooltip="{i18n>applyCoupon}"
                    press="onChangeCouponCode"
                    class="sapUiTinyMarginEnd myUnifiedBtn"
                    id="couponApplyBtn"
                    visible="{HostelModel>/CouponButtonVisible}"
                /> -->
                 <HBox
                id="SummaryCouponid"
                width="100%"
                justifyContent="SpaceBetween"
                alignItems="Center"
                class="sapUiSmallMarginBottom couponContainer"
            >
              <MessageStrip
        text="{= 'Secuerity Deposit' +' ' +${HostelModel>/Deposit} +' '+ ${HostelModel>/DepositCurrency}}"
        type="Information"
        showIcon="true"
        class="sapUiTinyMarginEnd"
    />
 
                <Button
                    text="Add Coupon"
                    type="Emphasized"
                    tooltip="{i18n>}"
                    press="onclickaddBTN"
                    class="sapUiTinyMarginEnd myUnifiedBtn"
                    id="addcouponBtn"
                                    />
                                    </HBox>
          
            <HBox
                justifyContent="End"
                class="sapUiSmallMarginTop"
            >
                <Label
                    text="{i18n>grandTotal}"
                    class="totalColumnBold1 sapUiTinyMarginEnd"
                />
                <Text
                    text="{parts:['HostelModel>/GrandTotal','HostelModel>/Currency'], formatter: '.Formatter.formatCurrency'}"
                    class="totalColumnBold1"
                />
                </HBox>
                
            
        </VBox>
    </FlexBox>
  
</mvc:View>