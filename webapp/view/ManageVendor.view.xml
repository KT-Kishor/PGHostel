<mvc:View
    controllerName="sap.ui.com.project1.controller.ManageVendor"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%"
    busyIndicatorDelay="0"
>
    <Page showHeader="true">
        <headerContent>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.Header"
                type="XML"
            />
        </headerContent>
        <content>
            <fb:FilterBar
                id="MV_id_FilterbarEmployee"
                persistencyKey="myPersKey"
                useToolbar="false"
                clear="FC_onPressClear"
                showClearOnFB="true"
                search="Onsearch"
                filterChange="IA_.onFilterChange"
                afterVariantLoad="IA_.onAfterVariantLoad"
                showFilterConfiguration="false"
                filterContainerWidth="auto"
                class="filterBarTheme"
            >
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="User"
                        label="{i18n>MVUserID}"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="MV_id_UserID"
                                items="{mainModel>/}"
                                showClearIcon="true"
                                showSecondaryValues="true"
								filterSecondaryValues="true"
                            >
                               <core:ListItem key="{mainModel>UserID}" text="{mainModel>UserID}" additionalText="{mainModel>UserName}"/>
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem
                        name="Status"
                        label="{i18n>status}"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="MV_id_Status"
                                items="{Vendorstatus>/}"
                                showClearIcon="true"
                            >
                                <core:Item
                                    key="{Vendorstatus>key}"
                                    text="{Vendorstatus>text}"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
					   <fb:FilterGroupItem
                        name="City"
                        label="{i18n>city}"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="MD_id_City"
                                items="{mainModel>/}"
                                showClearIcon="true"
                            >
                                <core:Item
                                    key="{mainModel>City}"
                                    text="{mainModel>City}"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>
            <Table
                id="MV_id_ManageVendor"
                sticky="ColumnHeaders,HeaderToolbar"
                mode="None"
                width="auto"
                busyIndicatorDelay="0"
               items="{
    path: 'mainModel>/',
    sorter: {
        path: 'BranchID',
        group: false
    },
    groupHeaderFactory: '.getGroupHeader'
}"
            >
                <headerToolbar>
                    <OverflowToolbar>
                        <Title
                            text="{i18n>MVDtitle} ({= ${mainModel>/}.length})"
                        />
                        <ToolbarSpacer />
                        <Button
                            text="{i18n>download}"
                            icon="sap-icon://excel-attachment"
                            tooltip="{i18n>download}"
                            press="MS_onDownload"
                            class="myUnifiedBtn"
                        />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column demandPopin="true">
                        <Text
                            text="{i18n>MVUserID}"
                            tooltip="{i18n>MVUserID}"
                        />
                    </Column>

                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
						width="20%"
                    >
                        <Text
                            text="{i18n>emailId}"
                            tooltip="{i18n>emailId}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                    >
                        <Text
                            text="{i18n>MVgender}"
                            tooltip="{i18n>MVgender}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>MSmobileNo}"
                            tooltip="{i18n>MSmobileNo}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                        width="20%"
                        hAlign="Center"
                    >
                        <Text
                            text="{i18n>address}"
                            tooltip="{i18n>address}"
                            textAlign="Center"
                            width="100%"
                        />
                    </Column>
					  <Column
                        demandPopin="true"
                    >
                        <Text
                            text="{i18n>city}"
                            tooltip="{i18n>city}"
                        />
                    </Column>

                </columns>
                <items>
                    <ColumnListItem
                        type="Navigation"
                        press="HM_OnPressManageStaffItem"
                    >
                        <cells>
                            <Text
                                text="{= ${mainModel>Salutation} + ' ' + ${mainModel>UserName} + ' (' + ${mainModel>UserID} + ')' }"
                            />

                            <Text text="{mainModel>EmailID}" />
                            <Text text="{mainModel>Gender}" />
                            <Text
                                text="{mainModel>STDCode} {mainModel>MobileNo}"
                            />
                            <Text
                                text="{mainModel>Address}"
                                wrapping="true"
                            />
                            <Text text="{mainModel>City}" />

                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
          <footer>
            <Bar>
                <contentLeft>
                <FlexBox class="profile-footer-scroll-text" alignItems="Center">
                <items>
                    <FlexBox class="profile-footer-marquee" alignItems="Center"> 

                    <Image
                        src="../image/TransparentKTlogo.png"
                        width="30px"
                        height="30px"
                    />
                    <Link
                        text="{i18n>devlopby}"
                        href="https://kalpavrikshatechnologies.com/"
                        target="_blank"
                        class="customLinkWhiteBg"
                    />
                        </FlexBox>
                    </items>
                    </FlexBox>
                </contentLeft>
            </Bar>
        </footer>
    </Page>
</mvc:View>
