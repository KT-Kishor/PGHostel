<mvc:View controllerName="sap.kt.com.minihrsolution.controller.Listofholidays"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified"
	xmlns:filterbar="sap.ui.comp.filterbar">
	<Page id="LOH_id_ListOfholidays">
		<headerContent>
			<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
		</headerContent>
		<content>
			<filterbar:FilterBar id="LOH_id_AdminFilter"
    useToolbar="false"
    search="onSearch"
    showFilterConfiguration="false">
				<filterbar:filterGroupItems>
					<filterbar:FilterGroupItem 
            name="YearPicker" 
            label="{i18n>year}" 
            groupName="Group1"
            visibleInFilterBar="true">
						<filterbar:control>
							<DatePicker 
                    id="LOH_id_Holidays"
                   value="{path: '/selectedYear', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'yyyy' }}"
                    displayFormat="yyyy"
					valueFormat="yyyy"
                    placeholder="yyyy"/>
						</filterbar:control>
					</filterbar:FilterGroupItem>
			</filterbar:filterGroupItems>
			</filterbar:FilterBar>
			<Table
                 growingScrollToLoad="true"
                     id="LOH_id_HolidayTable"
                     width="auto"
                     items="{path: 'HolidayModel>/'}"
                     growing="true"
                     growingThreshold="50"
                     alternateRowColors="true">
				<headerToolbar>
					<OverflowToolbar>
						<Title  id="LOH_id_Title" text="{i18n>headerListOfHolidays}"/>
						<ToolbarSpacer />
						<Button text="{i18n>import}" icon="sap-icon://sys-next-page" press="LOH_onOpenImport" type="Ghost"/>
						<Button text="{i18n>export}" icon="sap-icon://excel-attachment" press="LOH_onExport" type="Ghost"/>
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>name}" textAlign="Center"></Text>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true" >
						<Text text="{i18n>date}" textAlign="Center"></Text>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>day}" textAlign="Center"></Text>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>karnataka}" textAlign="Center"></Text>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>otherStates}" textAlign="Center"></Text>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>maharashtra}" textAlign="Center"></Text>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>delhi}" textAlign="Center"></Text>
					</Column>
				</columns>
				<items>
					<ColumnListItem>
						<cells>
							<Text text="{HolidayModel>Name}"/>
							<Text text="{path:'HolidayModel>Date' ,formatter:'.Formatter.formatDate'}" />
							<Text text="{HolidayModel>Day}"/>
							<ObjectStatus 
    state="{= ${HolidayModel>Karnataka} === '✓' ? 'Success' : 'Error'}" 
    icon="{= ${HolidayModel>Karnataka} === '✓' ? 'sap-icon://sys-enter-2' : 'sap-icon://error'}" />
							<ObjectStatus 
    state="{= ${HolidayModel>OtherStates} === '✓' ? 'Success' : 'Error'}" 
    icon="{= ${HolidayModel>OtherStates} === '✓' ? 'sap-icon://sys-enter-2' : 'sap-icon://error'}" />
							<ObjectStatus 
    state="{= ${HolidayModel>Maharashtra} === '✓' ? 'Success' : 'Error'}" 
    icon="{= ${HolidayModel>Maharashtra} === '✓' ? 'sap-icon://sys-enter-2' : 'sap-icon://error'}" />
							<ObjectStatus 
    state="{= ${HolidayModel>Delhi} === '✓' ? 'Success' : 'Error'}" 
    icon="{= ${HolidayModel>Delhi} === '✓' ? 'sap-icon://sys-enter-2' : 'sap-icon://error'}" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar>
				<contentLeft>
					<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
				</contentLeft>
				<contentRight></contentRight>
			</Bar>
		</footer>
	</Page>
</mvc:View>