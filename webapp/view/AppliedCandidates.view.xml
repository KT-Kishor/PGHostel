<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="sap.kt.com.minihrsolution.controller.AppliedCandidates"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
>
    <Page>
        <headerContent>
            <core:Fragment
                fragmentName="sap.kt.com.minihrsolution.fragment.Header"
                type="XML"
            />
        </headerContent>
        
        <!-- FilterBar with clear IDs and event handlers -->
        <fb:FilterBar
            id="appliedCandidatesFilterBar"
            persistencyKey="myPersKey"
            useToolbar="false"
            search="onFilterBarSearch"
            clear="onFilterBarClear"
            showClearOnFB="true"
            showFilterConfiguration="false"
        >
            <fb:filterGroupItems>
                <!-- Filter 1: Employee Name (as a text input) -->
                <fb:FilterGroupItem
                    name="name"
                    label="{i18n>compName}"
                    groupName="Group1"
                    visibleInFilterBar="true"
                >
                    <fb:control>
                             <ComboBox
                            name="Name"
                            items="{path: 'UniqueNamesModel>/'}"
                            id="filterEmployeeName"
                            showClearIcon="true"
                        >
                            <core:Item
                                key="{UniqueNamesModel>FullName}"
                                text="{UniqueNamesModel>FullName}"
                            />
                        </ComboBox>
                    </fb:control>
                </fb:FilterGroupItem>

                <!-- Filter 2: Notice Period (as a dropdown) -->
                <fb:FilterGroupItem
                    name="SupplierName"
                    label="{i18n>TableColNoticePeriod}"
                    groupName="Group1"
                    visibleInFilterBar="true"
                >
                    <fb:control>
                        <ComboBox
    id="filterNoticePeriod"
    items="{path: 'ExpectedCTC>/data'}"
    showClearIcon="true"
    selectedKey="">
    <core:Item key="{ExpectedCTC>value}" text="{ExpectedCTC>value}" />
</ComboBox>
                    </fb:control>
                </fb:FilterGroupItem>

                <!-- Filter 3: Skills (as a dropdown) -->
                <fb:FilterGroupItem
                    name="skills"
                    label="{i18n>TableColSkills}"
                    groupName="Group1"
                    visibleInFilterBar="true"
                >
                    <fb:control>
                       <Input
                       id="filterSkills"
                            placeholder="Type skill..."
                            showSuggestion="true"
                            suggest="onSuggestSkills"
                            suggestionItems="{path: 'skillModel>/skills'}"
                        >
                            <core:Item text="{skillModel>skill}" />
                        </Input>
                    </fb:control>
                </fb:FilterGroupItem>
                
                <!-- Filter 4: Experience (as a dropdown) -->
                <fb:FilterGroupItem
                    name="Experince"
                    label="{i18n>TableColExperience}"
                    groupName="Group1"
                    visibleInFilterBar="true"
                >
                    <fb:control>
                        <ComboBox
                            id="filterExperience"
                            items="{path: 'Experience>/data'}"
                            showClearIcon="true"
                        >
                            <core:Item
                                key="{Experience>key}"
                                text="{Experience>value}"
                            />
                        </ComboBox>
                    </fb:control>
                </fb:FilterGroupItem>
            </fb:filterGroupItems>
        </fb:FilterBar>

        <!-- Table with a clear ID -->
        <Table
            id="appliedCandidatesTable"
            items="{DataTableModel>/}"
        >
            <columns>
                <Column><Text text="{i18n>compName}" /></Column>
                <Column><Text text="{i18n>TableColNameHeistQualification}" /></Column>
                <Column><Text text="{i18n>TableColSkills}" /></Column>
                <Column><Text text="{i18n>TableColNoticePeriod}" /></Column>
                <Column><Text text="{i18n>TableColNameJob}" /></Column>
                                <Column><Text text="{i18n>experience}" /></Column>

            </columns>
            <items>
                <ColumnListItem type="Navigation" press="onCandidatePress">
                    <cells>
                        <Text text="{DataTableModel>FullName}" />
                        <Text text="{DataTableModel>HighestQualifaction}" />
                        <Text text="{DataTableModel>Skills}" />
                        <Text text="{DataTableModel>NoticePeriod}" />
                        <Text text="{DataTableModel>JobTitle}" />
                        <Text text="{DataTableModel>Experience} Years" />

                    </cells>
                </ColumnListItem>
            </items>
        </Table>
        <footer>
            <Bar>
                <contentLeft>
                    <core:Fragment
                        fragmentName="sap.kt.com.minihrsolution.fragment.Footer"
                        type="XML"
                    />
                </contentLeft>
            </Bar>
        </footer>
    </Page>
</mvc:View>