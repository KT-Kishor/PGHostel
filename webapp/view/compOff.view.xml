<mvc:View controllerName="sap.kt.com.minihrsolution.controller.compOff" 
	xmlns:mvc="sap.ui.core.mvc" 
	xmlns="sap.m" 
	xmlns:filterbar="sap.ui.comp.filterbar" 
	xmlns:core="sap.ui.core">
	<Page id="AL_id_compOffPage">
		<headerContent>
			<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
		</headerContent>
		<content>
			<filterbar:FilterBar id="AL_id_compofffilterbar" persistencyKey="myPersKey" useToolbar="false" clear="AL_onClear" showClearOnFB="true" search="AL_onSearch" filterChange=".onFilterChange" showFilterConfiguration="false">
				<filterbar:filterGroupItems>
					<filterbar:FilterGroupItem name="dateRange" label="{i18n>dateRange}" groupName="LeaveGroup" visibleInFilterBar="true">
						<filterbar:control>
							<DateRangeSelection id="AL_id_compoff_DateRangeSelection" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy"/>
						</filterbar:control>
					</filterbar:FilterGroupItem>
					<filterbar:FilterGroupItem id="CO_id_compoff_EmpID" name="typeOfLeave" label="Employee ID" groupName="LeaveGroup" visibleInFilterBar="true">
						<filterbar:control>
							<ComboBox id="AL_id_compoff_Leavetype_fil" showClearIcon="true" items="{Employees>/}" showSecondaryValues="true">
								<core:ListItem key="{Employees>EmployeeID}" text="{Employees>EmployeeID}" additionalText="{Employees>EmployeeName}" />
							</ComboBox>
						</filterbar:control>
					</filterbar:FilterGroupItem>
				</filterbar:filterGroupItems>
			</filterbar:FilterBar>
			<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.compoffSmartTable" type="XML" />
		</content>
		<footer>
			<Bar>
				<contentLeft>
					<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML"/>
				</contentLeft>
			</Bar>
		</footer>
	</Page>
</mvc:View>

