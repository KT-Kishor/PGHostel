<mvc:View controllerName="sap.kt.com.minihrsolution.controller.AdminPaySlip"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:fb="sap.ui.comp.filterbar"
	xmlns:core="sap.ui.core">
	<Page id="AP_id_PaySlipPage">
		<headerContent>
        <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
        </headerContent>
		<content>
			<fb:FilterBar id="AP_id_AdminPaySlip"
    clear="onClear"
    showClearOnFB="true"
    search=".onSearch"
    showFilterConfiguration="false"
    showRestoreButton="true"
    useToolbar="false">
				<fb:filterGroupItems>
					<fb:FilterGroupItem groupName="Basic" name="EmployeeID" label="{i18n>employeeID}" visibleInFilterBar="true">
						<fb:control>
							<ComboBox id="AP_id_Employee" showClearIcon="true" items="{/EmployeeList}" selectedKey="{filters>/EmployeeID}">
								<core:Item key="{EmployeeID}" text="{EmployeeName}" />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem groupName="Basic" name="Month" label="{i18n>month}" visibleInFilterBar="true">
						<fb:control>
							<ComboBox id="AP_id_Month" showClearIcon="true" items="{/MonthList}" selectedKey="{filters>/Month}">
								<core:Item key="{Month}" text="{Month}" />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table id="AP_id_AdminPaySlipTable">
				<headerToolbar>
					<Toolbar>
						<Title id="AP_id_Title" text="{i18n>paySlipDetails}"/>
						<ToolbarSpacer/>
						<ToolbarSeparator/>
						<Button icon="sap-icon://add" tooltip="{i18n>addPaySlip}" press="AP_onPressAddPayslip" />
						<ToolbarSeparator />
					</Toolbar>
				</headerToolbar>
				<columns>
					<Column>
						<Text text="{i18n>employeeID}" />
					</Column>
					<Column>
						<Text text="{i18n>employeeName}" />
					</Column>
					<Column>
						<Text text="{i18n>month}" />
					</Column>
					<Column>
						<Text text="{i18n>year}" />
					</Column>
					<Column>
						<Text text="{i18n>payableDays}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="AP_onPressPayslip">
						<cells>
							<Text text="{EmployeeID}" />
						</cells>
						<cells>
							<Text text="{EmployeeName}" />
						</cells>
						<cells>
							<Text text="{Month}" />
						</cells>
						<cells>
							<Text text="{Year}" />
						</cells>
						<cells>
							<Text text="{PayableDays}" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
            <Bar>
                <contentLeft>
                    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
                </contentLeft>
                <contentRight>
                </contentRight>
            </Bar>
        </footer>
	</Page>
</mvc:View>