<mvc:View
    controllerName="sap.kt.com.minihrsolution.controller.AdminPaySlipDetails"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.uxap"
    xmlns:g="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:m="sap.m"
>
    <m:Page
        title="{i18n>paySlipTitle}"
        navButtonPress="APD_onPressBack"
        showNavButton="true"
    >
        <ObjectPageLayout
            id="APD_id_NavAdmin"
            enableLazyLoading="true"
            useIconTabBar="false"
            class="sapUiSmallmarginResponsive"
            upperCaseAnchorBar="false"
            showHeaderContent="{PaySlip>/isIdSelected}"
        >
            <headerTitle>
                <ObjectPageDynamicHeaderTitle visible="{PaySlip>/isIdSelected}">
                    <expandedHeading>
                        <m:Title
                            text="{payrollModel>/EmployeeName}"
                            wrapping="true"
                        />
                    </expandedHeading>

                    <snappedHeading>
                        <m:Title
                            text="{payrollModel>/EmployeeName}"
                            wrapping="true"
                        />
                    </snappedHeading>

                    <expandedContent>
                        <m:Text text="{payrollModel>/ID}" />
                    </expandedContent>

                    <snappedContent>
                        <m:Text text="{payrollModel>/ID}" />
                    </snappedContent>
                </ObjectPageDynamicHeaderTitle>
            </headerTitle>

            <headerContent>
                <m:FlexBox
                    busyIndicatorDelay="0"
                    id="QF_id_Header"
                    wrap="Wrap"
                    fitContainer="true"
                >
                    <m:Avatar
                        class="sapUiLargeMarginEnd"
                        displayShape="Circle"
                        displaySize="L"
                        src="../image/logo.jpg"
                    />

                    <layout:VerticalLayout class="sapUiSmallMarginEnd">
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>baseLocation}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/BaseLocation}"
                            />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>role}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/Role}"
                            />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>department}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/Designation}"
                            />
                        </layout:HorizontalLayout>
                    </layout:VerticalLayout>

                    <layout:VerticalLayout
                        class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom sapUiMediumMarginEnd sapUiSmallMarginBottom"
                    >
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>bankName}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/BankName}"
                            />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>accountNo}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/AccountNo}"
                            />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>PAN}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/PAN}"
                            />
                        </layout:HorizontalLayout>
                    </layout:VerticalLayout>

                    <layout:VerticalLayout
                        class="sapUiTinyMarginBottom sapUiSmallMarginBegin"
                    >
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>payableDays}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/payableDays}"
                            />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>joiningDate}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/joiningDate}"
                            />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                            visible="{= !${PaySlip>/isCreate} }"
                        >
                            <m:Label text="{i18n>monthAndYear}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/monthAndYear}"
                            />
                        </layout:HorizontalLayout>
                    </layout:VerticalLayout>
                </m:FlexBox>
            </headerContent>
            <sections>
                <ObjectPageSection
                    id="APD_id_First"
                    showTitle="false"
                >
                    <subSections>
                        <ObjectPageSubSection
                            title="{i18n>selectID}"
                            visible="{PaySlip>/isCreate}"
                        >
                            <f:SimpleForm
                                editable="true"
                                layout="ColumnLayout"
                                labelSpanXL="4"
                                labelSpanL="3"
                                labelSpanM="4"
                                labelSpanS="12"
                                columnsXL="4"
                                columnsL="4"
                                columnsM="2"
                            >
                                <f:content>
                                    <m:Label text="{i18n>employeeID}" />
                                    <m:ComboBox
                                        showSecondaryValues="true"
                                        id="APD_id_Employee"
                                        change="onEmployeeIDChange"
                                        items="{Employeemodel>/employees}"
                                    >
                                        <core:ListItem
                                            key="{Employeemodel>key}"
                                            text="{Employeemodel>key}"
                                            additionalText="{Employeemodel>text}"
                                        />
                                    </m:ComboBox>
                                    <!-- <m:Label text="{i18n>selectMonth}" />
                                    <m:ComboBox
                                        showSecondaryValues="true"
                                        id="APD_id_Month"
                                        items="{MonthsModel>/results}"
                                        value="{payrollModel>/Month}"
                                        change="onMonthChange"
                                        editable="false"
                                    >
                                        <core:Item
                                            key="{MonthsModel>ID}"
                                            text="{MonthsModel>Month}"
                                        />
                                    </m:ComboBox> -->
                                    <m:Label text="{i18n>monthAndYear}" />
                                    <m:DatePicker
                                        id="APD_id_Payroll"
                                        value="{path: 'payrollModel>/Year', type: 'sap.ui.model.type.String'}"
                                        displayFormat="MM-yyyy"
                                        editable="true"
                                    />
                                </f:content>
                            </f:SimpleForm>
                        </ObjectPageSubSection>
                        <!-- Salary Details SubSection -->
                        <ObjectPageSubSection
                            title="{i18n>salaryDetailsEmployee}"
                            class="earnDedTable"
                        >
                            <m:VBox class="sapUiSmallMargin">
                                <!-- GridContainer for Tables -->
                                <g:GridContainer
                                    columnsChange=".onGridColumnsChange"
                                >
                                    <g:layout>
                                        <g:GridContainerSettings
                                            columnSize="49.5%"
                                            gap="10px"
                                        />
                                    </g:layout>
                                    <g:layoutXS>
                                        <g:GridContainerSettings
                                            columnSize="100%"
                                            gap="10px"
                                        />
                                    </g:layoutXS>
                                    <g:layoutS>
                                        <g:GridContainerSettings
                                            columnSize="100%"
                                            gap="10px"
                                        />
                                    </g:layoutS>
                                    <g:layoutM>
                                        <g:GridContainerSettings
                                            columnSize="100%"
                                            gap="10px"
                                        />
                                    </g:layoutM>
                                    <!-- Earnings m:Table -->
                                    <g:Card>
                                        <g:content>
                                            <m:VBox
                                                class="sapUiTinyMarginBeginEnd"
                                            >
                                                <m:Table
                                                    id="APD_id_SalaryTable"
                                                    items="{EarningModel>/SalaryFields}"
                                                    mode="Delete"
                                                    delete="onPressDeleteSalaryFields"
                                                >
                                                    <m:headerToolbar>
                                                        <m:OverflowToolbar>
                                                            <m:Title
                                                                text="{i18n>salaryDetails}"
                                                                level="H2"
                                                            />
                                                            <m:ToolbarSpacer />
                                                            <m:Button
                                                                text="{i18n>add}"
                                                                type="Accept"
                                                                press="Q_onPressCreate"
                                                                enabled="{PaySlip>/isIdSelected}"
                                                                visible="{PaySlip>/isCreate}"
                                                            />
                                                        </m:OverflowToolbar>
                                                    </m:headerToolbar>
                                                    <m:columns>
                                                        <m:Column
                                                            minScreenWidth="Tablet"
                                                            demandPopin="true"
                                                        >
                                                            <m:Text
                                                                text="{i18n>desc}"
                                                            />
                                                        </m:Column>
                                                        <m:Column
                                                            minScreenWidth="Tablet"
                                                            demandPopin="true"
                                                        >
                                                            <m:Text
                                                                text="{i18n>amount}"
                                                            />
                                                        </m:Column>
                                                        <m:Column
                                                            minScreenWidth="Tablet"
                                                            demandPopin="true"
                                                        >
                                                            <m:Text
                                                                text="{i18n>yearlyAmount}"
                                                            />
                                                        </m:Column>
                                                    </m:columns>
                                                    <m:items>
                                                        <m:ColumnListItem>
                                                            <m:cells>
                                                                <m:Input
                                                                    value="{EarningModel>Description}"
                                                                    maxLength="25"
                                                                    editable="{= ${EarningModel>Flag} === true }"
                                                                />
                                                                <m:Input
                                                                    value="{EarningModel>Amount}"
                                                                    change="onEarningAmountChange"
                                                                    textAlign="End"
                                                                    type="Number"
                                                                />
                                                                <m:Input
                                                                    value="{EarningModel>Year}"
                                                                    editable="false"
                                                                    textAlign="End"
                                                                />
                                                            </m:cells>
                                                        </m:ColumnListItem>
                                                    </m:items>
                                                </m:Table>

                                                <m:HBox
                                                    class="customEarningBox sapUiTinyMarginBottom"
                                                    width="100%"
                                                >
                                                    <m:Text
                                                        class="boldBlackText"
                                                        text="{i18n>totalEarningAmount} :"
                                                        textAlign="End"
                                                    />
                                                    <m:Text
                                                        class="boldBlackText"
                                                        text="{path:'EarningModel>/TotalEarningMonth', formatter: '.Formatter.numberFormater'}"
                                                        textAlign="End"
                                                    />
                                                    <m:Text
                                                        class="boldBlackText"
                                                        text="{path:'EarningModel>/TotalEarningYearly', formatter: '.Formatter.numberFormater'}"
                                                        textAlign="End"
                                                    />
                                                </m:HBox>
                                            </m:VBox>
                                        </g:content>
                                    </g:Card>
                                    <!-- Deductions m:Table -->
                                    <g:Card>
                                        <g:content>
                                            <m:VBox
                                                class="sapUiTinyMarginBeginEnd"
                                            >
                                                <m:Table
                                                    items="{DeductionModel>/DeductionFields}"
                                                    mode="Delete"
                                                    delete="onPressDeleteDeductionFields"
                                                >
                                                    <m:headerToolbar>
                                                        <m:OverflowToolbar>
                                                            <m:Title
                                                                text="{i18n>deductionDetails}"
                                                                level="H2"
                                                            />
                                                            <m:ToolbarSpacer />
                                                            <m:Button
                                                                text="{i18n>add}"
                                                                type="Accept"
                                                                press="Q_onPressCreate"
                                                                enabled="{PaySlip>/isIdSelected}"
                                                                visible="{PaySlip>/isCreate}"
                                                            />
                                                        </m:OverflowToolbar>
                                                    </m:headerToolbar>
                                                    <m:columns>
                                                        <m:Column
                                                            minScreenWidth="Tablet"
                                                            demandPopin="true"
                                                        >
                                                            <m:Text
                                                                text="{i18n>desc}"
                                                            />
                                                        </m:Column>
                                                        <m:Column
                                                            minScreenWidth="Tablet"
                                                            demandPopin="true"
                                                        >
                                                            <m:Text
                                                                text="{i18n>amount}"
                                                            />
                                                        </m:Column>
                                                        <m:Column
                                                            minScreenWidth="Tablet"
                                                            demandPopin="true"
                                                        >
                                                            <m:Text
                                                                text="{i18n>yearlyAmount}"
                                                            />
                                                        </m:Column>
                                                    </m:columns>
                                                    <m:items>
                                                        <m:ColumnListItem>
                                                            <m:cells>
                                                                <m:Input
                                                                    value="{DeductionModel>Description}"
                                                                    maxLength="25"
                                                                    editable="{= ${DeductionModel>Flag} === true }"
                                                                />
                                                                <m:Input
                                                                    value="{DeductionModel>Amount}"
                                                                    change="onDeductionAmountChange"
                                                                    textAlign="End"
                                                                    type="Number"
                                                                />
                                                                <m:Input
                                                                    value="{DeductionModel>Year}"
                                                                    editable="false"
                                                                    textAlign="End"
                                                                />
                                                            </m:cells>
                                                        </m:ColumnListItem>
                                                    </m:items>
                                                </m:Table>
                                                <m:HBox
                                                    class="customDeductionBox sapUiTinyMarginBottom"
                                                    width="100%"
                                                >
                                                    <m:Text
                                                        class="boldBlackText"
                                                        text="{i18n>totalDeductionAmount} :"
                                                        textAlign="End"
                                                    />
                                                    <m:Text
                                                        class="boldBlackText"
                                                        text="{path:'DeductionModel>/TotalDeductionMonth', formatter: '.Formatter.numberFormater'}"
                                                        textAlign="Right"
                                                    />
                                                    <m:Text
                                                        class="boldBlackText"
                                                        text="{path:'DeductionModel>/TotalDeductionYearly', formatter: '.Formatter.numberFormater'}"
                                                        textAlign="Right"
                                                    />
                                                </m:HBox>
                                            </m:VBox>
                                        </g:content>
                                    </g:Card>
                                </g:GridContainer>
                                <m:HBox
                                    class="customNetPayBox"
                                    width="100%"
                                >
                                    <m:Text
                                        text="Net Pay ( INR ) : INR 12,34.876.90 (Twelve Lakh Thirty Four Thousand Eight Hundred Seventy Six Rupees and Ninety Paise)"
                                        class="boldBlackText"
                                        width="100%"
                                    />
                                    <!-- <m:Text
                                        text=" :  {path: 'DeductionModel>/totalNetPay', formatter: '.Formatter.numberFormater'} ({DeductionModel>/totalNetPayText})"
                                        class="boldBlackText"
                                        width="100%"
                                    /> -->
                                </m:HBox>
                            </m:VBox>
                        </ObjectPageSubSection>
                    </subSections>
                </ObjectPageSection>
            </sections>
        </ObjectPageLayout>
        <m:footer>
            <m:Toolbar>
                <core:Fragment
                    fragmentName="sap.kt.com.minihrsolution.fragment.Footer"
                    type="XML"
                />
                <m:ToolbarSpacer />
                <m:Button
                    text="{i18n>submit}"
                    type="Emphasized"
                    press="APD_onPressSubmit"
                    class="sendMail"
                    visible="{PaySlip>/isCreate}"
                    enabled="{PaySlip>/isIdSelected}"
                />
                <m:Button
                    text="{i18n>jsPdf}"
                    type="Reject"
                    press="APD_onPressGeneratePdf"
                    visible="{= !${PaySlip>/isCreate} }"
                />
            </m:Toolbar>
        </m:footer>
    </m:Page>
</mvc:View>
