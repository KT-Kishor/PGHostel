<mvc:View
    controllerName="sap.kt.com.minihrsolution.controller.AdminPaySlipDetails"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.uxap"
    xmlns:g="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:m="sap.m"
>
    <m:Page
        title="{i18n>paySlipTitle}"
        navButtonPress="APD_onPressBack"
        showNavButton="true"
    >
        <ObjectPageLayout
            id="APD_id_NavAdmin"
            enableLazyLoading="true"
            useIconTabBar="false"
            class="sapUiSmallmarginResponsive"
            upperCaseAnchorBar="false"
            showHeaderContent="true"
        >
            <headerTitle>
                <ObjectPageDynamicHeaderTitle visible="true">
                    <expandedHeading>
                        <m:Title
                            text="{payrollModel>/EmployeeName}"
                            wrapping="true"
                        />
                    </expandedHeading>

                    <snappedHeading>
                        <m:Title
                            text="{payrollModel>/EmployeeName}"
                            wrapping="true"
                        />
                    </snappedHeading>

                    <expandedContent>
                        <m:Text text="{payrollModel>/ID}" />
                    </expandedContent>

                    <snappedContent>
                        <m:Text text="{payrollModel>/ID}" />
                    </snappedContent>
                </ObjectPageDynamicHeaderTitle>
            </headerTitle>

            <headerContent>
                <m:FlexBox
                    busyIndicatorDelay="0"
                    id="QF_id_Header"
                    wrap="Wrap"
                    fitContainer="true"
                >
                    <m:Avatar
                        class="sapUiLargeMarginEnd"
                        displayShape="Circle"
                        displaySize="L"
                        src="../image/logo.jpg"
                    />

                    <layout:VerticalLayout class="sapUiSmallMarginEnd">
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>baseLocation}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/BaseLocation}"
                            />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>role}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/Role}"
                            />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>department}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/Designation}"
                            />
                        </layout:HorizontalLayout>
                    </layout:VerticalLayout>

                    <layout:VerticalLayout
                        class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom sapUiMediumMarginEnd sapUiSmallMarginBottom"
                    >
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>bankName}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/BankName}"
                            />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>accountNo}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/AccountNo}"
                            />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>PAN}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/PAN}"
                            />
                        </layout:HorizontalLayout>
                    </layout:VerticalLayout>

                    <layout:VerticalLayout
                        class="sapUiTinyMarginBottom sapUiSmallMarginBegin"
                    >
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>payableDays}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/payableDays}"
                            />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>joiningDate}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/joiningDate}"
                            />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                        >
                            <m:Label text="{i18n>monthAndYear}" />
                            <m:Text
                                class="sapUiTinyMarginBegin"
                                text="{payrollModel>/monthAndYear}"
                            />
                        </layout:HorizontalLayout>
                    </layout:VerticalLayout>
                </m:FlexBox>
            </headerContent>
            <sections>
                <ObjectPageSection id="APD_id_First" showTitle="false">
                    <subSections>
                        <ObjectPageSubSection title="{i18n>selectID}">
                            <f:SimpleForm
                                editable="true"
                                layout="ColumnLayout"
                                labelSpanXL="4"
                                labelSpanL="3"
                                labelSpanM="4"
                                labelSpanS="12"
                                columnsXL="4"
                                columnsL="4"
                                columnsM="2"
                            >
                                <f:content>
                                    <m:Label text="{i18n>employeeID}" />
                                    <m:ComboBox
                                        showSecondaryValues="true"
                                        id="APD_id_Employee"
                                        change="onEmployeeIDChange"
                                        items="{Employeemodel>/employees}"
                                    >
                                        <core:ListItem
                                            key="{Employeemodel>key}"
                                            text="{Employeemodel>key}"
                                            additionalText="{Employeemodel>text}"
                                        />
                                    </m:ComboBox>
                                    <!-- <m:Label text="{i18n>selectMonth}" />
                                    <m:ComboBox
                                        showSecondaryValues="true"
                                        id="APD_id_Month"
                                        items="{MonthsModel>/results}"
                                        value="{payrollModel>/Month}"
                                        change="onMonthChange"
                                        editable="false"
                                    >
                                        <core:Item
                                            key="{MonthsModel>ID}"
                                            text="{MonthsModel>Month}"
                                        />
                                    </m:ComboBox> -->
                                    <m:Label text="{i18n>monthAndYear}" />
                                    <m:DatePicker
                                        id="APD_id_Payroll"
                                        value="{path: 'payrollModel>/Year', type: 'sap.ui.model.type.String'}"
                                        displayFormat="MM-yyyy"
                                        editable="true"
                                    />
                                </f:content>
                            </f:SimpleForm>
                        </ObjectPageSubSection>
                        <!-- Salary Details SubSection -->
                        <ObjectPageSubSection
                            title="{i18n>salaryDetailsEmployee}"
                        >
                            <core:Fragment
                                fragmentName="sap.kt.com.minihrsolution.fragment.PaySlipTable"
                                type="XML"
                            />
                        </ObjectPageSubSection>
                    </subSections>
                </ObjectPageSection>
            </sections>
        </ObjectPageLayout>
        <m:footer>
            <m:Toolbar>
                <core:Fragment
                    fragmentName="sap.kt.com.minihrsolution.fragment.Footer"
                    type="XML"
                />
                <m:ToolbarSpacer />
                <m:Button
                    text="{i18n>submit}"
                    type="Emphasized"
                    press="APD_onPressSubmit"
                    class="sendMail"
                />
                <m:Button
                    text="{i18n>jsPdf}"
                    press="APD_onPressGeneratePdf"
                    class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
                    visible="false"
                />
            </m:Toolbar>
        </m:footer>
    </m:Page>
</mvc:View>
