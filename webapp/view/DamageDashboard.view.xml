<mvc:View
    controllerName="sap.ui.com.project1.controller.DamageDashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:com="sap.suite.ui.commons"
    displayBlock="true"
>
    <Page showHeader="true">
        <headerContent>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.Header"
                type="XML"
            />
        </headerContent>
        <content>
            <fb:FilterBar
                useToolbar="false"
                clear="DD_onPressClear"
                showClearOnFB="true"
                search="DD_search"
                filterChange="onFilterChange"
                showFilterConfiguration="false"
            >
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="Name"
                        label="Branch Name"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="id_DD_branch"
                                items="{branchModel>/}"
                                showSecondaryValues="true"
                                showClearIcon="true"
                                width="100%"
                            >
                                <core:ListItem
                                    key="{branchModel>BranchID}"
                                    text="{branchModel>Name} - {branchModel>BranchID}"
                                    additionalText="{branchModel>City}"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="year"
                        label="{i18n>dashYear}"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <DateRangeSelection
                                id="id_DD_year"
                                valueFormat="yyyy-MM-dd"
                                displayFormat="dd/MM/yyyy"
                            />
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>

            <layout:Grid
                defaultSpan="XL6 L6 M12 S12"
                class="sapUiResponsiveMargin sapUiMediumMarginTop"
            >
                <f:Card class="sapUiTinyMargin">
                    <f:header>
                        <Toolbar class="customdashboard">
                            <Title
                                text="Damaged Items"
                                level="H5"
                                wrapping="true"
                                class="Dashboardtitle"
                            />
                            <ToolbarSpacer />
                            <Button
                                icon="sap-icon://vertical-bar-chart"
                                press="onColumnChart"
                            />
                            <Button
                                icon="sap-icon://bar-chart"
                                press="onBarChart"
                            />
                            <Button
                                icon="sap-icon://line-chart"
                                press="onLineChart"
                            />
                            <Button
                                icon="sap-icon://pie-chart"
                                press="onPieChart"
                            />
                        </Toolbar>
                    </f:header>

                    <f:content>
                        <com:ChartContainer
                            showFullScreen="true"
                            showPersonalization="false"
                        >
                            <com:content>
                                <com:ChartContainerContent>
                                    <com:content>
                                        <viz:VizFrame
                                            height="400px"
                                            width="100%"
                                            vizType="{chartTypeModel>/monthly}"
                                            uiConfig="{applicationSet:'fiori'}"
                                            vizProperties="{
                                                title: {visible: false},
                                plotArea: { dataLabel: { visible: true } },
                                valueAxis: { title: { text: 'Damage Count' } },
                                categoryAxis: { title: { text: 'Item Name' } },
                                legend: { visible: true }
                            }"
                                        >
                                            <viz:dataset>
                                                <viz.data:FlattenedDataset
                                                    data="{damageChartModel>/}"
                                                >
                                                    <viz.data:dimensions>
                                                        <viz.data:DimensionDefinition
                                                            name="Item Name"
                                                            value="{damageChartModel>ItemName}"
                                                        />
                                                    </viz.data:dimensions>
                                                    <viz.data:measures>
                                                        <viz.data:MeasureDefinition
                                                            name="Damage Count"
                                                            value="{damageChartModel>Count}"
                                                        />
                                                    </viz.data:measures>
                                                </viz.data:FlattenedDataset>
                                            </viz:dataset>

                                            <viz:feeds>
                                                <viz.feeds:FeedItem
                                                    uid="valueAxis"
                                                    type="Measure"
                                                    values="Damage Count"
                                                />
                                                <viz.feeds:FeedItem
                                                    uid="categoryAxis"
                                                    type="Dimension"
                                                    values="Item Name"
                                                />
                                            </viz:feeds>
                                        </viz:VizFrame>
                                    </com:content>
                                </com:ChartContainerContent>
                            </com:content>
                        </com:ChartContainer>
                    </f:content>
                </f:Card>

                <f:Card class="sapUiTinyMargin">
                    <f:header>
                        <Toolbar class="customdashboard">
                            <Title
                                text="Daily Damage"
                                level="H5"
                                wrapping="true"
                                class="Dashboardtitle"
                            />
                            <ToolbarSpacer />
                            <Button
                                icon="sap-icon://vertical-bar-chart"
                                press="ondayColumnChart"
                            />
                            <Button
                                icon="sap-icon://bar-chart"
                                press="ondayBarChart"
                            />
                            <Button
                                icon="sap-icon://line-chart"
                                press="ondayLineChart"
                            />
                            <Button
                                icon="sap-icon://pie-chart"
                                press="ondayPieChart"
                            />
                        </Toolbar>
                    </f:header>

                    <f:content>
                        <com:ChartContainer
                            showFullScreen="true"
                            showPersonalization="false"
                        >
                            <com:content>
                                <com:ChartContainerContent>
                                    <com:content>
                                        <viz:VizFrame
                                            height="400px"
                                            vizType="{chartTypeModel>/daily}"
                                            uiConfig="{applicationSet:'fiori'}"
                                            vizProperties="{
                                                title: {visible: false},
                                                    plotArea: { dataLabel: { visible: true } },
                                                    valueAxis: { title: { text: 'Damage Count' } },
                                                    categoryAxis: { title: { text: 'Day of month' } }
                                                }"
                                        >
                                            <viz:dataset>
                                                <viz.data:FlattenedDataset
                                                    data="{dailyModel>/}"
                                                >
                                                    <viz.data:dimensions>
                                                        <viz.data:DimensionDefinition
                                                            name="Day"
                                                            value="{dailyModel>Day}"
                                                        />
                                                    </viz.data:dimensions>
                                                    <viz.data:measures>
                                                        <viz.data:MeasureDefinition
                                                            name="Damage Count"
                                                            value="{dailyModel>Count}"
                                                        />
                                                    </viz.data:measures>
                                                </viz.data:FlattenedDataset>
                                            </viz:dataset>

                                            <viz:feeds>
                                                <viz.feeds:FeedItem
                                                    uid="valueAxis"
                                                    type="Measure"
                                                    values="Damage Count"
                                                />
                                                <viz.feeds:FeedItem
                                                    uid="categoryAxis"
                                                    type="Dimension"
                                                    values="Day"
                                                />
                                            </viz:feeds>
                                        </viz:VizFrame>
                                    </com:content>
                                </com:ChartContainerContent>
                            </com:content>
                        </com:ChartContainer>
                    </f:content>
                </f:Card>

                <f:Card class="sapUiTinyMargin">
                    <f:header>
                        <Toolbar class="customdashboard">
                            <Title
                                text="Damage Status"
                                level="H5"
                                wrapping="true"
                                class="Dashboardtitle"
                            />
                            <ToolbarSpacer />
                            <Button
                                icon="sap-icon://vertical-bar-chart"
                                press="onStatusColumnChart"
                            />
                            <Button
                                icon="sap-icon://bar-chart"
                                press="onStatusBarChart"
                            />
                            <Button
                                icon="sap-icon://line-chart"
                                press="onStatusLineChart"
                            />
                            <Button
                                icon="sap-icon://pie-chart"
                                press="onStatusPieChart"
                            />
                        </Toolbar>
                    </f:header>

                    <f:content>
                        <com:ChartContainer
                            showFullScreen="true"
                            showPersonalization="false"
                        >
                            <com:content>
                                <com:ChartContainerContent>
                                    <com:content>
                                        <viz:VizFrame
                                            height="400px"
                                            vizType="{chartTypeModel>/status}"
                                            uiConfig="{applicationSet:'fiori'}"
                                            vizProperties="{
                                                title: {visible: false},
                                                    plotArea: { dataLabel: { visible: true } },
                                                    valueAxis: { title: { text: 'Total records' } },
                                                    categoryAxis: { title: { text: 'Status' } }
                                                }"
                                        >
                                            <viz:dataset>
                                                <viz.data:FlattenedDataset
                                                    data="{damageChartModel>/}"
                                                >
                                                    <viz.data:dimensions>
                                                        <viz.data:DimensionDefinition
                                                            name="Status"
                                                            value="{damageChartModel>Status}"
                                                        />
                                                    </viz.data:dimensions>
                                                    <viz.data:measures>
                                                        <viz.data:MeasureDefinition
                                                            name="Total Records"
                                                            value="{damageChartModel>Count}"
                                                        />
                                                    </viz.data:measures>
                                                </viz.data:FlattenedDataset>
                                            </viz:dataset>

                                            <viz:feeds>
                                                <viz.feeds:FeedItem
                                                    uid="size"
                                                    type="Measure"
                                                    values="Total Records"
                                                />
                                                <viz.feeds:FeedItem
                                                    uid="color"
                                                    type="Dimension"
                                                    values="Status"
                                                />
                                            </viz:feeds>
                                        </viz:VizFrame>
                                    </com:content>
                                </com:ChartContainerContent>
                            </com:content>
                        </com:ChartContainer>
                    </f:content>
                </f:Card>

                <f:Card class="sapUiTinyMargin">
                    <f:header>
                        <Toolbar class="customdashboard">
                            <Title
                                text="Damage Type"
                                level="H5"
                                wrapping="true"
                                class="Dashboardtitle"
                            />
                            <ToolbarSpacer />
                            <Button
                                icon="sap-icon://vertical-bar-chart"
                                press="onPayColumnChart"
                            />
                            <Button
                                icon="sap-icon://bar-chart"
                                press="onPayBarChart"
                            />
                            <Button
                                icon="sap-icon://line-chart"
                                press="onPayLineChart"
                            />
                            <Button
                                icon="sap-icon://pie-chart"
                                press="onPayPieChart"
                            />
                        </Toolbar>
                    </f:header>

                    <f:content>
                        <com:ChartContainer
                            showFullScreen="true"
                            showPersonalization="false"
                        >
                            <com:content>
                                <com:ChartContainerContent>
                                    <com:content>
                                        <viz:VizFrame
                                            height="400px"
                                            vizType="{chartTypeModel>/payment}"
                                            uiConfig="{applicationSet:'fiori'}"
                                            vizProperties="{
                                                title: {visible: false},
                                                    plotArea: { dataLabel: { visible: true } },
                                                    valueAxis: { title: { text: 'Total records' } },
                                                    categoryAxis: { title: { text: 'Damage type' } }
                                                }"
                                        >
                                            <viz:dataset>
                                                <viz.data:FlattenedDataset
                                                    data="{damageChartModel>/}"
                                                >
                                                    <viz.data:dimensions>
                                                        <viz.data:DimensionDefinition
                                                            name="Status"
                                                            value="{damageChartModel>Status}"
                                                        />
                                                    </viz.data:dimensions>
                                                    <viz.data:measures>
                                                        <viz.data:MeasureDefinition
                                                            name="Total Records"
                                                            value="{damageChartModel>Count}"
                                                        />
                                                    </viz.data:measures>
                                                </viz.data:FlattenedDataset>
                                            </viz:dataset>

                                            <viz:feeds>
                                                <viz.feeds:FeedItem
                                                    uid="size"
                                                    type="Measure"
                                                    values="Total Records"
                                                />
                                                <viz.feeds:FeedItem
                                                    uid="color"
                                                    type="Dimension"
                                                    values="Status"
                                                />
                                            </viz:feeds>
                                        </viz:VizFrame>
                                    </com:content>
                                </com:ChartContainerContent>
                            </com:content>
                        </com:ChartContainer>
                    </f:content>
                </f:Card>
            </layout:Grid>
        </content>
        <footer>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.AppFooter"
                type="XML"
            />
        </footer>
    </Page>
</mvc:View>