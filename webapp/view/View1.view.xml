<mvc:View controllerName="sap.kt.com.minihrsolution.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

        	<f:SimpleForm id="SimpleFormDisplay480_12120"
			editable="false"
			layout="ResponsiveGridLayout"
			title="Address"
			labelSpanXL="4"
			labelSpanL="4"
			labelSpanM="12"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="0"
			emptySpanL="0"
			emptySpanM="0"
			emptySpanS="0"
			columnsXL="2"
			columnsL="2"
			columnsM="1"
			singleContainerFullSize="false" >
			<f:content>
				<Label text="Mobile Number"></Label>
                <Input id="idMobileNumber" liveChange="MobileNumberLC" value="" type="Tel"></Input>

				<Label text="Name"></Label>
                <Input id="idName" liveChange="NameLC" value="" type="Text"></Input>

				<Label text="Email ID"></Label>
                <Input id="idEmail" liveChange="EmailIDLC" value="" type="Email"></Input>

				<Label text="Amount"></Label>
                <Input id="idAmount" liveChange="AmountLC" value="" maxLength="15"></Input>
				
				<Label text="Account Number"></Label>
                <Input id="isAccount" liveChange="AccountNumberLC" value="" maxLength="18"></Input>

				<Label text="Date (dd/MM/yyyy)"></Label>
				<DatePicker id="idDate" change="DateFormatLC" placeholder="dd/MM/yyyy"></DatePicker>

				<Label text="PAN Card Number"></Label>
				<Input id="idPanCard" liveChange="PANCardFormatLC" placeholder="AAAAA1234A" maxLength="10"></Input>

				<Label text="Aadhaar Number"></Label>
				<Input id="idAadhar" liveChange="AadhaarFormatLC" placeholder="Enter 12-digit Aadhaar" maxLength="12"></Input>

				<Label text="GST Number"></Label>
				<Input id="idGST" liveChange="GSTFormatLC" placeholder="11AAAAA1234A1Z1" maxLength="15"></Input>

				<Label text="IFSC Code"></Label>
				<Input id="idIFSC" liveChange="IFSCFormatLC" placeholder="ABCD0123456" maxLength="11"></Input>

				<Label text="Passport Number"></Label>
				<Input id="idPassport" liveChange="PassportFormatLC" placeholder="A1234567" maxLength="8"></Input>

				<Label text="Voter ID"></Label>
				<Input id="idVoter" liveChange="VoterIDFormatLC" placeholder="ABC1234567" maxLength="10"></Input>

				<Label text="Address"></Label>
				<TextArea id="idAddress" liveChange="AddressLC" maxLength="120"></TextArea>
			</f:content>
			<Button text="Submit" press="onPressSubmit"></Button>  							
		</f:SimpleForm>
    </Page>
</mvc:View>