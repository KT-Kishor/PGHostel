<mvc:View controllerName="sap.kt.com.minihrsolution.controller.View1"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:form="sap.ui.layout.form"
	xmlns:l="sap.ui.layout"
	xmlns:u="sap.ui.unified"
	xmlns:f="sap.ui.layout.form">
	<Page id="page" title="{i18n>title}">
		<content>
			<f:SimpleForm
    layout="ColumnLayout" editable="true"
   >
				<f:content>
					<Label text="Mobile No" />
					<Input id="idMobileNo"  required="true" liveChange="validateMobileNo" maxLength="10" valueStateText="{i18n>mobileNoValueState}"/>

					<Label text="Email" />
					<Input id="idEmail" type="Email"  required="true"  liveChange="validateEmail" maxLength="50" valueStateText="{i18n>emailValueState}"/>

					<Label text="Name" />
					<Input id="idName"  required="true"  liveChange="validateName" maxLength="50" valueStateText="{i18n>nameValueState}"/>

					<Label text="Amount" />
					<Input id="idAmount"   required="true" liveChange="validateAmount" maxLength="15" valueStateText="{i18n>ammountValuState}"/>

					<Label text="Account Number" />
					<Input id="idAccountNumber"  required="true"  liveChange="validateAccountNo" maxLength="18" valueStateText="{i18n>accountnoValueState}"/>

					<Label text="Date" />
					<DatePicker id="idDate"  required="true" displayFormat="dd/MM/yyyy"  valueFormat="dd/MM/yyyy" change="validateDate" valueStateText="{i18n>dateValueState}" />

					<Label text="Address" />
					<TextArea id="idAddress"  required="true" liveChange="ValidateCommonFields"  maxLength="120" valueStateText="{i18n>addressValueState}"/>

					<Label text="PAN Card" />
					<Input id="idPanCard"  required="true"  liveChange="validatePanCard" maxLength="10" valueStateText="{i18n>panCardValueState}"/>

					<Label text="Aadhar Card" />
					<Input id="idAadharCard"  required="true" liveChange="validateAadharCard" maxLength="12" valueStateText="{i18n>aadharNoValueState}"/>

					<Label text="GST" />
					<Input id="idGst"  required="true" liveChange="validateGstNumber" maxLength="15" valueStateText="{i18n>gstNoValueState}" />

					<Label text="Company Name" />
					<Input id="idCompanyName"  required="true"  liveChange="ValidateCommonFields" maxLength="50" valueStateText="{i18n>companyNameValueState}"/>

					<Label text="Comments" />
					<TextArea id="idComments"  required="true" liveChange="ValidateCommonFields" maxLength="1000" valueStateText="{i18n>commentsValueState}"/>

					<Label text="Source" />
					<Input id="idSource"  required="true" liveChange="ValidateCommonFields" maxLength="20" valueStateText="{i18n>sourceValueState}"/>

					<Label text="Destination" />
					<Input id="idDestination"  required="true"  liveChange="ValidateCommonFields" maxLength="20" valueStateText="{i18n>destinationValueState}"/>

					<Label text="Country" />
					<Input id="idCountry"  required="true" liveChange="ValidateCommonFields" maxLength="20" valueStateText="{i18n>countryValueState}" />

					<Label text="Account Holder Name" />
					<Input id="idAccountantName"  required="true" liveChange="validateName" maxLength="50"  valueStateText="{i18n>accountHolderValueState}"/>

					<Label text="Bank Name" />
					<Input id="idBankName"  required="true" liveChange="ValidateCommonFields" maxLength="20" valueStateText="{i18n>bankNameValueState}"/>

					<Label text="IFSC Code" />
					<Input id="idIfscCode"  required="true"  liveChange="validateIfcCode" maxLength="11" valueStateText="{i18n>ifcsCodeValueState}"/>

					<Label text="Passport" />
					<Input id="idPassport"  required="true"  liveChange="validatePassport" maxLength="8" valueStateText="{i18n>passportNoValueState}"/>

					<Label text="Voter ID" />
					<Input id="idVoterID"  required="true" liveChange="validateVoterId" maxLength="10" valueStateText="{i18n>voterIdValueState}"/>

					<Label text="Upload File" required="true"/>
					<u:FileUploader
                    id="idFileUploader"
                    buttonText="File Uploader"
                    fileType="xlsx"
                    change="ValidateCommonFields"
                    placeholder="Choose an Excel file"
                    icon="sap-icon://upload"
                    valueStateText="{i18n>fileUploaderValueState}" />

					<Button text="Save" press="onSubmitData" />

				</f:content>
			</f:SimpleForm>
		</content>
	</Page>
</mvc:View>