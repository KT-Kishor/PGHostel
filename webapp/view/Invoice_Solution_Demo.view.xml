            <m:Title text="{i18n>headerCompanyInvoice}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>CompanyInv_Par}" class="jioParagraph" />
        </m:VBox>
    </g:GridContainer>
    <!-- CompanyInvoice -->
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

