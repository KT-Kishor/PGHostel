        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Right Column -->
         <m:VBox id="videoBox21" class="sapUiMediumMarginTop">
    <core:HTML id="videoFrameHtml21"
        content="&lt;video controls autoplay muted playsinline
                         style='width:100%;height:auto;border-radius:15px;object-fit:cover;'&gt;
                    &lt;source src='../Videos/Manage Customer.mp4' type='video/mp4'&gt;
                    Your browser does not support the video tag.
                 &lt;/video&gt;" />
</m:VBox>

        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiMediumMarginTop">
            <m:Title text="{i18n>headerCustomer}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>ManageCust_Par}" class="jioParagraph" />
        </m:VBox>
    </g:GridContainer>
    <!-- Manage Customer -->
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
