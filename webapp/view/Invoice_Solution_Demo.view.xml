<mvc:View
	controllerName="sap.kt.com.minihrsolution.controller.Invoice_Solution_Demo"
	xmlns:mvc="sap.ui.core.mvc"
  xmlns:m="sap.m"
  xmlns="sap.m"
   xmlns:core="sap.ui.core"
	displayBlock="true"
       xmlns:g="sap.f"
           xmlns:f="sap.ui.layout.form"
             xmlns:l="sap.ui.layout"
	height="100%"
	busyIndicatorDelay="0"
>

	<Page >
    <headerContent>
			<Avatar src="./image/logo.jpg" displaySize="XS" press="onAvatarPressed" tooltip="Company Logo"/>
			<Title level="H1" text="{i18n>companynameKT}" class="custom-text" wrapping="false"/>
			<ToolbarSpacer/>
			<Button icon="sap-icon://home" press="onpresshome" class="sapUiTinyMarginEnd" tooltip="{i18n>toolHome}"/>
		</headerContent>
			<Title level="H1" text="{i18n>InvoiceManage}" class="HeadDemoSection" wrapping="false"/>

    <m:ScrollContainer horizontal="false" vertical="true" height="100%">
    <!-- MSA & NDA -->
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiSmallMarginTop">
            <m:Title text="{i18n>MSADemo}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>MSA_Par}" class="jioParagraph" />
        </m:VBox>

          <!-- Right Column -->
       <m:VBox id="videoBox11" class="sapUiMediumMarginTop">
    <core:HTML id="videoFrameHtml11"
        content="&lt;iframe src='../Videos/MSA and SOW Application.mp4' 
                         allowfullscreen 
                         style='width:100%;height:auto;border-radius:15px;overflow:hidden;object-fit:cover;'&gt;
                 &lt;/iframe&gt;" />
</m:VBox>
<!-- Sow -->
    </g:GridContainer>
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
