        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiSmallMarginTop">
            <m:Title text="{i18n>headerContractorInvoice}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>ContractorInvoice_Par}" class="jioParagraph" />
        </m:VBox>

        <!-- Right Column -->
        <m:VBox alignItems="Center" id="videoBox5" justifyContent="Center" class="sapUiMediumMarginTop">
           <core:HTML id="videoFrameHtml5"
                   content="&lt;iframe src='../Videos/Contractor Invoice Application.mp4' allowfullscreen style='width:560px;height:315px;border:none;'&gt;&lt;/iframe&gt;"
                />
        </m:VBox>
    </g:GridContainer>
    <!-- ContractorInvoice -->
   <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
