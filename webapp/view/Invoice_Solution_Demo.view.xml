<mvc:View
	controllerName="sap.kt.com.minihrsolution.controller.Invoice_Solution_Demo"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:m="sap.m"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	displayBlock="true"
	xmlns:g="sap.f"
	xmlns:f="sap.ui.layout.form"
	xmlns:l="sap.ui.layout"
	height="100%"
	busyIndicatorDelay="0"
