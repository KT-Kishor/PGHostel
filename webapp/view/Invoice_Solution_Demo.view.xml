<mvc:View
	controllerName="sap.kt.com.minihrsolution.controller.Invoice_Solution_Demo"
	xmlns:mvc="sap.ui.core.mvc"
  xmlns:m="sap.m"
  xmlns="sap.m"
   xmlns:core="sap.ui.core"
	displayBlock="true"
       xmlns:g="sap.f"
           xmlns:f="sap.ui.layout.form"
             xmlns:l="sap.ui.layout"
	height="100%"
	busyIndicatorDelay="0"
>

	<Page >
    <headerContent>
			<Avatar src="./image/logo.jpg" displaySize="XS" press="onAvatarPressed" tooltip="Company Logo"/>
			<Title level="H1" text="{i18n>companynameKT}" class="custom-text" wrapping="false"/>
			<ToolbarSpacer/>
			<Button icon="sap-icon://home" press="onpresshome" class="sapUiTinyMarginEnd" tooltip="{i18n>toolHome}"/>
		</headerContent>
    <m:ScrollContainer horizontal="false" vertical="true" height="100%">
    <!-- MSA & NDA -->
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiSmallMarginTop">
            <m:Title text="{i18n>MSADemo}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>MSA_Par}" class="jioParagraph" />
        </m:VBox>

        <!-- Right Column -->
        <m:VBox id="videoBox1" alignItems="Center" justifyContent="Center" class="sapUiMediumMarginTop">
    <core:HTML id="videoFrameHtml1"
        content="&lt;iframe src='../Videos/MSA and SOW Application.mp4' allowfullscreen style='width:560px;height:315px;border:none;'&gt;&lt;/iframe&gt;" />

</m:VBox>
<!-- Sow -->
    </g:GridContainer>
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Right Column -->
        <m:VBox alignItems="Center" id="videoBox2" justifyContent="Center" class="sapUiMediumMarginTop">
            <core:HTML id="videoFrameHtml2"
                    content="&lt;iframe src='https://www.youtube.com/embed/XFCJNqHHfQQ?si=1IxhnYYx_xS-Wk1M' allowfullscreen style='width:560px;height:315px;border:none;'&gt;&lt;/iframe&gt;"
                />
        </m:VBox>

        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiMediumMarginTop">
            <m:Title text="{i18n>headerCustomer}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>ManageCust_Par}" class="jioParagraph" />
        </m:VBox>
    </g:GridContainer>
    <!-- Manage Customer -->
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiMediumMarginTop">
