<mvc:View
    controllerName="sap.ui.com.project1.controller.BranchData"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
    displayBlock="true"
    busyIndicatorDelay="0"
>
    <Page showHeader="true">
        <headerContent>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.Header"
                type="XML"
            />
        </headerContent>
        <content>
            <fb:FilterBar
                id="MD_id_Filterbar"
                persistencyKey="myPersKey"
                useToolbar="false"
                clear="MD_onPressClear"
                showClearOnFB="true"
                search="MD_onSearch"
                showFilterConfiguration="false"
                filterContainerWidth="auto"
            >
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="Name"
                        label="{i18n>MSbranchCode}"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="MD_id_BranchCode"
                                items="{mainModel>/}"
                                showSecondaryValues="true"
                                showClearIcon="true"
                                width="100%"
                            >
                                <core:ListItem
                                    key="{mainModel>BranchID}"
                                    text="{mainModel>BranchID} - {mainModel>Name}"
                                    additionalText="{mainModel>City}"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="Pincode"
                        label="{i18n>pinCode}"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <SearchField
                                id="MD_id_SearchField"
                                width="250px"
                                liveChange="onGlobalSearch"
                                placeholder="{i18n>search}"
                            />
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>
            <Table
                id="id_MD_Table"
                mode="MultiSelect"
                sticky="ColumnHeaders,HeaderToolbar"
                growing="true"
                busyIndicatorDelay="0"
                growingThreshold="100"
                alternateRowColors="true"
                selectionChange="MC_onTableSelectionChange"
                items="{ path: 'mainModel>/',
                templateShareable: false }"
                updateFinished="onTableUpdateFinished"
            >
                <headerToolbar>
                    <OverflowToolbar>
                        <Title
                            text="{i18n>branchDetails} ({mainModel>/count})"
                        />
                        <ToolbarSpacer />
                        <Button
                            text="{i18n>MSadd}"
                            tooltip="{i18n>MSadd}"
                            press="MD_AddButtonPress"
                            class="myUnifiedBtn"
                        />
                        <Button
                            text="{i18n>MSedit}"
                            tooltip="{i18n>MSedit}"
                            press="MD_UpdateTableRow"
                            class="myUnifiedBtn"
                        />
                        <Button
                            text="{i18n>MSdelete}"
                            tooltip="{i18n>deleteSelectedBranch}"
                            press="MD_DeleteRow"
                            class="myUnifiedBtn"
                        />
                        <Button
                            text="{i18n>download}"
                            tooltip="{i18n>downloadBranchData}"
                            press="MD_onDownload"
                            class="myUnifiedBtn"
                        />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column demandPopin="true">
                        <Text
                            text="{i18n>MSbranchCode}"
                            tooltip="{i18n>MSbranchCode}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>branchName}"
                            tooltip="{i18n>branchName}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>address}"
                            tooltip="{i18n>address}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>pinCode}"
                            tooltip="{i18n>pinCode}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>contactNumber}"
                            tooltip="{i18n>contactNumber}"
                        />
                    </Column>
                    <Column demandPopin="true">
                        <Text
                            text="{i18n>MVDcountry}"
                            tooltip="{i18n>MVDcountry}"
                        />
                    </Column>
                    <Column demandPopin="true">
                        <Text
                            text="{i18n>MVDstate}"
                            tooltip="{i18n>MVDstate}"
                        />
                    </Column>
                    <Column demandPopin="true">
                        <Text
                            text="{i18n>city}"
                            tooltip="{i18n>city}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>penalty}"
                            tooltip="{i18n>penalty}"
                        />
                    </Column>
                    <Column demandPopin="true">
                        <Text
                            text="{i18n>image}"
                            tooltip="{i18n>image}"
                        />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{mainModel>BranchID}" />
                            <Text text="{mainModel>Name}" />
                            <Text text="{mainModel>Address}" />
                            <Text text="{mainModel>Pincode}" />
                            <Text text="{mainModel>STD} {mainModel>Contact}" />
                            <Text text="{mainModel>Country}" />
                            <Text text="{mainModel>State}" />
                            <Text text="{mainModel>City}" />
                            <Text
                                text="{parts: ['mainModel>Penalty','mainModel>Currency'], formatter: '.Formatter.formatPrice'}"
                            />
                            <Button
                                text="{i18n>view}"
                                press="HF_viewroom"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>