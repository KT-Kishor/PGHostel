<mvc:View
    controllerName="sap.ui.com.project1.controller.BranchData"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
    displayBlock="true"
    busyIndicatorDelay="0"
>
    <Page showHeader="true">
        <headerContent>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.Header"
                type="XML"
            />
        </headerContent>
        <content>
            <fb:FilterBar
                id="MD_id_Filterbar"
                persistencyKey="myPersKey"
                useToolbar="false"
                clear="MD_onPressClear"
                showClearOnFB="true"
                search="MD_onSearch"
                showFilterConfiguration="false"
                filterContainerWidth="auto"
            >
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="Name"
                        label="Branch Code"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="MD_id_BranchCode"
                                items="{mainModel>/}"
                                showSecondaryValues="true"
                                showClearIcon="true"
                                width="100%"
                            >
                                <core:ListItem
                                    key="{mainModel>BranchID}"
                                    text="{mainModel>BranchID} - {mainModel>Name}"
                                    additionalText="{mainModel>City}"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="Pincode"
                        label="Pin Code"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <SearchField
                                id="MD_id_SearchField"
                                width="250px"
                                liveChange="onGlobalSearch"
                                placeholder="Search"
                            />
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>
            <Table
                id="id_MD_Table"
                mode="MultiSelect"
                sticky="ColumnHeaders,HeaderToolbar"
                growing="true"
                busyIndicatorDelay="0"
                growingThreshold="100"
                alternateRowColors="true"
                selectionChange="MC_onTableSelectionChange"
                items="{ path: 'mainModel>/',
                templateShareable: false }"
                updateFinished="onTableUpdateFinished"
            >
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Branch Details ({mainModel>/count})" />
                        <ToolbarSpacer />
                        <Button
                            text="Add"
                            tooltip="Add New Branch"
                            press="MD_AddButtonPress"
                            class="myUnifiedBtn"
                        />
                        <Button
                            text="Edit"
                            tooltip="Edit Selected Branch"
                            press="MD_UpdateTableRow"
                            class="myUnifiedBtn"
                        />
                        <Button
                            text="Delete"
                            tooltip="Delete Selected Branch"
                            press="MD_DeleteRow"
                            class="myUnifiedBtn"
                        />
                        <Button
                            text="Download"
                            tooltip="Download Branch Data"
                            press="MD_onDownload"
                            class="myUnifiedBtn"
                        />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column demandPopin="true">
                        <Text text="Branch Code" tooltip="Branch Code" />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text text="Branch Name" tooltip="Branch Name" />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text text="Address" tooltip="Address" />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text text="Pin Code" tooltip="Pin Code" />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text text="Contact Number" tooltip="Contact Number" />
                    </Column>
                    <Column demandPopin="true">
                        <Text text="Country" tooltip="Country" />
                    </Column>
                    <Column demandPopin="true">
                        <Text text="State" tooltip="State" />
                    </Column>
                    <Column demandPopin="true">
                        <Text text="City" tooltip="City" />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text text="Penalty" tooltip="Penalty" />
                    </Column>
                    <Column demandPopin="true">
                        <Text text="Image" tooltip="Image" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{mainModel>BranchID}" />
                            <Text text="{mainModel>Name}" />
                            <Text text="{mainModel>Address}" />
                            <Text text="{mainModel>Pincode}" />
                            <Text text="{mainModel>STD} {mainModel>Contact}" />
                            <Text text="{mainModel>Country}" />
                            <Text text="{mainModel>State}" />
                            <Text text="{mainModel>City}" />
                            <Text text="{mainModel>Penalty}" />
                            <Button
                                text="View"
                                press="HF_viewroom"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>