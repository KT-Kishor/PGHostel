<mvc:View
    controllerName="sap.kt.com.minihrsolution.controller.AssetAssignment"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
>
    <Page id="AA_id_Page">
        <headerContent>
            <core:Fragment
                fragmentName="sap.kt.com.minihrsolution.fragment.Header"
                type="XML"
            />
        </headerContent>
        <fb:FilterBar
            id="AA_id_FilterBarAsset"
            persistencyKey="myPersKey"
            useToolbar="false"
            clear="AA_onPressClear"
            showClearOnFB="true"
            search="AA_onSearch"
            filterChange="AA_onFilterChange"
            showFilterConfiguration="false"
            afterVariantLoad=".onAfterVariantLoad"
        >
            <fb:filterGroupItems>
                <fb:FilterGroupItem
                    name="AssignEmployeeName"
                    label="{i18n>employeeName}"
                    groupName="Group1"
                    visibleInFilterBar="true"
                >
                    <fb:control>
                        <ComboBox
                            name="AssignEmployeeName"
                            showClearIcon="true"
                            id="AA_id_EmployeeName"
                            items="{EmpModel>/}"
                        >
                            <core:ListItem
                                key="{EmpModel>EmployeeName}"
                                text="{EmpModel>EmployeeName}"
                                additionalText="{EmpModel>EmployeeID}"
                            />
                        </ComboBox>
                    </fb:control>
                </fb:FilterGroupItem>
                <fb:FilterGroupItem
                    name="Type"
                    label="{i18n>type}"
                    groupName="Group1"
                    visibleInFilterBar="true"
                >
                    <fb:control>
                        <ComboBox
                            name="Type"
                            showClearIcon="true"
                            id="AA_id_Type"
                            items="{assetType>/}"
                        >
                            <core:ListItem
                                key="{assetType>Type}"
                                text="{assetType>Type}"
                            />
                        </ComboBox>
                    </fb:control>
                </fb:FilterGroupItem>

                <fb:FilterGroupItem
                    name="Status"
                    label="{i18n>status}"
                    groupName="Group1"
                    visibleInFilterBar="true"
                >
                    <fb:control>
                        <ComboBox
                            items="{AssetAssignmentStatus>/}"
                            showClearIcon="true"
                            id="AA_id_Status"
                        >
                            <core:ListItem
                                key="{AssetAssignmentStatus>ID}"
                                text="{AssetAssignmentStatus>Value}"
                            />
                        </ComboBox>
                    </fb:control>
                </fb:FilterGroupItem>

                <fb:FilterGroupItem
                    name="AssignedDate"
                    label="{i18n>assignedDate}"
                    groupName="Group1"
                    visibleInFilterBar="true"
                >
                    <fb:control>
                        <DateRangeSelection
                            id="AA_id_Date"
                            change="AA_handleChange"
                            displayFormat="MM/dd/yyyy"
                            valueFormat="MM/dd/yyyy"
                        />
                    </fb:control>
                </fb:FilterGroupItem>
            </fb:filterGroupItems>
        </fb:FilterBar>
        <Table
            alternateRowColors="false"
            id="AA_id_AssestTable"
            busyIndicatorDelay="0"
            items="{
                path: 'assetModel>/',
                sorter: {
						path: 'Type',
						descending: false,
						group: true
					}
            }"
            class="sapUiResponsiveMargin"
            width="auto"
            mode="SingleSelectLeft"
        >
            <headerToolbar>
                <OverflowToolbar>
                    <Title
                        text="{i18n>assetData} ({= ${assetModel>/}.length})"
                    />
                    <ToolbarSpacer />
                    <Button
                        icon="sap-icon://excel-attachment"
                        press="AA_onExport"
                        type="Ghost"
                        text="{i18n>download}"
                    />

                    <Button
                        icon="sap-icon://add"
                        text="{i18n>assign}"
                        type="Accept"
                        press="AA_onPressAssign"
                        id="AA_AssignBtn"
                    />
                    <Button
                        icon="sap-icon://edit"
                        type="Neutral"
                        press="AA_onPressEdit"
                        text="{i18n>update}"
                        visible="false"
                    />
                    <Button
                        icon="sap-icon://clear-all"
                        type="Negative"
                        press="AA_onOpenUnassign"
                        text="{i18n>un-Assign}"
                    />
                </OverflowToolbar>
            </headerToolbar>
            <columns>
                <!-- <Column>
                    <Text text="{i18n>assignEmployeeID}" />
                </Column>
                <Column>
                    <Text text="{i18n>assignEmployeeName}" />
                </Column> -->
                <Column>
                    <Text text="{i18n>type}" />
                </Column>
                <Column>
                    <Text text="{i18n>model}" />
                </Column>
                <Column>
                    <Text text="{i18n>equipmentNumber}" />
                </Column>
                <Column>
                    <Text text="{i18n>serialNumber}" />
                </Column>
                <Column>
                    <Text text="{i18n>assignedByEmployeeName}" />
                </Column>
                <Column>
                    <Text text="{i18n>assignBranch}" />
                </Column>
                <Column>
                    <Text text="{i18n>assignedDate}" />
                </Column>
                <Column>
                    <Text text="{i18n>assetValue}" />
                </Column>
                <Column>
                    <Text text="{i18n>status}" />
                </Column>
                <Column>
                    <Text text="{i18n>returnDate}" />
                </Column>
            </columns>
            <items>
                <ColumnListItem class="tableRow">
                    <cells>
                   <ObjectIdentifier 
                           title="{assetModel>AssignEmployeeID}" 
                           text="{assetModel>AssignEmployeeName}" /> 
                        <!-- <Text text="{assetModel>Type}" /> -->
                        <Text text="{assetModel>Model}" />
                        <Text text="{assetModel>EquipmentNumber}" />
                        <Text text="{assetModel>SerialNumber}" />
                        <Text text="{assetModel>AssignedByEmployeeName}" />
                        <Text text="{assetModel>AssignBranch}" />
                        <Text
                            text="{= ${assetModel>AssignedDate} === '1899-11-30T00:00:00.000Z' || !${assetModel>AssignedDate} ? '' : ${assetModel>AssignedDate}.substring(8,10) + '/' + ${assetModel>AssignedDate}.substring(5,7) + '/' + ${assetModel>AssignedDate}.substring(0,4) }"
                        />
                        <Text
                            text="{path:'assetModel>AssetValue',formatter:'.Formatter.formatCurrencyInINRText'}"
                        />  
                        <ObjectStatus
                            inverted="true"
                            state="{= ${assetModel>Status} === 'Assigned' ? 'Success' : 'Error' }"
                            text="{assetModel>Status}"
                        />
                        <Text
                            text="{= ${assetModel>ReturnDate} === '1899-11-30T00:00:00.000Z' || !${assetModel>ReturnDate} ? '' : ${assetModel>ReturnDate}.substring(8,10) + '/' + ${assetModel>ReturnDate}.substring(5,7) + '/' + ${assetModel>ReturnDate}.substring(0,4) }"
                        />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
        <footer>
            <Bar>
                <contentLeft>
                    <core:Fragment
                        fragmentName="sap.kt.com.minihrsolution.fragment.Footer"
                        type="XML"
                    />
                </contentLeft>
            </Bar>
        </footer>
    </Page>
</mvc:View>
