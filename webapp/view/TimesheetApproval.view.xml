<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
    controllerName="sap.kt.com.minihrsolution.controller.TimesheetApproval"
	xmlns:fb="sap.ui.comp.filterbar"	
    displayBlock="true"
    xmlns:u="sap.ui.unified">
	<Page id="TSA_id_Page" >
		<headerContent>
			<Button  press="TSA_onPressback" icon="sap-icon://home" />
			<Text text="{i18n>headerTimesheetApproval}" class="boldBlackText"></Text>
			<ToolbarSpacer />
			<Button  press="TSA_onSignout" icon="sap-icon://log"></Button>
		</headerContent>
		<content>
		  <u:CalendarDateInterval
 id="TSA_id_calendar"
 width="100%"
 startDateChange="TSA_onSelect"/>
			<fb:FilterBar  class="sapUiTinyMargin" id="TSA_id_Filter" persistencyKey="myPersKey" useToolbar="false" clear="onPressClear" showClearOnFB="true" search=".onSearch" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad" >
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="Employee ID" label="Employee ID" groupName="Group1" visibleInFilterBar="true">
					<fb:control>
						<ComboBox name="Employee ID"  showClearIcon="true" items="" >
							<core:Item key="" text=""/>
						</ComboBox>
					</fb:control>
				</fb:FilterGroupItem>
					<fb:FilterGroupItem name="Month" label="Month" groupName="Group1" visibleInFilterBar="true">
					<fb:control>
						<ComboBox name="Month"  showClearIcon="true" items="" >
							<core:Item key="" text=""/>
						</ComboBox>
					</fb:control>
				</fb:FilterGroupItem>
					<fb:FilterGroupItem name="Status" label="Status" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
                   		<ComboBox name="Status"  showClearIcon="true" items="" >
							<core:Item key="" text=""/>
						</ComboBox>	
					</fb:control>
						</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table class="sapUiTinyMargin" growingScrollToLoad="true" width="auto"   items="" growing="true"  growingThreshold="50"  alternateRowColors="true">
				<columns>
					<Column demandPopin="true">
						<Text text="{i18n>employeeID}"/>
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>taskName}"/>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>date}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>day}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>hoursWorked}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>manager}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>status}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>employeeComment}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>managerComment}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem >
						<cells>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar>
				<contentLeft>
					   <HBox class="sapUiTinyMarginTop">
    <Image src="../image/logo.jpg" width="30px" height="30px" class="companylogo" />
    <Link
        class="footer-CoName sapUiTinyMarginBegin"
        text="Developed by Kalpavriksha Technologies"
        href="https://www.kalpavrikshatechnologies.com/" 
        target="_blank"  
    />
</HBox>
				</contentLeft>
				<contentRight>
					<Button text="{i18n>approve}" press="TSA_onApprove" type="Success"  id="TSA_id_Approve"/>
                <Button text="{i18n>reject}" press="TSA_onReject" type="Negative"  id="TSA_id_Reject"/>
				</contentRight>
			</Bar>
		</footer>
	</Page>
</mvc:View>
