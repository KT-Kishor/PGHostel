<mvc:View
	controllerName="sap.kt.com.minihrsolution.controller.ExpenseApplication"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	displayBlock="true"
	xmlns:core="sap.ui.core"
	height="100%"
	xmlns:fb="sap.ui.comp.filterbar"
	busyIndicatorDelay="0">
<Page >
    <headerContent>
	    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
		</headerContent>

    <content>
        <fb:FilterBar id="Exp-id-FilterBar" persistencyKey="myPersKey" useToolbar="false" clear="Exp_onPressClear" showClearOnFB="true" search="Exp_onSearch" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad" class="sapUiResponsiveMargin" >
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="EmployeeID" label="{i18n>employeeID}" groupName="Group1" visibleInFilterBar="true">
					<fb:control>
						<ComboBox name="EmployeeID" showSecondaryValues="true" showClearIcon="true" items="{EmpModel>/}" id="Exp_id_EmployeeName">
							<core:ListItem key="{EmpModel>EmployeeID}" text="{EmpModel>EmployeeID}" additionalText="{EmpModel>EmployeeName}" />
						</ComboBox>
					</fb:control>
				</fb:FilterGroupItem>
				<fb:FilterGroupItem name="ExpenseName" label="{i18n>expExpenseName}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox name="ExpenseName"  items="{FilterExpenseModel>/}" showClearIcon="true" id="Exp_id_ConsFilterBar">
								<core:Item key="{FilterExpenseModel>ExpenseName}" text="{FilterExpenseModel>ExpenseName}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
				<fb:FilterGroupItem name="Source" label="{i18n>expSource}" groupName="Group1" visibleInFilterBar="true">
					<fb:control>
						<ComboBox name="Source" showClearIcon="true" showSecondaryValues="true" id="Exp_id_SourceFilter" items="{BaseLocationModel>/}">
							<core:ListItem key="{BaseLocationModel>city}" text="{BaseLocationModel>city}" additionalText="{BaseLocationModel>branchCode}" />
						</ComboBox>
					</fb:control>
				</fb:FilterGroupItem>
				<fb:FilterGroupItem name="Destination" label="{i18n>expDestination}" groupName="Group1" visibleInFilterBar="true">
					<fb:control>
						<ComboBox name="Destination" id="Exp_id_DestinationFilter" showSecondaryValues="true" showClearIcon="true" items="{BaseLocationModel>/}">
							<core:ListItem key="{BaseLocationModel>city}" text="{BaseLocationModel>city}" additionalText="{BaseLocationModel>branchCode}" />
						</ComboBox>
					</fb:control>
				</fb:FilterGroupItem>
				<fb:FilterGroupItem name="Status" label="{i18n>status}" groupName="Group1" visibleInFilterBar="true">
					<fb:control>
						<ComboBox name="Status" id="Exp_id_StatusFilter" showClearIcon="true" items="{MyInbox>/}">
							<core:Item key="{MyInbox>StatusName}" text="{MyInbox>StatusName}"/>
						</ComboBox>
					</fb:control>
				</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>

			<Table id="exp_Id_ExpenseTable" items="{ExpenseModel>/}" class="sapUiResponsiveMargin" growing="true" growingThreshold="50"  alternateRowColors="true" growingScrollToLoad="true" width="auto" >
			 <headerToolbar>
                <OverflowToolbar >
                    <Title id="title" text="Expense Details"/>
                    <!-- <ToolbarSeparator/> -->
                    <ToolbarSpacer/>
                   <Button icon="sap-icon://add-employee" tooltip="{i18n>expenseAddTooltip}" press="Exp_onPressAddExpense" />
					<Button icon="sap-icon://download" press="Exp_onPressExpenseDownload" />
                </OverflowToolbar>
            </headerToolbar>
				<columns>
					<Column demandPopin="true">
						<Label text="{i18n>employeeName}" />
					</Column>
					<Column demandPopin="true">
						<Label text="{i18n>expExpenseName}" />
					</Column>
					<Column  minScreenWidth="Desktop" demandPopin="true">
						<Label text="{i18n>startDate}" />
					</Column>
					<Column  minScreenWidth="Desktop" demandPopin="true">
						<Label text="{i18n>endDate}" />
					</Column>
					<Column  demandPopin="true">
						<Label text="{i18n>expDestination}" />
					</Column>
					<Column  minScreenWidth="Desktop" demandPopin="true">
						<Label text="{i18n>totalAmount}" />
					</Column>
					<Column  minScreenWidth="Desktop" demandPopin="true">
						<Label text="{i18n>expReimbursementAmount}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Label text="{i18n>status}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Label text="" />
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="Exp_onCheckExpenseDetails">
						<cells>
							<Text text="{ExpenseModel>EmployeeID}" />
							<Text text="{ExpenseModel>EmployeeName}" />
							<Text text="{path:'ExpenseModel>ExpStartDate',formatter: '.Formatter.formatDate'}" />
							<Text text="{path:'ExpenseModel>ExpEndDate',formatter: '.Formatter.formatDate'}" />
							<Text text="{ExpenseModel>Destination}" />
							<Text text="{path:'ExpenseModel>TotalAmount', formatter: '.Formatter.fromatNumber'}" />
							<Text text="{path:'ExpenseModel>ReimbursementAmount',formatter: '.Formatter.fromatNumber'}" />						
							<ObjectStatus text="{ExpenseModel>Status}" inverted="true" state="{path:'ExpenseModel>Status', formatter: '.Formatter.formatObjectStatus'}" />
							<Button icon="sap-icon://delete" visible="{= ${ExpenseModel>Status} === 'Draft' }" press="Exp_onPressDeleteExpense" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
    </content>
	<footer>
			<Bar>
					    <contentLeft>
                    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
                </contentLeft>
			</Bar>
		</footer>
    
</Page>
</mvc:View>