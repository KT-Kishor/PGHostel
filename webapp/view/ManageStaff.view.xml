<mvc:View controllerName="sap.ui.com.project1.controller.ManageStaff"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:m="sap.m"
	xmlns:c="sap.ui.core"
	xmlns:fb="sap.ui.comp.filterbar"
	xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%"
    busyIndicatorDelay="0">
	<Page showHeader="true">
		<headerContent>
			<core:Fragment fragmentName="sap.ui.com.project1.fragment.Header" type="XML"/>
		</headerContent>
		<content>
			<fb:FilterBar
                id="MS_id_FilterbarEmployee"
                persistencyKey="myPersKey"
                useToolbar="false"
                clear="FC_onPressClear"
                showClearOnFB="true"
                search="Onsearch"
                filterChange="IA_.onFilterChange"
                afterVariantLoad="IA_.onAfterVariantLoad"
                showFilterConfiguration="false"
                filterContainerWidth="auto"
				class="filterBarTheme">
				<fb:filterGroupItems>
					<fb:FilterGroupItem
                        name="UserID"
                        label="{i18n>MVUserID}"
                        groupName="Group"
                        visibleInFilterBar="true">
						<fb:control>
							<ComboBox
                                id="MS_id_UserID"
                                items="{mainModel>/}"
                                showClearIcon="true" showSecondaryValues="true" filterSecondaryValues="true">
								<core:ListItem key="{mainModel>UserID}" text="{mainModel>UserID}" additionalText="{mainModel>UserName}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem
                        name="City"
                        label="{i18n>city}"
                        groupName="Group"
                        visibleInFilterBar="true">
						<fb:control>
							<ComboBox
                                id="MS_id_City"
                                items="{mainModel>/}"
                                showClearIcon="true">
								<core:Item key="{mainModel>City}" text="{mainModel>City}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table id="MS_id_ManageStaff"
                sticky="ColumnHeaders,HeaderToolbar"
                mode="SingleSelectLeft"
                width="auto"
                busyIndicatorDelay="0"
                items="{path: 'mainModel>/', sorter: {path: 'Role',descending: false,group: true}}">
				<headerToolbar>
					<OverflowToolbar>
						<Title text="{i18n>MSstaffheading} ({= ${mainModel>/}.length})"/>
						<ToolbarSpacer />
						<Button text="{i18n>MSadd}" press="HM_AddHostelFeature" tooltip="{i18n>MSadd}"
                            class="myUnifiedBtn"/>
						<Button text="{i18n>MSedit}" press="HM_EditHostelFeature" tooltip="{i18n>MSedit}"
                            class="myUnifiedBtn"/>
						<Button text="{i18n>MSdelete}" press="HM_DeleteHostelFeature" tooltip="{i18n>MSdelete}"
                            class="myUnifiedBtn"/>
						<Button text="{i18n>download}" tooltip="{i18n>download}" press="MS_onDownload" icon="sap-icon://excel-attachment"
                            class="myUnifiedBtn"/>
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column demandPopin="true">
						<Text text="{i18n>MVstaffName}" tooltip="{i18n>MVstaffName}"/>
					</Column>
					<Column demandPopin="true" width="15%" minScreenWidth="Tablet">
						<Text text="{i18n>emailId}" tooltip="{i18n>emailId}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet">
						<Text text="{i18n>branchCode}" tooltip="{i18n>branchCode}"/>
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>MVgender}" tooltip="{i18n>MVgender}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet">
						<Text text="{i18n>MSmobileNo}" tooltip="{i18n>MSmobileNo}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet">
						<Text text="{i18n>city}" tooltip="{i18n>city}"/>
					</Column>
					<Column demandPopin="true" minScreenWidth="Tablet" width="20%" hAlign="Center">
						<Text text="{i18n>address}" tooltip="{i18n>address}" textAlign="Center" width="100%"/>
					</Column>
				</columns>
				<items>
					<ColumnListItem>
						<cells>
							<Text text="{mainModel>Salutation} {mainModel>UserName} ({mainModel>UserID})"/>
							<Text text="{mainModel>EmailID}"/>
							<Text text="{
									parts: [
										{ path: 'mainModel>BranchCode' },
										{ path: 'BranchModel>/' }
									],
									formatter: '.Formatter.formatBranchNames'
								}"
							/>
							<Text text="{mainModel>Gender}" />
							<Text text="{mainModel>STDCode} {mainModel>MobileNo}"/>
							<Text text="{mainModel>City}" />
							<Text text="{mainModel>Address}"  wrapping="true"/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<core:Fragment fragmentName="sap.ui.com.project1.fragment.AppFooter" type="XML"/>
		</footer>
	</Page>
</mvc:View>