<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
    controllerName="sap.kt.com.minihrsolution.controller.Timesheet"
	xmlns:fb="sap.ui.comp.filterbar"	
    displayBlock="true"
    xmlns:u="sap.ui.unified">
	<Page id="TS_id_Page" >
		<headerContent>
			        <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />

		</headerContent>
		<content>
		  <u:CalendarDateInterval
 id="TS_id_calendarTimesheet"
 width="100%"
 startDateChange="onCalendarSelect"/>
			<fb:FilterBar  class="sapUiTinyMargin" id="TS_id_FilterBar" persistencyKey="myPersKey" useToolbar="false" clear="onPressClear" showClearOnFB="true" search=".onSearch" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad" >
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="Month" label="{i18n>month}" groupName="Group1" visibleInFilterBar="true">
					<fb:control>
						<ComboBox   showClearIcon="true" items="" >
							<core:Item key="" text=""/>
						</ComboBox>
					</fb:control>
				</fb:FilterGroupItem>
					<fb:FilterGroupItem name="Year" label="{i18n>year}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
                    <DatePicker
                    id="TS_id_Year"
                    valueFormat="yyyy" 
                    displayFormat="yyyy"
                    change="onDateChange" />						
					</fb:control>
						</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<MessageStrip
                text="{i18n>notification}"
                type="Information"
                showIcon="true"
                class="sapUiResponsiveLayout"/>
			<Table class="sapUiTinyMargin" growingScrollToLoad="true" width="auto"   items="" growing="true"  growingThreshold="50"  alternateRowColors="true">
			 <headerToolbar>
                <OverflowToolbar >
                    <Title text="{i18n>tileTimesheetFooter}"/>
                    <ToolbarSpacer/>
                    <Button text="{i18n>fillTimesheet}" press="TS_onFillDetails" type="Accept" icon="sap-icon://create-entry-time"/>
                </OverflowToolbar>
            </headerToolbar>
				<columns>
					<Column demandPopin="true">
						<Text text="{i18n>taskName}"/>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>date}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>day}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>hoursWorked}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>manager}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>status}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>employeeComment}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>managerComment}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem >
						<cells>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar>
				 <contentLeft>
                    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
                </contentLeft>
				<contentRight>
					<Button text="{i18n>submit}" press="TS_onSubmitTimesheet" type="Success"  id="TS_id_Submited"/>
                <Button text="{i18n>delete}" press="TS_onDeleteTimesheet" type="Negative"  id="TS_id_Delete"/>
				</contentRight>
			</Bar>
		</footer>
	</Page>
</mvc:View>
