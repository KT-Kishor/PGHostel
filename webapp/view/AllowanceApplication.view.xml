<mvc:View
	controllerName="sap.kt.com.minihrsolution.controller.AllowanceApplication"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	displayBlock="true"
	xmlns:core="sap.ui.core"
	height="100%"
	xmlns:fb="sap.ui.comp.filterbar"
	busyIndicatorDelay="0">
	<Page >
		<headerContent>
			<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
		</headerContent>
		<content>
			<fb:FilterBar id="All_id_FilterBar" showFilterConfiguration="false" persistencyKey="myPersKey" useToolbar="false" clear="Exp_onPressClear" showClearOnFB="true" search="Exp_onSearch" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad" class="sapUiResponsiveMargin" >
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="EmployeeID" label="{i18n>employeeID}" groupName="Group1" visibleInFilterBar="{= ${LoginModel>/Role} === 'Admin' ? true : false}">
						<fb:control>
							<ComboBox name="EmployeeID" change="onChangeEmployeeID" showSecondaryValues="true" showClearIcon="true" items="{ManagerModel>/}" id="All_id_EmployeeName">
								<core:ListItem key="{EmpModel>EmployeeID}" text="{ManagerModel>EmployeeID}" additionalText="{ManagerModel>EmployeeName}" />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="AllowanceName" label="{i18n>allowanceName}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox name="AllowanceName"  items="{FilterAllowanceModel>/AllowanceNameSet}" showClearIcon="true" id="All_id_ConsFilterBar">
								<core:Item key="{FilterAllowanceModel>AllowanceName}" text="{FilterAllowanceModel>AllowanceName}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="Source" label="{i18n>expSource}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox name="Source" showClearIcon="true" showSecondaryValues="true" id="All_id_SourceFilter" items="{path:'FilterAllowanceModel>/SourceSet',length:1000}">
								<core:ListItem key="{FilterAllowanceModel>Source}" text="{FilterAllowanceModel>Source}" />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="Destination" label="{i18n>expDestination}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox name="Destination" id="All_id_DestinationFilter" showSecondaryValues="true" showClearIcon="true" items="{path:'FilterAllowanceModel>/DestinationSet',length:1000}">
								<core:ListItem key="{FilterAllowanceModel>Destination}" text="{FilterAllowanceModel>Destination}" />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="Status" label="{i18n>status}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox name="Status" id="All_id_StatusFilter" showClearIcon="true" items="{MyInbox>/}">
								<core:Item key="{MyInbox>StatusName}" text="{MyInbox>StatusName}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="AllowanceDate" label="{i18n>expDetExpenseDate}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<DateRangeSelection id="All_id_InvoiceDatePicker" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy" change="onDateRangeChange" />
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table id="All_id_Expense" items="{path: 'AllowanceModel>/', sorter: {path: 'Status',descending: false,group: true},groupHeaderFactory: '.getGroupHeader'}"
			class="sapUiResponsiveMargin"
			growing="true"
			growingThreshold="50"
			alternateRowColors="true"
			growingScrollToLoad="true"
			width="auto"
			mode="SingleSelectLeft"
			selectionChange="onTableSelectionChange"
			sticky="ColumnHeaders,HeaderToolbar"
			busyIndicatorDelay="0">
				<headerToolbar>
					<OverflowToolbar >
						<Title id="All_id_title" text="{i18n>allowanceDetails} ({= ${AllowanceModel>/}.length })"/>
						<ToolbarSpacer/>
						<Button type="Transparent" tooltip="{i18n>deleteallowance}" enabled="false" id="All_id_DeleteBtn" text="{i18n>deleteallowance}" press="Exp_onPressDeleteExpense" />
						<Button type="Transparent" text="{i18n>allowance}" tooltip="{i18n>allowance}" press="Exp_onPressAddExpense" />
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column demandPopin="true">
						<Label text="{i18n>employeeName}" />
					</Column>
					<Column demandPopin="true">
						<Label text="{i18n>allowanceType}" />
					</Column>
					<Column demandPopin="true">
						<Label text="{i18n>allowanceName}" />
					</Column>
					<Column  minScreenWidth="Desktop" demandPopin="true">
						<Label text="{i18n>startDate}" />
					</Column>
					<Column  minScreenWidth="Desktop" demandPopin="true">
						<Label text="{i18n>endDate}" />
					</Column>
					<Column  demandPopin="true">
						<Label text="{i18n>expDestination}" />
					</Column>
					<Column  minScreenWidth="Desktop" demandPopin="true">
						<Label text="{i18n>totalAmount}" />
					</Column>
					<Column  minScreenWidth="Desktop" demandPopin="true">
						<Label text="{i18n>expReimbursementAmountExp}"  tooltip="{i18n>expReimbursementAmount}"/>
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="Exp_onCheckExpenseDetails">
						<cells>
							<ObjectIdentifier title="{AllowanceModel>EmployeeID}" text="{AllowanceModel>EmployeeName}"/>
							<Text text="{AllowanceModel>AllowanceType}" />
							<Text text="{AllowanceModel>AllowanceName}" />
							<Text text="{path:'AllowanceModel>AllowanceStartDate',formatter: '.Formatter.formatDate'}" />
							<Text text="{path:'AllowanceModel>AllowanceEndDate',formatter: '.Formatter.formatDate'}" />
							<Text text="{AllowanceModel>Destination}" />
							<Text text="INR {path:'AllowanceModel>TotalAmount', formatter: '.Formatter.fromatNumber'}" />
							<Text text="INR {path:'AllowanceModel>ReimbursementAmount',formatter: '.Formatter.fromatNumber'}" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar>
				<contentLeft>
					<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
				</contentLeft>
			</Bar>
		</footer>
	</Page>
</mvc:View>