                <columns>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text text="{i18n>bookingID}" />
                    </Column>

                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text text="{i18n>customerName}" />
                    </Column>

                    <!-- TIMELINE INFORMATION (Tablet and up) -->
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text text="{i18n>DdepositDate}" />
                    </Column>

                    <!-- FINANCIAL STATUS (Always visible) -->
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text text="{i18n>depositAmount}" />
                    </Column>

                    <!-- TRANSACTION REFERENCES (Desktop only - detailed view) -->
                    <Column
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>DepositMTransactionID}" />
                    </Column>

                    <Column
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>depositTakenBy}" />
                    </Column>

                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text text="{i18n>returnDate}" />
                    </Column>

                    <Column
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>returnAmount}" />
                    </Column>

                    <Column
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>returnTransactionID}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>returnDepositBy}" />
                    </Column>

                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text text="{i18n>status}" />
                    </Column>
                </columns>

                <!-- Row Template - UPDATE CELLS HERE -->
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{DepositModel>BookingID}" />
                            <Text text="{DepositModel>CustomerName}" />
                            <Text
                                text="{ 
                                    path: 'DepositModel>DepositDate',
                                    formatter: '.Formatter.formatDate' 
                                }"
                            />

                            <Text
                                text="{ 
                                    parts: [
                                        {path: 'DepositModel>DepositAmount'},{path: 'DepositModel>DepositCurrency'}
                                    ],
                                    formatter: '.Formatter.formatCurrency'
                                }"
                            />
                            <!-- <Text text="{DepositModel>DepositCurrency}" /> -->

                            <Text
                                text="{  parts: [  { path: 'DepositModel>DepositMode' },  { path: 'DepositModel>DepositTransactionID' }  ],  formatter: '.Formatter.joinWithSlash'  }"
                            />
                            <!-- NEW CELL: DepositTakenBy -->
                            <Text text="{DepositModel>DepositTakenBy}" />
                            <Text
                                text="{ 
                                    path: 'DepositModel>ReturnDepositDate',
                                    formatter: '.Formatter.formatDate' 
                                }"
                            />

                            <Text
                                text="{ 
                                    parts: [
                                        {path: 'DepositModel>ReturnDepositAmount'},{path: 'DepositModel>ReturnDepositCurrency'}
                                    ],
                                    formatter: '.Formatter.formatCurrency'
                                }"
                            />

                            <Text
                                text="{parts: [{ path: 'DepositModel>ReturnDepositMode' }, { path: 'DepositModel>ReturnDepositTransactionID' }],formatter: '.Formatter.joinWithSlash'}"
                            />
                            <!-- NEW CELL: ReturnDepositBy -->
                            <Text text="{DepositModel>ReturnDepositBy}" />
                            <!-- <Text text="{DepositModel>BranchCode}" /> -->
                            <!-- Branch Cell - SHOW BRANCH NAME -->
                            <ObjectStatus
                                text="{DepositModel>Status}"
                                state="{ 
                                    path: 'DepositModel>Status',
                                    formatter: '.Formatter.formatObjectStatus'
                                }"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
