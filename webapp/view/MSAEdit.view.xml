<mvc:View
    controllerName="sap.kt.com.minihrsolution.controller.MSAEdit"
	xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
	xmlns:f="sap.ui.layout.form"
	xmlns="sap.uxap"
	xmlns:core="sap.ui.core"
	xmlns:layout="sap.ui.layout"
	xmlns:m="sap.m">
	<m:Page id="MsaE_id_Page" title="{i18n>msaDetails}" navButtonPress="MsaE_onBack" showNavButton="true">
		<ObjectPageLayout  busyIndicatorDelay="0"
            enableLazyLoading="true"
            useIconTabBar="true"
            showTitleInHeaderContent="true"
			id="MsaE_id_ObjectPageLayout"
            upperCaseAnchorBar="false">
			<headerTitle>
				<ObjectPageDynamicHeaderTitle>
					<actions>
					<m:Button text="Edit"  type="Transparent" press="MsaE_onEditOrSavePress" />
						<!-- <m:Button  
            text="{= ${simpleForm>/editable} ? 'Save' : 'Edit' }" 
            type="{= ${simpleForm>/editable} ? 'Accept' : 'Transparent' }" 
            press="MsaE_onEditOrSavePress" 
        /> -->
						<m:Button 
            text="{i18n>tileFooter}" 
            enabled="{simpleForm>/isEnabled}" 
            press="MsaE_onSendEmailMSA" 
        />
						<m:Button 
            text="{i18n>tileUnit}" 
            enabled="{simpleForm>/isEnabled}"  
            press="MsaE_onPressMerge"  
        />
					</actions>
					<expandedHeading>
						<m:Title
                text="{FilteredMsaModel>/0/CompanyName}"
                wrapping="true"
            />
					</expandedHeading>
					<!-- Snapped Header Title (with Avatar + Title) -->
					<snappedHeading>
						<m:FlexBox fitContainer="true" alignItems="Center">
							<m:Avatar
                    displayShape="Circle"
                    displaySize="M"
                    backgroundColor="Accent1"
                    initials="{= ${FilteredMsaModel>/0/CompanyName} ? ${FilteredMsaModel>/0/CompanyName}.substring(0,2).toUpperCase() : '' }"
                    class="sapUiSmallMarginEnd"
                />
							<m:Title
                    text="{FilteredMsaModel>/0/CompanyName}"
                    wrapping="true"
                />
						</m:FlexBox>
					</snappedHeading>
					<!-- Expanded Content -->
					<expandedContent>
						<m:Text text="{FilteredMsaModel>/0/PanCard}" />
					</expandedContent>
					<!-- Snapped Content -->
					<snappedContent>
						<layout:VerticalLayout>
							<m:Text text="{FilteredMsaModel>/0/PanCard}" />
							<layout:HorizontalLayout class="sapUiTinyMarginTop">
								<m:Label text="{i18n>companyHeadName}" showColon="true" />
								<m:Text
                        class="sapUiTinyMarginBegin"
                        text="{FilteredMsaModel>/0/Salutation} {FilteredMsaModel>/0/CompanyHeadName}"
                    />
							</layout:HorizontalLayout>
						</layout:VerticalLayout>
					</snappedContent>
				</ObjectPageDynamicHeaderTitle>
			</headerTitle>
			<!-- 3-Column Header Content -->
			<headerContent>
				<m:FlexBox
                    busyIndicatorDelay="0"
                    id="QF_id_HeaderContent"
                    wrap="Wrap"
                    fitContainer="true"
                >
					<m:Avatar
                displayShape="Circle"
                displaySize="M"
                backgroundColor="Accent1"
                initials="{= ${FilteredMsaModel>/0/CompanyName} ? ${FilteredMsaModel>/0/CompanyName}.substring(0,2).toUpperCase() : '' }"
                class="sapUiLargeMarginEnd"
            />
					<layout:VerticalLayout
                        class="sapUiSmallMarginBottom sapUiSmallMarginEnd"
                    >
						<layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd"
                        >
							<m:Label showColon="true" text="{i18n>companyHeadName}" />
							<m:Text text="{FilteredMsaModel>/0/Salutation} {FilteredMsaModel>/0/CompanyHeadName}" />
						</layout:HorizontalLayout>
						<layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd"
                        >
							<m:Label text="{i18n>companyHeadPosition}" showColon="true" />
							<m:Text text="{FilteredMsaModel>/0/CompanyHeadPosition}" />
						</layout:HorizontalLayout>
						<layout:HorizontalLayout class="sapUiSmallMarginBeginEnd">
							<m:Label text="{i18n>branch}" showColon="true" />
							<m:Text text="{FilteredMsaModel>/0/BranchCode}" />
						</layout:HorizontalLayout>
						<layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd"
                        >
							<m:Label text="{i18n>createMSADate}" showColon="true" />
							<m:Text text="{path:'FilteredMsaModel>/0/CreateMSADate', formatter: '.Formatter.formatDate'}" />
						</layout:HorizontalLayout>
					</layout:VerticalLayout>
					<layout:VerticalLayout
                        class="sapUiSmallMarginBeginEnd sapUiMediumMarginEnd sapUiSmallMarginBottom"
                    >
						<layout:HorizontalLayout>
							<m:Label text="{i18n>paymentterms}" showColon="true" />
							<m:Text text="{FilteredMsaModel>/0/PaymentTerms}" />
						</layout:HorizontalLayout>
						<layout:HorizontalLayout>
							<m:Label text="{i18n>contractPeriod}" showColon="true" />
							<m:Text text="{FilteredMsaModel>/0/ContractPeriod}" />
						</layout:HorizontalLayout>
						<layout:HorizontalLayout>
							<m:Label text="{i18n>panCard}" showColon="true" />
							<m:Text text="{FilteredMsaModel>/0/PanCard}" />
						</layout:HorizontalLayout>
						<layout:HorizontalLayout>
							<m:Label text="{i18n>emailId}" showColon="true" />
							<m:Text text="{FilteredMsaModel>/0/MsaEmail}" />
						</layout:HorizontalLayout>
						<layout:HorizontalLayout />
					</layout:VerticalLayout>
					<layout:VerticalLayout
                        class="sapUiTinyMarginBottom sapUiSmallMarginBegin"
                    >
						<layout:HorizontalLayout>
							<m:Label text="{i18n>Address}" showColon="true" />
							<m:Text text="{FilteredMsaModel>/0/Address}" width="300px"
                            wrapping="true"
                            wrappingType="Normal" />
						</layout:HorizontalLayout>
					</layout:VerticalLayout>
				</m:FlexBox>
			</headerContent>
			<sections>
				<ObjectPageSection titleUppercase="false" title="Sow Details" id="MsaE_id_SowDetailsSection">
					<subSections>
						<ObjectPageSubSection title=" " titleUppercase="false">
							<blocks>
								<m:Table items="{path:'SowReadModel>/',sorter: {path: 'SowID',descending: false,group: true}}"  busyIndicatorDelay="0" id="Sow_Id_ReadTable"  mode="SingleSelectLeft" selectionChange="onPressChangeSow">
									<m:headerToolbar>
										<m:OverflowToolbar>
											<m:Title text="{i18n>sowTitle}"/>
											<m:ToolbarSpacer />
											<!-- <m:ToolbarSeparator /> -->
											<m:ComboBox id="MsaE_id_SowStatus" items="{SowStatusModel>/SowStatus}" width="10%" change="MsaE_onChangeSowStatus">
												<core:Item key="{SowStatusModel>ID}" text="{SowStatusModel>Status}" />
											</m:ComboBox>
											<m:ToolbarSeparator />
											<m:Button icon="sap-icon://action" text="Actions" press="onOpenActionSheet"/>
											
										</m:OverflowToolbar>
									</m:headerToolbar>
									<m:columns>
										<m:Column demandPopin="true">
											<m:Text text="{i18n>sowId}"/>
										</m:Column>
										<m:Column demandPopin="true">
											<m:Text text="{i18n>consultantName}" />
										</m:Column>
										<m:Column minScreenWidth="Tablet" demandPopin="true">
											<m:Text text="{i18n>assignmentDes}" />
										</m:Column>
										<m:Column minScreenWidth="Desktop" demandPopin="true">
											<m:Text text="{i18n>startDate}" />
										</m:Column>
										<m:Column minScreenWidth="Tablet" demandPopin="true">
											<m:Text text="{i18n>endDate}" />
										</m:Column>
										<m:Column minScreenWidth="Tablet" demandPopin="true">
											<m:Text text="{i18n>designation}" />
										</m:Column>
										<m:Column minScreenWidth="Tablet" demandPopin="true">
											<m:Text text="{i18n>status}" />
										</m:Column>
									</m:columns>
									<m:items>
										<m:ColumnListItem >
											<m:cells>
												<m:Text text="{SowReadModel>SowID}"/>
												<m:Text text="{SowReadModel>ConsultantName}"/>
												<m:Text text="{SowReadModel>Description}"/>
												<m:Text text="{path:'SowReadModel>StartDate',formatter: '.Formatter.formatDate'}"/>
												<m:Text text="{path:'SowReadModel>EndDate',formatter: '.Formatter.formatDate'}"/>
												<m:Text text="{SowReadModel>Designation}"/>
												<m:Text text="{SowReadModel>Status}"/>
											</m:cells>
										</m:ColumnListItem>
									</m:items>
								</m:Table>
							</blocks>
						</ObjectPageSubSection>
					</subSections>
				</ObjectPageSection>
				<!-- <ObjectPageSection titleUppercase="false" title="PO">
					<subSections>
						<ObjectPageSubSection title=" " titleUppercase="false">
							<blocks>
								<m:Button text="Generate PDF" press="onPressOpenRTE"/>
							</blocks>
						</ObjectPageSubSection>
					</subSections>
				</ObjectPageSection> -->
			</sections>
		</ObjectPageLayout>
	</m:Page>
</mvc:View>
