<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:form="sap.ui.layout.form" 
    controllerName="sap.kt.com.minihrsolution.controller.LoginPage" 
    displayBlock="true">
	<Page id="Lp_id_Loginpage" class="login-background">
		<headerContent>
			<Avatar src="./image/logo.jpg" displaySize="XS" press="onAvatarPressed" tooltip="Company Logo"/>
			<Title level="H1" text="{i18n>companynameKT}" class="custom-text" wrapping="false"/>
			<ToolbarSpacer/>
			<Button icon="sap-icon://home" press="onpresshome" class="sapUiTinyMarginEnd" tooltip="{i18n>toolHome}"/>
		</headerContent>
		<content>
			<FlexBox class="sapUiMediumMargin" direction="Column" alignItems="End" justifyContent="End">
				<form:SimpleForm editable="true" layout="ResponsiveGridLayout" 
                class="loginForm"
                title="{i18n>loginDetails}" singleContainerFullSize="false" >
					<form:content>
						<Label text="{i18n>userId}" required="true"/>
						<Input placeholder="{i18n>placeUserId}"  valueStateText="{i18n>placeUserId}" liveChange="LP_onValidateUserId" id="Lp_id_Userid" value="{loginModel>/userIds}" maxLength="50" />
						
						<Label text="{i18n>userName}" required="true"/>
						<Input placeholder="{i18n>placeUserName}" valueStateText="{i18n>placeUserName}" liveChange="LP_onValidateUsername" id="Lp_id_Username"  value="{loginModel>/userNames}"  maxLength="50" />
						
						<Label text="{i18n>headloginwith}" />
<HBox alignItems="End" justifyContent="Start" >
    <RadioButton id="Lp_id_PasswordRadio" text="{i18n>btnpass}" groupName="loginOption" select="onLoginOptionChange" class="sapUiTinyMarginEnd"/>
    <RadioButton id="Lp_id_OtpRadio" text="{i18n>btnotp}" groupName="loginOption" select="onLoginOptionChange" class="sapUiTinyMarginEnd"/>
	<Button text="{i18n>sendOtp}" press="LP_onOtppress" id="idbtnsendotp" type="Ghost" class="Login" width="8rem" visible="false" />
</HBox>
						 
						<!-- OTP Input Field -->
						<Label text="{i18n>btnotp}" id="Lp_id_OtpLabel" visible="false" required="true" />
						<Input value="{loginModel>/enteredCaptcha}" id="Lp_id_CaptchaInput" class="sapUiTinyMarginEnd" 
                            placeholder="{i18n>placeOtp}" visible="{LoginModel>/isRadioVisible}"  maxLength="6"/>
                          
						<!-- Password Input Field (Initially Hidden) -->
						<Label text="{i18n>btnpass}" id="Lp_id_PasswordLabel" visible="false" required="true" />
						<Input id="Lp_id_PasswordInput" liveChange="LP_onpresPassword"  type="Password" placeholder="{i18n>placepass}" valueStateText="{i18n>placepass}" visible="false" valueHelpIconSrc="sap-icon://show" valueHelpRequest="LP_onTogglePasswordVisibility" showValueHelp="true"  maxLength="20"/>

						<!-- Forgot Password Link (Initially Hidden) -->
						<Link text="{i18n>forgotPass}" press="LP_onForgotPassword" id="Lp_id_ForgotPasswordLink" visible="false"/>
						
						<HBox alignContent="Center" justifyContent="End">
							<Button text="{i18n>btnLogin}" press="LP_onLogin" icon="sap-icon://key" type="Emphasized" class="Login" width="8rem"/>
						</HBox>
					</form:content>
				</form:SimpleForm>
			</FlexBox>
		</content>
	</Page>
</mvc:View>