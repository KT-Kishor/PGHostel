<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:form="sap.ui.layout.form" 
    controllerName="sap.kt.com.minihrsolution.controller.LoginPage" 
    displayBlock="true">
	<Page id="idLoginpage" class="login-background">
		<headerContent>
			<Avatar src="./image/logo.jpg" displaySize="XS" press=".onAvatarPressed" tooltip="Company Logo"/>
			<Title level="H1" text="{i18n>companynameKT}" class="custom-text" wrapping="false"/>
			<ToolbarSpacer/>
			<Button icon="sap-icon://home" press="onpresshome" class="sapUiTinyMarginEnd" tooltip="{i18n>toolHome}"/>
		</headerContent>
		<content>
			<FlexBox class="sapUiMediumMargin" direction="Column" alignItems="End" justifyContent="End">
				<form:SimpleForm editable="true" layout="ResponsiveGridLayout" 
                class="loginForm"
                title="{i18n>loginDetails}" singleContainerFullSize="false" >
					<form:content>
						<Label text="{i18n>userId}" required="true"/>
						<Input placeholder="{i18n>placeUserId}" id="idUserid" value="{loginModel>/userIds}" maxLength="50" valueStateText="Enter user ID" change="onDetailscheck"/>
						
						<Label text="{i18n>userName}" required="true"/>
						<Input placeholder="{i18n>placeUserName}" id="idUsername"  value="{loginModel>/userNames}" valueStateText="Enter user Name" maxLength="50" change="onDetailscheck"/>
						
						<Label text="{i18n>headloginwith}" />
<HBox alignItems="End" justifyContent="Start" >
    <RadioButton id="idOtpRadio" text="{i18n>btnotp}" groupName="loginOption" select="onLoginOptionChange" class="sapUiTinyMarginEnd"/>
    <RadioButton id="idPasswordRadio" text="{i18n>btnpass}" groupName="loginOption" select="onLoginOptionChange" class="sapUiTinyMarginEnd"/>
	<Button text="Send OTP" press="onOtppress" id="idbtnsendotp" type="Ghost" class="Login" width="8rem" visible="false" />
</HBox>
						
						<!-- OTP Input Field -->
						<Label text="{i18n>btnotp}" id="idOtpLabel" visible="false"/>
						<Input value="{loginModel>/enteredCaptcha}" id="idCaptchaInput" class="sapUiTinyMarginEnd" 
                            placeholder="{i18n>placeOtp}" visible="{LoginModel>/isRadioVisible}" submit="onLoginSubmit" maxLength="6"/>
                          
						<!-- Password Input Field (Initially Hidden) -->
						<Label text="{i18n>btnpass}" id="idPasswordLabel" visible="false"/>
						<Input id="idPasswordInput" type="Password" placeholder="{i18n>placepass}" visible="false"/>

						<!-- Forgot Password Link (Initially Hidden) -->
						<Link text="{i18n>forgotPass}" press="onForgotPassword" id="idForgotPasswordLink" visible="false"/>
						
						<HBox alignContent="Center" justifyContent="End">
							<Button text="{i18n>btnLogin}" press="onLogin" icon="sap-icon://key" type="Ghost" class="Login" width="8rem"/>
						</HBox>
					</form:content>
				</form:SimpleForm>
			</FlexBox>
		</content>
	</Page>
</mvc:View>