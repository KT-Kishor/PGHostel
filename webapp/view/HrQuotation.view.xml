<mvc:View
    controllerName="sap.kt.com.minihrsolution.controller.HrQuotation"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Page id="HQ_id_QuotationPage">
        <headerContent>
            <core:Fragment
                fragmentName="sap.kt.com.minihrsolution.fragment.Header"
                type="XML"
            />
        </headerContent>
        <content>
            <fb:FilterBar
                id="HQ_id_QuotationFilterBar"
                persistencyKey="myPersKey"
                filterChange="HQ_onFilterChange"
                afterVariantLoad=".onAfterVariantLoad"
                clear="HQ_onClearFilters"
                showClearOnFB="true"
                showFilterConfiguration="false"
                useToolbar="false"
                search="HQ_onSearch"
            >
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="QuotationNo"
                        label="{i18n>quotationNo}"
                        groupName="Group1"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                showSecondaryValues="true"
                                items="{path: 'CompanyQuotationModel>/'}"
                                showClearIcon="true"
                                id="HQ_id_quotationNo"
                            >
                                <core:ListItem
                                    key="{CompanyQuotationModel>QuotationNo}"
                                    text="{CompanyQuotationModel>QuotationNo}"
                                    additionalText="{CompanyQuotationModel>CompanyName}"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>
            <Table
                items="{path: 'CompanyQuotationModel>/'}"
                alternateRowColors="true"
                busyIndicatorDelay="0"
                id="HQ_id_QuotationItemTable"
                class="sapUiResponsiveMargin"
                width="auto"
            >
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{i18n>quotation}({= ${CompanyQuotationModel>/}.length })" />
                        <ToolbarSpacer />
                        <Button
                            text="{i18n>create}"
                            tooltip="{i18n>addQuotation}"
                            press="HQ_onPressAddQuotation"
                            type="Accept"
                        />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column hAlign="Left" demandPopin="true">
                        <Text text="{i18n>quotationNo}" />
                    </Column>
                    <Column hAlign="Left" minScreenWidth="Tablet" demandPopin="true">
                        <Text text="{i18n>companyName}" />
                    </Column>
                    <Column hAlign="Left" minScreenWidth="Tablet" demandPopin="true">
                        <Text text="{i18n>date}" />
                    </Column>
                    <Column hAlign="Left" minScreenWidth="Desktop" demandPopin="true">
                        <Text text="{i18n>companyGSTNO}" />
                    </Column>
                    <Column hAlign="Left" minScreenWidth="Desktop" demandPopin="true">
                        <Text text="{i18n>customerName}" />
                    </Column>
                    <Column hAlign="Left" minScreenWidth="Desktop" demandPopin="true">
                        <Text text="{i18n>customerGSTNO}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="HQ_onPressQuotation">
                        <cells>
                            <Text text="{CompanyQuotationModel>QuotationNo}" />
                            <Text text="{CompanyQuotationModel>CompanyName}" />
                            <Text text="{path:'CompanyQuotationModel>Date',formatter:'.Formatter.formatDate'}" />
                            <Text text="{CompanyQuotationModel>CompanyGSTNO}" />
                            <Text text="{CompanyQuotationModel>CustomerName}" />
                            <Text text="{CompanyQuotationModel>CustomerGSTNO}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <footer>
            <Bar>
                <contentLeft>
                    <core:Fragment
                        fragmentName="sap.kt.com.minihrsolution.fragment.Footer"
                        type="XML"
                    />
                </contentLeft>
            </Bar>
        </footer>
    </Page>
</mvc:View>
