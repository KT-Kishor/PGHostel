<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    controllerName="sap.kt.com.minihrsolution.controller.ManagePayroll"
    displayBlock="true"
    xmlns:u="sap.ui.unified"
>
    <Page id="MP_id_Page">
        <headerContent>
            <Button
                press="MP_onPressback"
                icon="sap-icon://home"
                tooltip="{i18n>home}"
            />
            <Text
                text="{i18n>headerManagePayroll}"
                class="boldBlackText"
            />
            <ToolbarSpacer />
            <Button
                press="MP_onLogout"
                icon="sap-icon://log"
                tooltip="{i18n>logoutTooltip}"
            />
        </headerContent>
        <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.SalaryTable" type="XML" />
        <footer>
            <Bar>
                <contentLeft>
                    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
                </contentLeft>
                <contentRight>
                    <u:FileUploader
                        id="MP_id_UpdateSalBtn"
                        buttonText="{i18n>updateSal}"
                        sameFilenameAllowed="true"
                        buttonOnly="true"
                        fileType="XLSX,xlsx,XLS,xls"
                        style="Attention"
                        icon="sap-icon://sys-next-page"
                        change=".MP_onPressSalUpdate"
                        visible="{Payroll>/isSELVisible}"
                    />
                    <Button
                        id="MP_id_DeleteBtn"
                        type="Negative"
                        text="{i18n>delete}"
                        icon="sap-icon://delete"
                        press=".MP_onPressDelete"
                        visible="{Payroll>/isSELVisible}"
                    />
                    <Button
                        type="Emphasized"
                        text="{i18n>export}"
                        icon="sap-icon://sys-prev-page"
                        press=".MP_onPressExport"
                        visible="{Payroll>/isSELVisible}"
                    />
                    <Button
                        type="Neutral"
                        text="{i18n>legend}"
                        icon="sap-icon://message-popup"
                        press=".MP_onOpenMessagePopover"
                        visible="{Payroll>/isSELVisible}"
                    />
                </contentRight>
            </Bar>
        </footer>
    </Page>
</mvc:View>
