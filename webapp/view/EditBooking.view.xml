<mvc:View
    controllerName="sap.ui.com.project1.controller.EditBooking"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified"
    displayBlock="true"
    xmlns:l="sap.ui.layout"
>
    <Page
        showHeader="true"
        enableScrolling="true"
        class="BookBGBlur"
    >
        <headerContent>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.BookingHeader"
                type="XML"
            />
        </headerContent>
        <l:Grid
            defaultSpan="XL12 L12 M12 S12"
            hSpacing="1"
            vSpacing="1"
            width="100%"
        >
            <l:content>
                <VBox>
                    <layoutData>
                        <l:GridData span="XL8 L8 M12 S12" />
                    </layoutData>
                    <!-- Booking Details Section -->
                    <Title
                        text="Booking Details"
                        class="booking-section-header"
                        wrapping="true"
                    />

                    <Panel
                        class="customBookingPanel booking-panel-enhanced panelbracket"
                    >
                        <MessageStrip
                            text="CheckIn Time : {HostelModel>/CheckInTime}     ; CheckOut Time : {HostelModel>/CheckOutTime}"
                            showIcon="true"
                            showCloseButton="false"
                            class="sapUiTinyMarginBottom"
                        />

                        <f:SimpleForm
                            editable="true"
                            layout="ResponsiveGridLayout"
                            labelSpanXL="4"
                            labelSpanL="4"
                            labelSpanM="4"
                            labelSpanS="12"
                            columnsXL="2"
                            columnsL="2"
                            columnsM="1"
                            class="responsiveForm"
                        >
<Label text="Property" />

                            <Input
                                id="EditBookProperty_ID"
                                value="{= ${HostelModel>/Area} + (${HostelModel>/PropertyType} ? ' (' + ${HostelModel>/PropertyType} + ')' : '') }"
                                editable="false"
                            />

<Label text="Room Type" />


                            <Input
                                id="EditBookBedType_ID"
                                value="{= ${HostelModel>/BedType} + (${HostelModel>/ACType} ? ' (' + ${HostelModel>/ACType} + ')' : '') }"
                                editable="false"
                            />


                            
                            <Label
                                text="Room Plan"
                                required="true"
                            />
                            <ComboBox
                                id="EditBookRoom_ID"
                                selectedKey="{HostelModel>/SelectedPriceType}"
                                items="{HostelModel>/AvailablePaymentMethods}"
                                selectionChange="onRoomPlanChange"
                                change="onRoomplane"
                                valueStateText="Select Room plan"
                                enabled="{BookingView>/editModeEnabled}"
                            >
                                <core:Item
                                    key="{HostelModel>key}"
                                    text="{HostelModel>text}"
                                />
                            </ComboBox>

                            <Label text="Rent Price" />
                            <Input
                                value="{= ${HostelModel>/FinalPrice} + ' ' + ${HostelModel>/Currency}}"
                                editable="false"
                            />
                       <Label text="No. of Persons" />
<Input
    value="{= (${HostelModel>/PropertyType} === 'Hostel' || ${HostelModel>/PropertyType} === 'PG') ? 1 : ${HostelModel>/Capacity} }"
    editable="false"
/>
                            <!-- <Label text="No. of Persons" />
                            <Input
                                value="{HostelModel>/SelectedPerson}"
                                editable="false"
                            /> -->

                            <Label
                                text="Duration"
                                visible="{BookingView>/showDurationSelector}"
                            />
                            <ComboBox
                                id="EditBookDuration_ID"
                                class="boldSelectItems"
                                width="100%"
                                selectedKey="{HostelModel>/SelectedMonths}"
                                items="{BookingView>/DurationOptions}"
                                visible="{BookingView>/showDurationSelector}"
                                change="onDurationChange"
                                valueStateText="Select Duration"
                                enabled="{BookingView>/editModeEnabled}"
                            >
                                <core:Item
                                    key="{BookingView>key}"
                                    text="{BookingView>text}"
                                />
                            </ComboBox>

                            <Label
                                text="Start Date"
                                required="true"
                            />
                            <DatePicker
                                id="EditBookStartdate_ID"
                                value="{HostelModel>/StartDate}"
                                valueFormat="dd/MM/yyyy"
                                displayFormat="dd/MM/yyyy"
                                minDate="{HostelModel>/TodayDate}"
                                change="onStartDateChange"
                                liveChange="onStartDateChange"
                                valueStateText="Please select a valid start date (cannot be in the past)"
                                showValueStateMessage="true"
                                placeholder="Select start date"
                                enabled="{BookingView>/editModeEnabled}"
                            />

                            <Label text="End Date" />
                            <DatePicker
                                id="EditBookEnddate_ID"
                                value="{HostelModel>/EndDate}"
                                valueFormat="dd/MM/yyyy"
                                displayFormat="dd/MM/yyyy"
                                editable="{= ${BookingView>/endDateEditable} &amp;&amp; ${BookingView>/editModeEnabled} }"
                                valueStateText="End date must be after start date"
                                change="onEndDateChange"
                                liveChange="onEndDateChange"
                                showValueStateMessage="true"
                                placeholder="Select end date"
                            />
                           
                        </f:SimpleForm>
                    </Panel>

                    <!-- Guest Information Section -->
                    <Title
                        text="Select Occupants"
                        class="booking-section-header"
                        wrapping="true"
                    />

                    <Panel
                        class="customBookingPanel booking-panel-enhanced panelbracket"
                    >
                        <VBox class="sapUiTinyMargin">
                            <Input
                                id="EditmemberValueHelpInput"
                                value="{path: 'BookingView>/FamilyMembers', formatter: '.formatSelectedMembersSummary'}"
                                placeholder="Click here to select or add members"
                                showValueHelp="{BookingView>/editModeEnabled}"
                                valueHelpOnly="true"
                                valueHelpRequest="onMemberValueHelpRequest"
                                enabled="{BookingView>/editModeEnabled}"
                            />
                            <MessageStrip
                                text="You can change any occupant as the primary occupant; they will be the contact person"
                                type="Information"
                                showIcon="true"
                                showCloseButton="false"
                                class="sapUiTinyMarginTop sapUiTinyMarginBottom"
                                visible="{BookingView>/showFamilySection}"
                            />

                            <Text
                                text="{path: 'BookingView>/FamilyMembers', formatter: '.formatSelectedMembersCount'}"
                                class="sapUiTinyMarginTop sapUiTinyMarginBottom"
                            />

                            <VBox
                                class="sapUiTinyMarginBottom"
                                visible="{BookingView>/showFamilySection}"
                            >
                                <Text
                                    text="Primary occupant (Contact Person): {path: 'BookingView>/FamilyMembers', formatter: '.formatPrimaryOccupantName'}"
                                    class="sapUiSmallMarginBottom"
                                    visible="{= ${BookingView>/FamilyMembers}.length > 0 }"
                                />
                            </VBox>

                            <Table
                                items="{BookingView>/FamilyMembers}"
                                noDataText="No members selected"
                                class="responsiveTable"
                            >
                                <columns>
                                    <Column  
                                        visible="{BookingView>/showFamilySection}"
                                    >
                                        <Text text="Primary" />
                                    </Column>

                                    <Column
                                       
                                        width="3rem"
                                    >
                                        <Text text="Full Name" />
                                    </Column>
                                    <Column
                                      
                                    >
                                        <Text text="Age" />
                                    </Column>
                                    <Column
                                        minScreenWidth="Tablet"
                                        demandPopin="true"
                                    >
                                        <Text text="Gender" />
                                    </Column>
                                    <Column
                                             minScreenWidth="Tablet"
                                        demandPopin="true"
                                    >
                                        <Text text="Relationship" />
                                    </Column>
                                    <Column >
                                    </Column>
                                </columns>

                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <RadioButton
                                                groupName="primaryOccupantGroup"
                                                selected="{BookingView>IsPrimary}"
                                                select="onPrimaryOccupantRadioSelect"
                                                visible="{BookingView>/showFamilySection}"
                                                enabled="{BookingView>/editModeEnabled}"
                                            />

                                            <Text
                                                text="{= (${BookingView>Salutation} ? ${BookingView>Salutation} + ' ' : '') + (${BookingView>Name} || '')}"
                                            />
                                            <Text
                                                text="{path: 'BookingView>Age', formatter: '.Formatter.formatAgeFromDOBOrAge'}"
                                            />

                                           <Text text="{BookingView>Gender}" />
                                            <Text
                                                text="{BookingView>Relation}"
                                            />

                                          
                                            <Button
                                                icon="sap-icon://delete"
                                                tooltip="Remove member"
                                                press="onDeleteFamilyMemberRow"
                                                class="myUnifiedBtn"
                                                enabled="{BookingView>/editModeEnabled}"
                                            />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </Panel>

                    <!-- Facilities Section -->
                    <Title
                        text="Facilities"
                        class="booking-section-header"
                        wrapping="true"
                        visible="{= ${FacilityModel>/Facilities}.length > 0 }"
                    />

                    <Panel
                        class="customBookingPanel booking-panel-enhanced facilityBookingPanel panelbracket"
                        visible="{= ${FacilityModel>/Facilities}.length > 0 }"
                    >
                        <VBox class="sapUiTinyMargin">
                            <MessageStrip
                                text="Add only the facilities you need. Package charge type is fixed by setup: Daily or Once per booking."
                                type="Information"
                                showIcon="true"
                                showCloseButton="false"
                                class="sapUiTinyMarginBottom facilityMessageStrip"
                            />

                            <HBox
                                width="100%"
                                alignItems="Center"
                                justifyContent="SpaceBetween"
                                class="facilitiesNavContainer facilityCarouselShell"
                            >
                                <Button
                                    id="facilityPrevBtn"
                                    icon="sap-icon://slim-arrow-left"
                                    press="onFacilityPrev"
                                    class="facilityNavBtn sapUiTinyMarginEnd myUnifiedBtn"
                                />

                                <HBox
                                    id="facilityViewport"
                                    width="100%"
                                    renderType="Bare"
                                    class="facilityViewport"
                                >
                                    <HBox
                                        id="facilityCardsContainer"
                                        renderType="Bare"
                                        class="facilityTrack"
                                    />
                                </HBox>

                                <Button
                                    id="facilityNextBtn"
                                    icon="sap-icon://slim-arrow-right"
                                    press="onFacilityNext"
                                    class="facilityNavBtn sapUiTinyMarginBegin myUnifiedBtn"
                                />
                            </HBox>
<!-- Dot indicators for mobile swipe navigation -->
<HBox
    id="facilityDotsContainer"
    justifyContent="Center"
    alignItems="Center"
    class="facilityDotsRow sapUiTinyMarginTop"
    visible="false"
/>

                        </VBox>
                    </Panel>
                </VBox>
            </l:content>

            <!-- Right Column - Takes full width on mobile, 35% on tablet/desktop -->

            <l:content>
                <VBox>
                    <layoutData>
                        <l:GridData span="XL4 L4 M12 S12" />
                    </layoutData>
                    <!-- Advertisement Carousel Section -->
                    <Title
                        text="Advertisements"
                        class="booking-section-header"
                        wrapping="true"
                        visible="{= ${AdvertisementModel>/Advertisements}.length > 0 }"
                    />

                    <Panel
                        class="adPanel panelbracket"
                        visible="{= ${AdvertisementModel>/Advertisements}.length > 0 }"
                    >
                        <VBox class="sapUiTinyMargin">
                            <Carousel
                                id="AdvertisementCarousel"
                                visible="{= ${AdvertisementModel>/Advertisements}.length > 0 }"
                                showPageIndicator="true"
                                arrowsPlacement="Content"
                                loop="true"
                                pages="{
                                    path: 'AdvertisementModel>/Advertisements',
                                    templateShareable: false
                                }"
                            >
                                <pages>
                                    <Image
                                        src="{AdvertisementModel>image}"
                                        alt="{AdvertisementModel>title}"
                                        width="100%"
                                        height="300px"
                                        press="onAdvertisementImagePress"
                                    />
                                </pages>
                            </Carousel>
                        </VBox>
                    </Panel>

                    <!-- Coupon Section -->
                    <Title
                        text="Have a Coupon?"
                        class="booking-section-header"
                        wrapping="true"
                    />

                    <Panel class="couponPanel panelbracket">
                        <HBox
                            width="100%"
                            alignItems="Center"
                            justifyContent="Start"
                            wrap="NoWrap"
                            class="sapUiTinyMarginTop"
                        >
                            <Input
                                value="{HostelModel>/CouponCode}"
                                placeholder="Enter coupon code"
                                liveChange="onCouponLiveChange"
                                class="sapUiSmallMarginEnd couponInput"
                                width="100%"
                                maxLength="15"
                                submit="onApplyCoupon"
                                enabled="{BookingView>/editModeEnabled}"
                            >
                                <layoutData>
                                    <FlexItemData
                                        growFactor="1"
                                        shrinkFactor="1"
                                    />
                                </layoutData>
                            </Input>
                            <Button
                                text="Apply Coupon"
                                press="onApplyCoupon"
                                class="myUnifiedBtn couponButton sapUiTinyMarginBegin"
                                visible="{= !${HostelModel>/AppliedCouponCode} }"
                                enabled="{BookingView>/editModeEnabled}"
                            >
                                <layoutData>
                                    <FlexItemData
                                        growFactor="0"
                                        shrinkFactor="0"
                                    />
                                </layoutData>
                            </Button>
                            <Button
                                text="Remove"
                                press="onRemoveCoupon"
                                class="myUnifiedBtn couponButton sapUiTinyMarginBegin"
                                visible="{= !!${HostelModel>/AppliedCouponCode} }"
                                enabled="{BookingView>/editModeEnabled}"
                            >
                                <layoutData>
                                    <FlexItemData growFactor="0" />
                                </layoutData>
                            </Button>
                        </HBox>
                    </Panel>

                    <!-- Payment Summary Section -->
                    <Title
                        text="Pricing Details"
                        class="booking-section-header"
                        wrapping="true"
                    />

                    <Panel
                        class="customBookingPanel booking-panel-enhanced panelbracket"
                    >
                        <VBox class="sapUiTinyMargin">
                            <MessageStrip
                                text="{HostelModel>/RefundMessage}"
                                type="Information"
                                showIcon="true"
                                showCloseButton="true"
                                visible="{HostelModel>/ShowRefundMessage}"
                                class="sapUiTinyMarginBottom"
                            />
                            <HBox
                                justifyContent="SpaceBetween"
                                alignItems="Center"
                                visible="{BookingView>/showBusinessTravelOption}"
                                class="sapUiTinyMarginBottom"
                            >
                                <Text text="GST Details(optional)" />
                                <Switch
                                    state="{HostelModel>/IsBusinessTravel}"
                                    change="onBusinessTravelToggle"
                                    enabled="{= ${BookingView>/showBusinessTravelOption} &amp;&amp; ${BookingView>/editModeEnabled} }"
                                />
                            </HBox>

                            <Label
                                required="true"
                                text="GSTIN"
                                visible="{BookingView>/showBusinessGSTSection}"
                                class="sapUiTinyMarginBottom"
                            />
                            <Input
                                id="EditBookGst_ID"
                                value="{HostelModel>/CustomerGSTIN}"
                                placeholder="Enter GSTIN"
                                visible="{BookingView>/showBusinessGSTSection}"
                                liveChange="onGSTINLiveChange"
                                change="onGSTINChange"
                                class="sapUiTinyMarginBottom"
                                valueStateText="{i18n>gstError}"
                                width="100%"
                                enabled="{BookingView>/editModeEnabled}"
                            />

                            <Label
                                required="true"
                                text="Company Name"
                                visible="{BookingView>/showBusinessGSTSection}"
                                class="required-field-label sapUiTinyMarginBottom"
                            />
                            <Input
                                id="EditBookCompanyname_ID"
                                value="{HostelModel>/CompanyName}"
                                placeholder="Enter company name (minimum 3 characters)"
                                visible="{BookingView>/showBusinessGSTSection}"
                                class="sapUiTinyMarginBottom"
                                width="100%"
                                change="onchangeCompanyname"
                                liveChange="onchangeCompanyname"
                                valueStateText="Please enter a valid company name"
                                showValueStateMessage="true"
                                maxLength="100"
                                enabled="{BookingView>/editModeEnabled}"
                            />

                            <Label
                                required="true"
                                text="Company Address"
                                visible="{BookingView>/showBusinessGSTSection}"
                                class="required-field-label sapUiTinyMarginBottom"
                            />
                            <TextArea
                                value="{HostelModel>/CompanyAddress}"
                                placeholder="Enter complete company address"
                                visible="{BookingView>/showBusinessGSTSection}"
                                rows="3"
                                class="sapUiTinyMarginBottom"
                                width="100%"
                                change="onchangeConpanyAddress"
                                liveChange="onchangeConpanyAddress"
                                valueStateText="Please enter a valid company address (minimum 10 characters)"
                                showValueStateMessage="true"
                                id="EditBookconpanyAddress_ID"
                                maxLength="500"
                                growing="true"
                                growingMaxLines="5"
                                enabled="{BookingView>/editModeEnabled}"
                            />

                            <Title
                                text="GSTIN: {HostelModel>/PropertyGSTIN}"
                                level="H5"
                                class="sapUiSmallMarginTop sapUiTinyMarginBottom"
                                visible="{= !!${HostelModel>/EffectiveGSTType} }"
                            />

                            <Table
                                width="100%"
                                inset="false"
                                fixedLayout="Strict"
                                showSeparators="Inner"
                                class="pricingDetailsTable sapUiTinyMarginBottom"
                            >
                                <columns>
                                    <Column width="53%">
                                        <header>
<Title
    text="Item"
    level="H6"
/>

                                        </header>
                                    </Column>
                                    <Column
                                        width="47%"
                                        hAlign="End"
                                    >
                                        <header>
                                            <Title
                                                text="{= 'Amount (' + ${HostelModel>/Currency} + ')' }"
                                                level="H6"
                                            />
                                        </header>
                                    </Column>
                                </columns>

                                <items>
                                    <ColumnListItem vAlign="Bottom">
                                        <cells>
                                            <VBox
                                                class="sapUiTinyMarginTop sapUiTinyMarginBottom"
                                            >
                                                <Title
                                                    text="Room"
                                                    level="H6"
                                                />
                                                <Text
                                                    text="{HostelModel>/RoomBreakdownText}"
                                                    wrapping="true"
                                                    class="sapThemeBaseText sapUiTinyMarginTop"
                                                />
                                            </VBox>

                                            <VBox
                                                alignItems="End"
                                                justifyContent="End"
                                                class="sapUiTinyMarginTop sapUiTinyMarginBottom"
                                            >
                                                <HBox
                                                    renderType="Bare"
                                                    justifyContent="End"
                                                >
                                                    <Text
                                                        text="{path: 'HostelModel>/RoomPrice', formatter: '.Formatter.fromatNumber'}"
                                                        class="sapUiTinyMarginEnd sapUiStrongText"
                                                    />
                                                    <Text
                                                        text="{HostelModel>/Currency}"
                                                        class="sapUiStrongText"
                                                    />
                                                </HBox>
                                            </VBox>
                                        </cells>
                                    </ColumnListItem>

                                    <!-- Per-facility-item breakdown -->
                                    <ColumnListItem
                                        vAlign="Middle"
                                        visible="{= ${HostelModel>/AllSelectedFacilities}.length > 0}"
                                    >
                                        <cells>
                                            <VBox class="sapUiTinyMarginTop sapUiTinyMarginBottom">
                                                <HBox alignItems="Center" wrap="NoWrap">
                                                    <Title text="Facilities" level="H6" />
                                                    <core:Icon
                                                        id="editFacilitiesBreakdownIcon"
                                                        src="sap-icon://hint"
                                                        size="1rem"
                                                        color="#1a5f6b"
                                                        hoverColor="DarkBlue"
                                                        press="onFacilitiesBreakdownPress"
                                                        tooltip="View facilities breakdown"
                                                        class="sapUiTinyMarginBegin"
                                                    />
                                                </HBox>
                                            </VBox>

                                            <HBox
                                                renderType="Bare"
                                                justifyContent="End"
                                                class="sapUiTinyMarginTop sapUiTinyMarginBottom"
                                            >
                                                <Text
                                                    text="{path: 'HostelModel>/TotalFacilityPrice', formatter: '.Formatter.fromatNumber'}"
                                                    class="sapUiTinyMarginEnd sapUiStrongText"
                                                />
                                                <Text
                                                    text="{HostelModel>/Currency}"
                                                    class="sapUiStrongText"
                                                />
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>

                                    <ColumnListItem
                                        vAlign="Middle"
                                        class="grandTotalBar"
                                    >
                                        <cells>
                                            <Title
                                                text="Sub Total"
                                                level="H6"
                                            />
                                            <HBox
                                                justifyContent="End"
                                                alignItems="Center"
                                                renderType="Bare"
                                            >
                                                <Title
                                                    text="{path: 'HostelModel>/SubTotalBeforeDiscount', formatter: '.Formatter.fromatNumber'}"
                                                    class="sapUiTinyMarginEnd"
                                                    level="H6"
                                                />
                                                <Title
                                                    text="{HostelModel>/Currency}"
                                                    level="H6"
                                                />
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>
                                    <ColumnListItem
                                        vAlign="Middle"
                                        visible="{= !!${HostelModel>/AppliedCouponCode} }"
                                        class="grandTotalBar"
                                    >
                                        <cells>
                                            <Title
                                                text="{= 'Coupon (' + ${HostelModel>/AppliedCouponCode} + ')' }"
                                                level="H6"
                                                wrapping="true"
                                            />
                                            <HBox
                                                justifyContent="End"
                                                alignItems="Center"
                                                renderType="Bare"
                                            >
                                                <Title
                                                    text="-{path: 'HostelModel>/AppliedDiscount', formatter: '.Formatter.fromatNumber'}"
                                                    level="H6"
                                                    class="sapUiTinyMarginEnd"
                                                />
                                                <Title
                                                    text="{HostelModel>/Currency}"
                                                    level="H6"
                                                />
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>

                                    <ColumnListItem
                                        vAlign="Middle"
                                        visible="{= !!${HostelModel>/AppliedCouponCode} }"
                                        class="grandTotalBar"
                                    >
                                        <cells>
                                            <Title
                                                text="Discounted Total"
                                                level="H6"
                                            />
                                            <HBox
                                                justifyContent="End"
                                                alignItems="Center"
                                                renderType="Bare"
                                            >
                                                <Title
                                                    text="{path: 'HostelModel>/BookingNetSubTotal', formatter: '.Formatter.fromatNumber'}"
                                                    class="sapUiTinyMarginEnd"
                                                    level="H6"
                                                />
                                                <Title
                                                    text="{HostelModel>/Currency}"
                                                    level="H6"
                                                />
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>

                                    <!-- <ColumnListItem
                                        vAlign="Middle"
                                        visible="{= !!${HostelModel>/CustomerGSTIN} }"
                                    >
                                        <cells>
                                            <Text text="Customer GSTIN" />
                                            <HBox
                                                justifyContent="End"
                                                alignItems="Center"
                                                renderType="Bare"
                                            >
                                                <Text
                                                    text="{HostelModel>/CustomerGSTIN}"
                                                />
                                            </HBox>
                                        </cells>
                                    </ColumnListItem> -->

                                    <ColumnListItem
                                        vAlign="Middle"
                                        visible="{= ${HostelModel>/CGST} > 0}"
                                        class="greyGST"
                                    >
                                        <cells>
                                            <Text
                                                text="{= ${HostelModel>/CGST} > 0 &amp;&amp; ${HostelModel>/EffectiveGSTValue} > 0 ? 'CGST (' + (${HostelModel>/EffectiveGSTType} === 'CGST/SGST' ? ${HostelModel>/EffectiveGSTValue}  : ${HostelModel>/EffectiveGSTValue}) + '%)' : 'CGST'}"
                                            />

                                            <HBox
                                                justifyContent="End"
                                                alignItems="Center"
                                                renderType="Bare"
                                                class="greyGST"
                                            >
                                                <Text
                                                    text="{path: 'HostelModel>/CGST', formatter: '.Formatter.fromatNumber'}"
                                                    class="sapUiTinyMarginEnd"
                                                />
                                                <Text
                                                    text="{HostelModel>/Currency}"
                                                />
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>

                                    <ColumnListItem
                                        vAlign="Middle"
                                        visible="{= ${HostelModel>/SGST} > 0}"
                                        class="greyGST"
                                    >
                                        <cells>
                                            <Text
                                                text="{= ${HostelModel>/SGST} > 0 &amp;&amp; ${HostelModel>/EffectiveGSTValue} > 0 ? 'SGST (' + (${HostelModel>/EffectiveGSTType} === 'CGST/SGST' ? ${HostelModel>/EffectiveGSTValue} : ${HostelModel>/EffectiveGSTValue}) + '%)' : 'SGST'}"
                                            />

                                            <HBox
                                                justifyContent="End"
                                                alignItems="Center"
                                                renderType="Bare"
                                                class="greyGST"
                                            >
                                                <Text
                                                    text="{path: 'HostelModel>/SGST', formatter: '.Formatter.fromatNumber'}"
                                                    class="sapUiTinyMarginEnd"
                                                />
                                                <Text
                                                    text="{HostelModel>/Currency}"
                                                />
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>

                                    <ColumnListItem
                                        vAlign="Middle"
                                        visible="{= ${HostelModel>/IGST} > 0}"
                                        class="greyGST"
                                    >
                                        <cells>
                                            <Text
                                                text="{= ${HostelModel>/IGST} > 0 &amp;&amp; ${HostelModel>/EffectiveGSTValue} > 0 ? 'IGST (' + ${HostelModel>/EffectiveGSTValue} + '%)' : 'IGST'}"
                                            />

                                            <HBox
                                                justifyContent="End"
                                                alignItems="Center"
                                                renderType="Bare"
                                                class="greyGST"
                                            >
                                                <Text
                                                    text="{path: 'HostelModel>/IGST', formatter: '.Formatter.fromatNumber'}"
                                                    class="sapUiTinyMarginEnd"
                                                />
                                                <Text
                                                    text="{HostelModel>/Currency}"
                                                />
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>
                                    <ColumnListItem
                                        vAlign="Middle" 
                                        class="grandTotalBar grandTotalFinalRow"
                                    >
                                        <cells>
                                            <Title
                                                text="Grand Total"
                                                level="H3"
                                                titleStyle="H3"
                                            />
                                            <HBox
                                                justifyContent="End"
                                                alignItems="Center"
                                                renderType="Bare"
                                            >
                                                <Title
                                                    text="{path: 'HostelModel>/GrandTotal', formatter: '.Formatter.fromatNumber'}"
                                                    level="H3"
                                                    titleStyle="H3"
                                                    class="sapUiTinyMarginEnd"
                                                    wrapping="true"
                                                />
                                                <Title
                                                    text="{HostelModel>/Currency}"
                                                    level="H3"
                                                    titleStyle="H3"
                                                    wrapping="true"
                                                />
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>

                            <MessageStrip
                                text="{= 'Security deposit to be paid at check-in: ' + ${HostelModel>/Deposit} + ' ' + ${HostelModel>/DepositCurrency}}"
                                type="Success"
                                showIcon="true"
                                showCloseButton="false"
                                visible="{= ${HostelModel>/Deposit} > 0}"
                                class="sapUiSmallMarginBottom sapUiLargeMarginTop"
                            />
                        </VBox>
                    </Panel>
                </VBox>
            </l:content>
        </l:Grid>

        <footer>
          	<Bar>
            <contentLeft>
             <Image src="../image/TransparentKTlogo.png" width="30px" height="30px" />
             <Link
                text="{i18n>devlopby}"
                href="https://kalpavrikshatechnologies.com/"
                target="_blank"
                class="customLinkWhiteBg"
            />
            
            </contentLeft>
				<contentRight>
                <!-- Edit booking button - only visible when status is New and not in edit mode -->
                <Button
                    text="Edit Booking"
                    class="myUnifiedBtn"
                    press="onEditBookingPress"
                    visible="{BookingView>/showEditButton}"
                    enabled="{= !${BookingView>/editModeEnabled} }"
                />
                <!-- Cancel button - only visible when in edit mode -->
                <Button
                    text="Cancel"
                    class="myUnifiedBtn"
                    press="onCancelEditPress"
                    visible="{BookingView>/editModeEnabled}"
                />
                <!-- Update booking button - only enabled when in edit mode -->
                <Button
                    text="Update Booking"
                    class="myUnifiedBtn"
                    press="onSubmitPress"
                    enabled="{BookingView>/editModeEnabled}"
                />
                  </contentRight>
			</Bar>
        </footer>
    </Page>
</mvc:View>
