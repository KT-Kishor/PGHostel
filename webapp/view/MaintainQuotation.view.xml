<mvc:View
    controllerName="project3.controller.MaintainQuotation"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.uxap"
    xmlns:layout="sap.ui.layout"
    xmlns:m="sap.m"
    xmlns:f="sap.ui.layout.form"
>
    <m:Page
        id="idMaintainQPage"
        busyIndicatorDelay="0"
        showHeader="true"
        title="{i18n>quotationTileHeader}"
        titleLevel="H1"
        navButtonPress="onNavBack"
        navButtonTooltip="{i18n>navBack}"
        showNavButton="true"
    >
        <ObjectPageLayout
            id="idMainQuotation"
            busyIndicatorDelay="0"
            enableLazyLoading="true"
            beforeNavigate="onBeforeNavigate"
            useIconTabBar="true"
            showTitleInHeaderContent="true"
            upperCaseAnchorBar="false"
        >
            <headerTitle>
                <ObjectPageDynamicHeaderTitle>
                    <expandedHeading>
                        <m:Title
                            text="{QData>/CompanyCodeData/CompanyName}"
                            wrapping="true"
                        />
                    </expandedHeading>

                    <snappedHeading>
                        <m:FlexBox
                            fitContainer="true"
                            alignItems="Center"
                        >
                            <m:Avatar
                                displayShape="Square"
                                displaySize="M"
                                src="{= ${QData>/CompanyCodeData/Company} === 'Hyundai' ? ${QData>/HLogo1} : ${QData>/MLogo} }"
                                class="sapUiTinyMarginEnd"
                            />
                            <m:Title
                                text="{QData>/CompanyCodeData/CompanyName}"
                                wrapping="true"
                            />
                        </m:FlexBox>
                    </snappedHeading>

                    <expandedContent>
                        <m:Text
                            visible="{= ${QData>/CompanyCodeData/Company} === 'Hyundai' ? true : false }"
                            text="{QData>/CompanyCodeData/FirmName}"
                        />
                    </expandedContent>

                    <snappedContent>
                        <layout:VerticalLayout>
                            <m:Text
                                visible="{= ${QData>/CompanyCodeData/Company} === 'Hyundai' ? true : false }"
                                text="{QData>/CompanyCodeData/FirmName}"
                            />
                            <layout:HorizontalLayout class="sapUiTinyMarginTop">
                                <m:Label
                                    text="{i18n>qIssuedBy} "
                                    showColon="true"
                                />
                                <m:Text
                                    class="sapUiTinyMarginBegin"
                                    text="{QData>/QuotationIssuedBy}, {QData>/EmployeeMobile}"
                                />
                            </layout:HorizontalLayout>
                        </layout:VerticalLayout>
                    </snappedContent>
                </ObjectPageDynamicHeaderTitle>
            </headerTitle>

            <headerContent>
                <m:FlexBox
                    wrap="Wrap"
                    fitContainer="true"
                >
                    <m:Avatar
                        class="sapUiLargeMarginEnd"
                        displayShape="Square"
                        displaySize="XL"
                        src="{= ${QData>/CompanyCodeData/Company} === 'Hyundai' ? ${QData>/HLogo1} : ${QData>/MLogo} }"
                    />

                    <layout:VerticalLayout
                        class="sapUiSmallMarginBottom sapUiSmallMarginEnd"
                    >
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd"
                        >
                            <m:Label
                                showColon="true"
                                text="{i18n>cell} "
                            />
                            <m:Text width="5px" />
                            <m:Link text="{QData>/CompanyCodeData/mobile}" />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd"
                        >
                            <m:Label
                                showColon="true"
                                text="{i18n>empOfemail} "
                            />
                            <m:Text width="5px" />
                            <m:Link text="{QData>/CompanyCodeData/email}" />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            visible="{= ${QData>/CompanyCodeData/Company} === 'Hyundai' ? true : false }"
                            class="sapUiSmallMarginBeginEnd"
                        >
                            <m:Label
                                showColon="true"
                                text="{i18n>website} "
                            />
                            <m:Text width="5px" />
                            <m:Link
                                text="{QData>/CompanyCodeData/website}"
                                href="https://{QData>/CompanyCodeData/website}"
                                target="_blank"
                            />
                        </layout:HorizontalLayout>
                        <layout:HorizontalLayout
                            class="sapUiSmallMarginBeginEnd"
                        >
                            <m:Label
                                text="GSTIN: {QData>/CompanyCodeData/GSTIN}"
                            />
                        </layout:HorizontalLayout>
                    </layout:VerticalLayout>

                    <layout:VerticalLayout
                        class="sapUiSmallMarginBeginEnd sapUiMediumMarginEnd sapUiSmallMarginBottom"
                    >
                        <m:Label
                            text="{QData>/CompanyCodeData/Address}"
                            width="300px"
                            wrapping="true"
                            wrappingType="Normal"
                        />
                        <layout:HorizontalLayout />
                    </layout:VerticalLayout>

                    <layout:VerticalLayout
                        class="sapUiTinyMarginBottom sapUiSmallMarginBegin"
                    >
                        <layout:HorizontalLayout>
                            <m:ObjectStatus
                                title="{i18n>status}"
                                visible="{= ${QData>/VisibleStatus} ? false : true }"
                                text="{QData>/Status}"
                                inverted="true"
                                state="{= ${QData>/Status} === 'New' ? 'Information' : 
                                        ${QData>/Status} === 'Booked' ? 'Success' :
                                        ${QData>/Status} === 'Cancelled' ? 'Error' : 'None'}"
                                press="handleStatusPressed"
                            />
                        </layout:HorizontalLayout>
                    </layout:VerticalLayout>
                </m:FlexBox>
            </headerContent>
            <sections>
                <ObjectPageSection
                    id="idSectionQuotation"
                    showTitle="false"
                    titleVisible="false"
                >
                    <subSections>
                        <ObjectPageSubSection
                            showTitle="true"
                            title="{i18n>coDetails}"
                            titleLevel="H1"
                            titleUppercase="false"
                            titleVisible="true"
                        >
                            <f:SimpleForm
                                editable="true"
                                layout="ColumnLayout"
                                columnsL="4"
                                columnsM="2"
                                singleContainerFullSize="true"
                            >
                                <f:content>
                                    <m:Label
                                        text="{i18n>qIssuedBy} "
                                        showColon="true"
                                    />
                                    <m:Input
                                        value="{QData>/QuotationIssuedBy}"
                                        editable="false"
                                    />
                                    <m:Label
                                        text="{i18n>cell} "
                                        showColon="true"
                                    />
                                    <m:Input
                                        id="idEmpMobile"
                                        editable="{QData>/MasterEdit}"
                                        value="{QData>/EmployeeMobile}"
                                        liveChange=".onEmpMobileChange"
                                        type="Number"
                                    />
                                    <m:Label
                                        text="{i18n>frgCompanyCode} "
                                        showColon="true"
                                    />
                                    <m:ComboBox
                                        width="auto"
                                        id="idCoCodes"
                                        selectedKey="{QData>/CompanyCode}"
                                        items="{
                                            path: 'QData>/allCompanyCodeDetails',
                                            sorter: {
                                                path: 'Company',
                                                descending: false,
                                                group: true
                                            },
                                            length: 1000
                                        }"
                                        change="onCompanyCodeChange"
                                        editable="{= ${QData>/AddCase} ? true : false }"
                                        showSecondaryValues="true"
                                        visible="{= ${UserDetails>/Role} === 'Admin' || ${UserDetails>/Role} === 'CEO' || ${UserDetails>/Role} === 'GM' ? true : false }"
                                    >
                                        <core:ListItem
                                            key="{QData>CompanyCode}"
                                            text="{QData>CompanyCode}"
                                            additionalText="{QData>Branch}"
                                        />
                                    </m:ComboBox>
                                    <m:Label
                                        text="{i18n>status} "
                                        showColon="true"
                                        visible="{QData>/VisibleStatus}"
                                    />
                                    <m:Select
                                        visible="{QData>/VisibleStatus}"
                                        selectedKey="{QData>/Status}"
                                        items="{
                                            path: 'QData>/StatusList'
                                        }"
                                    >
                                        <core:Item
                                            key="{QData>key}"
                                            text="{QData>text}"
                                        />
                                    </m:Select>
                                </f:content>
                            </f:SimpleForm>
                        </ObjectPageSubSection>
                        <ObjectPageSubSection
                            showTitle="true"
                            title="{i18n>custDetails} "
                        >
                            <f:SimpleForm
                                editable="true"
                                layout="ColumnLayout"
                                columnsL="4"
                                columnsM="2"
                                singleContainerFullSize="true"
                            >
                                <f:content>
                                    <m:Label
                                        showColon="true"
                                        text="{i18n>qNo} "
                                    />
                                    <m:Input
                                        value="{QData>/QuotationNumber}"
                                        editable="false"
                                        visible="{QData>/ShowCase}"
                                    />

                                    <m:Label
                                        showColon="true"
                                        text="{i18n>date} "
                                    />
                                    <m:DatePicker
                                        id="idQCreateDate"
                                        editable="false"
                                    />

                                    <m:Label
                                        showColon="true"
                                        text="{i18n>qValidDate} "
                                    />
                                    <m:DatePicker
                                        id="idQLastDate"
                                        editable="false"
                                        value="{QData>/ValidUpto}"
                                        displayFormat="dd/MM/yyyy"
                                        valueFormat="dd/MM/yyyy"
                                    />

                                    <m:Label
                                        showColon="true"
                                        text="{i18n>qTo} "
                                    />
                                    <m:Input
                                        id="idCustomerName"
                                        editable="{QData>/MasterEdit}"
                                        value="{QData>/CustomerName}"
                                        liveChange=".onNameChange"
                                        required="true"
                                        maxLength="25"
                                    />

                                    <m:Label
                                        showColon="true"
                                        text="{i18n>cell} "
                                    />
                                    <m:Input
                                        id="idCustMobile"
                                        editable="{QData>/MasterEdit}"
                                        value="{QData>/CustMobile}"
                                        required="true"
                                        type="Number"
                                        liveChange=".onMobileChange"
                                    />

                                    <m:Label
                                        showColon="true"
                                        text="{i18n>custEmail} "
                                    />
                                    <m:Input
                                        id="idCustEmail"
                                        editable="{QData>/MasterEdit}"
                                        value="{QData>/CustEmail}"
                                        liveChange=".onEmailChange"
                                        maxLength="49"
                                    />

                                    <m:Label
                                        showColon="true"
                                        text="{i18n>custAadhar} "
                                    />
                                    <m:Input
                                        id="idCustAadhar"
                                        editable="{QData>/MasterEdit}"
                                        value="{QData>/CustAadhar}"
                                        liveChange=".onAadharChange"
                                        type="Number"
                                    />

                                    <m:Label
                                        showColon="true"
                                        text="{i18n>custPan} "
                                    />
                                    <m:Input
                                        id="idCustPanNumber"
                                        editable="{QData>/MasterEdit}"
                                        value="{QData>/CustPanNumber}"
                                        liveChange=".onPanChange"
                                        maxLength="10"
                                    />

                                    <m:Label
                                        showColon="true"
                                        text="{i18n>custGSTIN} "
                                    />
                                    <m:Input
                                        id="idCustGSTNo"
                                        editable="{QData>/MasterEdit}"
                                        value="{QData>/CustGSTNo}"
                                        liveChange=".onGSTChange"
                                        maxLength="15"
                                    />

                                    <m:Label
                                        showColon="true"
                                        text="{i18n>empOfaddress} "
                                    />
                                    <m:TextArea
                                        id="idCustAddress"
                                        editable="{QData>/MasterEdit}"
                                        value="{QData>/CustAddress}"
                                        change=".onAddressChange"
                                        rows="4"
                                        required="true"
                                        maxLength="60"
                                    />  

                                    <m:Label
                                        showColon="true"
                                        text="{i18n>pinCode} "
                                    />
                                    <m:Input
                                        id="idCustPinCode"
                                        editable="{QData>/MasterEdit}"
                                        value="{QData>/CustPinCode}"
                                        liveChange=".onPinChange"
                                        required="true"
                                        type="Number"
                                        maxLength="6"
                                    />
                                </f:content>
                            </f:SimpleForm>
                        </ObjectPageSubSection>

                        <ObjectPageSubSection
                            class="sapUiSmallMarginBottom"
                            showTitle="true"
                            title="{i18n>quotDetails}"
                            titleLevel="H1"
                            titleUppercase="false"
                            titleVisible="true"
                        >
                            <layout:VerticalLayout width="100%">
                                <m:Label
                                    class="sapUiTinyMarginTop"
                                    design="Bold"
                                    text="{i18n>vehicleDetails} "
                                />

                                <f:SimpleForm
                                    editable="true"
                                    layout="ColumnLayout"
                                    columnsL="4"
                                    columnsM="2"
                                    singleContainerFullSize="true"
                                >
                                    <f:content>
                                        <m:Label
                                            showColon="true"
                                            text="{i18n>quoSchemeModel} "
                                        />
                                        <m:ComboBox
                                            editable="{QData>/MasterEdit}"
                                            id="idVehModel"
                                            change=".onModelSelect"
                                            value="{QData>/Model}"
                                            selectedKey=""
                                            items="{
                                                path: 'QData>/ModelList',
                                                length: 1000
                                            }"
                                            required="true"
                                            selectionChange=".onModelSelectionChange"
                                        >
                                            <core:Item
                                                key="{QData>}"
                                                text="{QData>}"
                                            />
                                        </m:ComboBox>

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>quoSchemeVariant} "
                                        />
                                        <m:Input
                                            editable="{QData>/MasterEdit}"
                                            id="idVehVariant"
                                            change=".onVariantChange"
                                            value="{QData>/Variant}"
                                            showValueHelp="true"
                                            valueHelpRequest="onOpenValueHelpDialog"
                                            required="true"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>quoSchemeTransmission} "
                                        />
                                        <m:Input
                                            value="{QData>/Transmission}"
                                            editable="false"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>quoSchemeFuel} "
                                        />
                                        <m:Input
                                            value="{QData>/Fuel}"
                                            editable="false"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>quoSchemeColor} "
                                        />
                                        <m:Input
                                            editable="false"
                                            value="{QData>/Color}"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>quoSchemeBoardPlate} "
                                        />
                                        <m:Input
                                            value="{QData>/BoardPlate}"
                                            editable="false"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>quoSchemeMake} "
                                        />
                                        <m:Input
                                            value="{QData>/Make}"
                                            editable="false"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>emissionNorms} "
                                        />
                                        <m:Input
                                            value="{QData>/Emission}"
                                            editable="false"
                                        />
                                    </f:content>
                                </f:SimpleForm>
                                <m:Label
                                    class="sapUiSmallMarginTop"
                                    text="{i18n>priceBreakdown} "
                                    design="Bold"
                                    textAlign="Center"
                                />

                                <f:SimpleForm
                                    editable="true"
                                    layout="ColumnLayout"
                                    columnsL="4"
                                    columnsM="2"
                                    singleContainerFullSize="true"
                                >
                                    <f:content>
                                        <m:Label
                                            showColon="true"
                                            text="{i18n>quoSchemeExShowroom} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/ExShowroom', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="{QData>/isEditable}"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>quoSchemeTCS} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/TCS1Perc', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="{QData>/isEditable}"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>insurance} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/AddOnInsurance', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="{QData>/isEditable}"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>quoSchemeRoadTax} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/ROADTAX', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="{QData>/isEditable}"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>regHyp} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/RegHypCharge', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="{QData>/isEditable}"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>quoSchemeFastTag} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/FastTag', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="{QData>/isEditable}"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>stdFitAcc} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/STDFittings', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="{QData>/MasterEdit}"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>extWarranty} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/EXTDWarrantyFOR4YR80K', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="{QData>/MasterEdit}"
                                            visible="{= ${QData>/CompanyCodeData/Company} === 'Hyundai' ? true : false }"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>sot} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/ShieldOfTrust4YR45K', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="{QData>/MasterEdit}"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>quoSchemeVAS} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/VAS', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="{QData>/MasterEdit}"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>quoSchemeRSA} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/RSA', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="{QData>/isEditable}"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>scmeDiscount} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/ConsumerScheme', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="{QData>/isEditable}"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>exShowDiscount} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/ExShowroomAfterScheme', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="false"
                                            visible="{= ${QData>/CompanyCodeData/Company} === 'Hyundai' ? false : true }"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>discOffer} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/DiscountOffers', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="{QData>/isEditable}"
                                            change=".onPriceChange"
                                            maxLength="15"
                                        />

                                        <m:Label
                                            showColon="true"
                                            text="{i18n>onRoad} "
                                        />
                                        <m:Input
                                            value="{ path: 'QData>/TotalOnRoad', formatter: '.formatter.IndiaNumberFormatter' }"
                                            editable="false"
                                        />
                                    </f:content>
                                </f:SimpleForm>
                            </layout:VerticalLayout>
                        </ObjectPageSubSection>
                    </subSections>
                </ObjectPageSection>
            </sections>
        </ObjectPageLayout>
        <m:footer>
            <m:Bar>
                <m:contentLeft>
                    <m:HBox class="sapUiTinyMarginTop">
                        <m:Image
                            src="../image/TransparentKTlogo.png"
                            width="30px"
                            height="30px"
                            class="companylogo"
                        />
                        <m:Link
                            class="footer-CoName sapUiTinyMarginBegin"
                            text="{i18n>developedBy}"
                            href="https://www.kalpavrikshatechnologies.com/"
                            target="_blank"
                        />
                    </m:HBox>
                </m:contentLeft>
                <m:contentRight>
                    <m:Button
                        iconFirst="true"
                        icon="sap-icon://pdf-attachment"
                        text="{i18n>btnGeneratePDF}"
                        id="idPDFBtn"
                        type="Reject"
                        press="onDownloadPDF"
                        visible="{QData>/ShowCase}"
                    />
                    <m:Button
                        text="{= ${QData>/MasterEdit} ? ${i18n>btnSave} : ${i18n>btnEdit}}"
                        press="onPressEdit"
                        type="{= ${QData>/MasterEdit} ? 'Accept' : 'Neutral'}"
                        visible="{QData>/ShowCase}"
                        icon="{= ${QData>/MasterEdit} ? '' : 'sap-icon://edit'}"
                    />

                    <m:Button
                        text="{i18n>Submit}"
                        press="onPressSubmit"
                        type="Accept"
                        visible="{QData>/AddCase}"
                        enabled="{QData>/EnableSubmit}"
                    />
                </m:contentRight>
            </m:Bar>
        </m:footer>
    </m:Page>
</mvc:View>
