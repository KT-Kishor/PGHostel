<mvc:View
    xmlns:filterbar="sap.ui.comp.filterbar"
    controllerName="project3.controller.QuotationDetails"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
>
    <Page>
        <headerContent>
            <Button
                press="onPressback"
                icon="sap-icon://home"
                tooltip="{i18n>home}"
            />
            <Text
                text="{i18n>qDetailsHeader}"
                class="boldBlackText"
            />
            <ToolbarSpacer />
            <Button
                press="onLogout"
                icon="sap-icon://log"
                tooltip="{i18n>backButtonTooltip}"
            />
        </headerContent>
        <content>
            <filterbar:FilterBar
                persistencyKey="myPersKey"
                useToolbar="false"
                clear="onPressClear"
                showClearOnFB="true"
                search=".onSearch"
                filterChange=".onFilterChange"
                afterVariantLoad=".onAfterVariantLoad"
                class="sapUiTinyMargin"
            >
                <filterbar:filterGroupItems>
                    <filterbar:FilterGroupItem
                        name="Company"
                        label="{i18n>quoSchemeCompany}"
                        groupName="Group1"
                        controlTooltip="Filter by Company"
                        visibleInFilterBar="true"
                    >
                        <filterbar:control>
                            <ComboBox
                                showClearIcon="true"
                                id="idFilterCompany"
                                name="Company"
                                editable="{QData>/isCoEdit}"
                                items="{
                                    path: 'QData>/CompanyDetailsData',
                                    length: 1000
                                }"
                                selectionChange="onCompanyFilterChange"
                                showSecondaryValues="true"
                            >
                                <core:ListItem
                                    key="{QData>CompanyCode}"
                                    text="{QData>CompanyCode}"
                                    additionalText="{QData>CompanyName}"
                                />
                            </ComboBox>
                        </filterbar:control>
                    </filterbar:FilterGroupItem>
                    <filterbar:FilterGroupItem
                        name="Branch"
                        label="{i18n>empOfbranch}"
                        groupName="Group1"
                        visibleInFilterBar="true"
                    >
                        <filterbar:control>
                            <ComboBox
                                showClearIcon="true"
                                id="idBranch"
                                name="Branch"
                                editable="{QData>/isEditable}"
                                items="{
                                    path: 'QData>/BaseLocationData',
                                    sorter: {
                                        path: 'Company',
                                        descending: false,
                                        group: true
                                    },
                                    length: 1000
                                }"
                                selectionChange="onBranchFilterChange"
                            >
                                <core:Item
                                    key="{QData>City}"
                                    text="{QData>City}"
                                />
                            </ComboBox>
                        </filterbar:control>
                    </filterbar:FilterGroupItem>
                    <filterbar:FilterGroupItem
                        name="QIBy"
                        label="{i18n>qIssuedBy}"
                        groupName="Group1"
                        visibleInFilterBar="true"
                    >
                        <filterbar:control>
                            <ComboBox
                                showClearIcon="true"
                                id="idQIBy"
                                name="QIBy"
                                editable="{QData>/isEditable}"
                                items="{
                                    path: 'QData>/SelfServiceData',
                                    sorter: {
                                        path: 'Branch',
                                        descending: false,
                                        group: true
                                    },
                                    length: 1000
                                }"
                            >
                                <core:Item
                                    key="{QData>EmployeeName}"
                                    text="{QData>EmployeeName}"
                                />
                            </ComboBox>
                        </filterbar:control>
                    </filterbar:FilterGroupItem>
                    <filterbar:FilterGroupItem
                        name="QDate"
                        label="{i18n>qDate}"
                        groupName="Group1"
                        visibleInFilterBar="true"
                    >
                        <filterbar:control>
                            <DateRangeSelection
                                id="idQDate"
                                name="QDate"
                                delimiter="to"
                                displayFormat="yyyy-MM-dd"
                                valueFormat="yyyy-MM-dd"
                                change=".onFilterChange"
                            />
                        </filterbar:control>
                    </filterbar:FilterGroupItem>
                    <filterbar:FilterGroupItem
                        name="PinCode"
                        label="{i18n>pinCode}"
                        groupName="Group1"
                        visibleInFilterBar="true"
                    >
                        <filterbar:control>
                            <Input
                                id="idFilterPinCode"
                                name="PinCode"
                                type="Number"
                                liveChange=".onFilterPinChange"
                            />
                        </filterbar:control>
                    </filterbar:FilterGroupItem>
                    <filterbar:FilterGroupItem
                        name="Status"
                        label="{i18n>status}"
                        groupName="Group1"
                        visibleInFilterBar="true"
                    >
                        <filterbar:control>
                            <ComboBox
                                showClearIcon="true"
                                id="idStatus"
                                name="Status"
                                items="{
                                    path: 'QData>/StatusList',
                                    length: 1000
                                }"
                            >
                                <core:Item
                                    key="{QData>key}"
                                    text="{QData>text}"
                                />
                            </ComboBox>
                        </filterbar:control>
                    </filterbar:FilterGroupItem>
                </filterbar:filterGroupItems>
            </filterbar:FilterBar>
            <Table
                id="idQTable"
                busyIndicatorDelay="0"
                class="sapUiTinyMargin"
                width="auto"
                inset="false"
                growing="true"
                growingThreshold="50"
                growingScrollToLoad="true"
                items="{
                    path: 'QData>/QTableData',
                    sorter: {
                        path: 'Company',
                        descending: false,
                        group: true
                    }
                }"
            >
                <headerToolbar>
                    <OverflowToolbar>
                        <Title
                            text="{i18n>qTableTitle} ({QData>/RowCount})"
                            level="H2"
                        />
                        <ToolbarSpacer />
                        <Button
                            type="Emphasized"
                            press="onRouteToDash"
                            text="{i18n>dashboard}"
                        />
                        <Button
                            icon="sap-icon://add"
                            text="Create"
                            type="Accept"
                            press="onPresstoQ"
                            tooltip="{i18n>qCreateBtn}"
                        />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column
                        mergeDuplicates="true"
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        visible="{= ${UserDetails>/Role} === 'Admin' || ${UserDetails>/Role} === 'CEO' || ${UserDetails>/Role} === 'GM' ? true : false }"
                    >
                        <Text text="{i18n>qIssuedBy}" />
                    </Column>
                    <Column
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text text="{i18n>qNumber}" />
                    </Column>
                    <Column
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text text="{i18n>empOfbranch}" />
                    </Column>
                    <Column
                        vAlign="Middle"
                        minScreenWidth="Desktop"
                        demandPopin="true"
                    >
                        <Text text="{i18n>qCreateDate}" />
                    </Column>
                    <Column vAlign="Middle">
                        <Text text="{i18n>qCustName}" />
                    </Column>
                    <Column
                        vAlign="Middle"
                        minScreenWidth="Desktop"
                        demandPopin="true"
                    >
                        <Text text="{i18n>pinCode}" />
                    </Column>
                    <Column vAlign="Middle">
                        <Text text="{i18n>qAmount}" />
                    </Column>
                    <Column
                        vAlign="Middle"
                        minScreenWidth="Desktop"
                        demandPopin="true"
                        width="10%"
                    >
                        <Text text="{i18n>status}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem
                        vAlign="Middle"
                        type="Navigation"
                        press="onRowPress"
                    >
                        <cells>
                            <Text text="{QData>QuotationIssuedBy}" />
                            <Text text="{QData>QuotationNumber}" />
                            <Text text="{QData>Branch}" />
                            <Text
                                text="{ path: 'QData>QuotationDate', formatter: '.formatter.DateFormatter' }"
                            />
                            <Text text="{QData>CustomerName}" />
                            <Text text="{QData>CustPinCode}" />
                            <Text
                                text="{ path: 'QData>TotalOnRoad', formatter: '.formatter.IndiaNumberFormatter' }"
                            />
                            <ObjectStatus
                                inverted="true"
                                state="{= ${QData>Status} === 'New' ? 'Information' : 
                                        ${QData>Status} === 'Booked' ? 'Success' :  
                                        ${QData>Status} === 'Cancelled' ? 'Error' : 'None'}"
                                text="{QData>Status}"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <footer>
            <Bar>
                <contentLeft>
                    <HBox class="sapUiTinyMarginTop">
                        <Image
                            src="../image/TransparentKTlogo.png"
                            width="30px"
                            height="30px"
                            class="companylogo"
                        />
                        <Link
                            class="footer-CoName sapUiTinyMarginBegin"
                            text="{i18n>developedBy}"
                            href="https://www.kalpavrikshatechnologies.com/"
                            target="_blank"
                        />
                    </HBox>
                </contentLeft>
            </Bar>
        </footer>
    </Page>
</mvc:View>
