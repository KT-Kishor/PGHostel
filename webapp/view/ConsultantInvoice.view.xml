<mvc:View controllerName="sap.kt.com.minihrsolution.controller.ConsultantInvoice"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:fb="sap.ui.comp.filterbar"
	xmlns:core="sap.ui.core">
	<Page id="CI_id_ConsultantInvoicePage">
		<headerContent>
        <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
        </headerContent>
		<content>
			<fb:FilterBar id="CI_id_ConsultantInvoiceFilterBar" persistencyKey="consultantInvoicePersKey" 
    useToolbar="false" clear="onClear" showClearOnFB="true" search=".onSearch" 
    filterChange=".onFilterChange"  showFilterConfiguration="false">
				<fb:filterGroupItems>
				<fb:FilterGroupItem name="InvoiceTo" label="{i18n>invoiceTo}" groupName="ConsultantInvoice" visibleInFilterBar="true" >
						<fb:control>
							<ComboBox id="CI_id_InvoiceTo" 
                items="{path:'ConsultantModel>/', length:1000}"
                showSecondaryValues="true" showClearIcon="true">
								<core:ListItem key="{ConsultantModel>InvoiceTo}" text="{ConsultantModel>InvoiceTo}" />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="InvoiceNo" label="{i18n>invoiceNo}" groupName="ConsultantInvoice" visibleInFilterBar="true">
						<fb:control>
							<ComboBox id="CI_id_InvoiceNo" 
                items="{path:'ConsultantModel>/', length:1000}"
                showSecondaryValues="true" showClearIcon="true">
								<core:ListItem key="{ConsultantModel>InvoiceNo}" text="{ConsultantModel>InvoiceNo}" additionalText="{ConsultantModel>EmployeeID}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table items="{path: 'ConsultantModel>/'}" id="CI_id_ConsultantInvoiceTable">
				<headerToolbar>
					<Toolbar>
						<Title id="CI_id_TitleInv" text="{i18n>consultantInvoiceDetails}"/>
						<ToolbarSpacer />
						<ToolbarSeparator />
						<Button icon="sap-icon://add" tooltip="{i18n>addInvoice}" press="CI_onPressAddInvoice" />
						<ToolbarSeparator />
					</Toolbar>
				</headerToolbar>
				<columns>
					<Column>
						<Text text="{i18n>employeeID}" />
					</Column>
					<Column>
						<Text text="{i18n>consultantName}" />
					</Column>
					<Column>
						<Text text="{i18n>invoiceNo}" />
					</Column>
					<Column>
						<Text text="{i18n>invoiceTo}" />
					</Column>
					<Column>
						<Text text="{i18n>invoiceDate}" />
					</Column>
					<Column>
						<Text text="{i18n>payBy}" />
					</Column>
					<Column>
						<Text text="{i18n>GSTNO}" />
					</Column>
					<Column>
						<Text text="{i18n>totalAmount}" />
					</Column>
					<Column>
						<Text text="{i18n>currency}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem  type="Navigation" press="CI_onPressInvoice">
					<cells>
						<Text text="{ConsultantModel>EmployeeID}" />
						<Text text="{ConsultantModel>ConsultantName}" />
						<Text text="{ConsultantModel>InvoiceNo}" />
						<Text text="{ConsultantModel>InvoiceTo}" />
						<Text text="{path:'ConsultantModel>InvoiceDate' ,formatter:'.Formatter.formatDate'}" />
						<Text text="{path:'ConsultantModel>PayBy' ,formatter:'.Formatter.formatDate'}" />
						<Text text="{ConsultantModel>GSTNO}" />
						<Text text="{ConsultantModel>TotalSum}" />
						<Text text="{ConsultantModel>Currency}" />
					</cells>
				</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
            <Bar>
                <contentLeft>
                    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
                </contentLeft>
                <contentRight>
                </contentRight>
            </Bar>
        </footer>
	</Page>
</mvc:View>