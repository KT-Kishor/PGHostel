<mvc:View
	controllerName="sap.kt.com.minihrsolution.controller.IT_Asset_Demo"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:m="sap.m"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	displayBlock="true"
	xmlns:g="sap.f"
	xmlns:f="sap.ui.layout.form"
	xmlns:l="sap.ui.layout"
	height="100%"
	busyIndicatorDelay="0">
	<Page >
		<headerContent>
			<Avatar src="./image/logo.jpg" displaySize="XS" press="onAvatarPressed" tooltip="Company Logo"/>
			<Title level="H1" text="{i18n>companynameKT}" class="custom-text" wrapping="false"/>
			<ToolbarSpacer/>
			<Button icon="sap-icon://home" press="onpresshome" class="sapUiTinyMarginEnd" tooltip="{i18n>toolHome}"/>
		</headerContent>
		<Title level="H1" text="{i18n>AssetDemotitle}" class="HeadDemoSection " wrapping="false"/>
		<!-- Company Asset -->
		<g:GridContainer class="jioSection sapUiSmallMarginTop">
			<g:layout>
				<g:GridContainerSettings columnSize="49.5%" gap="10px" />
			</g:layout>
			<g:layoutXS>
				<g:GridContainerSettings columnSize="100%" gap="10px" />
			</g:layoutXS>
			<g:layoutS>
				<g:GridContainerSettings columnSize="100%" gap="10px" />
			</g:layoutS>
			<g:layoutM>
				<g:GridContainerSettings columnSize="100%" gap="10px" />
			</g:layoutM>
			<!-- Left Column -->
			<m:VBox alignItems="Start" justifyContent="Center" class="sapUiSmallMarginTop">
				<m:Title text="{i18n>headerIncomeAsset}" level="H1" class="jioHeading" />
				<m:Text text="{i18n>Asset_Par}" class="jioParagraph" />
			</m:VBox>
			<!-- Right Column -->
			<m:VBox id="videoBox101" class="sapUiMediumMarginTop">
				<core:HTML id="videoFrameHtml101"
            content="&lt;div style='position:relative;width:100%;padding-top:56.25%;overflow:hidden;border-radius:15px;background:#f3f3f3;'&gt;
                        &lt;video controls autoplay muted playsinline 
                               style='position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;border:none;border-radius:15px;'&gt;
                            &lt;source src='../Videos/Company Asset.mp4' type='video/mp4'&gt;
                            Your browser does not support the video tag.
                        &lt;/video&gt;
                     &lt;/div&gt;" />
			</m:VBox>
			<!-- Asset Assignment -->
		</g:GridContainer>
		<g:GridContainer class="jioSection sapUiSmallMarginTop">
			<g:layout>
				<g:GridContainerSettings columnSize="49.5%" gap="10px" />
			</g:layout>
			<g:layoutXS>
				<g:GridContainerSettings columnSize="100%" gap="10px" />
			</g:layoutXS>
			<g:layoutS>
				<g:GridContainerSettings columnSize="100%" gap="10px" />
			</g:layoutS>
			<g:layoutM>
				<g:GridContainerSettings columnSize="100%" gap="10px" />
			</g:layoutM>
			<!-- Right Column -->
			<m:VBox id="videoBox201" class="sapUiMediumMarginTop">
				<core:HTML id="videoFrameHtml201"
            content="&lt;div style='position:relative;width:100%;padding-top:56.25%;overflow:hidden;border-radius:15px;background:#f3f3f3;'&gt;
                        &lt;video controls muted playsinline
                               style='position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;border:none;border-radius:15px;'&gt;
                            &lt;source src='../Videos/Asset Assignment.mp4' type='video/mp4'&gt;
                            Your browser does not support the video tag.
                        &lt;/video&gt;
                     &lt;/div&gt;" />
			</m:VBox>
			<!-- Left Column -->
			<m:VBox alignItems="Start" justifyContent="End" class="sapUiMediumMarginTop">
				<m:Title text="{i18n>headerAssignment}" level="H1" class="jioHeading" />
				<m:Text text="{i18n>AssetAssignment_Par}" class="jioParagraph" />
			</m:VBox>
		</g:GridContainer>
		<g:GridContainer class="jioSection sapUiSmallMarginTop">
			<g:layout>
				<g:GridContainerSettings columnSize="49.5%" gap="10px" />
			</g:layout>
			<g:layoutXS>
				<g:GridContainerSettings columnSize="100%" gap="10px" />
			</g:layoutXS>
			<g:layoutS>
				<g:GridContainerSettings columnSize="100%" gap="10px" />
			</g:layoutS>
			<g:layoutM>
				<g:GridContainerSettings columnSize="100%" gap="10px" />
			</g:layoutM>
			<!-- Left Column -->
			<m:VBox alignItems="Start" justifyContent="Center" class="sapUiSmallMarginTop">
				<m:Title text="{i18n>MyAssetTitle}" level="H1" class="jioHeading" />
				<m:Text text="{i18n>MyAsset_Par}" class="jioParagraph" />
			</m:VBox>
			<!-- Right Column -->
			<m:VBox id="videoBox301" class="sapUiMediumMarginTop">
				<core:HTML id="videoFrameHtml301"
            content="&lt;div style='position:relative;width:100%;padding-top:56.25%;overflow:hidden;border-radius:15px;background:#f3f3f3;'&gt;
                        &lt;video controls muted playsinline
                               style='position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;border:none;border-radius:15px;'&gt;
                            &lt;source src='../Videos/My Asset.mp4' type='video/mp4'&gt;
                            Your browser does not support the video tag.
                        &lt;/video&gt;
                     &lt;/div&gt;" />
			</m:VBox>
		</g:GridContainer>
		<!-- <m:Button
            text="Request Demo"
            press="onOpenForm"
            class="demoBtn"
        /> -->
		<Image
        src="../image/Request_Demo.png"
        class="floatingButton"
        press="onOpenForm"
      />
	</Page>
</mvc:View>
