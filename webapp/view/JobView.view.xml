<mvc:View controllerName="sap.kt.com.minihrsolution.controller.JobView" 
	xmlns:mvc="sap.ui.core.mvc" 
	xmlns="sap.m" 
	xmlns:core="sap.ui.core" 
	xmlns:f="sap.f" 
	xmlns:fb="sap.ui.comp.filterbar" 
	xmlns:svm="sap.ui.comp.smartvariants" 
	xmlns:l="sap.ui.layout" 
	xmlns:form="sap.ui.layout.form" 
	xmlns:tnt="sap.tnt" 
	height="100%">
	<Page id="page2" title="{i18n>JobAppHeader}" showNavButton="true" navButtonPress=".onNavBack">
		<headerContent>
			<ToolbarSpacer />
		</headerContent>
		<content>
			<!-- ✅ Scoped wrapper to contain all styling -->
			<VBox class="myCustomViewWrapper">

				<!-- Section: Job Not Available -->
				<ScrollContainer id="idJobNotAvailable" visible="{= !${JobApplicationModel>/JobTitle} }" horizontal="false" vertical="true" height="97.6%" class="care-background">
					<l:VerticalLayout width="100%">
						<l:BlockLayout background="Dashboard">
							<l:BlockLayoutRow>
								<l:BlockLayoutCell width="2" title="{i18n>jobNotAvailableMessage}">
									<VBox>
										<Text text="{i18n>jobNotAvailableSubMessage}" class="carrer-Des" />
										<HBox justifyContent="End">
											<Button text="{i18n>backToCareers}" tooltip="Return to Careers Page" press=".onNavBack" class="myCustomButton" />
										</HBox>
									</VBox>
								</l:BlockLayoutCell>
							</l:BlockLayoutRow>
						</l:BlockLayout>
					</l:VerticalLayout>
				</ScrollContainer>

				<!-- Section: Job Details -->
				<VBox binding="{JobApplicationModel>/}" id="jobDetailsContainer" visible="{= ${JobApplicationModel>isValidJob} === true }" class="mobileSafeWrapper">
					<ScrollContainer horizontal="false" vertical="true" height="97.6%" class="myAppBackground">
						<VBox>
							<HBox id="mainContainer" class="mainJobContainer" wrap="Wrap">
								<!-- Left Column -->
								<VBox class="leftColumn">
									<Panel expandable="false" expanded="true" class="contentPanel contentPanelLimitedWidth">
										<VBox>
											<HBox justifyContent="SpaceBetween" width="100%">
												<Title id="jobTitleTest" text="{JobApplicationModel>JobTitle}" wrapping="true" level="H1" titleStyle="H1" />
												<Button icon="sap-icon://action" tooltip="Share this job" class="myCustomIconBtn" press="onSharePress" />
											</HBox>

											<!-- FormattedText Sections -->
											<VBox visible="{ path: 'JobApplicationModel>JobDescription', formatter: '.hasValue' }">
												<Title text="Job Description" level="H2" wrapping="true" titleStyle="H2" />
												<FormattedText class="myFormattedText" htmlText="{JobApplicationModel>JobDescription}" />
											</VBox>

											<VBox visible="{ path: 'JobApplicationModel>SecondarySkills', formatter: '.hasValue' }">
												<Title text="Secondary Skills" level="H2" wrapping="true" titleStyle="H2" />
												<FormattedText class="myFormattedText" htmlText="{JobApplicationModel>SecondarySkills}" />
											</VBox>

											<VBox visible="{ path: 'JobApplicationModel>SkillRequirements', formatter: '.hasValue' }">
												<Title text="Required Skills" level="H2" wrapping="true" titleStyle="H2" />
												<FormattedText class="myFormattedText" htmlText="{JobApplicationModel>SkillRequirements}" />
											</VBox>
										</VBox>

										<!-- Key Responsibilities -->
										<VBox visible="{ path: 'JobApplicationModel>KeyResponsibilities', formatter: '.hasValue' }">
											<Title text="Key Responsibilities" level="H2" wrapping="true" titleStyle="H2" />
											<FormattedText class="myFormattedText" htmlText="{JobApplicationModel>KeyResponsibilities}" />
										</VBox>

										<!-- Job Summary -->
										<Title text="Job Summary" level="H2" titleStyle="H2" />

										<!-- Details Blocks -->
										<HBox visible="{ path: 'JobApplicationModel>Location', formatter: '.hasValue' }">
											<Title text="Location" width="150px" wrapping="true" level="H5" titleStyle="H5" />
											<Title text="{JobApplicationModel>Location}" wrapping="true" level="H5" titleStyle="H5" />
										</HBox>

										<HBox visible="{ path: 'JobApplicationModel>Location', formatter: '.hasValue' }">
											<Title text="Work mode" width="150px" wrapping="true" level="H5" titleStyle="H5" />
											<Title text="{ path: 'JobApplicationModel>LocationService', formatter: '.formatWorkModeLabel' }"
												tooltip="{ path: 'JobApplicationModel>LocationService', formatter: '.getWorkModeTooltip' }"
												wrapping="true" level="H5" titleStyle="H5" />
										</HBox>

										<HBox visible="{ path: 'JobApplicationModel>JobTitle', formatter: '.hasValue' }">
											<Title text="Job Title" width="150px" wrapping="true" level="H5" titleStyle="H5" />
											<Title text="{JobApplicationModel>JobTitle}" wrapping="true" level="H5" titleStyle="H5" />
										</HBox>

										<HBox visible="{ path: 'JobApplicationModel>Qualification', formatter: '.hasValue' }">
											<Title text="Qualification" width="150px" wrapping="true" level="H5" titleStyle="H5" />
											<Title text="{JobApplicationModel>Qualification}" wrapping="true" level="H5" titleStyle="H5" />
										</HBox>

										<HBox visible="{ path: 'JobApplicationModel>Experience', formatter: '.hasValue' }">
											<Title text="Experience" width="150px" wrapping="true" level="H5" titleStyle="H5" />
											<Title text="{JobApplicationModel>Experience}" wrapping="true" level="H5" titleStyle="H5" />
										</HBox>

										<HBox visible="{ path: 'JobApplicationModel>Certifications', formatter: '.hasValue' }">
											<Title text="Certifications" width="150px" wrapping="true" level="H5" titleStyle="H5" />
											<Title text="{JobApplicationModel>Certifications}" wrapping="true" level="H5" titleStyle="H5" />
										</HBox>

										<HBox visible="{ path: 'JobApplicationModel>NoOfPositions', formatter: '.hasValue' }">
											<Title text="Positions" width="150px" wrapping="true" level="H5" titleStyle="H5" />
											<Title text="{JobApplicationModel>NoOfPositions}" wrapping="true" level="H5" titleStyle="H5" />
										</HBox>

										<HBox visible="{ path: 'JobApplicationModel>PrimarySkills', formatter: '.hasValue' }">
											<Title text="Primary Skills" width="150px" wrapping="true" level="H5" titleStyle="H5" />
											<Title text="{JobApplicationModel>PrimarySkills}" wrapping="true" level="H5" titleStyle="H5" />
										</HBox>
									</Panel>
								</VBox>

								<!-- Right Column -->
								<VBox class="rightColumn">
									<Panel class="actionPanel">
										<VBox alignItems="Center">
											<Button text="Apply Now" tooltip="Apply for this job" press="onApply" class="myCustomButton" />
										</VBox>
									</Panel>
								</VBox>
							</HBox>
						</VBox>
					</ScrollContainer>
				</VBox>
			</VBox> 
		</content>
	</Page>
</mvc:View>
