<mvc:View controllerName="sap.kt.com.minihrsolution.controller.JobView" 
	xmlns:mvc="sap.ui.core.mvc" 
	xmlns="sap.m" 
	xmlns:core="sap.ui.core" 
	xmlns:f="sap.f" 
	xmlns:fb="sap.ui.comp.filterbar" 
	xmlns:svm="sap.ui.comp.smartvariants" 
	xmlns:l="sap.ui.layout" 
	xmlns:form="sap.ui.layout.form" height="100%">
	<Page class="myAppBackground" id="page2" title="{i18n>JobAppHeader}" showNavButton="true" navButtonPress=".onNavBack">
		<headerContent>
			<Label class="Strong" text="Carriers" design="Bold" />
			<ToolbarSpacer />
		</headerContent>
		<content>
			<ScrollContainer height="100%" horizontal="false" vertical="true">
				<HBox id="mainContainer" class="mainJobContainer">
					<VBox class="leftColumn">
						<Panel expandable="false" expanded="true" class="contentPanel">
							<VBox class="sapUiSmallMargin">
								<HBox justifyContent="End" width="100%">
									<Button icon="sap-icon://action" tooltip="Share this job" class="myCustomIconBtn sapUiSmallMarginTop sapUiSmallMarginEnd" press="onSharePress" />
								</HBox>
								<!-- Left Panel -->
								<Title text="Job Description" class="sapUiLargeMarginBegin" level="H1" titleStyle="H1" wrapping="true" />
								<Title id="jobTitleTest" text="{SelectedCandidate>JobTitle}" wrapping="true" level="H2" titleStyle="H2" class="sapUiSmallMarginBottom sapUiLargeMarginTop sapUiLargeMarginBegin" />
								<Title text="Job Summary" wrapping="true" level="H2" titleStyle="H2" class="sapUiLargeMarginBegin sapUiSmallMarginBottom sapUiSmallMarginTop" />
								<!-- Job Info Blocks -->
								<HBox visible="{ path: 'SelectedCandidate>Location', formatter: '.hasValue' }">
									<Title text="Location" wrapping="true" width="150px" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
									<Title text="{SelectedCandidate>Location}" wrapping="true" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
								</HBox>
								<HBox visible="{ path: 'SelectedCandidate>Location', formatter: '.hasValue' }">
									<Title text="Work mode" wrapping="true" width="150px" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
									
									
									<Title text="{ path: 'SelectedCandidate>LocationService', formatter: '.formatWorkModeLabel' }" tooltip="{ path: 'SelectedCandidate>LocationService', formatter: '.getWorkModeTooltip' }" wrapping="true" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
								
								
								
								
									</HBox>
								<HBox visible="{ path: 'SelectedCandidate>JobTitle', formatter: '.hasValue' }">
									<Title text="Job Title" width="150px" wrapping="true" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
									<Title text="{SelectedCandidate>JobTitle}" wrapping="true" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
								</HBox>
								<HBox visible="{ path: 'SelectedCandidate>Qualification', formatter: '.hasValue' }">
									<Title text="Qualification" width="150px" wrapping="true" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
									<Title text="{SelectedCandidate>Qualification}" wrapping="true" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
								</HBox>
								<HBox visible="{ path: 'SelectedCandidate>Experience', formatter: '.hasValue' }">
									<Title text="Experience" width="150px" wrapping="true" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
									<Title text="{SelectedCandidate>Experience}" wrapping="true" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
								</HBox>
								<HBox visible="{ path: 'SelectedCandidate>Certifications', formatter: '.hasValue' }">
									<Title text="Certifications" width="150px" wrapping="true" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
									<Title text="{SelectedCandidate>Certifications}" wrapping="true" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
								</HBox>
								<HBox visible="{ path: 'SelectedCandidate>NoOfPositions', formatter: '.hasValue' }">
									<Title text="Positions" width="150px" wrapping="true" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
									<Title text="{SelectedCandidate>NoOfPositions}" wrapping="true" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
								</HBox>
								<VBox>
									<HBox visible="{ path: 'SelectedCandidate>PrimarySkills', formatter: '.hasValue' }">
										<Title text="Primary Skills" width="150px" wrapping="true" class="sapUiSmallMargin sapUiLargeMarginBegin" level="H4" titleStyle="H4" />
										<Title class="sapUiSmallMargin sapUiLargeMarginBegin" text="{SelectedCandidate>PrimarySkills}" wrapping="true" level="H4" titleStyle="H4" />
									</HBox>
									<VBox visible="{ path: 'SelectedCandidate>SecondarySkills', formatter: '.hasValue' }" class="sapUiSmallMargin sapUiLargeMarginBegin">
										<Title text="Secondary Skills" level="H2" wrapping="true" titleStyle="H2" />
										<FormattedText class="myFormattedText" htmlText="{SelectedCandidate>SecondarySkills}" />
									</VBox>
									<VBox visible="{ path: 'SelectedCandidate>SkillRequirements', formatter: '.hasValue' }" class="sapUiSmallMargin sapUiLargeMarginBegin">
										<Title text="Required Skills" wrapping="true" level="H2" titleStyle="H2" />
										<FormattedText class="myFormattedText" htmlText="{SelectedCandidate>SkillRequirements}" />
									</VBox>
								</VBox>
								<VBox visible="{ path: 'SelectedCandidate>KeyResponsibilities', formatter: '.hasValue' }" class="sapUiSmallMargin sapUiLargeMarginBegin">
									<Title text="Key Responsibilities" wrapping="true" level="H2" titleStyle="H2" />
									<FormattedText class="myFormattedText" htmlText="{SelectedCandidate>KeyResponsibilities}" />
								</VBox>
								<VBox visible="{ path: 'SelectedCandidate>JobDescription', formatter: '.hasValue' }" class="sapUiSmallMargin sapUiLargeMarginBegin">
									<Title text="Job Description" level="H2" wrapping="true" titleStyle="H2" />
									<FormattedText class="myFormattedText" htmlText="{SelectedCandidate>JobDescription}" />
								</VBox>
							</VBox>
						</Panel>
					</VBox>
					<!-- Right Panel -->
					<VBox class="rightColumn">
						<Panel class="actionPanel">
							<VBox alignItems="Center" class="sapUiSmallMargin">
								<Button text="Apply Now" tooltip="Apply for this job" press="onApply" class="myCustomButton" />
							</VBox>
						</Panel>
					</VBox>
				</HBox>
			</ScrollContainer>
		</content>
	</Page>
</mvc:View>