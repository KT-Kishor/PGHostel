<mvc:View controllerName="sap.ui.com.project1.controller.ManageVendorDetail"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:m="sap.m"
	xmlns:suite="sap.suite.ui.commons"
	xmlns="sap.uxap"
	xmlns:uxap="sap.uxap"
	xmlns:richtexteditor="sap.ui.richtexteditor"
	xmlns:layout="sap.ui.layout"
	xmlns:f="sap.ui.layout.form"
	xmlns:c="sap.ui.core"
    displayBlock="true"
    height="100%"
	xmlns:core="sap.ui.core"
    busyIndicatorDelay="0"
	xmlns:u="sap.ui.unified">
	<m:Page navButtonPress="BI_onButtonPress" showNavButton="true" title="Vendor Details">
		<m:headerContent>
			<core:Fragment fragmentName="sap.ui.com.project1.fragment.Header" type="XML"/>
		</m:headerContent>
		<ObjectPageLayout id="MV_id_ObjectPageLayout">
			<sections>
				<ObjectPageSection titleUppercase="false" id="MV_id_OrderHeaderSection1"
                    title="Vendor Information">
					<subSections>
						<ObjectPageSubSection id="MV_id_dsd1">
							<blocks>
								<f:SimpleForm
                                    id="MV_id_simpleCompanyDetails"
                                    busyIndicatorDelay="0" editable="true"
                                    layout="ColumnLayout"  labelSpanXL="4"
                                    labelSpanL="3"
                                    labelSpanM="4"
                                    labelSpanS="12"
                                    columnsXL="2"
                                    columnsL="2"
                                    columnsM="1">
									<f:content>
										<m:Label text="Vendor Name" required="true"/>
                                        <m:ComboBox id="MV_id_adminSalutation" selectedKey="{AdminSignupModel>/Salutation}" editable="{editable>/Edit}" change="onAdminChangeSalutation" placeholder="Mr." valueStateText="Select Salutation">
                                            <core:ListItem key="Mr." text="Mr."/>
                                            <core:ListItem key="Ms." text="Ms."/>
                                            <core:ListItem key="Mrs." text="Mrs."/>
                                            <core:ListItem key="Dr." text="Dr."/>
                                        </m:ComboBox>
										<m:Input value="{AdminSignupModel>/VendorName}"
                                        liveChange="onAdminLiveValidate" editable="{editable>/Edit}"/>
										<m:Label text="Date of Birth" required="true"/>
										<m:DatePicker value="{AdminSignupModel>/DateOfBirth}"
                                        valueStateText="Pick Date of Birth" displayFormat="dd/MM/yyyy"
                                        valueFormat="dd/MM/yyyy" change="onChangeDOB" editable="{editable>/Edit}"
                                        initialFocusedDateValue="{controller>/focusedDate}"
                                        minDate="{controller>/minDate}"/>
										<m:Label text="Gender" required="true"/>
										<m:Select selectedKey="{AdminSignupModel>/Gender}" change="ADMIN_onChangeGender"  editable="{editable>/Edit}">
											<core:Item key="Male" text="Male"/>
											<core:Item key="Female" text="Female"/>
											<core:Item key="Other" text="Other"/>
										</m:Select>
										<m:Label text="Email" required="true"/>
										<m:Input value="{AdminSignupModel>/Email}" type="Email"
                                         liveChange="onAdminLiveValidate" editable="{editable>/Edit}"/>
										<m:Label text="Country" required="true"/>
										<m:ComboBox selectedKey="{AdminSignupModel>/Country}" change="ADMIN_onChangeCountry"  id="MV_id_Country" selectionChange="ADMIN_onChangeCountry" placeholder="Select Country" valueStateText="Select a valid Country" items="{path:'CountryModel>/', length:1000}"  showSecondaryValues="true" editable="{editable>/Edit}">
                                        <core:ListItem key="{CountryModel>countryName}" text="{CountryModel>countryName}" additionalText="{CountryModel>code}"/>   
                                        </m:ComboBox>
										<m:Label text="State" required="true"/>
										<m:ComboBox selectedKey="{AdminSignupModel>/State}" change="ADMIN_onChangeState" items="{StateModel>/}" editable="{editable>/Edit}" placeholder="Select State" valueStateText="Select a valid State" showSecondaryValues="true" id="MV_id_State">
											<core:ListItem key="{StateModel>stateName}" text="{StateModel>stateName}"/>
										</m:ComboBox>
										<m:Label text="City" required="true"/>
										<m:ComboBox selectedKey="{AdminSignupModel>/City}" change="ADMIN_onChangeCity" selectionChange="ADMIN_onChangeCity" placeholder="Select City" valueStateText="Select a valid City" id="MV_id_City"
                                         items="{path:'CityModel>/', length:1000}" showSecondaryValues="true" editable="{editable>/Edit}">
                                        <core:ListItem
                                            key="{CityModel>cityName}"
                                            text="{CityModel>cityName}"
                                            additionalText="{CityModel>branchCode}"
                                        />
										</m:ComboBox>
										<!-- ISD + Mobile -->
										<m:Label text="Mobile Number" required="true"/>
											<m:ComboBox selectedKey="{AdminSignupModel>/STDCode}" change="ADMIN_onChangeSTD" placeholder="ISD" showSecondaryValues="true" width="100%" items="{path:'CountryModel>/', length:1000}" filterSecondaryValues="true" editable="{editable>/Edit}"> 
		                                    <core:ListItem key="{CountryModel>stdCode}" text="{CountryModel>stdCode}" additionalText="{CountryModel>code}" />
											</m:ComboBox>
											<m:Input value="{AdminSignupModel>/Mobile}"
                                            liveChange="ADMIN_onMobileLiveChange"  editable="{editable>/Edit}"/>
										<m:Label text="Address" required="true"/>
										<m:TextArea value="{AdminSignupModel>/Address}" rows="3"
                                        liveChange="onAdminLiveValidate"  editable="{editable>/Edit}"/>
									</f:content>
								</f:SimpleForm>
							</blocks>
						</ObjectPageSubSection>
					</subSections>
				</ObjectPageSection>
				<ObjectPageSection titleUppercase="false" id="connections1" title="{i18n>Attachment}">
					<subSections>
						<ObjectPageSubSection id="connectionsSS4" titleUppercase="false">
							<blocks>
								<m:VBox>
									<m:VBox class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop ">
										<m:MessageStrip text="Upload clear and valid documents only. Max size: 5 MB per file" showIcon="true" type="Warning" class="sapUiTinyMarginBottom" />
									</m:VBox>
									<m:Table id="MV_id_adminAttachmentTable" items="{AdminSignupModel>/Documents}" mode="{= ${editable>/Edit} ? 'Delete' : 'None' }" delete="onAdminDeleteDoc" sticky="ColumnHeaders,HeaderToolbar" width="100%">
										<m:headerToolbar>
											<m:OverflowToolbar>
												<m:Title text="Documents" />
												<m:Text text="*" class="requiredStar" />
												<m:ToolbarSpacer />
												<m:ComboBox change="onAdminDocTypeChange" id="MV_id_adminDocType" selectedKey="{AdminSignupModel>/CurrentDocType}" enabled="{editable>/Edit}" placeholder="Select Document" width="200px">
													<core:ListItem key="Aadhaar" text="Aadhar Card"/>
													<core:ListItem key="PAN" text="PAN Card"/>
													<core:ListItem key="Driving License" text="Driving License"/>
													<core:ListItem key="Bank" text="Bank Account Proof"/>
													<core:ListItem key="Other" text="Other"/>
												</m:ComboBox>
												<!-- Upload button -->
												<m:VBox id="MV_id_adminUploaderWrapper">
													<u:FileUploader enabled="{editable>/Edit}" id="MV_id_adminFileUploader" buttonOnly="true" buttonText="Upload" uploadOnChange="false" change="onAdminFileSelect" fileType="jpg,jpeg,png,pdf,doc,docx" />
												</m:VBox>
											</m:OverflowToolbar>
										</m:headerToolbar>
										<m:columns>
											<m:Column>
												<m:Text text="File Name" />
											</m:Column>
											<m:Column>
												<m:Text text="Document" />
											</m:Column>
											<m:Column>
												<m:Text text="Size" />
											</m:Column>
										</m:columns>
										<m:items>
											<m:ColumnListItem>
												<m:cells>
													<m:Link text="{AdminSignupModel>FileName}"
                                                    press="onAdminPreviewDoc" tooltip="{path:'AdminSignupModel>', formatter:'.Formatter.fileTooltip'}"/>
													<m:Text text="{AdminSignupModel>VdocType}" />
													<m:Text text="{path:'AdminSignupModel>size', formatter:'.Formatter.formatFileSize'}" />
												</m:cells>
											</m:ColumnListItem>
										</m:items>
									</m:Table>
								</m:VBox>
							</blocks>
						</ObjectPageSubSection>
					</subSections>
				</ObjectPageSection>
			</sections>
		</ObjectPageLayout>
		<m:footer>
			<m:Bar id="MV_id_FooterBar">
				<m:contentRight>
					<m:Button id="MV_id_editButton" visible="{= !${editable>/Edit} }"
                        text="Edit" class="myUnifiedBtn" press="BI_onEditButtonPress"/>
					<m:Button id="MV_id_SaveButton" visible="{=${editable>/Edit}}"
                        text="Save" class="myUnifiedBtn" press="BT_onsavebuttonpress"/>
				</m:contentRight>
			</m:Bar>
		</m:footer>
	</m:Page>
</mvc:View>