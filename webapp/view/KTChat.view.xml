<mvc:View
  controllerName="sap.kt.com.minihrsolution.controller.KTChat"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:suite="sap.suite.ui.commons"
  displayBlock="true">

  <SplitApp id="splitApp">
    <!-- Master Page (Groups List) -->
    <masterPages>
      <Page id="masterPage" title="KT Chat App">
        <content>
          <Input
            placeholder="Enter your name and Press ↵ to submit."
            submit="changeName"
            width="100%"/>
            
          <List
            id="groupsList"
            headerText="Available Groups"
            items="{EmpDetails>/}">
            <StandardListItem
             title="{EmpDetails>EmployeeName}"  icon="{path:'EmpDetails>ProfilePhoto',formatter: '.Formatter.getImageSrc'}" type="Navigation" press=".onPressGoToMaster"/>
          </List>
        </content>
      </Page>
    </masterPages>

    <!-- Detail Page (Chat Timeline) -->
    <detailPages>
      <Page id="detailPage" title="{chat>/current_room}">
        <content>
          <ScrollContainer
            width="100%"
            height="90%"
            horizontal="false"
            vertical="true">
            <suite:Timeline
              id="messageTimeline"
              noDataText="Select a group to start chatting"
             
              width="100%"
              enableScroll="false"
              content="{chat>/current_chat}">
              <suite:content>
                <suite:TimelineItem
                  dateTime="{chat>timestamp}"
                  text="{chat>message}"
                  userName="{chat>username}"
                  icon="sap-icon://person-placeholder"/>
              </suite:content>
            </suite:Timeline>
          </ScrollContainer>
          
          <Input
            id="messageInput1"
            placeholder="Enter your message and Press ↵ to submit."
            submit="sendMessage"
            enabled="{= !!${chat>/current_room}}"
            width="100%"/>
        </content>
      </Page>
    </detailPages>
  </SplitApp>

</mvc:View>