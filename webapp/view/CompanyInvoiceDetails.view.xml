<mvc:View controllerName="sap.kt.com.minihrsolution.controller.CompanyInvoiceDetails"
	xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
	xmlns:core="sap.ui.core"
	xmlns:m="sap.m"
	xmlns="sap.uxap"
	xmlns:f="sap.ui.layout.form">
	<m:Page title="{i18n>invoiceDetails}" showNavButton="true" navButtonPress="CI_onPressback" id="myPageId" >
		<!-- <m:ScrollContainer > -->
		<ObjectPageLayout id="idCmpInvObjectPageLayout"
            enableLazyLoading="true"
            useIconTabBar="false"
            class="sapUiSmallmarginResponsive">
			<!-- Sections in the ObjectPage -->
			<sections>
				<!-- First section containing MSA details -->
				<ObjectPageSection titleUppercase="false" id="idCmpInvGoals">
					<subSections>
						<ObjectPageSubSection id="idCmpInvGoalsSS1" titleUppercase="false" title="{i18n>invoiceBasicDetails}">
							<blocks>
								<f:SimpleForm	 	
										editable="true" layout="ColumnLayout"
              labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
              adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"
              emptySpanM="0" emptySpanS="0" columnsXL="2" columnsL="2" columnsM="1">
									<f:content>
										<m:Label visible="{visiablityPlay>/createVisi}" text="{i18n>customerName}" required="true" />
										<m:ComboBox id="idAddCustComboBox" visible="{visiablityPlay>/createVisi}" items="{AddCustomerModel>/results}" value="{SelectedCustomerModel>/Customer}" change="onChangeAddCustomer">
											<core:Item key="{AddCustomerModel>ID}" text="{AddCustomerModel>CompanyName}" />
										</m:ComboBox>
										<m:Label visible="{visiablityPlay>/editVisi}" text="{i18n>customerName}" required="true" />
										<m:Input visible="{visiablityPlay>/editVisi}" id="idCustmer" value="{SelectedCustomerModel>/CustomerName}" editable="false" maxLength="50" />
										<m:Label text="{i18n>invoiceNo}" />
										<m:Input editable="false" value="{SelectedCustomerModel>/InvNo}" liveChange="onPressLiveChange" maxLength="20" />
										<m:Label visible="{visiablityPlay>/createVisi}"  text="{i18n>invoiceDate}" required="true" />
										<m:DatePicker visible="{visiablityPlay>/createVisi}" id="idInvoice" value="{path:'SelectedCustomerModel>/InvoiceDate','type':'sap.ui.model.type.Date','formatOptions':{'pattern':'dd/MM/yyyy'}}" change="onChangeInvoiceDate" />
										<m:Label visible="{visiablityPlay>/createVisi}"  text="{i18n>PayByDate}" required="true" />
										<m:DatePicker visible="{visiablityPlay>/createVisi}" id="idPayby" value="{path:'SelectedCustomerModel>/PayByDate','type':'sap.ui.model.type.Date','formatOptions':{'pattern':'dd/MM/yyyy'}}"/>
										<m:Label visible="{visiablityPlay>/editVisi}" text="{i18n>invoiceDate}" required="true" />
										<m:DatePicker visible="{visiablityPlay>/editVisi}" id="idNavInvoice" displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy" value="{SelectedCustomerModel>/InvoiceDate}"  editable="{visiablityPlay>/editable}" change="validateDate"/>
										<m:Label visible="{visiablityPlay>/editVisi}"  text="{i18n>PayByDate}" required="true" />
										<m:DatePicker visible="{visiablityPlay>/editVisi}" id="idNavPayby" displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy" value="{SelectedCustomerModel>/PayByDate}" editable="{visiablityPlay>/editable}" change="validateDate"/>
										<m:Label text="{i18n>invoiceDescription}" required="true" />
										<m:Input id="idInvoiceDesc" value="{SelectedCustomerModel>/InvoiceDescription}" placeholder="{i18n>companyInvoiceDescPlaceH}"  maxLength="120" editable="{visiablityPlay>/editable}" liveChange="onliveInvoicDesc" />
										<m:Label text="{i18n>sowPO}" required="true"></m:Label>
										<m:Input id="idSowPO" value="{SelectedCustomerModel>/POSOW}" maxLength="14" placeholder="Enter the SOW" editable="{visiablityPlay>/editable}" liveChange="onChangeSOWPO" ></m:Input>
										<m:Label visible="{visiablityPlay>/GST}"  text="{i18n>type}" />
										<m:Text visible="{visiablityPlay>/GST}" text="{ parts: [{path: 'SelectedCustomerModel>/Type'}, {path: 'SelectedCustomerModel>/Value'}], formatter: '.Formatter.formatCustomerTypeValue' }" id="idType"/>
										<m:Label visible="{visiablityPlay>/gstVisiable}" text="{i18n>cgs}" required="true"/>
										<m:Input visible="{visiablityPlay>/gstVisiable}"  value="{path:'SelectedCustomerModel>/CGST',formatter: '.Formatter.numberFormater'}" editable="{visiablityPlay>/editable}" maxLength="50"/>
										<m:Label visible="{visiablityPlay>/igstVisi}" text="{i18n>igst}" required="true"/>
										<m:Input visible="{visiablityPlay>/igstVisi}" value="{path:'SelectedCustomerModel>/IGST',formatter: '.Formatter.numberFormater'}" editable="{visiablityPlay>/editable}" maxLength="50" />
										<m:Label visible="{visiablityPlay>/gstVisiable}"  text="{i18n>sgst}" required="true"/>
										<m:Input visible="{visiablityPlay>/gstVisiable}"  value="{path:'SelectedCustomerModel>/SGST',formatter: '.Formatter.numberFormater'}" editable="{visiablityPlay>/editable}" maxLength="50"/>
										<m:Label  visible="{= ${FilteredSOWModel>/Currency} === 'INR'?false:true}" text="{i18n>expenseConversionRate}" required="true" />
										<m:Input id="idConversionRate" visible="{= ${FilteredSOWModel>/Currency} === 'INR'?false:true}" placeholder="{i18n>companyInvoiceConversionRatePlace}" value="{SelectedCustomerModel>/ConversionRate}" change="onChangeConversionRate" maxLength="50" type="Number" editable="{visiablityPlay>/editable}" liveChange="onChnageConvertion"/>
										<m:Label visible="{= ${FilteredSOWModel>/Currency} === 'INR'?false:true}"  text="{i18n>amountInINR}" required="true" />
										<m:Input visible="{= ${FilteredSOWModel>/Currency} === 'INR'?false:true}"  value="{path:'SelectedCustomerModel>/AmountInFCurrency',formatter: '.Formatter.numberFormater'}" maxLength="50" editable="false"/>
										<m:Label visible="{= ${FilteredSOWModel>/Currency} === 'INR'?false:true}"  text="{i18n>custLutVa}" />
										<m:Input visible="{= ${FilteredSOWModel>/Currency} === 'INR'?false:true}"  value="{SelectedCustomerModel>/LUT}" maxLength="50" editable="{visiablityPlay>/editable}"/>
										<m:Label text="{i18n>panCard}" />
										<m:Input value="{SelectedCustomerModel>/PAN}" id="idInputPAN" liveChange="onPressLiveChange" maxLength="50" editable="{visiablityPlay>/CInvoice}" />
										<m:Label text="{i18n>gst}" visible="{visiablityPlay>/GST}"/>
										<m:Input value="{SelectedCustomerModel>/GST}" id="idInputGST" liveChange="onPressLiveChange" maxLength="50" editable="{visiablityPlay>/CInvoice}" visible="{visiablityPlay>/GST}" />
										<m:Label text="{i18n>address}" />
										<m:TextArea id="idInputAddress" value="{SelectedCustomerModel>/Address}" maxLength="120" liveChange="onPressLiveChange" editable="{visiablityPlay>/CInvoice}"/>
										<m:Label text="{i18n>emailID}" required="true"/>
										<m:Input value="{SelectedCustomerModel>/MailID}" id="idInputMailID" maxLength="500" liveChange="onPressLiveChange" editable="{visiablityPlay>/CInvoice}" change="onchangeEmail"/>
										<m:Label text="{i18n>mobileNo}" />
										<m:Input value="{SelectedCustomerModel>/MobileNo}" id="idInputMobileNo" maxLength="10" liveChange="onPressLiveChange" editable="{visiablityPlay>/CInvoice}" />
										<m:Label  visible="{visiablityPlay>/TDS}" text="{i18n>TDS}" />
										<m:Input  visible="{visiablityPlay>/TDS}" value="{SelectedCustomerModel>/TDS}"  editable="{visiablityPlay>/editable}" />
										<m:Label visible="{visiablityPlay>/createVisi}" text="{i18n>selectSOW}" />
										<m:ComboBox visible="{visiablityPlay>/createVisi}" items="{CombinedData>/items}" value="{SelectedCustomerModel>/SOWDetails}" change="onChangeSOWDetails" id="idSowDetails">
											<core:Item key="{CombinedData>MsaID} - {CombinedData>SowID}" text="{parts:[{path:'CombinedData>CompanyName'},{path:'CombinedData>Description'},{path:'CombinedData>StartDate'},{path:'CombinedData>EndDate'}],formatter: '.Formatter.formatCompanyAndDescription'}"/>
										</m:ComboBox>
										<m:Label text="{i18n>currency}" required="true"/>
										<m:ComboBox items="{currencyModel>/results}" value="{FilteredSOWModel>/Currency}" id="idCurrencySelect" change="onChangeCurrency">
											<core:Item key="{currencyModel>Currency}" text="{currencyModel>Currency}" />
										</m:ComboBox>
										<m:Label text="{i18n>invoiceStatus}" visible="{visiablityPlay>/editVisi}" required="true"/>
										<m:ComboBox visible="{visiablityPlay>/editVisi}" items="{CompanyInvoiceStatus>/results}" value="{SelectedCustomerModel>/Status}" editable="{visiablityPlay>/CInvoice}" change="onChangeInvoiceStatus" >
											<core:Item key="{CompanyInvoiceStatus>InvoiceStatus}" text="{CompanyInvoiceStatus>InvoiceStatus}" />
										</m:ComboBox>
									</f:content>
								</f:SimpleForm>
							</blocks>
							<actions>
								<m:Button visible="{visiablityPlay>/createVisi}" type="Transparent" icon="sap-icon://add" text="{i18n>addCustomerBtn}" press="onPressAddCustomer" />
								<m:Button visible="{visiablityPlay>/createVisi}" type="Transparent" text="{i18n>ActiveSOW}" press="onPressMSAandSOW" />
							</actions>
						</ObjectPageSubSection>
						<ObjectPageSubSection  titleUppercase="false">
							<blocks>
								<m:VBox >
									<m:Table id="idTableInvoiceItem" mode="Delete" delete="onPressDelete">
										<m:headerToolbar>
											<m:Toolbar>
												<m:ToolbarSpacer />
												<m:Button text="{i18n>btnTransaction}" 
                      press="onPressDisplayPaymentDetail" 
                      visible="{= ${SelectedCustomerModel>/Status} === 'Payment Received' || ${SelectedCustomerModel>/Status} === 'Payment Partially' }"/>
												<m:Button visible="{visiablityPlay>/addInvBtn}" 
                      icon="sap-icon://add" 
                      type="Default" 
                      press="onPressAddInvoiceItems" />
												<m:ToolbarSeparator />
											</m:Toolbar>
										</m:headerToolbar>
										<m:columns>
											<m:Column>
												<m:Text text="{i18n>itemID}" />
											</m:Column>
											<m:Column>
												<m:Text text="{i18n>particulars}" />
											</m:Column>
											<m:Column id="idSAC">
												<m:Text text="{i18n>SAC}" />
											</m:Column>
											<m:Column id="idGSTCalculation">
												<m:Text text="{i18n>GSTCalculation}" />
											</m:Column>
											<m:Column>
												<m:Text text="{i18n>Unit}" />
											</m:Column>
											<m:Column>
												<m:Text text="{i18n>rate}" />
											</m:Column>
											<m:Column>
												<m:Text text="{i18n>discount}" />
											</m:Column>
											<m:Column>
												<m:Text text="{i18n>total}" />
											</m:Column>
										</m:columns>
										<m:items>
											<m:ColumnListItem>
												<m:cells>
													<m:Input value="{IndexNo}" editable="false" />
												</m:cells>
												<m:cells>
													<m:Input value="{Particulars}" editable="{visiablityPlay>/editable}" maxLength="60" />
												</m:cells>
												<m:cells>
													<m:ComboBox showSecondaryValues="true" 
                            items="{InvoiceSACModel>/results}" 
                            editable="{visiablityPlay>/editable}" 
                            value="{SAC}" 
                            selectedKey="1">
														<core:ListItem key="{InvoiceSACModel>ID}" 
                                   additionalText="{InvoiceSACModel>Description}" 
                                   text="{InvoiceSACModel>SAC}" />
													</m:ComboBox>
												</m:cells>
												<m:cells>
													<m:ComboBox editable="{visiablityPlay>/editable}" 
                            value="{GSTCalculation}" 
                            selectedKey="Yes" 
                            change="onChangeGSTCalculation">
														<core:Item key="{i18n>yes}" text="{i18n>yes}"/>
														<core:Item key="{i18n>no}" text="{i18n>no}"/>
													</m:ComboBox>
												</m:cells>
												<m:cells>
													<m:Input value="{Unit}" editable="{visiablityPlay>/editable}" type="Number" 
                         change="onChangeSowDetailsCal" textAlign="End" maxLength="20" />
												</m:cells>
												<m:cells>
													<m:Input value="{Rate}" editable="{visiablityPlay>/editable}" type="Number" 
                         change="onChangeSowDetailsCal" textAlign="End" maxLength="20" />
												</m:cells>
												<m:cells>
													<m:Input value="{Discount}" editable="{visiablityPlay>/editable}" 
                         liveChange="onchangeDiscount" textAlign="End" maxLength="20" />
												</m:cells>
												<m:cells>
													<m:Input value="{path:'Total',formatter: '.Formatter.numberFormater'}" 
                         editable="false" textAlign="End" />
												</m:cells>
											</m:ColumnListItem>
										</m:items>
									</m:Table>
									<m:FlexBox class="custom-flexbox sapUiContentPadding" direction="Column" >
										<m:VBox class="custom-vbox">
											<!-- Sub Total (Non-Taxable) -->
											<m:HBox justifyContent="SpaceBetween" >
												<m:Label text="{i18n>subTotal} ({i18n>NonTaxable}) ({FilteredSOWModel>/Currency}) :" 
															class="boldBlackText sapUiTinyMarginBottom rightAlignLabel" />
												<m:Text class="amountText" text="{path:'SelectedCustomerModel>/SubTotalNotGST',formatter: '.Formatter.numberFormater'}" 
															textAlign="End" />
											</m:HBox>
											<!-- Sub Total (Taxable) -->
											<m:HBox justifyContent="SpaceBetween" visible="{= ${FilteredSOWModel>/Currency} === 'INR' }">
												<m:Label text="{i18n>subTotal} ({i18n>Taxable}) ({FilteredSOWModel>/Currency}) :" 
															class="boldBlackText sapUiTinyMarginBottom rightAlignLabel" />
												<m:Text class="amountText" text="{path:'SelectedCustomerModel>/SubTotalInGST',formatter: '.Formatter.numberFormater'}" 
															textAlign="End" />
											</m:HBox>
											<!-- CGST -->
											<m:HBox justifyContent="SpaceBetween" visible="{= ${SelectedCustomerModel>/Type} === 'CGST/SGST' }">
												<m:Label text="{i18n>CGST} ({SelectedCustomerModel>/Value}%) :" 
															class="boldBlackText sapUiTinyMarginBottom rightAlignLabel" />
												<m:Text class="amountText" text="{path:'FilteredSOWModel>/gstAmount',formatter: '.Formatter.numberFormater'}" 
															textAlign="End" />
											</m:HBox>
											<!-- SGST -->
											<m:HBox justifyContent="SpaceBetween" visible="{= ${SelectedCustomerModel>/Type} === 'CGST/SGST' }">
												<m:Label text="{i18n>SGST} ({SelectedCustomerModel>/Value}%) :" 
															class="boldBlackText sapUiTinyMarginBottom rightAlignLabel" />
												<m:Text class="amountText" text="{path:'FilteredSOWModel>/gstAmount',formatter: '.Formatter.numberFormater'}" 
															textAlign="End" />
											</m:HBox>
											<!-- IGST -->
											<m:HBox justifyContent="SpaceBetween" visible="{= ${SelectedCustomerModel>/Type} === 'IGST' }">
												<m:Label text="{i18n>IGST} ({SelectedCustomerModel>/Value}%) :" 
															class="boldBlackText sapUiTinyMarginBottom rightAlignLabel" />
												<m:Text class="amountText" text="{path: 'FilteredSOWModel>/gstAmount', formatter: '.Formatter.numberFormater'}" 
															textAlign="End" />
											</m:HBox>
											<!-- Total Amount -->
											<m:HBox justifyContent="SpaceBetween">
												<m:Label text="{i18n>total} ({FilteredSOWModel>/Currency}) :" 
															class="boldBlackText sapUiTinyMarginBottom rightAlignLabel" />
												<m:Text class="amountText" text="{path:'FilteredSOWModel>/TotalAmount',formatter: '.Formatter.numberFormater'}" 
															textAlign="End" />
											</m:HBox>
											<!-- Received Amount -->
											<m:HBox justifyContent="SpaceBetween" visible="{= ${SelectedCustomerModel>/Status} === 'Payment Received' || ${SelectedCustomerModel>/Status} === 'Payment Partially' }">
												<m:Label text="{i18n>invoiceReceivedAmount} ({FilteredSOWModel>/Currency}) :" class="boldBlackText sapUiTinyMarginBottom rightAlignLabel" />
												<m:Text class="amountText" text="{path:'InvoicePayment>/AllReceivedAmount',formatter: '.Formatter.numberFormater'}" textAlign="End" />
											</m:HBox>
											<!-- Due Amount -->
											<m:HBox justifyContent="SpaceBetween" visible="{= ${SelectedCustomerModel>/Status} === 'Payment Received' || ${SelectedCustomerModel>/Status} === 'Payment Partially' }">
												<m:Label text="{i18n>invoiceDueAmount} ({FilteredSOWModel>/Currency}) :" class="boldBlackText sapUiTinyMarginBottom rightAlignLabel" />
												<m:Text class="amountText" text="{path:'InvoicePayment>/AllDueAmount',formatter: '.Formatter.numberFormater'}" textAlign="End" />
											</m:HBox>
										</m:VBox>
									</m:FlexBox>
								</m:VBox>
							</blocks>
						</ObjectPageSubSection>
					</subSections>
				</ObjectPageSection>
			</sections>
		</ObjectPageLayout>
		<m:footer>
			<m:Toolbar>
				<m:ToolbarSpacer/>
				<m:Button visible="{visiablityPlay>/createVisi}" text="{i18n>submit}" type="Emphasized" press="onPressSubmit" class="sendMail" />
				<m:Button text="{i18n>companyInvoiceSendEmail}" press="onPressSendEmail" visible="{visiablityPlay>/payByDate}" />
				<m:Button visible="{visiablityPlay>/Edit}" text="{= ${visiablityPlay>/editable} === true?'Save':'Edit'}"  press="onPressEdit" class="sendMail" />
				<m:Button text="{i18n>sendInvoiceText}" press="onPressSendMultipalEmail" visible="{visiablityPlay>/MultiEmail}"/>
				<m:Button text="{i18n>GeneratePDF}" press="onPressGeneratePdf"  visible="{visiablityPlay>/merge}" />
			</m:Toolbar>
		</m:footer>
	</m:Page>
</mvc:View>