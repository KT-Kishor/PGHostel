<mvc:View
    controllerName="sap.ui.com.project1.controller.Payment"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%"
    busyIndicatorDelay="0"
>
    <Page showHeader="true">
        <headerContent>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.Header"
                type="XML"
            />
        </headerContent>
        <content>
            <fb:FilterBar
                id="P_id_Filterbar"
                persistencyKey="myPersKey"
                useToolbar="false"
                clear="FC_onPressClear"
                showClearOnFB="true"
                search="Onsearch"
                filterChange="IA_.onFilterChange"
                afterVariantLoad="IA_.onAfterVariantLoad"
                showFilterConfiguration="false"
                filterContainerWidth="auto"
            >
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="CustomerID"
                        label="{i18n>customerID}"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="P_id_CustomerID"
                                items="{mainModel>/}"
                                showClearIcon="true"
                            >
                                <core:Item
                                    key="{mainModel>CustomerID}"
                                    text="{mainModel>CustomerID} - {mainModel>CustomerName}"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem
                        name="BookingID"
                        label="{i18n>bookingID}"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="P_id_BookingID"
                                items="{mainModel>/}"
                                showClearIcon="true"
                            >
                                <core:Item
                                    key="{mainModel>BookingID}"
                                    text="{mainModel>BookingID}"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="BranchCode"
                        label="{i18n>MSbranchCode}"
                        groupName="Group"
                        visible="{RoleModel>/isSuperAdmin}"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="P_id_BranchCode"
                                items="{mainModel>/}"
                                showClearIcon="true"
                                showSecondaryValues="true"
                                busyIndicatorDelay="0"
                            >
                                <core:ListItem
                                    key="{mainModel>BranchID}"
                                    text="{mainModel>BranchID} - {mainModel>Name}"
                                    additionalText="{mainModel>City}"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="StartDate"
                        label="{i18n>date}"
                        groupName="Group"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <DateRangeSelection
                                id="P_id_Date"
                                valueFormat="yyyy-MM-dd"
                                displayFormat="dd/MM/yyyy"
                            />
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>
            <Table
                id="P_id_PaymentTable"
                sticky="ColumnHeaders,HeaderToolbar"
                mode="None"
                width="auto"
                busyIndicatorDelay="0"
                class="sapUiResponsiveMargin"
                items="{path: 'mainModel>/', sorter: {path: '',descending: false,group: true}}"
            >
                <headerToolbar>
                    <OverflowToolbar>
                        <Title
                            text="{i18n>invoicePaymentTitle} ({= ${mainModel>/}.length})"
                        />
                        <ToolbarSpacer />
                        <Button
                            text="{i18n>download}"
                            tooltip="{i18n>download}"
                            press="P_onDownload"
                            class="myUnifiedBtn"
                        />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column demandPopin="true">
                        <Text
                            text="{i18n>bookingID}"
                            tooltip="{i18n>bookingID}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>paymentDate}"
                            tooltip="{i18n>paymentDate}"
                        />
                    </Column>
                    <Column demandPopin="true">
                        <Text
                            text="{i18n>bankName}"
                            tooltip="{i18n>bankName}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>amount}"
                            tooltip="{i18n>amount}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>paymentType}"
                            tooltip="{i18n>paymentType}"
                        />
                    </Column>
                    <Column demandPopin="true">
                        <Text
                            text="{i18n>bankTransactionID}"
                            tooltip="{i18n>bankTransactionID}"
                        />
                    </Column>
                    <!-- <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>customerID}"
                            tooltip="{i18n>customerID}"
                        />
                    </Column> -->
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>customerName}"
                            tooltip="{i18n>customerName}"
                        />
                    </Column>
                    <!-- <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>mode}"
                            tooltip="{i18n>mode}"
                        />
                    </Column> -->
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>deposit}"
                            tooltip="{i18n>deposit}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>depositDate}"
                            tooltip="{i18n>depositDate}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>depositMode}"
                            tooltip="{i18n>depositMode}"
                        />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>depositTransactionID}"
                            tooltip="{i18n>depositTransactionID}"
                        />
                    </Column>
                    <!-- <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>MSbranchCode}"
                            tooltip="{i18n>MSbranchCode}"
                        />
                    </Column> -->
                    <!-- <Column
                        demandPopin="true"
                        minScreenWidth="Tablet"
                    >
                        <Text
                            text="{i18n>perMonthTotalRent}"
                            tooltip="{i18n>perMonthTotalRent}"
                        />
                    </Column> -->
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{mainModel>BookingID}" />
                            <Text
                                text="{parts:['mainModel>Date'], formatter: '.Formatter.displayFormatDate'}"
                            />
                            <Text text="{mainModel>BankName}" />
                            <Text
                                text="{parts:['mainModel>Amount', 'mainModel>Currency'], formatter: '.Formatter.formatCurrency'}"
                            />
                            <Text text="{mainModel>PaymentType}" />
                            <Text text="{mainModel>BankTransactionID}" />
                            <!-- <Text text="{mainModel>CustomerID}" /> -->
                            <Text text="{mainModel>CustomerName}" />
                            <!-- <Text text="{mainModel>Mode}" /> -->
                            <Text
                                text="{parts:['mainModel>Deposit', 'mainModel>Currency'], formatter: '.Formatter.formatCurrency'}"
                            />
                            <Text
                                text="{parts:['mainModel>ReturnDepositDate'], formatter: '.Formatter.displayFormatDate'}"
                            />
                            <Text text="{mainModel>ReturnDepositMode}" />
                            <Text
                                text="{mainModel>ReturnDepositTransactionID}"
                            />
                            <!-- <Text text="{mainModel>BranchCode}" /> -->
                            <!-- <Text text="{mainModel>PerMonthTotalRent}" /> -->
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
