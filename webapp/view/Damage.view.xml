<mvc:View controllerName="sap.ui.com.project1.controller.Damage"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:m="sap.m"
	xmlns:c="sap.ui.core"
	xmlns:fb="sap.ui.comp.filterbar"
	xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%"
    busyIndicatorDelay="0">
	<Page showHeader="true">
		<headerContent>
			<core:Fragment fragmentName="sap.ui.com.project1.fragment.Header" type="XML"/>
		</headerContent>
		<content>
			<fb:FilterBar 
			    id="HD_id_FilterbarEmployee"
                persistencyKey="myPersKey"
                useToolbar="false"
                clear="HD_onPressClear"
                showClearOnFB="true"
                search="DamageOnsearch"
                filterChange="IA_.onFilterChange"
                afterVariantLoad="IA_.onAfterVariantLoad"
                showFilterConfiguration="false"
                filterContainerWidth="auto">
					<fb:filterGroupItems>
					<fb:FilterGroupItem
                        name="Customer Name"
                        label="{i18n>customerName}"
                        groupName="Group"
                        visibleInFilterBar="true">
						<fb:control>
							<ComboBox
                                id="Dm_id_CustomerName"
                                items="{CustomerModel1>/}"
                                showClearIcon="true">
								<core:ListItem
                                    key="{CustomerModel1>CustomerName}"
                                    text="{CustomerModel1>CustomerName}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
				<fb:filterGroupItems>
					<fb:FilterGroupItem
                        name="Room Number"
                        label="{i18n>roomNumber}"
                        groupName="Group"
                        visibleInFilterBar="true">
						<fb:control>
							<ComboBox
                                id="DM_id_RoomNo"
                                items="{RoomDetailsModel>/}"
                                showClearIcon="true">
								<core:Item key="{RoomDetailsModel>RoomNo}" 
                                text="{RoomDetailsModel>RoomNo}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			
				<fb:filterGroupItems>
					<fb:FilterGroupItem
                        name="Status"
                        label="{i18n>status}"
                        groupName="Group"
                        visibleInFilterBar="true">
						<fb:control>
							<ComboBox
                                id="DM_id_Status"
                                showClearIcon="true">
                                <core:ListItem
                                    key="Damage Raised"
                                    text="Damage Raised"
                                />
								  <core:ListItem
                                    key="Damage Claimed"
                                    text="Damage Claimed"
                                />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table id="HD_id_ARD_Table"
                sticky="ColumnHeaders,HeaderToolbar"
                mode="SingleSelectLeft"
                width="auto"
                busyIndicatorDelay="0"
				items="{path:'Damage>/', sorter: {path:'BranchName',descending: false,group: true}}">
				<headerToolbar>
					<OverflowToolbar>
						<Title text="{i18n>damagelist} ({= ${Damage>/}.length})"/>
						<ToolbarSpacer />
						<Button
                            text="Create Damage"
                            tooltip="Create Damage"
                            press="HM_GenearteDamage"
                            class="myUnifiedBtn"
                             />
						<Button
                            text="{i18n>ReturnDamage}"
                            tooltip="{i18n>ReturnDamage}"
                            press="HM_ReturnDamage"
                            class="myUnifiedBtn"
                            visible="{= ${LoginModel>/Role} !== 'Front Office Employee' }"/>
						
						<Button
                            text="{i18n>download}"
							icon="sap-icon://excel-attachment"
                            tooltip="{i18n>download}"
                            press="RD_onDownload"
                            class="myUnifiedBtn"
                            visible="{= ${LoginModel>/Role} !== 'Front Office Employee' }"/>
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column demandPopin="true">
						<Text text="{i18n>customerID}" tooltip="{i18n>customer}"/>
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>customerName}" tooltip="{i18n>customerName}"/>
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>roomNo}" tooltip="{i18n>roomNo}"/>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>Cost}" tooltip="{i18n>Cost}"/>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>date}" tooltip="{i18n>Cost}"/>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>Status}" tooltip="{i18n>Status}"/>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>RecoverDate}" tooltip="{i18n>RecoverDate}"/>
					</Column>
				</columns>
				<items>
					<ColumnListItem
						type="Navigation"
						press="DM_onPressEditDetails"
					>
						<cells>
							<Text text="{Damage>CustomerID}" />
							<Text text="{Damage>CustomerName}" />
							<Text text="{Damage>RoomNo}" />
							<Text text="{parts: ['Damage>TotalCost','Damage>Currency'], formatter: '.Formatter.formatPrice'}"/>
							<Text text="{path: 'Damage>InvoiceDate', formatter: '.Formatter.formatDate'}"/>
							<ObjectStatus
							inverted="false"
							text="{Damage>Status}"
							state="{ path: 'Damage>Status', formatter: '.Formatter.formatObjectStatus'}"
							class="sapUiTinyMarginBottom"
							/>
							<Text text="{path: 'Damage>ReturnDamageDate', formatter: '.Formatter.formatDate'}"/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar>
				<contentLeft>
					<Image src="../image/TransparentKTlogo.png" width="30px" height="30px" />
					<Link text="{i18n>devlopby}" href="https://kalpavrikshatechnologies.com/"  target="_blank"
                class="customLinkWhiteBg"/>
				</contentLeft>
			</Bar>
		</footer>
	</Page>
</mvc:View>