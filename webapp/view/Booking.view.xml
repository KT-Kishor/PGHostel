                        </f:SimpleForm>
                    </Panel>

                    <!-- Guest Information Section -->
                    <Title
                        text="Select Occupants"
                        class="booking-section-header"
                        wrapping="true"
                    />

                    <Panel
                        class="customBookingPanel booking-panel-enhanced"
                    >
                        <VBox class="sapUiTinyMargin">
                            <Input
                                id="memberValueHelpInput"
                                value="{path: 'BookingView>/FamilyMembers', formatter: '.formatSelectedMembersSummary'}"
                                placeholder="Click here to select or add members"
                                showValueHelp="true"
                                valueHelpOnly="true"
                                valueHelpRequest="onMemberValueHelpRequest"
                            />
<MessageStrip
    text="Select a primary occupant using the radio button. The primary occupant will be the contact person for the booking."
    type="Information"
    showIcon="true"
    showCloseButton="false"
    class="sapUiTinyMarginTop sapUiTinyMarginBottom"
    visible="{BookingView>/showFamilySection}"
/>

                            <Text
                                text="{path: 'BookingView>/FamilyMembers', formatter: '.formatSelectedMembersCount'}"
                                class="sapUiTinyMarginTop sapUiTinyMarginBottom"
                            />

<VBox
    class="sapUiTinyMarginBottom"
    visible="{BookingView>/showFamilySection}"
>
    <Text
        text="Primary occupant (Contact Person): {path: 'BookingView>/FamilyMembers', formatter: '.formatPrimaryOccupantName'}"
        class="sapUiSmallMarginBottom"
        visible="{= ${BookingView>/FamilyMembers}.length > 0 }"
    />
    <!-- <Text
        text="This name will be used in the booking details."
        class="sapUiTinyMarginTop"
        visible="{= ${BookingView>/FamilyMembers}.length > 0 }"
    /> -->
</VBox>

                            <Table
                                items="{BookingView>/FamilyMembers}"
                                noDataText="No members selected"
                                class="responsiveTable"
                            >
                                <columns>
<Column width="6rem" visible="{BookingView>/showFamilySection}">
    <Text text="Primary" />
</Column>

                                    <Column>
                                        <Text text="Full Name" />
                                    </Column>
                                    <Column
                                        minScreenWidth="Tablet"
                                        demandPopin="true"
                                    >
                                        <Text text="Gender" />
                                    </Column>
                                    <Column
                                        minScreenWidth="Tablet"
                                        demandPopin="true"
                                    >
                                        <Text text="Relationship" />
                                    </Column>
                                    <!-- <Column minScreenWidth="Tablet" demandPopin="true">
                                            <Text text="Document Type" />
                                        </Column>
                                        <Column minScreenWidth="Desktop" demandPopin="true" width="14rem">
                                            <Text text="Document" />
                                        </Column> -->
                                    <Column width="6rem">
                                        <Text text="Action" />
                                    </Column>
                                </columns>

                                <items>
                                    <ColumnListItem>
                                        <cells>
<RadioButton
    groupName="primaryOccupantGroup"
    selected="{BookingView>IsPrimary}"
    select="onPrimaryOccupantRadioSelect"
    visible="{BookingView>/showFamilySection}"
/>

                                            <Text
                                                text="{= (${BookingView>Salutation} ? ${BookingView>Salutation} + ' ' : '') + (${BookingView>Name} || '')}"
                                            />
                                            <!-- <Select selectedKey="{BookingView>Gender}" items="{BookingView>/GenderOptions}">
                                                    <core:Item key="{BookingView>key}" text="{BookingView>text}" />
                                                </Select> -->
                                            <Text text="{BookingView>Gender}" />
                                            <Text text="{BookingView>Relation}" />
                                            <!-- <Select selectedKey="{BookingView>DocumentType}" items="{BookingView>/DocumentTypeOptions}">
                                                    <core:Item key="{BookingView>key}" text="{BookingView>text}" />
                                                </Select>
                                                <<HBox alignItems="Center" wrap="Wrap">
                                                    <unified:FileUploader
                                                        width="8rem"
                                                        buttonOnly="true"
                                                        maximumFileSize="2"
                                                        sameFilenameAllowed="true"
                                                        change="onFamilyDocumentChange"
                                                        typeMissmatch="onDocumentUploadTypeMismatch"
                                                        fileSizeExceed="onDocumentUploadSizeExceed"
                                                        buttonText="Upload"
                                                        fileType="pdf,jpg,jpeg,png,webp"
                                                        class="myUnifiedBtn sapUiTinyMarginEnd"
                                                    />
                                                    <Text text="{BookingView>DocumentName}" />
                                                </HBox> -->
                                            <Button
                                                icon="sap-icon://delete"
                                                tooltip="Remove member"
                                                press="onDeleteFamilyMemberRow"
                                                class="myUnifiedBtn"
                                            />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </Panel>

                    <!-- Facilities Section -->
                    <Title
                        text="Facilities"
                        class="booking-section-header"
                        wrapping="true"
                         visible="{= ${FacilityModel>/Facilities}.length > 0 }"
                    />

                    <Panel class="customBookingPanel booking-panel-enhanced facilityBookingPanel" visible="{= ${FacilityModel>/Facilities}.length > 0 }">
                        <VBox class="sapUiTinyMargin">
                            <MessageStrip
                                text="Add only the facilities you need. Person-wise quantity facilities also let you choose whether they apply once for the booking or daily."
                                type="Information"
                                showIcon="true"
                                showCloseButton="false"
                                class="sapUiTinyMarginBottom facilityMessageStrip"
                            />

                            <HBox
                                width="100%"
                                alignItems="Center"
                                justifyContent="SpaceBetween"
                                class="facilitiesNavContainer facilityCarouselShell"
                            >
                                <Button
                                    icon="sap-icon://slim-arrow-left"
                                    press="onFacilityPrev"
                                    class="facilityNavBtn sapUiTinyMarginEnd myUnifiedBtn"
                                />

                                <HBox
                                    id="facilityViewport"
                                    width="100%"
                                    renderType="Bare"
                                    class="facilityViewport"
                                >
                                    <HBox
                                        id="facilityCardsContainer"
                                        renderType="Bare"
                                        class="facilityTrack"
                                    />
                                </HBox>

                                <Button
                                    icon="sap-icon://slim-arrow-right"
                                    press="onFacilityNext"
                                    class="facilityNavBtn sapUiTinyMarginBegin myUnifiedBtn"
                                />
                            </HBox>
                        </VBox>
                    </Panel>
                </VBox>
            </l:content>

            <!-- Right Column - Takes full width on mobile, 35% on tablet/desktop -->

            <l:content>
                <VBox>
                    <layoutData>
                        <l:GridData span="XL4 L4 M12 S12" />
                    </layoutData>
                    <!-- Coupon Section -->
                    <Title
                        text="Have a Coupon?"
                        class="booking-section-header"
                        wrapping="true"
                    />

                        <Panel
                            class="customBookingPanel booking-panel-enhanced"
                        >
                            <!-- <HBox class="sapUiTinyMarginTop couponContainer" alignItems="Center"> -->
                            <HBox
    width="100%"
    alignItems="Center"
    justifyContent="Start"
    wrap="NoWrap"
    class="sapUiTinyMarginTop"
>
                                <Input
                                    value="{HostelModel>/CouponCode}"
                                    placeholder="Enter coupon code"
                                    liveChange="onCouponLiveChange"
                                    class="sapUiSmallMarginEnd couponInput"
                                    width="100%"
                                >

                                    <layoutData>
                                        <FlexItemData growFactor="1"  shrinkFactor="1"/>
                                    </layoutData>
                                </Input>
                                <Button
                                    text="Apply Coupon"
                                    press="onApplyCoupon"
                                    class="myUnifiedBtn couponButton sapUiTinyMarginBegin"
                                    visible="{= !${HostelModel>/AppliedCouponCode} }"
                                >
                                <layoutData>
        <FlexItemData growFactor="0" shrinkFactor="0"/>
    </layoutData>
                                
                                </Button>
                                <Button
                                    text="Remove"
                                    press="onRemoveCoupon"
                                    class="myUnifiedBtn couponButton sapUiTinyMarginBegin"
                                    visible="{= !!${HostelModel>/AppliedCouponCode} }"
                                >
                                <layoutData>
        <FlexItemData growFactor="0"/>
    </layoutData>
                                </Button>
                            </HBox>
                        </Panel>

                    <!-- Payment Summary Section -->
<Title
    text="Pricing Details"
    class="booking-section-header"
    wrapping="true"
/>


      <Panel class="customBookingPanel booking-panel-enhanced">
    <VBox class="sapUiTinyMargin">
        <HBox
            justifyContent="SpaceBetween"
            alignItems="Center"
            visible="{BookingView>/showBusinessTravelOption}"
            class="sapUiTinyMarginBottom"
        >
            <Text text="GST Details(optional)" />
            <Switch
                state="{HostelModel>/IsBusinessTravel}"
                change="onBusinessTravelToggle"
                enabled="{BookingView>/showBusinessTravelOption}"
            />
        </HBox>

        <Label
            required="true"
            text="GSTIN"
            visible="{BookingView>/showBusinessGSTSection}"
            class="sapUiTinyMarginBottom"
        />
        <Input
            id="BookGst_ID"
            value="{HostelModel>/CustomerGSTIN}"
            placeholder="Enter GSTIN"
            visible="{BookingView>/showBusinessGSTSection}"
            liveChange="onGSTINLiveChange"
            change="onGSTINChange"
            class="sapUiTinyMarginBottom"
            valueStateText="{i18n>gstError}"
            width="100%"
        />

        <Label
            required="true"
            text="Company Name"
            visible="{BookingView>/showBusinessGSTSection}"
            class="required-field-label sapUiTinyMarginBottom"
        />
        <Input
            id="BookCompanyname_ID"
            value="{HostelModel>/CompanyName}"
            placeholder="Enter company name (minimum 3 characters)"
            visible="{BookingView>/showBusinessGSTSection}"
            class="sapUiTinyMarginBottom"
            width="100%"
            change="onchangeCompanyname"
            liveChange="onchangeCompanyname"
            valueStateText="Please enter a valid company name"
            showValueStateMessage="true"
            maxLength="100"
        />

        <Label
            required="true"
            text="Company Address"
            visible="{BookingView>/showBusinessGSTSection}"
            class="required-field-label sapUiTinyMarginBottom"
        />
        <TextArea
            value="{HostelModel>/CompanyAddress}"
            placeholder="Enter complete company address"
            visible="{BookingView>/showBusinessGSTSection}"
            rows="3"
            class="sapUiTinyMarginBottom"
            width="100%"
            change="onchangeConpanyAddress"
            liveChange="onchangeConpanyAddress"
            valueStateText="Please enter a valid company address (minimum 10 characters)"
            showValueStateMessage="true"
            id="BookconpanyAddress_ID"
            maxLength="500"
            growing="true"
            growingMaxLines="5"
        />

    <!-- <HBox
            justifyContent="SpaceBetween"
            alignItems="Center"
            visible="{BookingView>/showBusinessTravelOption}"
            class="sapUiTinyMarginBottom"
        > -->
    <Title
        text="GSTIN: {HostelModel>/PropertyGSTIN}"
                    level="H5"
            class="sapUiSmallMarginTop sapUiTinyMarginBottom"
              visible="{= !!${HostelModel>/EffectiveGSTType} }"

    />

        <Table
            width="100%"
            inset="false"
            fixedLayout="Strict"
            showSeparators="Inner"
            class="pricingDetailsTable sapUiTinyMarginBottom"
        >
            <columns>
                <Column width="70%">
                    <header>
                        <Text text="Item" />
                    </header>
                </Column>
                <Column
                    width="30%"
                    hAlign="End"
                >
                    <header>
                        <Text
                            text="{= 'Amount (' + ${HostelModel>/Currency} + ')' }"
                        />
                    </header>
                </Column>
            </columns>

            <items>
<ColumnListItem vAlign="Bottom">
    <cells>
        <VBox class="sapUiTinyMarginTop sapUiTinyMarginBottom">
            <Title
                text="Room"
                level="H6"
            />
            <Text
                text="{HostelModel>/RoomBreakdownText}"
                wrapping="true"
                class="sapThemeBaseText sapUiTinyMarginTop"
            />
        </VBox>

        <VBox
            alignItems="End"
            justifyContent="End"
            class="sapUiTinyMarginTop sapUiTinyMarginBottom"
        >
            <HBox
                renderType="Bare"
                justifyContent="End"
            >
                <Text
                    text="{path: 'HostelModel>/RoomPrice', formatter: '.Formatter.fromatNumber'}"
                    class="sapUiTinyMarginEnd sapUiStrongText"
                />
                <Text
                    text="{HostelModel>/Currency}"
                    class="sapUiStrongText"
                />
            </HBox>
        </VBox>
    </cells>
</ColumnListItem>




                <ColumnListItem
                    vAlign="Middle"
                    visible="{= ${HostelModel>/TotalFacilityPrice} > 0}"
                >
                    <cells>
                        <Title text="Facilities" level='H6'/>
                        <HBox
                            justifyContent="End"
                            alignItems="Center"
                            renderType="Bare"
                        >
                            <Text
                                text="{path: 'HostelModel>/TotalFacilityPrice', formatter: '.Formatter.fromatNumber'}"
                                class="sapUiTinyMarginEnd sapUiStrongText"
                            />
                            <Text
                                text="{HostelModel>/Currency}"
                                class="sapUiStrongText"
                            />
                        </HBox>
                    </cells>
                </ColumnListItem>

                <ColumnListItem vAlign="Middle">
                    <cells>
                        <Title
                            text="Sub Total"
                            level="H6"
                        />
                        <HBox
                            justifyContent="End"
                            alignItems="Center"
                            renderType="Bare"
                        >
                            <Text
                                text="{path: 'HostelModel>/BookingSubTotal', formatter: '.Formatter.fromatNumber'}"
                                class="sapUiTinyMarginEnd sapUiStrongText"
                            />
                            <Text
                                text="{HostelModel>/Currency}"
                                class="sapUiStrongText"
                            />
                        </HBox>
                    </cells>
                </ColumnListItem>
                <ColumnListItem
    vAlign="Middle"
    visible="{= !!${HostelModel>/AppliedCouponCode} }"
>
    <cells>
  
            <Title
                text="{= 'Coupon (' + ${HostelModel>/AppliedCouponCode} + ')' }"
             level="H6"/>
            <HBox
                justifyContent="End"
                alignItems="Center"
                renderType="Bare"
            >
                <Title
                    text="-{path: 'HostelModel>/AppliedDiscount', formatter: '.Formatter.fromatNumber'}"
                   level="H6" class="sapUiTinyMarginEnd"
                />
                <Title
                    text="{HostelModel>/Currency}"
                    level="H6"
                />
        </HBox>
    </cells>
</ColumnListItem>

<ColumnListItem
    vAlign="Middle"
    visible="{= !!${HostelModel>/AppliedCouponCode} }"
>
    <cells>
        <Title
            text="Discounted Total"
            level="H6"
        />
        <HBox
            justifyContent="End"
            alignItems="Center"
            renderType="Bare"
        >
            <Text
                text="{path: 'HostelModel>/BookingNetSubTotal', formatter: '.Formatter.fromatNumber'}"
                class="sapUiTinyMarginEnd sapUiStrongText"
            />
            <Text
                text="{HostelModel>/Currency}"
                class="sapUiStrongText"
            />
        </HBox>
    </cells>
</ColumnListItem>

