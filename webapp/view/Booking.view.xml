                        </HBox>
                    </cells>
                </ColumnListItem>

                <ColumnListItem
                    vAlign="Middle"
                    visible="{= ${HostelModel>/IGST} > 0}"
                >
                    <cells>
<Text
    text="{= ${HostelModel>/IGST} > 0 &amp;&amp; ${HostelModel>/EffectiveGSTValue} > 0 ? 'IGST (' + ${HostelModel>/EffectiveGSTValue} + '%)' : 'IGST'}"
/>

                        <HBox
                            justifyContent="End"
                            alignItems="Center"
                            renderType="Bare"
                        >
                            <Text
                                text="{path: 'HostelModel>/IGST', formatter: '.Formatter.fromatNumber'}"
                                class="sapUiTinyMarginEnd"
                            />
                            <Text text="{HostelModel>/Currency}" />
                        </HBox>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>

        <!-- <MessageStrip
            text="{= ${HostelModel>/EffectiveGSTType} ? 'Applied Tax: ' + ${HostelModel>/EffectiveGSTType} + ' (' + ${HostelModel>/EffectiveGSTValue} + '%)' : 'No GST applied'}"
            type="Information"
            showIcon="true"
            showCloseButton="false"
              visible="{= !!${HostelModel>/EffectiveGSTType} }"
            class="sapUiTinyMarginBottom"
        /> -->

        <HBox
            justifyContent="SpaceBetween"
            alignItems="Center"
            class="sapUiTinyMarginBottom grandTotalBar"
        >
            <Title
                text="Grand Total"
                 level="H3"
                 titleStyle="H3"
                 class="sapUiSmallMarginBegin"
            />
            <HBox
                justifyContent="End"
                alignItems="Center"
                renderType="Bare"
            >
                <Title
                    text="{path: 'HostelModel>/GrandTotal', formatter: '.Formatter.fromatNumber'}"
                     level="H3"
                     titleStyle="H3"
                    class="sapUiTinyMarginEnd"
                />
                <Title
                    text="{HostelModel>/Currency}"
                     level="H3"
                     titleStyle="H3"
                     class="sapUiTinyMarginEnd"
                />
            </HBox>
        </HBox>

        <MessageStrip
            text="{= 'Security deposit to be paid at check-in: ' + ${HostelModel>/Deposit} + ' ' + ${HostelModel>/DepositCurrency}}"
            type="Success"
            showIcon="true"
            showCloseButton="false"
            visible="{= ${HostelModel>/Deposit} > 0}"
            class="sapUiSmallMarginBottom sapUiLargeMarginTop"
        />
    </VBox>
</Panel>

                        </VBox>
                    </l:content>

        </l:Grid>

        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Button
                    text="Continue"
                    class="myUnifiedBtn"
                    press="onContinueBooking"
                />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
