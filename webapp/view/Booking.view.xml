                <ColumnListItem
                    vAlign="Middle"
                    visible="{= !!${HostelModel>/CustomerGSTIN} }"
                >
                    <cells>
                        <Text text="Customer GSTIN" />
                        <HBox
                            justifyContent="End"
                            alignItems="Center"
                            renderType="Bare"
                        >
                            <Text text="{HostelModel>/CustomerGSTIN}" />
                        </HBox>
                    </cells>
                </ColumnListItem>

                <ColumnListItem
                    vAlign="Middle"
                    visible="{= ${HostelModel>/CGST} > 0}"
                >
                    <cells>
