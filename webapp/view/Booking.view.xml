<mvc:View
    controllerName="sap.ui.com.project1.controller.Booking"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified"
    displayBlock="true"
    xmlns:l="sap.ui.layout"
>
    <Page
        showHeader="true"
        enableScrolling="true"
        class="defaultBGBlur"
    >
        <headerContent>
            <core:Fragment
                fragmentName="sap.ui.com.project1.fragment.BookingHeader"
                type="XML"
            />
        </headerContent>

        <content>
            <VBox
                width="100%"
                class="sapUiSmallMargin"
            >
                <!-- Responsive HBox that wraps on mobile -->
                <HBox
                    width="100%"
                    wrap="Wrap"
                    alignItems="Start"
                    renderType="Bare"
                    class="responsiveColumns"
                >
                    <!-- Left Column - Takes full width on mobile, 60% on tablet/desktop -->
                    <VBox
                        width="{= ${device>/system/phone} ? '100%' : '60%'}"
                        class="sapUiTinyMarginEnd"
                    >
                        <!-- Booking Details Section -->
                        <Title
                            text="Booking Details"
                            class="booking-section-header"
                            wrapping="true"
                        />
                        
                        <Panel class="customBookingPanel booking-panel-enhanced" >
                            <MessageStrip
                                text="CheckIn Time : {HostelModel>/CheckInTime}     ; CheckOut Time : {HostelModel>/CheckOutTime}"
                                showIcon="true"
                                showCloseButton="false"
                                class="sapUiTinyMarginBottom"
                            />

                            <f:SimpleForm
                                editable="true"
                                layout="ResponsiveGridLayout"
                                labelSpanXL="4"
                                labelSpanL="4"
                                labelSpanM="4"
                                labelSpanS="12"
                                columnsXL="2"
                                columnsL="2"
                                columnsM="1"
                                class="responsiveForm"
                            >
                                <Label text="Property Type"  />
                                <ComboBox
                                id="BookProperty_ID"
                                    selectedKey="{HostelModel>/PropertyType}"
                                    items="{BookingView>/PropertyTypes}"
                                    selectionChange="onPropertyTypeChange"
                                    valueStateText="Select PropertyType"
                                    change="onPropertyChange"
                                >
                                    <core:Item
                                        key="{BookingView>key}"
                                        text="{BookingView>text}"
                                    />
                                </ComboBox>
                                <Label text="Room Plan" required="true"/>
                                <ComboBox
                                id="BookRoom_ID"
                                    selectedKey="{HostelModel>/SelectedPriceType}"
                                    items="{HostelModel>/AvailablePaymentMethods}"
                                    selectionChange="onRoomPlanChange"
                                    change="onRoomplane"
                                     valueStateText="Select Room plane"
                                >
                                    <core:Item
                                        key="{HostelModel>key}"
                                        text="{HostelModel>text}"
                                    />
                                </ComboBox>

                                <Label text="Rent Price" />
                                <Input
                                    value="{= ${HostelModel>/FinalPrice} + ' ' + ${HostelModel>/Currency}}"
                                    editable="false"
                                />


                                <Label text="No. of Persons" />
                                <Input
                                    value="{HostelModel>/SelectedPerson}"
                                    editable="false"
                                />

                                <Label
                                    text="Duration"
                                    visible="{BookingView>/showDurationSelector}"
                                />
                                <Select
                                id="BookDuration_ID"
                                    selectedKey="{HostelModel>/SelectedMonths}"
                                    items="{BookingView>/DurationOptions}"
                                    visible="{BookingView>/showDurationSelector}"
                                    change="onDurationChange"
                                    valueStateText="Select Duration"
                                >
                                    <core:Item
                                        key="{BookingView>key}"
                                        text="{BookingView>text}"
                                    />
                                </Select>

                                <Label text="Start Date" required="true"/>
                                <DatePicker
                                id="BookStartdate_ID"
                                    value="{HostelModel>/StartDate}"
                                    valueFormat="dd/MM/yyyy"
                                    displayFormat="dd/MM/yyyy"
                                    minDate="{HostelModel>/TodayDate}"
                                    change="onStartDateChange"
                                    liveChange="onStartDateChange"
                                    valueStateText="Please select a valid start date (cannot be in the past)"
                                    showValueStateMessage="true"
                                    placeholder="Select start date"
                                />

                                <Label text="End Date"  />
                                <DatePicker
                                id="BookEnddate_ID"
                                    value="{HostelModel>/EndDate}"
                                    valueFormat="dd/MM/yyyy"
                                    displayFormat="dd/MM/yyyy"
                                    editable="{BookingView>/endDateEditable}"
                                    valueStateText="End date must be after start date"
                                    change="onEndDateChange"
                                    liveChange="onEndDateChange"
                                    showValueStateMessage="true"
                                    placeholder="Select end date"
                                />
                                <Label text="Full Name" required="true"/>
                                <HBox width="100%" fitContainer="true" renderType="Bare" wrap="NoWrap" alignItems="Center">
                                    <layoutData>
                                        <l:GridData span="XL8 L8 M8 S12" />
                                    </layoutData>
                                    <Input 
                                        value="{HostelModel>/Salutation}" 
                                        editable="false">
                                        <layoutData>
                                            <FlexItemData growFactor="1" baseSize="1rem" />
                                        </layoutData>
                                    </Input>
                                <Input
                                    value="{HostelModel>/FullName}"
                                    id="BookFullname_Id"
                                    change="onChangeFullname"
                                    liveChange="onChangeFullname"
                                    valueStateText="Enter your full name (minimum 3 characters)"
                                    class="sapUiTinyMarginBegin"
                                    editable="false"
                                    placeholder="Enter your full name"
                                    showValueStateMessage="true">
                                    <layoutData>
                                        <FlexItemData growFactor="3" baseSize="0" />
                                    </layoutData>
                                </Input>
                                </HBox>
                                <Label
                                    text="Upload Document"
                                    visible="{= !!${HostelModel>/UserID} }"
                                />
                                <VBox
                                    visible="{= !!${HostelModel>/UserID} }"
                                >
                                    <layoutData>
                                        <l:GridData span="XL8 L8 M8 S12" />
                                    </layoutData>

                                    <HBox
                                        binding="{HostelModel>/Documents/0}"
                                        width="100%"
                                        fitContainer="true"
                                        wrap="{= ${device>/system/phone} ? 'Wrap' : 'NoWrap'}"
                                        alignItems="Center"
                                    >
                                        <core:Icon
                                            id="bookingDocumentInfoIcon"
                                            src="sap-icon://hint"
                                            size="1rem"
                                            color="#0064d1"
                                            hoverColor="DarkBlue"
                                            press="onDocumentInfoPress"
                                            tooltip="Upload info"
                                            class="sapUiTinyMarginEnd"
                                        />

                                        <ComboBox
                                            selectedKey="{HostelModel>DocumentType}"
                                            width="{= ${device>/system/phone} ? '100%' : '12rem'}"
                                            enabled="{= !${HostelModel>FileName} }"
                                            placeholder="Select document"
                                            items="{BookingView>/DocumentTypeOptions}"
                                            class="sapUiTinyMarginEnd"
                                        >
                                            <core:Item
                                                key="{BookingView>key}"
                                                text="{BookingView>text}"
                                            />
                                        </ComboBox>

                                        <HBox
                                            alignItems="Center"
                                        >
                                            <unified:FileUploader
                                                width="{= ${device>/system/phone} ? '100%' : '8rem'}"
                                                visible="{= !${HostelModel>FileName} }"
                                                enabled="{= !!${HostelModel>DocumentType} }"
                                                buttonOnly="true"
                                                maximumFileSize="2"
                                                sameFilenameAllowed="true"
                                                change="onCustomerDocumentChange"
                                                typeMissmatch="onDocumentUploadTypeMismatch"
                                                fileSizeExceed="onDocumentUploadSizeExceed"
                                                buttonText="Upload"
                                                fileType="pdf,jpg,jpeg,png,webp"
                                                class="sapUiTinyMarginEnd myUnifiedBtn"
                                            />

                                            <HBox
                                                visible="{= !!${HostelModel>FileName} }"
                                                wrap="{= ${device>/system/phone} ? 'Wrap' : 'NoWrap'}"
                                                alignItems="Center"
                                            >
                                                <Link
                                                    text="{path: 'HostelModel>FileName', formatter: '.formatDocumentFileName'}"
                                                    tooltip="{HostelModel>FileName}"
                                                    press="onPreviewCustomerDocument"
                                                    width="10rem"
                                                    class="automatedEllipsis"
                                                />
                                                <Button
                                                    text="Remove"
                                                    type="Transparent"
                                                    icon="sap-icon://delete"
                                                    press="onDeleteCustomerDocumentRow"
                                                    class="sapUiTinyMarginBegin myUnifiedBtn"
                                                />
                                            </HBox>
                                        </HBox>
                                    </HBox>
                                </VBox>
                            </f:SimpleForm>
                        </Panel>

<!-- Guest Information Section -->
<Title
    text="Manage Members"
    class="booking-section-header"
    wrapping="true"
    visible="{BookingView>/showFamilySection}"
/>

                        <Panel
                            class="customBookingPanel booking-panel-enhanced"
                            visible="{BookingView>/showFamilySection}"
                        >
                            <VBox class="sapUiTinyMargin">
                                <HBox justifyContent="End" class="sapUiTinyMarginBottom">
                                    <Button
                                        text="Add Member"
                                        icon="sap-icon://add"
                                        press="onAddFamilyMember"
                                        class="myUnifiedBtn"
                                    />
                                </HBox>
                            </VBox>

                            <!-- Responsive Table for Members -->
                            <Table
                                items="{BookingView>/FamilyMembers}"
                                noDataText="No members found"
                                class="responsiveTable"
                            >
                                <columns>
                                    <Column width="5rem">
                                        <Text text="Pick" />
                                    </Column>
                                    <Column>
                                        <Text text="Name" />
                                    </Column>
                                    <Column
                                        minScreenWidth="Tablet"
                                        demandPopin="true"
                                    >
                                        <Text text="Relation" />
                                    </Column>
                                    <Column
                                        minScreenWidth="Tablet"
                                        demandPopin="true"
                                    >
                                        <Text text="Age" />
                                    </Column>
                                    <Column
                                        minScreenWidth="Tablet"
                                        demandPopin="true"
                                    >
                                        <Text text="Gender" />
                                    </Column>
                                    <Column
                                        minScreenWidth="Tablet"
                                        demandPopin="true"
                                    >
                                        <Text text="Document Type" />
                                    </Column>
                                    <Column
                                        minScreenWidth="Desktop"
                                        demandPopin="true"
                                        width="14rem"
                                    >
                                        <Text text="Document" />
                                    </Column>
                                    <Column width="8rem">
                                        <Text text="Action" />
                                    </Column>
                                </columns>

                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <CheckBox
                                                selected="{BookingView>Selected}"
                                                select="onFamilyMemberSelect"
                                                enabled="{= !${BookingView>IsNew} }"
                                            />

                                            <VBox>
                                                <Input
                                                    value="{BookingView>Name}"
                                                    visible="{BookingView>IsNew}"
                                                    placeholder="Enter name"
                                                    width="100%"
                                                />
                                                <Text
                                                    text="{BookingView>Name}"
                                                    visible="{= !${BookingView>IsNew} }"
                                                />
                                            </VBox>

                                            <VBox>
                                                <Input
                                                    value="{BookingView>Relation}"
                                                    visible="{BookingView>IsNew}"
                                                    placeholder="Enter relation"
                                                    width="100%"
                                                />
                                                <Text
                                                    text="{BookingView>Relation}"
                                                    visible="{= !${BookingView>IsNew} }"
                                                />
                                            </VBox>

                                            <VBox>
                                                <Input
                                                    value="{BookingView>Age}"
                                                    type="Number"
                                                    visible="{BookingView>IsNew}"
                                                    placeholder="Enter age"
                                                    width="100%"
                                                />
                                                <Text
                                                    text="{BookingView>Age}"
                                                    visible="{= !${BookingView>IsNew} }"
                                                />
                                            </VBox>

                                            <VBox>
                                                <Select
                                                    selectedKey="{BookingView>Gender}"
                                                    visible="{BookingView>IsNew}"
                                                    width="100%"
                                                    items="{BookingView>/GenderOptions}"
                                                >
                                                    <core:Item
                                                        key="{BookingView>key}"
                                                        text="{BookingView>text}"
                                                    />
                                                </Select>
                                                <Text
                                                    text="{BookingView>Gender}"
                                                    visible="{= !${BookingView>IsNew} }"
                                                />
                                            </VBox>

                                            <VBox>
                                                <Select
                                                    selectedKey="{BookingView>DocumentType}"
                                                    visible="{BookingView>IsNew}"
                                                    width="100%"
                                                    items="{BookingView>/DocumentTypeOptions}"
                                                >
                                                    <core:Item
                                                        key="{BookingView>key}"
                                                        text="{BookingView>text}"
                                                    />
                                                </Select>
                                                <Text
                                                    text="{BookingView>DocumentType}"
                                                    visible="{= !${BookingView>IsNew} }"
                                                />
                                            </VBox>

                                            <VBox>
                                                <unified:FileUploader
                                                    width="100%"
                                                    visible="{BookingView>IsNew}"
                                                    maximumFileSize="2"
                                                    sameFilenameAllowed="true"
                                                    change="onFamilyDocumentChange"
                                                    typeMissmatch="onDocumentUploadTypeMismatch"
                                                    fileSizeExceed="onDocumentUploadSizeExceed"
                                                    buttonText="Upload"
                                                    fileType="pdf,jpg,jpeg,png"
                                                    class="myUnifiedBtn"

                                                />
                                                <Text
                                                    text="{BookingView>DocumentName}"
                                                    visible="{= !${BookingView>IsNew} }"
                                                />
                                            </VBox>

                                            <HBox
                                                renderType="Bare"
                                                justifyContent="Start"
                                                class="responsiveActionButtons"
                                            >
                                                <Button
                                                    text="Add"
                                                    visible="{BookingView>IsNew}"
                                                    press="onSaveFamilyMember"
                                                    class="sapUiTinyMarginEnd myUnifiedBtn"
                                                />
                                                <Button
                                                    text="Delete"
                                                    visible="{BookingView>IsNew}"
                                                    press="onDeleteFamilyMemberRow"
                                                    class="myUnifiedBtn"
                                                />
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </Panel>

<!-- Facilities Section -->
<Title
    text="Facilities"
    class="booking-section-header"
    wrapping="true"
/>

                        <Panel
                            class="customBookingPanel booking-panel-enhanced"
                        >
                            <VBox class="sapUiTinyMargin">
                                <MessageStrip
                                    text="Add only the facilities you need. Person-wise quantity facilities also let you choose whether they apply once for the booking or daily."
                                    type="Information"
                                    showIcon="true"
                                    showCloseButton="false"
                                    class="sapUiTinyMarginBottom facilityMessageStrip"
                                />

                                <HBox
                                    width="100%"
                                    alignItems="Center"
                                    justifyContent="SpaceBetween"
                                    class="facilitiesNavContainer"
                                >
                                    <Button
                                        icon="sap-icon://slim-arrow-left"
                                        type="Transparent"
                                        press="onFacilityPrev"
                                        class="facilityNavBtn sapUiTinyMarginEnd myUnifiedBtn"
                                    />

                                    <HBox
                                        id="facilityViewport"
                                        width="100%"
                                        renderType="Bare"
                                        class="facilityViewport"
                                    >
                                        <HBox
                                            id="facilityCardsContainer"
                                            renderType="Bare"
                                            class="facilityTrack"
                                        />
                                    </HBox>

                                    <Button
                                        icon="sap-icon://slim-arrow-right"
                                        type="Transparent"
                                        press="onFacilityNext"
                                        class="facilityNavBtn sapUiTinyMarginBegin myUnifiedBtn"
                                    />
                                </HBox>
                            </VBox>
                        </Panel>
                    </VBox>

                    <!-- Right Column - Takes full width on mobile, 35% on tablet/desktop -->
                    <VBox
                        width="{= ${device>/system/phone} ? '100%' : '35%'}"
                        class="sapUiLargeMarginBegin sapUiTinyMarginEnd"
                    >
<!-- Coupon Section -->
<Title
    text="Have a Coupon?"
    class="booking-section-header"
    wrapping="true"
/>

                        <Panel
                            class="customBookingPanel booking-panel-enhanced"
                        >
                            <HBox class="sapUiTinyMarginTop couponContainer" alignItems="Center">
                                <Input
                                    value="{HostelModel>/CouponCode}"
                                    placeholder="Enter coupon code"
                                    liveChange="onCouponLiveChange"
                                    class="sapUiSmallMarginEnd couponInput"
                                    width="100%"
                                >
                                    <layoutData>
                                        <FlexItemData growFactor="1" />
                                    </layoutData>
                                </Input>
                                <Button
                                    text="Apply Coupon"
                                    press="onApplyCoupon"
                                    class="myUnifiedBtn couponButton"
                                    visible="{= !${HostelModel>/AppliedCouponCode} }"
                                />
                                <Button
                                    text="Remove"
                                    press="onRemoveCoupon"
                                    class="myUnifiedBtn couponButton"
                                    visible="{= !!${HostelModel>/AppliedCouponCode} }"
                                />
                            </HBox>
                        </Panel>

<!-- Payment Summary Section -->
<Title
    text="Pricing Details"
    class="booking-section-header"
    wrapping="true"
/>

                        <Panel
                            class="customBookingPanel booking-panel-enhanced"
                        >
                            <VBox class="sapUiTinyMargin">
                                <HBox
                                    justifyContent="SpaceBetween"
                                    alignItems="Center"
                                    visible="{BookingView>/showBusinessTravelOption}"
                                    class="sapUiTinyMarginBottom"
                                >
                                    <Text text="GST Details(optional)" />
                                    <Switch
                                        state="{HostelModel>/IsBusinessTravel}"
                                        change="onBusinessTravelToggle"
                                        enabled="{BookingView>/showBusinessTravelOption}"
                                    />
                                </HBox>
                                <Label
                                required="true"
                                    text="GSTIN"
                                    visible="{BookingView>/showBusinessGSTSection}"
                                />
                                <Input
                                    id="BookGst_ID"
                                    value="{HostelModel>/CustomerGSTIN}"
                                    placeholder="Enter GSTIN"
                                    visible="{BookingView>/showBusinessGSTSection}"
                                    liveChange="onGSTINLiveChange"
                                    change="onGSTINChange"
                                    class="sapUiTinyMarginBottom"
                                    valueStateText="{i18n>gstError}"
                                    width="100%"
                                />
                                <Label
                                required="true"
                                    text="Company Name"
                                    visible="{BookingView>/showBusinessGSTSection}"
                                    class="required-field-label"
                                />
                                <Input
                                id="BookCompanyname_ID"
                                    value="{HostelModel>/CompanyName}"
                                    placeholder="Enter company name (minimum 3 characters)"
                                    visible="{BookingView>/showBusinessGSTSection}"
                                    class="sapUiTinyMarginBottom"
                                    width="100%"
                                    change="onchangeCompanyname"
                                    liveChange="onchangeCompanyname"
                                    valueStateText="Please enter a valid company name"
                                    showValueStateMessage="true"
                                    maxLength="100"
                                />
                                <Label
                                required="true"
                                    text="Company Address"
                                    visible="{BookingView>/showBusinessGSTSection}"
                                    class="required-field-label"
                                />
                                <TextArea
                                    value="{HostelModel>/CompanyAddress}"
                                    placeholder="Enter complete company address"
                                    visible="{BookingView>/showBusinessGSTSection}"
                                    rows="3"
                                    class="sapUiTinyMarginBottom"
                                    width="100%"
                                    change="onchangeConpanyAddress"
                                    liveChange="onchangeConpanyAddress"
                                    valueStateText="Please enter a valid company address (minimum 10 characters)"
                                    showValueStateMessage="true"
                                    id="BookconpanyAddress_ID"
                                    maxLength="500"
                                    growing="true"
                                    growingMaxLines="5"
                                />
                                <Text
                                    text="Room: {HostelModel>/RoomPrice} {HostelModel>/Currency}"
                                />
                                <Text
                                    text="{HostelModel>/RoomBreakdownText}"
                                    wrapping="true"
                                />
                                <Text
                                    text="Facilities: {HostelModel>/TotalFacilityPrice} {HostelModel>/Currency}"
                                />
                                <Text
                                    text="Sub Total: {HostelModel>/BookingSubTotal} {HostelModel>/Currency}"
                                />
                                <Text
                                    text="Property GSTIN: {HostelModel>/PropertyGSTIN}"
                                />
                                <Text
                                    text="Customer GSTIN: {HostelModel>/CustomerGSTIN}"
                                    visible="{= !!${HostelModel>/CustomerGSTIN}}"
                                />
                                <Text
                                    text="CGST: {HostelModel>/CGST} {HostelModel>/Currency}"
                                    visible="{= ${HostelModel>/CGST} > 0}"
                                />
                                <Text
                                    text="SGST: {HostelModel>/SGST} {HostelModel>/Currency}"
                                    visible="{= ${HostelModel>/SGST} > 0}"
                                />
                                <Text
                                    text="IGST: {HostelModel>/IGST} {HostelModel>/Currency}"
                                    visible="{= ${HostelModel>/IGST} > 0}"
                                />
                                <MessageStrip
                                    text="{= ${HostelModel>/EffectiveGSTType} ? 'Applied Tax: ' + ${HostelModel>/EffectiveGSTType} + ' (' + ${HostelModel>/EffectiveGSTValue} + '%)' : 'No GST applied'}"
                                    type="Information"
                                    showIcon="true"
                                    showCloseButton="false"
                                    class="sapUiTinyMarginBottom"
                                />
                                <MessageStrip
                                    text="{= 'Security Deposit (Collected Offline): ' + ${HostelModel>/Deposit} + ' ' + ${HostelModel>/DepositCurrency}}"
                                    type="Information"
                                    showIcon="true"
                                    showCloseButton="false"
                                    visible="{= ${HostelModel>/Deposit} > 0}"
                                />
                                <Title
                                    text="{= ${HostelModel>/AppliedCouponCode} ? 'Coupon (' + ${HostelModel>/AppliedCouponCode} + ') : -' + ${HostelModel>/AppliedDiscount} : 'Coupon : 0'}"
                                />
                                <Title
                                    text="Grand Total: {HostelModel>/GrandTotal} {HostelModel>/Currency}"
                                />
                            </VBox>
                        </Panel>
                    </VBox>
                </HBox>

<!-- Selected Facilities Summary Section -->
<Title
    text="Selected Facilities Summary"
    class="booking-section-header"
    wrapping="true"
/>

                <Panel
                    class="customBookingPanel booking-panel-enhanced"
                    width="98.5%"
                >
                    <Table
                        items="{HostelModel>/AllSelectedFacilities}"
                        noDataText="-- No facilities opted --"
                        autoPopinMode="true"
                        class="responsiveTable"
                    >
                        <columns>
                            <Column>
                                <Text text="Facility" />
                            </Column>
                            <Column
                                minScreenWidth="Tablet"
                                demandPopin="true"
                            >
<Text text="Rate / Unit" />

                            </Column>
                            <Column
                                minScreenWidth="Desktop"
                                demandPopin="true"
                                width="45%"
                            >
                                <Text
                                    text="Breakdown (Who &amp; Qty)"
                                />
                            </Column>
                            <Column hAlign="End">
                                <Text text="Total" />
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem vAlign="Top">
                                <cells>
                                    <Text
                                        text="{HostelModel>FacilityName}"
                                    />
                                    <Text
                                        text="{HostelModel>RateText}"
                                    />
                                    <Text
                                        text="{HostelModel>BreakdownText}"
                                        wrapping="true"
                                    />
                                    <Text
                                        text="{parts: [{path: 'HostelModel>TotalAmount'}, {path: 'HostelModel>Currency'}], formatter: '.formatFacilityTotal'}"
                                    />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>
            </VBox>
        </content>

        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Button
                    text="BOOK THIS NOW"
                    type="Emphasized"
                    class="myUnifiedBtn"
                    press="onContinueBooking"
                />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
