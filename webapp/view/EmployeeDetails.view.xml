<mvc:View
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:fb="sap.ui.comp.filterbar"
	controllerName="sap.kt.com.minihrsolution.controller.EmployeeDetails"
	height="100%">
	<Page >
		<headerContent>
	   <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
		</headerContent>
		<content>
			<fb:FilterBar  class="sapUiTinyMargin" id="ED_id_FilterBar" persistencyKey="myPersKey" useToolbar="false" showClearOnFB="true" search="Emp_det_onSearch" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad" clear="onClearEmployeeDetails" showFilterConfiguration="false" >	
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="EmployeeID" label="{i18n>employeeID}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox  showSecondaryValues= "true"  items="{FilterEmployeeDetails>/}" id="ED_id_EmpIDFilter" showClearIcon="true">
								<core:ListItem key="{FilterEmployeeDetails>EmployeeID}" text="{FilterEmployeeDetails>EmployeeID}" additionalText="{FilterEmployeeDetails>EmployeeName}" />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="ManagerName" label="{i18n>manager}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox showSecondaryValues= "true"  items="{EmployeeModel>/}" id="ED_id_ManagerFilter" showClearIcon="true">
								<core:ListItem key="{EmployeeModel>EmployeeID}" text="{EmployeeModel>EmployeeName}" additionalText="{EmployeeModel>EmployeeID}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>

				<fb:FilterGroupItem name="Status" label="{i18n>status}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox showSecondaryValues= "true"  items="{StatusEmp>/}" id="ED_id_Status" showClearIcon="true">
								<core:ListItem key="{StatusEmp>Value}" text="{StatusEmp>Value}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table id="ED_id_EmpDetailsTable" class="sapUiTinyMargin" items="{path:'sEmployeeDetails>/'}"  busyIndicatorDelay="0"  width="auto"
                   growingScrollToLoad="false" growing="true"  growingThreshold="50"  alternateRowColors="true">
				<headerToolbar>
					<OverflowToolbar >
						<Title id="ED_id_TitleTable" text="{i18n>headerEmpDetails} ({= ${sEmployeeDetails>/}.length})"/>
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column demandPopin="true">
						<Text text="{i18n>employeeID}"/>
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true" >
						<Text text="{i18n>employeeName}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>role}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>designation}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>dateOfBirth}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>email}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true" >
						<Text text="{i18n>manager}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>baseLocation}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="ED_onPressEmployeeRow">
						<cells>
							<Text text="{sEmployeeDetails>EmployeeID}"/>
							<Text text="{sEmployeeDetails>EmployeeName}"/>
							<Text text="{sEmployeeDetails>Role}"/>
							<Text text="{sEmployeeDetails>Designation}"/>
							<Text text="{path:'sEmployeeDetails>DateOfBirth',formatter: '.Formatter.formatDate'}"/>
							<Text text="{sEmployeeDetails>CompanyEmailID}"/>
						    <Text text="{= ${sEmployeeDetails>ManagerName} + '\n(' + ${sEmployeeDetails>ManagerID} + ')' }" />
							<Text text="{sEmployeeDetails>BaseLocation}"/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>	
		</content>
        	<footer>
			<Bar id="ED_id_FooterBar">
			    <contentLeft>
                    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
                </contentLeft>
            </Bar>
            </footer>
	</Page>
</mvc:View>