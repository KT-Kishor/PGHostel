<mvc:View
	controllerName="sap.kt.com.minihrsolution.controller.Payroll_Demo"
	xmlns:mvc="sap.ui.core.mvc"
  xmlns:m="sap.m"
    xmlns="sap.m"
   xmlns:core="sap.ui.core"
	displayBlock="true"
       xmlns:g="sap.f"
           xmlns:f="sap.ui.layout.form"
             xmlns:l="sap.ui.layout"
	height="100%"
	busyIndicatorDelay="0"
>
	<Page >
    	<headerContent>
			<Avatar src="./image/logo.jpg" displaySize="XS" press="onAvatarPressed" tooltip="Company Logo"/>
			<Title level="H1" text="{i18n>companynameKT}" class="custom-text" wrapping="false"/>
			<ToolbarSpacer/>
			<Button icon="sap-icon://home" press="onpresshome" class="sapUiTinyMarginEnd" tooltip="{i18n>toolHome}"/>
		</headerContent>
    <!-- Generate salary -->
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiSmallMarginTop">
            <m:Title text="{i18n>JobPosting}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>JobPosting_Par}" class="jioParagraph" />
        </m:VBox>

        <!-- Right Column -->
        <m:VBox id="videoBox1" alignItems="Center" justifyContent="Center" class="sapUiMediumMarginTop">
    <core:HTML id="videoFrameHtml1"
        content="&lt;iframe src='https://www.youtube.com/embed/XFCJNqHHfQQ?si=1IxhnYYx_xS-Wk1M' allowfullscreen style='width:560px;height:315px;border:none;'&gt;&lt;/iframe&gt;" />

</m:VBox>
<!-- Header PaySlip -->
    </g:GridContainer>
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Right Column -->
        <m:VBox alignItems="Center" id="videoBox2" justifyContent="Center" class="sapUiMediumMarginTop">
            <core:HTML id="videoFrameHtml2"
                    content="&lt;iframe src='https://www.youtube.com/embed/XFCJNqHHfQQ?si=1IxhnYYx_xS-Wk1M' allowfullscreen style='width:560px;height:315px;border:none;'&gt;&lt;/iframe&gt;"
                />
        </m:VBox>

        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiMediumMarginTop">
            <m:Title text="{i18n>Applyjob}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>Applyjob_Par}" class="jioParagraph" />
        </m:VBox>
    </g:GridContainer>
    <!-- offer Letter -->
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiMediumMarginTop">
            <m:Title text="{i18n>Interviews}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>Interviews_Par}" class="jioParagraph" />
        </m:VBox>

        <!-- Right Column -->
        <m:VBox alignItems="Center" id="videoBox3" justifyContent="Center" class="sapUiMediumMarginTop">
              <core:HTML id="videoFrameHtml3"
                     content="&lt;iframe src='https://www.youtube.com/embed/-hU_lFn92-4' allowfullscreen style='width:560px;height:315px;border:none;'&gt;&lt;/iframe&gt;"
                />
        </m:VBox>
    </g:GridContainer>
    <!-- Self Service -->
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Right Column -->
        <m:VBox alignItems="Center" id="videoBox4" justifyContent="Center" class="sapUiMediumMarginTop">
             <core:HTML id="videoFrameHtml4"
                    content="&lt;iframe src='https://www.youtube.com/embed/-hU_lFn92-4' allowfullscreen style='width:560px;height:315px;border:none;'&gt;&lt;/iframe&gt;"
                />
        </m:VBox>

        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiMediumMarginTop">
            <m:Title text="{i18n>Backgroundver}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>Backgroundver_Par}" class="jioParagraph" />
        </m:VBox>
    </g:GridContainer>
    <!-- Employee Details -->
     <m:Button
            text="Request Demo"
            press="onOpenForm"
            class="demoBtn"
        />
 </Page>
 
   <!-- <l:Grid defaultSpan="L12 M12 S12"  vSpacing="2" hSpacing="2" class="sapUiTinyMargin">
        <l:content>
            <m:Carousel id="videoCarousel" showPageIndicator="false" loop="true" class="allvideo"/>
         </l:content>
     </l:Grid> -->
   
       
</mvc:View>
