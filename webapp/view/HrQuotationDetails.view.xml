<mvc:View
    controllerName="sap.kt.com.minihrsolution.controller.HrQuotationDetails"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.uxap"
    xmlns:core="sap.ui.core"
    xmlns:m="sap.m"
    xmlns:rich="sap.ui.richtexteditor"
>
    <m:Page
        title="{i18n>generateQuotationDetails}"
        navButtonPress="HQD_onBack"
        showNavButton="true"
    >
        <ObjectPageLayout
            id="HQD_id_QuotationDetailsPage"
            enableLazyLoading="true"
            useIconTabBar="false"
        >
            <sections>
                <ObjectPageSection
                    id="HQD_id_Section"
                    titleUppercase="false"
                >
                    <subSections>
                        <ObjectPageSubSection
                            titleUppercase="false"
                            title="{i18n>from}"
                        >
                            <blocks>
                                <f:SimpleForm
                                    editable="true"
                                    layout="ColumnLayout"
                                    labelSpanXL="4"
                                    labelSpanL="3"
                                    labelSpanM="4"
                                    labelSpanS="12"
                                    columnsXL="2"
                                    columnsL="2"
                                    columnsM="1"
                                >
                                    <f:content>
                                        <m:Label text="{i18n>quotationNo}" />
                                        <m:Input
                                            id="HQD_id_QuotationNoFilter"
                                            value="{QuotationModel>/QuotationNo}"
                                            editable="false"
                                        />
                                        <m:Label
                                            text="{i18n>date}"
                                            required="true"
                                        />
                                        <m:DatePicker
                                            displayFormat="dd/MM/yyyy"
                                            valueFormat="dd/MM/yyyy"
                                            change="HQD_DateValidate"
                                            valueStateText="{i18n>invalidDate}"
                                            value="{QuotationModel>/Date}"
                                            editable="{visiablityPlay>/editable}"
                                            id="HQD_id_Quotation"
                                        />
                                        <m:Label
                                            text="{i18n>validUntil}"
                                            required="true"
                                        />
                                        <m:DatePicker
                                            displayFormat="dd/MM/yyyy"
                                            valueFormat="dd/MM/yyyy"
                                            change="HQD_LastDate"
                                            valueStateText="{i18n>invalidDate}"
                                            value="{QuotationModel>/ValidUntil}"
                                            editable="{visiablityPlay>/editable}"
                                            id="HQD_id_QuotationValid"
                                        />
                                        <m:Label
                                            text="{i18n>compName}"
                                            required="true"
                                        />
                                        <m:Input
                                            value="{QuotationModel>/CompanyName}"
                                            id="HQD_id_InputCompanyName"
                                            liveChange="HQD_onNameLiveChange"
                                            valueStateText="{i18n>placeName}"
                                            editable="{visiablityPlay>/editable}"
                                            maxLength="50"
                                        />
                                        <m:Label
                                            text="{i18n>companyMobileNo}"
                                            required="true"
                                        />
                                        <m:Input
                                            value="{QuotationModel>/CompanyMobileNo}"
                                            id="HQD_id_InputCompanyMobileNo"
                                            liveChange="HQD_onMNumberLiveChange"
                                            editable="{visiablityPlay>/editable}"
                                            maxLength="10"
                                            valueStateText="{i18n>mobileNoValueState}"
                                        />
                                        <m:Label
                                            text="{i18n>emailID}"
                                            required="true"
                                        />
                                        <m:Input
                                            value="{QuotationModel>/CompanyEmailID}"
                                            id="HQD_id_CompanyEmailID"
                                            liveChange="HQD_EmailIDLiveChange"
                                            editable="{visiablityPlay>/editable}"
                                            valueStateText="{i18n>emailValueState}"
                                            maxLength="100"
                                        />
                                        <m:Label
                                            text="{i18n>companyAddress}"
                                            required="true"
                                        />
                                        <m:TextArea
                                            value="{QuotationModel>/CompanyAddress}"
                                            id="HQD_id_InputCompanyAddress"
                                            liveChange="HQD_onAddressLiveChange"
                                            rows="2"
                                            valueStateText="{i18n>addressValueState}"
                                            maxLength="120"
                                            editable="{visiablityPlay>/editable}"
                                        />
                                        <m:Label text="{i18n>companyGSTNO}" />
                                        <m:Input
                                            value="{QuotationModel>/CompanyGSTNO}"
                                            id="HQD_id_CompGSTNO"
                                            liveChange="HQD_onComGSTLiveChange"
                                            valueStateText="{i18n>gstNoValueState}"
                                            change="HQD_onChangeGstNo"
                                            editable="{visiablityPlay>/editable}"
                                            maxLength="20"
                                        />
                                        <m:Label
                                            text="{i18n>type}"
                                            required="{QuotationModel>/GSTValid}"
                                        />
                                        <m:CheckBox
                                            text="{i18n>cgst}"
                                            id="HQD_id_CheckboxCGS"
                                            selected="{QuotationModel>/CGSTSelected}"
                                            select="onSelectCGST"
                                            editable="{QuotationModel>/GSTValid}"
                                        />
                                        <m:CheckBox
                                            text="{i18n>igst}"
                                            id="HQD_id_CheckboxIGS"
                                            selected="{QuotationModel>/IGSTSelected}"
                                            select="onSelectIGST"
                                            editable="{QuotationModel>/GSTValid}"
                                        />
                                        <m:Label
                                            text="{i18n>percentage}"
                                            required="{QuotationModel>/GSTValid}"
                                        />
                                        <m:Input
                                            value="{QuotationModel>/Percentage}"
                                            liveChange="HQD_onPercentageChange"
                                            editable="{QuotationModel>/GSTValid}"
                                            maxLength="10"
                                        />
                                        <m:Label
                                            text="{i18n>currency}"
                                            required="true"
                                        />
                                        <m:Select
                                            items="{currencyModel>/results}"
                                            selectedKey="{QuotationModel>/Currency}"
                                            width="100%"
                                            editable="{visiablityPlay>/editable}"
                                            id="HQD_id_Curency"
                                            change="HQD_onCurrencyChange"
                                        >
                                            <core:Item
                                                key="{currencyModel>Currency}"
                                                text="{currencyModel>Currency}"
                                            />
                                        </m:Select>
                                    </f:content>
                                </f:SimpleForm>
                            </blocks>
                        </ObjectPageSubSection>
                        <ObjectPageSubSection
                            titleUppercase="false"
                            title="{i18n>billTo}"
                        >
                            <blocks>
                                <f:SimpleForm
                                    editable="true"
                                    layout="ColumnLayout"
                                    labelSpanXL="4"
                                    labelSpanL="3"
                                    labelSpanM="4"
                                    labelSpanS="12"
                                    columnsXL="2"
                                    columnsL="2"
                                    columnsM="1"
                                >
                                    <f:content>
                                        <m:Label
                                            text="{i18n>customerName}"
                                            required="true"
                                        />
                                        <m:Input
                                            value="{QuotationModel>/CustomerName}"
                                            id="HQD_id_CustomerName"
                                            liveChange="HQD_onCustomerNameLiveChange"
                                            editable="{visiablityPlay>/editable}"
                                            maxLength="100"
                                        />
                                        <m:Label
                                            text="{i18n>emailID}"
                                            required="true"
                                        />
                                        <m:Input
                                            value="{QuotationModel>/CustomerEmailID}"
                                            id="HQD_id_CustomerEmailID"
                                            liveChange="HQD_EmailIDLiveChange"
                                            editable="{visiablityPlay>/editable}"
                                            maxLength="100"
                                        />
                                        <m:Label
                                            text="{i18n>customerMobileNo}"
                                            required="true"
                                        />
                                        <m:Input
                                            value="{QuotationModel>/CustomerMobileNo}"
                                            id="HQD_id_InputCustomerMobileNo"
                                            liveChange="HQD_onMNumberLiveChange"
                                            editable="{visiablityPlay>/editable}"
                                            maxLength="10"
                                        />
                                        <m:Label
                                            text="{i18n>customerAddress}"
                                            required="true"
                                        />
                                        <m:TextArea
                                            value="{QuotationModel>/CustomerAddress}"
                                            maxLength="120"
                                            id="HQD_id_InputCustomerAddress"
                                            liveChange="HQD_onAddressLiveChange"
                                            rows="2"
                                            editable="{visiablityPlay>/editable}"
                                        />
                                        <m:Label text="{i18n>customerGSTNO}" />
                                        <m:Input
                                            value="{QuotationModel>/CustomerGSTNO}"
                                            id="HQD_id_InputCustomerGSTNO"
                                            liveChange="HQD_onPressLiveChange"
                                            editable="{visiablityPlay>/editable}"
                                            maxLength="20"
                                        />
                                    </f:content>
                                </f:SimpleForm>
                            </blocks>
                        </ObjectPageSubSection>
                        <ObjectPageSubSection
                            titleUppercase="false"
                            title="{i18n>quotationItemDetails}"
                        >
                            <blocks>
                                <m:VBox>
                                    <m:Table
                                        id="HQD_id_SmartTableQuotationItem"
                                        alternateRowColors="true"
                                        busyIndicatorDelay="0"
                                        class="sapUiResponsiveMargin"
                                        width="auto"
                                        delete="HQD_onPressDelete"
                                        mode="Delete"
                                        items="{QuotationModel>/QuotationItemModel}"
                                    >
                                        <m:headerToolbar>
                                            <m:OverflowToolbar>
                                                <m:Title
                                                    text="{i18n>itemDetails}"
                                                />
                                                <m:ToolbarSpacer />
                                                <m:Button
                                                    visible="{visiablityPlay>/invBtn}"
                                                    icon="sap-icon://add"
                                                    tooltip="{i18n>addItem}"
                                                    press="HQD_onPressAddQuotationItem"
                                                    type="Emphasized"
                                                />
                                                <m:ToolbarSeparator />
                                            </m:OverflowToolbar>
                                        </m:headerToolbar>
                                            <m:columns>
                                                <m:Column width="100px">
                                                    <m:customData>
                                                        <core:CustomData
                                                            key="p13nData"
                                                            value='{"columnKey": "SNo", "leadingProperty": "SNo", "sortProperty": "SNo", "filterProperty": "SNo", "columnIndex": 1}'
                                                        />
                                                    </m:customData>
                                                    <m:Text
                                                        text="{i18n>siNo}"
                                                    />
                                                </m:Column>
                                                <m:Column width="300px">
                                                    <m:customData>
                                                        <core:CustomData
                                                            key="p13nData"
                                                            value='{"columnKey": "Item", "leadingProperty": "Item", "sortProperty": "Item", "filterProperty": "Item", "columnIndex": 2}'
                                                        />
                                                    </m:customData>
                                                    <m:Text
                                                        text="{i18n>item}"
                                                    />
                                                </m:Column>
                                                <m:Column id="HQD_id_SAC">
                                                    <m:customData>
                                                        <core:CustomData
                                                            key="p13nData"
                                                            value='{"columnKey": "SAC", "leadingProperty": "SAC", "sortProperty": "SAC", "filterProperty": "SAC", "columnIndex": 3 }'
                                                        />
                                                    </m:customData>
                                                    <m:Text text="{i18n>SAC}" />
                                                </m:Column>
                                                <m:Column
                                                    id="HQD_id_GSTCalculaton"
                                                >
                                                    <m:customData>
                                                        <core:CustomData
                                                            key="p13nData"
                                                            value='\{"columnKey": "GSTCalculation", "leadingProperty": "GSTCalculation", "sortProperty": "GSTCalculation", "filterProperty": "GSTCalculation", "columnIndex": 4}'
                                                        />
                                                    </m:customData>
                                                    <m:Text
                                                        text="{i18n>GSTCalculation}"
                                                    />
                                                </m:Column>
                                                <m:Column>
                                                    <m:customData>
                                                        <core:CustomData
                                                            key="p13nData"
                                                            value='{"columnKey": "Days", "leadingProperty": "Days", "sortProperty": "Days", "filterProperty": "Days", "columnIndex": 5}'
                                                        />
                                                    </m:customData>
                                                    <m:Text
                                                        text="{i18n>days}"
                                                    />
                                                </m:Column>
                                                <m:Column>
                                                    <m:customData>
                                                        <core:CustomData
                                                            key="p13nData"
                                                            value='{"columnKey": "UnitPrice", "leadingProperty": "UnitPrice", "sortProperty": "UnitPrice", "filterProperty": "UnitPrice", "columnIndex": 6}'
                                                        />
                                                    </m:customData>
                                                    <m:Text
                                                        text="{i18n>unitPrice}"
                                                    />
                                                </m:Column>
                                                <m:Column>
                                                    <m:customData>
                                                        <core:CustomData
                                                            key="p13nData"
                                                            value='\{"columnKey": "Discount", "leadingProperty": "Discount", "sortProperty": "Discount", "filterProperty": "Discount", "columnIndex": 7}'
                                                        />
                                                    </m:customData>
                                                    <m:Text
                                                        text="{i18n>discount}"
                                                    />
                                                </m:Column>
                                                <m:Column>
                                                    <m:customData>
                                                        <core:CustomData
                                                            key="p13nData"
                                                            value='{"columnKey": "Total", "leadingProperty": "Total", "sortProperty": "Total", "filterProperty": "Total", "columnIndex": 8}'
                                                        />
                                                    </m:customData>
                                                    <m:Text
                                                        text="{i18n>total}"
                                                    />
                                                </m:Column>
                                            </m:columns>
                                            <m:items>
                                                <m:ColumnListItem>
                                                    <m:cells>
                                                        <m:Input
                                                            value="{IndexNo}"
                                                            editable="false"
                                                        />
                                                    </m:cells>
                                                    <m:VBox>
                                                        <m:items>
                                                            <m:Input
                                                                value="{Item}"
                                                                placeholder="Item Description"
                                                                editable="{visiablityPlay>/editable}"
                                                                maxLength="40"
                                                            />
                                                            <m:Input
                                                                value="{Description}"
                                                                placeholder="Additional details"
                                                                editable="{visiablityPlay>/editable}"
                                                                maxLength="40"
                                                            />
                                                        </m:items>
                                                    </m:VBox>
                                                    <m:cells>
                                                        <m:ComboBox
                                                            showSecondaryValues="true"
                                                            items="{InvoiceSACModel>/results}"
                                                            value="{SAC}"
                                                            editable="{QuotationModel>/GSTValid}"
                                                            selectedKey="1"
                                                        >
                                                            <core:ListItem
                                                                key="{InvoiceSACModel>ID}"
                                                                additionalText="{InvoiceSACModel>Description}"
                                                                text="{InvoiceSACModel>SAC}"
                                                            />
                                                        </m:ComboBox>
                                                    </m:cells>
                                                    <m:cells>
                                                        <m:ComboBox
                                                            value="{GSTCalculation}"
                                                            selectedKey="1"
                                                            editable="{QuotationModel>/GSTValid}"
                                                            change="HQD_onChangeGSTCalculation"
                                                        >
                                                            <core:Item
                                                                key="{i18n>yes}"
                                                                text="{i18n>yes}"
                                                            />
                                                            <core:Item
                                                                key="{i18n>no}"
                                                                text="{i18n>no}"
                                                            />
                                                        </m:ComboBox>
                                                    </m:cells>
                                                    <m:cells>
                                                        <m:Input
                                                            value="{Days}"
                                                            editable="{visiablityPlay>/editable}"
                                                            change="HQD_onInputChange"
                                                            type="Number"
                                                            maxLength="20"
                                                            textAlign="End"
                                                        />
                                                    </m:cells>
                                                    <m:cells>
                                                        <m:Input
                                                            value="{UnitPrice}"
                                                            editable="{visiablityPlay>/editable}"
                                                            change="HQD_onInputChange"
                                                            type="Number"
                                                            maxLength="20"
                                                            textAlign="End"
                                                        />
                                                    </m:cells>
                                                    <m:cells>
                                                        <m:Input
                                                            value="{Discount}"
                                                            editable="{visiablityPlay>/editable}"
                                                            liveChange="HQD_onchangeDiscount"
                                                            maxLength="20"
                                                            textAlign="End"
                                                        />
                                                    </m:cells>
                                                    <m:cells>
                                                        <m:Input
                                                            value="{path:'Total',formatter: '.Formatter.numberFormater'}"
                                                            editable="false"
                                                            textAlign="End"
                                                        />
                                                    </m:cells>
                                                </m:ColumnListItem>
                                            </m:items>
                                        </m:Table>
                                    <m:FlexBox
                                        class="custom-flexbox"
                                        direction="Column"
                                    >
                                        <m:VBox class="custom-vbox">
                                            <!-- Sub Total(Non-Taxable) -->
                                            <m:HBox
                                                justifyContent="SpaceBetween"
                                            >
                                                <m:Label
                                                    text="{i18n>subTotal} ({i18n>NonTaxable}) ({QuotationModel>/Currency}) :"
                                                    class="boldBlackText sapUiTinyMarginBottom rightAlignLabel"
                                                    visible="{= ${QuotationItemModel>/TotalSum} > 0}"
                                                />
                                                <m:Text
                                                    text="{path:'QuotationItemModel>/SubTotalNotGST',formatter: '.Formatter.numberFormater'}"
                                                    id="id_Subtot"
                                                    class="amountText"
                                                    textAlign="End"
                                                    visible="{= ${QuotationItemModel>/TotalSum} > 0}"
                                                />
                                            </m:HBox>
                                            <!-- Sub Total(Taxable) -->
                                            <m:HBox
                                                justifyContent="SpaceBetween"
                                                visible="{= ${QuotationItemModel>/SubTotal} > 0  }"
                                            >
                                                <m:Label
                                                    text="{i18n>subTotal} ({i18n>Taxable}) ({QuotationModel>/Currency}) :"
                                                    class="boldBlackText sapUiTinyMarginBottom rightAlignLabel"
                                                />
                                                <m:Text
                                                    text="{path:'QuotationItemModel>/SubTotal',formatter: '.Formatter.numberFormater'}"
                                                    id="HQD_id_Sub"
                                                    class="amountText"
                                                    textAlign="End"
                                                />
                                            </m:HBox>
                                            <!-- CGST -->
                                            <m:HBox
                                                justifyContent="SpaceBetween"
                                            >
                                                <m:Label
                                                    text="{= 'CGST ( ' + (${QuotationItemModel>/CGSTPercentage} || ${QuotationModel>/Percentage}) + ' % ) : '}"
                                                    visible="{= ${QuotationItemModel>/CGSTVisible} === true || ${QuotationModel>/CGSTVisible} === true}"
                                                    class="boldBlackText sapUiTinyMarginBottom rightAlignLabel"
                                                />
                                                <m:Text
                                                    text="{path:'QuotationItemModel>/CGST',formatter: '.Formatter.numberFormater'}"
                                                    class="amountText"
                                                    textAlign="End"
                                                    visible="{= ${QuotationItemModel>/CGSTVisible} === true || ${QuotationModel>/CGSTVisible} === true}"
                                                />
                                            </m:HBox>
                                            <!-- SGST -->
                                            <m:HBox
                                                justifyContent="SpaceBetween"
                                            >
                                                <m:Label
                                                    text="{= 'SGST ( ' + (${QuotationItemModel>/SGSTPercentage} || ${QuotationModel>/Percentage}) + ' % ) : '}"
                                                    visible="{= ${QuotationItemModel>/SGSTVisible} === true || ${QuotationModel>/SGSTVisible} === true}"
                                                    class="boldBlackText sapUiTinyMarginBottom rightAlignLabel"
                                                />
                                                <m:Text
                                                    text="{path:'QuotationItemModel>/SGST',formatter: '.Formatter.numberFormater'}"
                                                    class="amountText"
                                                    textAlign="End"
                                                    visible="{= ${QuotationItemModel>/SGSTVisible} === true || ${QuotationModel>/SGSTVisible} === true}"
                                                />
                                            </m:HBox>
                                            <!-- IGST -->
                                            <m:HBox
                                                justifyContent="SpaceBetween"
                                            >
                                                <m:Label
                                                    text="{= 'IGST ( ' + (${QuotationItemModel>/IGSTPercentage} || ${QuotationModel>/Percentage}) + ' % ) : '}"
                                                    visible="{= ${QuotationItemModel>/IGSTVisible} === true || ${QuotationModel>/IGSTVisible} === true}"
                                                    class="boldBlackText sapUiTinyMarginBottom rightAlignLabel"
                                                />
                                                <m:Text
                                                    text="{path:'QuotationItemModel>/IGST',formatter: '.Formatter.numberFormater'}"
                                                    class="amountText"
                                                    textAlign="End"
                                                    visible="{= ${QuotationItemModel>/IGSTVisible} === true || ${QuotationModel>/IGSTVisible} === true}"
                                                />
                                            </m:HBox>
                                            <!-- Total -->
                                            <m:HBox
                                                justifyContent="SpaceBetween"
                                            >
                                                <m:Label
                                                    text="{= ${i18n>total} + ' ( ' + ${QuotationModel>/Currency} + ' ) : '}"
                                                    class="boldBlackText sapUiTinyMarginBottom rightAlignLabel"
                                                    visible="{= ${QuotationItemModel>/TotalSum} > 0}"
                                                />
                                                <m:Text
                                                    text="{path:'QuotationItemModel>/TotalSum',formatter: '.Formatter.numberFormater'}"
                                                    id="HQD_TotalAmountI"
                                                    class="amountText"
                                                    textAlign="End"
                                                    visible="{= ${QuotationItemModel>/TotalSum} > 0}"
                                                />
                                            </m:HBox>
                                        </m:VBox>
                                    </m:FlexBox>
                                    <m:Label
                                        text="{i18n>notes}"
                                        required="true"
                                    />
                                    <rich:RichTextEditor
                                        value="{QuotationModel>/Notes}"
                                        editable="{visiablityPlay>/editable}"
                                        class="sapUiContentPadding"
                                        width="100%"
                                        id="HQD_id_Notes"
                                        change="HQD_onNotesChange"
                                    />
                                </m:VBox>
                            </blocks>
                        </ObjectPageSubSection>
                    </subSections>
                </ObjectPageSection>
            </sections>
        </ObjectPageLayout>
        <m:footer>
            <m:Toolbar>
                <m:ToolbarSpacer />
                <m:Button
                    visible="{visiablityPlay>/createVisi}"
                    text="{i18n>submit}"
                    type="Emphasized"
                    press="HQD_onPressSubmit"
                    class="sendMail"
                />
                <m:Button
                    visible="{visiablityPlay>/editVisi}"
                    text="{= ${visiablityPlay>/editable} === true?'Save':'Edit'}"
                    press="HQD_onPressEdit"
                    class="sendMail"
                />
                <m:Button
                    text="{i18n>buttonSendEmail}"
                    id="HQD_id_QuotationMail"
                    press="HQD_onPressSendEmail"
                    visible="{visiablityPlay>/merge}"
                />
                <m:Button
                    text="{i18n>jsPdf}"
                    press="HQD_onPressMerge"
                    visible="{visiablityPlay>/merge}"
                />
            </m:Toolbar>
        </m:footer>
    </m:Page>
</mvc:View>
