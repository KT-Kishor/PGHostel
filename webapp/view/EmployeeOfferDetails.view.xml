<mvc:View controllerName="sap.kt.com.minihrsolution.controller.EmployeeOfferDetails"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core">
	<Page   title="{i18n>headerEmployeeOffer}" showNavButton="true" navButtonPress="EOD_onPressBack">
		<content>
			<NavContainer id="EOD_id_wizardNav">
				<pages>
					<Page>
						<content>
							<Wizard complete="EOD_onPressReview" id="EOD_id_Wizard" finishButtonText="{i18n>submit}" showNextButton="true">
								<WizardStep id="EOD_id_WizardStep"   complete="onCalculate" title="{i18n>basicDetails}" validated="true">
									<f:SimpleForm editable="true" layout="ColumnLayout" 	labelSpanXL="4"
			labelSpanL="4"
			labelSpanM="12"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="0"
			emptySpanL="0"
			emptySpanM="0"
			emptySpanS="0"
			columnsXL="2"
			columnsL="2"
			columnsM="2"
			singleContainerFullSize="false">
										<f:content>
											<Label text="{i18n>consultantName}" required="true" />
											<Select
                                             id=""
                                             selectedKey="{oTraineeDetails>/TSalutation}"
                                             items="{Salutation>/salutation}">
												<core:Item key="{Salutation>text}" text="{Salutation>text}" />
												<layoutData>
													<l:GridData span="XL2 L2 M2 S3" />
												</layoutData>
											</Select>
											<Input
                                             value="{employeeModel>/ConsultantName}"
                                             placeholder="{i18n>consultantName}"
                                             required="true"
                                             editable="true"
                                             id="EOD_id_Name"
                                             liveChange="validateName"
                                             maxLength="50"
                                             valueStateText="{i18n>nameEmployeeValueState}">
												<layoutData>
													<l:GridData span="XL4 L4 M6 S9" />
												</layoutData>
											</Input>
											<Label text="{i18n>offerReleaseDate}" required="true" />
											<DatePicker id="EOD_id_Reldate" placeholder="{i18n>offerReleaseDate}" displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy"
                                             value= "{employeeModel>/OfferReleaseDate}"
                                             change="validateDate" class="sapUiSmallMarginBottom" valueStateText="{i18n>dateValueState}"/>
											<Label text="{i18n>joiningDate}" required="true" />
											<DatePicker id="EOD_id_Joindate" placeholder="{i18n>joiningDate}" 
                                            value="{employeeModel>/JoiningDate}" displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy"
                                            change="validateDate" class="sapUiSmallMarginBottom disableInput" valueStateText="{i18n>dateValueState}"/>
											<Label text="{i18n>designation}" required="true" />
											<Select id="EOD_id_Designation" items="{oDesignationModel>/results}" selectedKey="{employeeModel>/Designation}">
												<core:Item key="{oDesignationModel>designationName}" text="{oDesignationModel>designationName}" />
											</Select>
											<Label text="{i18n>baseLocation}" required="true" />
											<Select items="{oBaseLocationModel>/results}" id="EOD_id_Location" selectedKey="{employeeModel>/BaseLocation}">
												<core:Item key="{oBaseLocationModel>city}" text="{oBaseLocationModel>city}" />
											</Select>
											<Label text="{i18n>emailId}" required="true" />
											<Input value="{employeeModel>/EmployeeEmail}" placeholder="{i18n>placeEmplyeeEmail}" 
                                             id="EOD_id_mail" maxLength="50" liveChange="validateEmail" valueStateText="{i18n>emailValueState}"/>
											<Label text="{i18n>consultantAddress}" required="true" />
											<TextArea value="{employeeModel>/ConsultantAddress}" placeholder="{i18n>consultantAddress}" liveChange="ValidateCommonFields"
                                            id="EOD_id_Address" maxLength="120" valueStateText="{i18n>addressValueState}"/>
											<Label text="{i18n>ctc}" required="true" />
											<Input value="{employeeModel>/CTC}" id="EOD_id_CTC" placeholder="{i18n>placeCtc}" 
                                             liveChange="validateAmount" maxLength="15" valueStateText="{i18n>ammountValuState}" />
											<Select items="{currencyModel>/results}" selectedKey="{oTraineeDetails>/Currency}" id="TD_id_Currency" width="100%" class="marginLeft">
												<core:Item key="{currencyModel>Currency}" text="{currencyModel>Currency}" />
											</Select>
											<Label text="{i18n>joiningBonus}" required="true" />
											<Input value="{employeeModel>/JoiningBonus}" placeholder="{i18n>joiningBonus}" 
                                             liveChange="validateAmount" maxLength="10" id="EOD_id_Bonus" valueStateText="{i18n>ammountValuState}" />
											<Label text="{i18n>salaryType}"/>
											<RadioButtonGroup id="EOD_id_Main" columns="3" select="onTDSCheckboxChange">
												<RadioButton id="EOD_id_Tds" text="{i18n>tds}" />
												<RadioButton id="EOD_id_NoTds" text="{i18n>noTds}" />
												<RadioButton id="EOD_id_Pf" text="{i18n>pf}" />
											</RadioButtonGroup>
											<Label text="{i18n>bond}" required="true" />
											<RadioButtonGroup columns="2" id="EOD_id_Bond" select="onRadioButtonSelect">
												<buttons>
													<RadioButton text="{i18n>yes}" key="yes" />
													<RadioButton text="{i18n>no}" key="no" selected="true" />
												</buttons>
											</RadioButtonGroup>
											<Label text="{i18n>selectYear}" id="EOD_id_Lyear" visible="false" />
											<Select items="{EmployementBond>/results}" id="EOD_id_BondCombo" selectedKey="{employeeModel>/EmploymentBond}" visible="false" change="validateInputs">
												<core:Item key="{EmployementBond>Value}" text="{EmployementBond>Value}" />
											</Select>
										</f:content>
									</f:SimpleForm>
								</WizardStep>
								<WizardStep  title="{i18n>ctcCalculation}" validated="true" id="EDO_id_WizardStepT">
									<f:SimpleForm  editable="false" layout="ColumnLayout" columnsM="2" columnsL="4" columnsXL="4">
										<f:content>
											<core:Title text="{i18n>monthlyComponents}" />
											<Label text="{i18n>basicSalary}" />
											<Text text="{employeeModel>/BasicSalary}"  />
											<Label text="{i18n>hra}" />
											<Text text="{employeeModel>/HRA}"  />
											<Label text="{i18n>statutoryBonus}" />
											<Text text="{employeeModel>/StatutoryBonus}"  />
											<Label text="{i18n>totalMonthly}" class="boldBlackText" />
											<Text text="{employeeModel>/TotalMontly}"  />
											<Label text="{i18n>totalMonthlyAnnualized}" class="boldBlackText" />
											<Text text="{employeeModel>/TotalmothlyAnnualized}"  />
											<core:Title text="{i18n>retiralsBenefits}" />
											<Label text="{i18n>tds}" />
											<Text text="{employeeModel>/TDS}"  />
											<Label text="{i18n>medicalInsurance}" />
											<Text text="{employeeModel>/MedicalInsurance}"  />
											<Label text="{i18n>gratuity}" />
											<Text text="{employeeModel>/Gratuity}"  />
											<Label text="{i18n>totalRetirals}" class="boldBlackText" />
											<Text text="{employeeModel>/TotalRetires}"  />
											<core:Title text="{i18n>variableComponents}" />
											<Label text="{i18n>performanceBonus}" />
											<Text text="{employeeModel>/PerformanceBonus}"  />
											<Label text="{i18n>engagementPB}" />
											<Text text="{employeeModel>/EngagementPB}"  />
											<Label text="{i18n>totalVariableComponents}" class="boldBlackText" />
											<Text text="{employeeModel>/TotalVariablePay}"  />
											<core:Title text="{i18n>totalCost}" />
											<Label text="{i18n>costOfCompany}" class="boldBlackText" />
											<Text text="{employeeModel>/CostofCompany}" class="boldBlackText"  />
											<Label text="{i18n>joiningBonus}" class="boldBlackText" />
											<Text text="{employeeModel>/DisplayJoiningBonus}"  />
											<Label text="{i18n>totalinr}" class="boldBlackText" />
											<Text text="{employeeModel>/Total}"  class="boldBlackText" />
										</f:content>
									</f:SimpleForm>
								</WizardStep>
								<!-- Review wizard step with simple form -->
								<WizardStep  complete="EOD_onSubmitData"  title="{i18n>review}" validated="true">
									<f:SimpleForm  editable="false"  layout="ColumnLayout"  title="{i18n>bothEmpDetails}" columnsM="2" columnsL="4" columnsXL="4">
										<f:content>
											<core:Title text="Basic Details" />
											<Label text="{i18n>consultantName}" />
											<Text text="{= ${employeeModel>/Salutation} + ' ' + ${employeeModel>/ConsultantName} }" />
											<Label text="{i18n>consultantAddress}" />
											<Text text="{employeeModel>/ConsultantAddress}" />
											<core:Title text="" />
											<Label text="{i18n>offerReleaseDate}" />
											<Text text="{path: 'employeeModel>/OfferReleaseDate', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd/MM/yyyy' }}" />
											<Label text="{i18n>joiningDate}" />
											<Text text="{path: 'employeeModel>/JoiningDate', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd/MM/yyyy' }}" />
											<core:Title text="" />
											<Label text="{i18n>designation}" />
											<Text text="{employeeModel>/Designation}" />
											<Label text="{i18n>baseLocation}" />
											<Text text="{employeeModel>/BaseLocation}" />
											<core:Title text="" />
											<Label text="{i18n>bond}" />
											<Text text="{employeeModel>/EmploymentBond}" />
											<Label text="{i18n>employeeEmail}" />
											<Text text="{employeeModel>/EmployeeEmail}" />
											<core:Title text="{i18n>monthlyComponents}" />
											<Label text="{i18n>basicSalary}" />
											<Text text="{path: 'employeeModel>/BasicSalary'}" />
											<Label text="{i18n>hra}" />
											<Text text="{path: 'employeeModel>/HRA'}" />
											<Label text="{i18n>statutoryBonus}" />
											<Text text="{path: 'employeeModel>/StatutoryBonus'}" />
											<Label text="{i18n>totalMontly}" />
											<Text text="{path: 'employeeModel>/TotalMontly'}" />
											<Label text="{i18n>totalAnnual}" />
											<Text text="{path: 'employeeModel>/TotalmothlyAnnualized'}" />
											<core:Title text="{i18n>retiralsBenefits}" />
											<Label text="{i18n>tds}" />
											<Text text="{path: 'employeeModel>/TDS'}" />
											<Label text="{i18n>medicalInsurancePremium}" />
											<Text text="{path: 'employeeModel>/MedicalInsurance'}" />
											<Label text="{i18n>gratuity}" />
											<Text text="{path: 'employeeModel>/Gratuity'}" />
											<Label text="{i18n>totalRetires}" />
											<Text text="{path: 'employeeModel>/TotalRetires'}" />
											<core:Title text="{i18n>Variable Components (INR)}" />
											<Label text="{i18n>performanceBonusSection}" />
											<Text text="{path: 'employeeModel>/PerformanceBonus'}" />
											<Label text="{i18n>engagementBonus}" />
											<Text text="{path: 'employeeModel>/EngagementPB'}" />
											<Label text="{i18n>totalVariableComponents}" />
											<Text text="{path: 'employeeModel>/TotalVariablePay'}" />
											<core:Title text="{i18n>totalCost}" />
											<Label text="{i18n>costOfCompany}" />
											<Text text="{path: 'employeeModel>/CostofCompany'}" />
											<Label text="{i18n>joiningBonus}" />
											<Text text="{path: 'employeeModel>/DisplayJoiningBonus'}" />
											<Label text="{i18n>totalinr}" />
											<Text text="{path: 'employeeModel>/Total'}" />
										</f:content>
									</f:SimpleForm>
								</WizardStep>
							</Wizard>
						</content>
					</Page>
				</pages>
			</NavContainer>
		</content>
	</Page>
</mvc:View>
