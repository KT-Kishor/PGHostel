<mvc:View controllerName="sap.kt.com.minihrsolution.controller.EmployeeOfferDetails"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core">
	<Page id="EOD_id_PageCrate" title="{i18n>headerEmployeeOffer}" showNavButton="true" navButtonPress="EOD_onPressBackBtn">
		<content >
			<NavContainer id="EOD_id_wizardNav">
				<pages >
					<Page>
						<content>
							<Wizard id="EOD_id_Wizard" finishButtonText="{i18n>review}" showNextButton="true">
								<WizardStep id="EOD_id_WizardStep"   complete="EOD_onStep2" title="{i18n>basicDetails}" validated="true">
									<f:SimpleForm editable="true" layout="ColumnLayout" 	labelSpanXL="4"
			labelSpanL="4"
			labelSpanM="12"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="0"
			emptySpanL="0"
			emptySpanM="0"
			emptySpanS="0"
			columnsXL="2"
			columnsL="2"
			columnsM="2"
			singleContainerFullSize="false">
										<f:content>
											<Label text="{i18n>consultantName}" required="true" />
											<Select
                                             selectedKey="{employeeModel>/Salutation}"
                                             items="{Salutation>/salutation}">
												<core:Item key="{Salutation>text}" text="{Salutation>text}" />
												<layoutData>
													<l:GridData span="XL2 L2 M2 S3" />
												</layoutData>
											</Select>
											<Input
                                             value="{employeeModel>/ConsultantName}"
                                             placeholder="{i18n>consultantName}"
                                             required="true"
                                             editable="true"
                                             id="EOD_id_Name"
                                             liveChange="EOD_validateName"
                                             maxLength="50"
                                             valueStateText="{i18n>nameEmployeeValueState}">
												<layoutData>
													<l:GridData span="XL4 L4 M6 S9" />
												</layoutData>
											</Input>
											<Label text="{i18n>offerReleaseDate}" required="true" />
											<DatePicker id="EOD_id_Reldate" placeholder="{i18n>offerReleaseDate}" displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy"
                                             value= "{employeeModel>/OfferReleaseDate}"
                                             change="EOD_validateDate" class="sapUiSmallMarginBottom" valueStateText="{i18n>dateValueState}"/>
											<Label text="{i18n>joiningDate}" required="true" />
											<DatePicker id="EOD_id_Joindate" placeholder="{i18n>joiningDate}" 
                                            value="{employeeModel>/JoiningDate}" displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy"
                                            change="EOD_validateDate" class="sapUiSmallMarginBottom disableInput" valueStateText="{i18n>dateValueState}"/>
											<Label text="{i18n>designation}" required="true" />
											<Select items="{DesignationModel>/}" id="EOD_id_Designation" showSecondaryValues="true" selectedKey="{employeeModel>/Designation}">
											    <items>
												<core:ListItem key="{DesignationModel>designationName}" text="{DesignationModel>designationName}" additionalText="{DesignationModel>department}" />
												</items>
											</Select>
											<Label text="{i18n>baseLocation}" required="true" />
											 <Select items="{BaseLocationModel>/}" id="EOD_id_Location" showSecondaryValues="true" selectedKey="{employeeModel>/BaseLocation}">
												<items>
													<core:ListItem key="{BaseLocationModel>city}" text="{BaseLocationModel>city}" additionalText="{BaseLocationModel>branchCode}" />
												</items>
											</Select>
											<Label text="{i18n>emailId}" required="true" />
											<Input value="{employeeModel>/EmployeeEmail}" placeholder="{i18n>placeEmplyeeEmail}" 
                                             id="EOD_id_mail" maxLength="50" liveChange="EOD_validateEmail" valueStateText="{i18n>emailValueState}"/>
											<Label text="{i18n>consultantAddress}" required="true" />
											<TextArea value="{employeeModel>/ConsultantAddress}" placeholder="{i18n>consultantAddress}" liveChange="EOD_ValidateCommonFields"
                                            id="EOD_id_Address" maxLength="120" valueStateText="{i18n>addressValueState}"/>
											<Label text="{i18n>pinCode}" required="true" />
											<Input value="{employeeModel>/PinCode}" placeholder="{i18n>enterPinCode}" id="EOD_id_PinCode" liveChange="EOD_validatePinCode"/>
											<Label text="{i18n>ctc}" required="true" />
		
											<Input value="{employeeModel>/CTC}" id="EOD_id_CTC" placeholder="{i18n>placeCtc}" 
                                             liveChange="EOD_validateAmount" maxLength="15" valueStateText="{i18n>ammountValuState}" />
											<Select items="{CurrencyModel>/}" enabled="false" selectedKey="{employeeModel>/Currency}" id="EOD_id_Currency" width="100%" class="marginLeft">
												<core:Item key="{CurrencyModel>currency}" text="{CurrencyModel>currency}" />
											</Select>
											<Label text="{i18n>joiningBonus}" required="true" />
											<Input value="{employeeModel>/JoiningBonus}" placeholder="{i18n>joiningBonus}" 
                                             liveChange="EOD_validateAmount" maxLength="10" id="EOD_id_Bonus" valueStateText="{i18n>ammountValuState}" />
											<Label text="{i18n>salaryType}"/>
											<RadioButtonGroup id="EOD_id_RadioButTds" columns="3" select="EOD_onTDSCheckboxChange">
												<RadioButton id="EOD_id_Tds" text="{i18n>tds}" />
												<!-- <RadioButton id="EOD_id_NoTds" text="{i18n>noTds}" /> -->
												<RadioButton id="EOD_id_Pf" text="{i18n>pf}" />
											</RadioButtonGroup>
											<Label text="{i18n>bond}" required="true" />
											<RadioButtonGroup columns="2" id="EOD_id_Bond" select="EOD_onRadioButtonSelect">
												<buttons>
													<RadioButton text="{i18n>yes}"  />
													<RadioButton text="{i18n>no}"  selected="true" />
												</buttons>
											</RadioButtonGroup>
											<Label text="{i18n>selectYear}" id="EOD_id_Lyear" visible="false" />
											<Select items="{EmployementBond>/bond}" id="EOD_id_BondCombo" selectedKey="{employeeModel>/EmploymentBond}" visible="false" change="validateInputs">
												<core:Item key="{EmployementBond>Value}" text="{EmployementBond>Value}" />
											</Select>
										</f:content>
									</f:SimpleForm>
								</WizardStep>
								<WizardStep  title="{i18n>ctcCalculation}"  validated="true" id="EDO_id_WizardStepT" complete="EOD_onStep3">
									<f:SimpleForm  editable="false" layout="ColumnLayout" columnsM="2" columnsL="4" columnsXL="5">
										<f:content>
											<core:Title text="{i18n>monthlyComponents}" />
											<Label text="{i18n>basicSalary}" />
											<Text text="INR {employeeModel>/BasicSalary}"  />
											<Label text="{i18n>hra}" />
											<Text text="INR {employeeModel>/HRA}"  />
											<Label text="{i18n>statutoryBonus}" />
											<Text text="INR {employeeModel>/StatutoryBonus}"  />
											<Label text="{i18n>totalMonthly}" class="boldBlackText" />
											<Text text="INR {employeeModel>/TotalMonthly}"  />
											<Label text="{i18n>totalMonthlyAnnualized}" class="boldBlackText" />
											<Text text="INR {employeeModel>/TotalmothlyAnnualized}"  />
											<core:Title text="{i18n>retiralsBenefits}" />
											<Label text="{i18n>tds}" />
											<Text text="{employeeModel>/TDS}" />
											<Label text="{i18n>eplyePF}" visible="{viewModel>/pfVisiblity}" />
											<Text text="{employeeModel>/PF}" visible="{viewModel>/pfVisiblity}"/>
											<Label text="{i18n>eplyrPF}" visible="{viewModel>/pfVisiblity}"/>
											<Text text="{employeeModel>/EPF}" visible="{viewModel>/pfVisiblity}" />
											<Label text="{i18n>medicalInsurance}" />
											<Text text="INR {employeeModel>/MedicalInsurance}"  />
											<Label text="{i18n>gratuity}" />
											<Text text="INR {employeeModel>/Gratuity}"  />
											<Label text="{i18n>totalRetirals}" class="boldBlackText" />
											<Text text="INR {employeeModel>/TotalRetires}"  />
											<core:Title text="{i18n>variableComponents}" />
											<Label text="{i18n>performanceBonus}" />
											<Text text="INR {employeeModel>/PerformanceBonus}"  />
											<Label text="{i18n>engagementPB}" />
											<Text text="INR {employeeModel>/EngagementPB}"  />
											<Label text="{i18n>totalVariableComponents}" class="boldBlackText" />
											<Text text="INR {employeeModel>/TotalVariablePay}"  />
											<core:Title text="{i18n>totalCost}" />
											<Label text="{i18n>costOfCompany}" class="boldBlackText" />
											<Text text="INR {employeeModel>/CostofCompany}"  />
											<Label text="{i18n>joiningBonus}" class="boldBlackText" />
											<Text text="INR {employeeModel>/JoiningBonus}"  />
											<Label text="{i18n>totalinr}" class="boldBlackText" />
											<Text text="INR {employeeModel>/Total}"   />
										</f:content>
									</f:SimpleForm>
								</WizardStep>
								<!-- Review wizard step with simple form -->
								<WizardStep   title="{i18n>review}" validated="true" >
									<f:SimpleForm  editable="false"  layout="ColumnLayout"  title="{i18n>bothEmpDetails}" columnsM="2" columnsL="4" columnsXL="4">
										<f:content>
											<core:Title text="{i18n>basicDetails}" />
											<Label text="{i18n>consultantName}" />
											<Text text="{= ${employeeModel>/Salutation} + ' ' + ${employeeModel>/ConsultantName} }" />
											<Label text="{i18n>consultantAddress}" />
											<Text text="{employeeModel>/ConsultantAddress}" />
											<Label text="{i18n>pinCode}" />
											<Text text="{employeeModel>/PinCode}" />
		
											<core:Title text="" />
											<Label text="{i18n>offerReleaseDate}" />
											<Text text="{employeeModel>/OfferReleaseDate}" />
											<Label text="{i18n>joiningDate}" />
											<Text text="{employeeModel>/JoiningDate}" />
											<core:Title text="" />
											<Label text="{i18n>designation}" />
											<Text text="{employeeModel>/Designation}" />
											<Label text="{i18n>baseLocation}" />
											<Text text="{employeeModel>/BaseLocation}" />
											<core:Title text="" />
											<Label text="{i18n>bond}" />
											<Text text="{employeeModel>/EmploymentBond}" />
											<Label text="{i18n>employeeEmail}" />
											<Text text="{employeeModel>/EmployeeEmail}" />
											<core:Title text="{i18n>monthlyComponents}" />
											<Label text="{i18n>basicSalary}" />
											<Text text="{path:'employeeModel>/BasicSalary',formatter:'.Formatter.formatCurrencyInINRText'}" />
											<Label text="{i18n>hra}" />
											<Text text="{path:'employeeModel>/HRA',formatter:'.Formatter.formatCurrencyInINRText'}" />
											<Label text="{i18n>statutoryBonus}" />
											<Text text="{path:'employeeModel>/StatutoryBonus',formatter:'.Formatter.formatCurrencyInINRText'}" />
											<Label text="{i18n>totalMontly}" />
											<Text text="{path:'employeeModel>/TotalMonthly',formatter:'.Formatter.formatCurrencyInINRText'}" />
											<Label text="{i18n>totalAnnual}" />
											<Text text="{path:'employeeModel>/TotalmothlyAnnualized',formatter:'.Formatter.formatCurrencyInINRText'}" />
											<core:Title text="{i18n>retiralsBenefits}" />
											<Label text="{i18n>tds}" />
											<Text text="{path:'employeeModel>/TDS',formatter:'.Formatter.formatCurrencyInINRText'}" />
											<Label text="{i18n>medicalInsurancePremium}" />
											<Text text="{path:'employeeModel>/MedicalInsurance',formatter:'.Formatter.formatCurrencyInINRText'}" />
											<Label text="{i18n>gratuity}" />
											<Text text="{path:'employeeModel>/Gratuity',formatter:'.Formatter.formatCurrencyInINRText'}" />
											<Label text="{i18n>totalRetires}" />
											<Text text="{path:'employeeModel>/TotalRetires',formatter:'.Formatter.formatCurrencyInINRText'}" />												<core:Title text="{i18n>Variable Components}" />
											<Label text="{i18n>performanceBonusSection}" />
											<Text text="{path:'employeeModel>/PerformanceBonus',formatter:'.Formatter.formatCurrencyInINRText'}" />
											<Label text="{i18n>engagementBonus}" />
											<Text text="{path:'employeeModel>/EngagementPB',formatter:'.Formatter.formatCurrencyInINRText'}" />
											<Label text="{i18n>totalVariableComponents}" />
											<Text text="{path:'employeeModel>/TotalVariablePay',formatter:'.Formatter.formatCurrencyInINRText'}" />
											<core:Title text="{i18n>totalCost}" />
											<Label text="{i18n>costOfCompany}" />
											<Text text="{path:'employeeModel>/CostofCompany',formatter:'.Formatter.formatCurrencyInINRText'}" />
											<Label text="{i18n>joiningBonus}" />
											<Text text="{path:'employeeModel>/JoiningBonus',formatter:'.Formatter.formatCurrencyInINRText'}" />
											<Label text="{i18n>totalinr}" />
											<Text text="{path:'employeeModel>/Total',formatter:'.Formatter.formatCurrencyInINRText'}" />
										</f:content>
									</f:SimpleForm>
								</WizardStep>
							</Wizard>
						</content>
					</Page>
				</pages>
			</NavContainer>
		</content>
		<footer>
			<Bar>
				<contentLeft>
					<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
				</contentLeft>
				<contentRight>
					<Button text="{i18n>submit}" press="EOD_onSubmitData" id="EOD_id_Submit" type="Success"  enabled="false"/>
				</contentRight>
			</Bar>
		</footer>
	</Page>
	<core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.EmployeeOfferUpdate" type="XML" />
</mvc:View>
