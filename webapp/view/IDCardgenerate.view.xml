<mvc:View
	controllerName="sap.kt.com.minihrsolution.controller.IDCardgenerate"
	xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
	displayBlock="true"
    xmlns:g="sap.f"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
	height="100%"
	busyIndicatorDelay="0"
    >
	<Page>
    <headerContent>
			<Avatar src="./image/logo.jpg" displaySize="XS" press="onAvatarPressed" tooltip="Company Logo"/>
			<Title level="H1" text="{i18n>companynameKT}" class="custom-text" wrapping="false"/>
			<ToolbarSpacer/>
			<Button icon="sap-icon://home" press="onpresshome" class="sapUiTinyMarginEnd" tooltip="{i18n>toolHome}"/>
		</headerContent>

        			<Title level="H1" text="{i18n>IDcard}" class="HeadDemoSection" wrapping="false"/>

    <!-- upload scheme -->
    <g:GridContainer class="jioSection sapUiSmallMarginTop">
        <g:layout>
            <g:GridContainerSettings columnSize="49.5%" gap="10px" />
        </g:layout>
        <g:layoutXS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutXS>
        <g:layoutS>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutS>
        <g:layoutM>
            <g:GridContainerSettings columnSize="100%" gap="10px" />
        </g:layoutM>

        <!-- Left Column -->
        <m:VBox alignItems="Start" justifyContent="Center" class="sapUiSmallMarginTop">
            <m:Title text="{i18n>Generateid}" level="H1" class="jioHeading" />
            <m:Text text="{i18n>Generateid_Par}" class="jioParagraph" />
        </m:VBox>

        <!-- Right Column -->
        <m:VBox id="videoBox_ID" alignItems="Center" justifyContent="Center" class="sapUiMediumMarginTop">
         <core:HTML id="videoFrameHtml_ID"
        content="&lt;video width='560' height='315' controls autoplay muted playsinline 
                     style='border:none;border-radius:15px;overflow:hidden;background:#f3f3f3'&gt;
                    &lt;source src='../Videos/ID Card Application.mp4' type='video/mp4'&gt;
                    Your browser does not support the video tag.
                 &lt;/video&gt;" />
</m:VBox>

    </g:GridContainer>
     <m:Button
            text="Request Demo"
            press="onOpenDemoForm"
            class="demoBtn"
        />
  </Page>
   <!-- <l:Grid defaultSpan="L12 M12 S12"  vSpacing="2" hSpacing="2" class="sapUiTinyMargin">
        <l:content>
            <m:Carousel id="videoCarousel" showPageIndicator="false" loop="true" class="allvideo"/>
         </l:content>
     </l:Grid> -->
   
       
</mvc:View>
