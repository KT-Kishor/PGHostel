<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
    controllerName="sap.kt.com.minihrsolution.controller.Trainee"
	xmlns:fb="sap.ui.comp.filterbar"
    displayBlock="true">
	<Page  >
		<headerContent>
	     <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />
			</headerContent>
		<content>
			<fb:FilterBar  class="sapUiTinyMargin" id="T_id_AdminFilter" persistencyKey="myPersKey" useToolbar="false" clear="onPressClear" showClearOnFB="true" search=".onSearch" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad" >
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="TraineeName" label="{i18n>traineeName}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox  showSecondaryValues= "true"  items="{traineeModel>/}" change="" id="T_id_TraineeName" showClearIcon="true">
								<core:ListItem key="{traineeModel>TraineeName}" text="{traineeModel>TraineeName}" />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="ReportingManager" label="{i18n>reportingManager}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox   items="{traineeModel>/}" id="T_id_RmFilterBar" showClearIcon="true">
								<core:Item key="{traineeModel>ReportingManager}" text="{traineeModel>ReportingManager}"/>
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="JoiningDate" label="{i18n>joiningDate}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
                    <DateRangeSelection id="T_id_JoiningDate" valueFormat="dd/MM/yyyy"  displayFormat="dd/MM/yyyy" change="onDateChange" />						
					</fb:control>
						</fb:FilterGroupItem>
						<fb:FilterGroupItem name="Status" label="{i18n>status}" groupName="Group1" visibleInFilterBar="true">
					<fb:control>
						<ComboBox name="Status" showClearIcon="true" selectionChange="T_onSelectionChange" items="{EmployeeStatus>/}">
							<core:Item key="{EmployeeStatus>ID}" text="{EmployeeStatus>StatusValue}"/>
						</ComboBox>
					</fb:control>
				</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table id="T_id_TraineeTable" class="sapUiTinyMargin"  items="{path: 'traineeModel>/'}"  busyIndicatorDelay="0"  width="auto" mode="SingleSelectLeft" selectionChange="T_onTableSelectionChange"
                    growingScrollToLoad="true" growing="true"  growingThreshold="50"  alternateRowColors="true">
				 <headerToolbar>
                <OverflowToolbar >
                    <Title id="T_id_Title" text="{i18n>traineeDetails}"/>
                    <ToolbarSpacer/>
                    <Button  tooltip="{i18n>downloadcCertificate}" id="T_id_Download"  type="Success" press="T_onCertDownload"  icon="sap-icon://document-text"/>
                    <Button  text="{i18n>onboard}" id="T_id_OnboardBtn"  type="Neutral" press="T_onOnboardPress"  icon="sap-icon://manager"/>
                    <Button text="{i18n>rejectTainee}" id="T_id_RejectBtn" type="Reject"  press="T_onRejectPress" icon="sap-icon://employee-rejections" />
                    <Button text="{i18n>addTrainee}" id="T_id_AddBtn" type="Accept"  press="T_onPressAddTrainee"  icon="sap-icon://employee-approvals"/>
                </OverflowToolbar>
            </headerToolbar>
				<columns>
					<Column demandPopin="true">
						<Text text="{i18n>traineeName}"/>
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>reportingManager}" />
					</Column>
					
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>stipend}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>joiningDate}" />
					</Column>
					<Column minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>emailId}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true" width="10%">
						<Text text="{i18n>status}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem  type="Navigation" press="T_onPressAddTrainee">
						<cells>
						    <Text text="{traineeModel>NameSalutation} {traineeModel>TraineeName}"/>							
							<Text text="{traineeModel>ReportingManagerSalutation} {traineeModel>ReportingManager}"/>
							<Text text="{traineeModel>Stipend} {traineeModel>Currency}"/>
							<Text text="{path:'traineeModel>JoiningDate' ,formatter:'.Formatter.formatDate'}" />
							<Text text="{traineeModel>TraineeEmail}"/>
							<ObjectStatus text="{traineeModel>Status}" inverted="true" state="{path:'traineeModel>Status',formatter:'.Formatter.formatObjectStatus'}"/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar>
				<contentLeft>
                    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
				</contentLeft>
				
			</Bar>
		</footer>
	</Page>
</mvc:View>