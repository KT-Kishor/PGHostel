<mvc:View
    controllerName="sap.ui.com.project1.controller.TilePage"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
>
    <Page
        id="idPageTile"
        class="service-background Tilehome"
    >
        <headerContent>
            <Text
                text="{= 'Welcome ' + ${LoginModel>/EmployeeName} }"
                class="boldBlueText sapUiLargeMarginBegin"
            />
            <ToolbarSpacer />
            <!-- <Button
                press="Tile_onHomePress"
                visible="{= ${LoginModel>/Role} === 'Admin' || ${LoginModel>/Role} === 'Super Admin' }"
                tooltip="{i18n>homeTooltip}"
                icon="sap-icon://home"
            /> -->
            <Button
                press="Tile_onLogPress"
                tooltip="{i18n>logoutTooltip}"
                icon="sap-icon://log"
            />
        </headerContent>
        <layout:VerticalLayout>
            <FlexBox
                wrap="Wrap"
                alignItems="Center"
                justifyContent="Center"
                class="tileContainer"
            >
                <GenericTile
                    id="branchTile"
                    visible="{= ${TileVisibility>/ManageBranch}!== 0?true:false }"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>manageBranchDetails}"
                    press="TileV_onpressBranchdata"
                >
                    <TileContent unit="{i18n>branchDetails}">
                        <ImageContent src="sap-icon://building" />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    id="bedTile"
                    visible="{= ${TileVisibility>/ManageBedType}!== 0?true:false }"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>manageBedDetails}"
                    press="TileV_onpressbeddetails"
                >
                    <TileContent unit="{i18n>tileBedDetails}">
                        <ImageContent src="sap-icon://bed" />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    id="roomTile"
                    visible="{= ${TileVisibility>/ManageRooms}!== 0?true:false }"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>tileManageRoomDetails}"
                    press="TileV_onpressroomdetails"
                >
                    <TileContent unit="{i18n>tileRoomDetails}">
                        <ImageContent src="sap-icon://detail-view" />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    id="customerTile"
                    visible="{= ${TileVisibility>/ManageFacility}!== 0?true:false }"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>manageExtraFacilities}"
                    press="TileV_onpressextrafacilities"
                >
                    <TileContent unit="{i18n>extraFacilities}">
                        <ImageContent src="sap-icon://activities" />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    id="id1roomTile"
                    visible="{= ${TileVisibility>/ManageAmenities}!== 0?true:false }"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>maintainHostelFeatures}"
                    press="TileV_onpresshostelfeatures"
                >
                    <TileContent unit="{i18n>TileHostelFeatures}">
                        <ImageContent src="sap-icon://home-share" />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    id="id2roomTile"
                    visible="{= ${TileVisibility>/ManageCoupon}!== 0?true:false }"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>manageCouponDetails}"
                    press="TileV_onpressCouponDetails"
                >
                    <TileContent unit="{i18n>couponDetails}">
                        <ImageContent src="sap-icon://tags" />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    id="id3roomTile"
                    visible="{= ${TileVisibility>/ManageCustomer}!== 0?true:false }"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>manageCustomerDetails}"
                    press="TileV_onpressInbox"
                >
                    <TileContent unit="{i18n>assignRooms}">
                        <ImageContent src="sap-icon://building" />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    id="id4roomTile"
                    visible="{= ${TileVisibility>/ManageInvoice}!== 0?true:false }"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>invoiceDetails}"
                    press="TileV_onpressManageInvoice"
                >
                    <TileContent unit="{i18n>TileinvoiceDetails}">
                        <ImageContent src="sap-icon://expense-report" />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    id="id5roomTile"
                    visible="{= ${TileVisibility>/ManageStaff}!== 0?true:false }"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>manageStaff}"
                    press="TileV_onpressManageStaff"
                >
                    <TileContent unit="{i18n>staffDirectory}">
                        <ImageContent src="sap-icon://employee" />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    id="id6roomTile"
                    visible="{= ${TileVisibility>/ManageVendor}!== 0?true:false }"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>manageVendors}"
                    press="TileV_onpressManageVendor"
                >
                    <TileContent unit="{i18n>vendorDirectory}">
                        <ImageContent src="sap-icon://employee" />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    id="id7roomTile"
                    visible="{= ${TileVisibility>/ManagePaymentHistory}!== 0?true:false }"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>payment}"
                    press="TileV_onpressPayment"
                >
                    <TileContent unit="{i18n>paymentHistory}">
                        <ImageContent src="sap-icon://monitor-payments" />
                    </TileContent>
                </GenericTile>
                <GenericTile
                    id="id8roomTile"
                    class="sapUiMediumMargin glassTile"
                    visible="{= ${TileVisibility>/ManageSecurityDeposit}!== 0?true:false }"
                    header="{i18n>returnDeposit}"
                    press="TileV_onpressDeposit"
                >
                    <TileContent unit="{i18n>ManageDeposit}">
                        <ImageContent src="sap-icon://batch-payments" />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    id="id9roomTile"
                    visible="{= ${TileVisibility>/ManageBookingDashboard}!== 0?true:false }"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>bookingDashboard}"
                    press="TileV_onpressdashboard"
                >
                    <TileContent unit="{i18n>viewDashboard}">
                        <ImageContent src="sap-icon://bbyd-dashboard" />
                    </TileContent>
                </GenericTile>
                <GenericTile
                    id="id10roomTile"
                    class="sapUiMediumMargin glassTile"
                    visible="{= ${TileVisibility>/ManagePaymentDashboard}!== 0?true:false }"
                    header="{i18n>paymentdashboard}"
                    press="TileV_onpresshosteldashboard"
                >
                    <TileContent unit="{i18n>paymentGraph}">
                        <ImageContent
                            src="sap-icon://business-objects-experience"
                        />
                    </TileContent>
                </GenericTile>
                <GenericTile
                    id="id11roomTile"
                    class="sapUiMediumMargin glassTile"
                    visible="{= ${TileVisibility>/ManageCustomerReview}!== 0?true:false }"
                    header="{i18n>customerReview}"
                    press="TileV_onpresscustomerreview"
                >
                    <TileContent unit="{i18n>customerReview}">
                        <ImageContent
                            src="sap-icon://crm-sales"
                        />
                    </TileContent>
                </GenericTile>
                   <GenericTile
                    id="id12roomTile"
                    class="sapUiMediumMargin glassTile"
                    visible="{= ${TileVisibility>/ManageCustomerReview}!== 0?true:false }"
                    header="{i18n>Complaintdetails}"
                    press="TileV_onpressComplaintdetails"
                >
                    <TileContent unit="{i18n>Complaintdetails}">
                        <ImageContent
                            src="sap-icon://discussion"
                        />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    id="TP_ComplaintDashBoardTile"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>complainDashboard}"
                    press="TileV_onpresscomplaintdashboard"
                     visible="{= ${TileVisibility>/ManageComplaintDashboard}!== 0?true:false }"
                >
                    <TileContent unit="{i18n>complaingraph}">
                        <ImageContent
                            src="sap-icon://bbyd-dashboard"
                        />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    id="TP_DamageTile"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>damageTracking}"
                     visible="{= ${TileVisibility>/ManageDamage}!== 0?true:false }"
                    press="TileV_onpressdamage"
                >
                    <TileContent unit="{i18n>damageDetails}">
                        <ImageContent
                            src="sap-icon://bbyd-dashboard"
                        />
                    </TileContent>
                </GenericTile>
                 <GenericTile
                    id="TP_DamageDashboard"
                    class="sapUiMediumMargin glassTile"
                    header="{i18n>damageDashboard}"
                     visible="{= ${TileVisibility>/DamageDashboard}!== 0?true:false }"
                    press="TileV_onpressdamagedashboard"
                >
                    <TileContent unit="{i18n>damageDashboard}">
                        <ImageContent
                            src="sap-icon://bbyd-dashboard"
                        />
                    </TileContent>
                </GenericTile>
            </FlexBox>
        </layout:VerticalLayout>
        <Button
            text="Steps Guide"
            icon="sap-icon://learning-assistant"
            press="onStartGuide"
            class="guideButtonLarge myunifiedBtn"
        />
    </Page>
</mvc:View>