
<mvc:View controllerName="sap.kt.com.minihrsolution.controller.TilePage"
	xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
	xmlns="sap.m"
	xmlns:layout="sap.ui.layout" >
	<Page id="idPageTile" class="service-background " >
	<headerContent>
	  <Text text="{= 'Welcome ' + ${loginModel>/userNames} }" class="boldBlueText sapUiLargeMarginBegin" />
	<ToolbarSpacer />
			<Button  press="backPress" icon="sap-icon://log"></Button>
		</headerContent>    
            <layout:VerticalLayout >
             <FlexBox wrap="Wrap" alignItems="Start" justifyContent="Start">
            
				<GenericTile visible="{modelTileVisible>/GenerateEmployeeOffer}"
                    class="sapUiMediumMargin"
                    
                    header="{i18n>headerEmployeeOffer}" press="onPressOffer"
                    subheader="{i18n>subhead}">
					<TileContent  unit="{i18n>tileUnit}" footer="{i18n>tileFooter}">
						<ImageContent src="sap-icon://employee-approvals" />					
					</TileContent>
					</GenericTile>
				
				<GenericTile visible="{modelTileVisible>/GenerateContract}"
                    class="sapUiMediumMargin"
                    header="{i18n>headerContractDetails}" press="onpressContract"
                    subheader="{i18n>subhead}">
					<TileContent  unit="{i18n>tileUnit}" footer="{i18n>tileFooter}">
						<ImageContent src="sap-icon://decision" />					
					</TileContent>
					</GenericTile>                    

                <GenericTile visible="{modelTileVisible>/GenerateMsaNda}"
                    class="sapUiMediumMargin"
                    header="{i18n>headerMSA}" press="onpressMSA"
                     subheader="{i18n>subhead}">
                    <TileContent  unit="{i18n>tileUnit}" footer="{i18n>SendMail}">
						<ImageContent src="sap-icon://add-document" />					
					</TileContent>
					</GenericTile>

                <GenericTile visible="{modelTileVisible>/GenerateTraineeOffer}"
                   class="sapUiMediumMargin"
                    header="{i18n>headerTrainee}" press="onpressTrainee"  subheader="{i18n>subhead}">
                    <TileContent  unit="{i18n>tileUnit}" footer="{i18n>SendMail}">
						<ImageContent src="sap-icon://account" />
					</TileContent>
                </GenericTile>

                <GenericTile  visible="{modelTileVisible>/ListOfHolidays}"
                   class="sapUiMediumMargin"
                    header="{i18n>headerListOfHolidays}" press="onpresslistofholidays">
					<TileContent unit="{i18n>tileLeaveFooter}">
						<ImageContent src="sap-icon://general-leave-request" />
					</TileContent>
                   </GenericTile>

                <GenericTile id="idLeaveGenericTile" visible="{modelTileVisible>/ApplyLeave}"
                   class="sapUiMediumMargin"
                    header="{i18n>headerLeave}" press="onpressLeave"
                    subheader="{i18n>subhead}">
					<TileContent unit="{i18n>createLeave}">
						<ImageContent src="sap-icon://time-off" />
					</TileContent>
					</GenericTile>

				<GenericTile visible="{modelTileVisible>/MyInbox}"
                    class="sapUiMediumMargin"
                    header="{i18n>headerInbox}" press="onpressInbox">
					<TileContent unit="{i18n>tileMyInboxFooter}" >
						<ImageContent src="sap-icon://inbox" />
					</TileContent>
					</GenericTile>
				
                <GenericTile visible="{modelTileVisible>/ExpenseApp}"
                    class="sapUiMediumMargin"
                    header="{i18n>headerExpense}" press="onpressExpenseApp">
                    <TileContent unit="{i18n>subhead}">
						<ImageContent src="sap-icon://expense-report" />
					</TileContent>
                    </GenericTile >

                <GenericTile visible="{modelTileVisible>/InvoiceApp}"
                    class="sapUiMediumMargin"
                    header="{i18n>headerCompanyInvoice}" press="onpressInvoiceApp">
                    <TileContent unit="{i18n>tileInvoiceFooter}">
						<ImageContent src="sap-icon://my-sales-order" />
					</TileContent>
                    </GenericTile >
    
                <GenericTile visible="{modelTileVisible>/SelfService}"
                    class="sapUiMediumMargin"
                    header="{i18n>headerSelfService}" press="onpressSelfservice"
                      subheader="{i18n>subhead}">
                      <TileContent unit="{i18n>tileSelfSerciceFooter}" >
                      <ImageContent src="sap-icon://form"/>
                      </TileContent>
                </GenericTile>
           
                <GenericTile visible="{modelTileVisible>/AddCustomer}"
                    class="sapUiMediumMargin"
                    header="{i18n>headerCustomer}" press="onpressAddCustomer"
                    subheader="{i18n>subhead}">
                    <TileContent unit="{i18n>tileManagecustFooter}">
						<ImageContent src="sap-icon://customer" />
					</TileContent>
                    </GenericTile >
            
				<GenericTile visible="{modelTileVisible>/IDCard}"
                   class="sapUiMediumMargin"
                    header="{i18n>headerIdCard}" press="onpressIDCARD"
                    subheader="{i18n>subhead}">
					<TileContent  unit="{i18n>tileIdCardFooter}" >
						<ImageContent src="sap-icon://badge" />					
					</TileContent>
					</GenericTile>   
                    
                <GenericTile visible="{modelTileVisible>/ConsultantInvoice}"
                   class="sapUiMediumMargin"
                    header="{i18n>headerContractorInvoice}" press="onpressConsultantInvoice">
					<TileContent  unit="{i18n>tileInvoiceFooter}">
						<ImageContent src="sap-icon://monitor-payments" />					
				</TileContent>
				</GenericTile>   

                <GenericTile visible="{modelTileVisible>/EmployeeDetail}"
                    class="sapUiMediumMargin"
                    header="{i18n>headerEmpDetails}" press="onpressEmployeeDetails"
                    subheader="{i18n>subheadEmphike}">
					<TileContent  unit="{i18n>tileEmplyeeFooter}">
						<ImageContent src="sap-icon://employee" />					
				</TileContent>
				</GenericTile>   

                 <GenericTile visible="{modelTileVisible>/QuotationApp}"
                   class="sapUiMediumMargin"
                    header="{i18n>headerQuotation}" press="onpressQuotaion">
					<TileContent  unit="{i18n>subheader}">
						<ImageContent src="sap-icon://my-sales-order" />					
				</TileContent>
				</GenericTile>   

                 <GenericTile visible="{modelTileVisible>/AssignmentTask}"
                   class="sapUiMediumMargin" 
                    header="{i18n>headerAssignTask}"  subheader="{i18n>subhead}" press="onpressAssignment">
					<TileContent  unit="{i18n>tileAssignmentFooter}">
						<ImageContent src="sap-icon://activity-assigned-to-goal" />					
				</TileContent>
				</GenericTile>   

                 <GenericTile visible="{modelTileVisible>/Timesheet}"
                   class="sapUiMediumMargin"  subheader="{i18n>subhead}"
                    header="{i18n>headerTimesheet}" press="onpresstimesheet">
					<TileContent  unit="{i18n>tileTimesheetFooter}">
						<ImageContent src="sap-icon://timesheet" />					
				</TileContent>
				</GenericTile>   

                <GenericTile  visible="{modelTileVisible>/TimeSheetApproval}"
                   class="sapUiMediumMargin"
                    header="{i18n>headerTimesheetApproval}" press="onPressTimesheetApp">
				<TileContent  unit="{i18n>tileMyInboxFooter}">
						<ImageContent src="sap-icon://timesheet" />					
				</TileContent>
				</GenericTile>   

                  <GenericTile  visible="{modelTileVisible>/PaySlip}"
                   class="sapUiMediumMargin"
                    header="{i18n>HeaderPaySlip}" press="onPressAdminPaySlip">
					<TileContent  unit="{i18n>tilePaySlipFooter}">
						<ImageContent src="sap-icon://money-bills" />					
				</TileContent>
				</GenericTile>

			</FlexBox>
		</layout:VerticalLayout>
        <footer>
			<Bar>
				<contentLeft>
					<HBox class="sapUiTinyMarginTop">
						<Image src="../image/logo.jpg" width="30px" height="30px" class="companylogo" />
						<Link
        class="footer-CoName sapUiTinyMarginBegin"
        text="Developed by Kalpavriksha Technologies"
        href="https://www.kalpavrikshatechnologies.com/" 
        target="_blank"  
    />
					</HBox>
				</contentLeft>
			</Bar>
		</footer>
    </Page>
</mvc:View>
