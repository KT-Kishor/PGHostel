<mvc:View controllerName="sap.kt.com.minihrsolution.controller.MyInbox"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:fb="sap.ui.comp.filterbar">
	<Page id="MI_id_MyInboxPage">
		<headerContent>
	    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Header" type="XML" />

		</headerContent>
		<content>
			<fb:FilterBar  class="sapUiTinyMargin" id="MI_id_FilterBar" persistencyKey="myPersKey" useToolbar="false" showClearOnFB="true" search=".onSearch" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad" >
				<fb:filterGroupItems>
					<fb:FilterGroupItem name="EmpID" label="{i18n>employeeID}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox  showSecondaryValues= "true"  items="" change="" id="MI_id_EmpIDFilter" showClearIcon="true">
								<core:ListItem key="" text="" additionalText="" />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="Status" label="{i18n>status}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<ComboBox  showSecondaryValues= "true"  items="" change="" id="MI_id_StatusFilter" showClearIcon="true">
								<core:ListItem key="" text="" additionalText="" />
							</ComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="Type" label="{i18n>type}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<MultiComboBox
							id="MI_id_TypeFilter"
							selectionChange="MI_onSelectionChangeType"
							items="{oTypeModel>/}">
								<core:Item key="{oTypeModel>type}" text="{oTypeModel>type}"/>
							</MultiComboBox>
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem name="SubmittedDate" label="{i18n>submittedDate}" groupName="Group1" visibleInFilterBar="true">
						<fb:control>
							<DateRangeSelection id="MI_id_SubmittedDateFilter" valueFormat="dd/MM/yyyy"  displayFormat="dd/MM/yyyy" change="MI_onDateChangeFilter" />
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
			<Table id="MI_id_MyInboxTable" class="sapUiTinyMargin" items="{ path:'',sorter: {
			path: '', descending: false, group:true}}"  busyIndicatorDelay="0"  width="auto"
                inset="false"    growingScrollToLoad="true" growing="true"  growingThreshold="50"  alternateRowColors="true">
				<headerToolbar>
					<OverflowToolbar >
						<Title id="MI_id_TitleTable" text="{i18n>headerEmpDetails}"/>
						<ToolbarSpacer />
						<Button icon="sap-icon://detail-view" visible="{modelButtonVisible>/LOPDataButt}" press="MI_onPressLOPData" tooltip="LOP Leave Details" />
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column demandPopin="true">
						<Text text="{i18n>employeeID}"/>
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>employeeName}" />
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>startDate}" />
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>endDate}" />
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>type}" />
					</Column>
					<Column demandPopin="true">
						<Text text="{i18n>subType}" />
					</Column>
					<Column demandPopin="true" >
						<Text text="{i18n>status}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="MI_onPressColNavigation">
						<cells>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<Text text=""/>
							<ObjectStatus text="{Status}" inverted="true" state="{path: 'Status', formatter: '.Formatter.statusStateFormatter'}" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Bar id="MI_id_FooterBar">
			    <contentLeft>
                    <core:Fragment fragmentName="sap.kt.com.minihrsolution.fragment.Footer" type="XML" />
                </contentLeft>
				<contentRight>
					<!-- Footer Buttons -->
					<Button id="MI_id_ButApprove" text="{i18n>approve}" press="MI_onPressApprove" type="Accept" visible="true"/>
					<Button id="MI_id_ButReject" text="{i18n>reject}" press="MI_onPressReject" type="Reject" visible="true"/>
					<Button id="MI_id_ButReSend" text="{i18n>resend}" press="MI_onPressReSend" type="Emphasized" visible="true"/>
					<Button id="MI_id_ButPaid" text="{i18n>paid}" press="MI_onPressPaidBut" type="Success" visible="true"/>
				</contentRight>
			</Bar>
		</footer>
	</Page>
</mvc:View>