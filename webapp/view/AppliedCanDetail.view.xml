<mvc:View
    controllerName="sap.kt.com.minihrsolution.controller.AppliedCanDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout.form"
>
    <Page  title="Recruitement Dashbord" navButtonPress="onPageNavButtonPress" showNavButton="true" icon="sap-icon://log">
     <headerContent>
          <Button
        press="onLogout"
        icon="sap-icon://log"
        tooltip="{i18n>logoutTooltip}"
        type="Transparent"
    />
</headerContent>
        <layout:SimpleForm
            labelSpanXL="4"
            labelSpanL="4"
            labelSpanM="12"
            labelSpanS="12"
            emptySpanXL="0"
            emptySpanL="0"
            emptySpanM="0"
            emptySpanS="0"
            columnsXL="3"
            columnsL="2"
            columnsM="2"
            layout="ColumnLayout"
            id=""
        >
            <layout:content>
                <Label text="{i18n>compName}" />
                <Input value="{setDataToForm>/FullName}" editable="false"/>

                <Label text="{i18n>gender}" />
                <Input value="{setDataToForm>/Gender}" editable="false"/>

                <Label text="{i18n>FormField}" />
                <Input value="{path :'setDataToForm>/DOB',formatter:'.formatter.formatDate'}" editable="false"/>

                <Label text="{i18n>address}" />
                <Input value="{setDataToForm>/Address}" editable="false"/>

                <Label text="{i18n>city}" />
                <Input value="{setDataToForm>/City}" editable="false"/>

                <Label text="{i18n>expCountry}" />
                <Input value="{setDataToForm>/Country}" editable="false"/>

                <Label text="{i18n>mobilenumber}" />
                <Input value="{setDataToForm>/ISD}" editable="false"/>
                <Input value="{setDataToForm>/Mobile}" editable="false"/>

                <Label text="{i18n>CurrentCompanyField}" />
                <Input value="{setDataToForm>/CurrentCompany}" editable="false"/>

                <Label text="{i18n>designation}" />
                <Input value="{setDataToForm>/Designation}" editable="false"/>

                <Label text="{i18n>EmploymentTypeField}" />
                <Input value="{setDataToForm>/EmploymentType}" editable="false"/>

                <Label text="{i18n>TableColExperience}" />
                <Input value="{setDataToForm>/Experience}" editable="false"/>

                <Label text="{i18n>TableColNoticePeriod}" />
                <Input value="{setDataToForm>/NoticePeriod}" editable="false"/>

                <Label text="{i18n>CurrentSalaryField}" />
                <Input value="{setDataToForm>/CurrentSalary}" editable="false"/>

                <Label text="{i18n>ExpectedSalaryField}" />
                <Input value="{setDataToForm>/ExpectedSalary}" editable="false"/>

                <Label text="{i18n>Jobtitle}" />
                <Input value="{setDataToForm>/JobTitle}" editable="false"/>

                <Label text="{i18n>RolesFields}" />
                <Input value="{setDataToForm>/Roles}" editable="false"/>

                <Label text="{i18n>ExpertiseInField}" />
                <Input value="{setDataToForm>/ExpertiseIn}" editable="false"/>

                <Label text="{i18n>TableColSkills}" />
                <Input value="{setDataToForm>/Skills}" editable="false"/>

                <Label text="{i18n>DescribeYourselfField}" />
                <TextArea
                    rows="2"
                    cols="4"
                    value="{setDataToForm>/DescribeYourSelf}"
                    editable="false"
                />

                <Label text="{i18n>TableColNameHeistQualification}" />
                <Input value="{setDataToForm>/HighestQualifaction}" editable="false"/>

                <Label text="{i18n>UniversityFiled}" />
                <Input value="{setDataToForm>/University}" editable="false"/>

                <Label text="{i18n>PassingYearField}" />
                <Input value="{setDataToForm>/PassingYear}" editable="false"/>

                <Label text="{i18n>WorkDurationStartField}" />
                <Input value="{path: 'setDataToForm>/WorkDurationStart', formatter:'.formatter.formatDate'}" editable="false"/>
                
                <Label text="{i18n>WorkDurationEndField}" />
                <Input value="{path: 'setDataToForm>/WorkDurationEnd', formatter: '.formatter.formatDate'}" editable="false"/>

                <Label />
                <Button  type="Emphasized" press="onDownloadResume" text="Download Resume"/>
                <Button type="Emphasized" press="openResumePreview" text="View Resume"/>
            </layout:content>
        </layout:SimpleForm>
        <footer>
            <Bar id="ACD_id_FooterBar">
                <contentLeft>
                    <core:Fragment
                        fragmentName="sap.kt.com.minihrsolution.fragment.Footer"
                        type="XML"
                    />
                </contentLeft>
            </Bar>
        </footer>
    </Page>
</mvc:View>
