            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "sap.kt.com.minihrsolution.i18n.i18n"
                }
            },
            "AssignmentStatus": {
                "type": "sap.ui.model.json.JSONModel",
