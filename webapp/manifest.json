{
    "_version": "1.65.0",
    "sap.app": {
        "id": "sap.kt.com.minihrsolution",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "0.0.1"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "resources": "resources.json",
        "sourceTemplate": {
            "id": "@sap/generator-fiori:basic",
            "version": "1.16.5",
            "toolsId": "e41e0e16-770d-46f8-9339-aef876c756f5"
        }
    },
    "sap.ui": {
        "technology": "UI5",
