<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="invoiceListDialog"
        contentWidth="900px"
        contentHeight="500px"
        resizable="true"
        draggable="true">
                <customHeader >
        <Bar class="Coursetitle" >
        <contentLeft>
              <Title  text="{i18n>invoiceFor} {popoverData>/status}"  />
        </contentLeft>
         
            <contentRight>
                <Button icon="sap-icon://decline" press="onCloseDialog" tooltip="Close"/>
            </contentRight>
        </Bar>
    </customHeader>
        <content>
        
            <Table
                id="invoiceListTable"
                inset="false"
                sticky="ColumnHeaders"
                items="{popoverData>/invoices}"
                noDataText="{i18n>noInvoiceStatus}">
                
                <columns>
                      <Column><Text text="{i18n>invoiceNo}" /></Column>
                    <Column><Text text="{i18n>invoiceDate}" /></Column>
                     <Column><Text text="{i18n>customerName}" /></Column>

                     <Column><Text text="{i18n>currency}" /></Column>
                    <Column hAlign="End"><Text text="{i18n>exchRate}" /></Column>

                    <Column hAlign="End"><Text text="{i18n>totalAmount}" /></Column>
                    <!-- <Column><Text text="{i18n>status}" /></Column> -->
                </columns>
                
                <items>
                    <ColumnListItem type="Navigation" press="onInvoiceNumberPress">
                        <cells>
                            <Text text="{popoverData>InvNo}" />
                             <Text text="{
                                path: 'popoverData>InvoiceDate',
                             formatter:'.Formatter.formatDate'}" />
                            <Text text="{popoverData>CustomerName}" />

                     <!-- <ObjectNumber number="{popoverData>TotalAmount}" unit="{popoverData>Currency}" /> -->
                      <ObjectNumber
    number="{
        parts: [
          
            { path: 'popoverData>TotalAmount' }
        
        ], 
        formatter: '.Formatter.fromatNumber'
    }"
    unit="{popoverData>Currency}" />


                           <ObjectIdentifier 
  title="{path:'popoverData>ConversionRate', formatter: '.Formatter.fromatNumber'}"
 />

                          <ObjectNumber
    number="{
        parts: [
            { path: 'popoverData>Currency' },
            { path: 'popoverData>TotalAmount' },
            { path: 'popoverData>AmountInINR' }
        ], 
        formatter: '.Formatter.fromatNumber'
    }"
    unit="INR" />

                         
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        
        <!-- <endButton>
            <Button text="{i18n>close}" type="Ghost" press="onCloseDialog" />
        </endButton> -->
    </Dialog>
</core:FragmentDefinition>
