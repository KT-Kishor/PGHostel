<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
>
    <Dialog
        id="invoiceListDialog"
        contentWidth="1000px"
        contentHeight="500px"
        resizable="true"
        draggable="true"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <!-- <Title text="{i18n>invoiceFor} {popoverData>/status}" /> -->
   <Title text="{i18n>invoiceFor} {popoverData>/status} {headerModel>/filterSuffix }" />
                </contentMiddle>
                <contentRight>
                    <Button
                        icon="sap-icon://decline"
                        press="onCloseDialog"
                        tooltip="{i18n>close}"
                    />
                </contentRight>
            </Bar>
        </customHeader>

        <content>
            <Table
                id="invoiceListTable"
                inset="false"
                sticky="ColumnHeaders"
                items="{popoverData>/invoices}"
                noDataText="{i18n>noInvoiceStatus}"
            >
                <columns>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                    >
                        <Text text="{i18n>invoiceNo}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                    >
                        <Text text="{i18n>invoiceDate}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>customerName}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>bookingID}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>transactionAmount}" />
                    </Column>
                    <!-- <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop">
						<Text text="{i18n>creditNotesAmount}" />
					</Column> -->
                    <Column
                        hAlign="End"
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>exchRate}" />
                    </Column>
                    <Column
                        hAlign="End"
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>totalAmount}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem
                        type="Navigation"
                        press="onInvoiceNumberPress"
                    >
                        <cells>
                            <Text text="{popoverData>InvNo}" />
                            <Text
                                text="{path: 'popoverData>InvoiceDate', formatter: '.Formatter.formatDate'}"
                            />
                            <Text text="{popoverData>CustomerName}" />
                            <Text text="{popoverData>BookingID}" />
                            <ObjectNumber
                                number="{parts: [{ path: 'popoverData>OldTotalAmount' }], formatter: '.Formatter.fromatNumber'}"
                                unit="{popoverData>Currency}"
                            />
                            <!-- <layout:VerticalLayout>
								<Link wrapping="true" class="creditLinkStyle" press="onInvoiceCreditNotesPress" text="{parts: [{ path: 'popoverData>CreditNotesTotal' },{ path: 'popoverData>Currency' }], formatter: '.Formatter.formatAmountWithCurrency'}" />
								<Link wrapping="true" visible="{= ${popoverData>Currency} !== 'INR' }" class="creditLinkStyle" press="onInvoiceCreditNotesPress" text="{parts: [{ path: 'popoverData>CreditNotesTotalInINR' },{ value: 'INR' }], formatter: '.Formatter.formatAmountWithCurrency'}" />
							</layout:VerticalLayout> -->
                            <ObjectIdentifier
                                title="{path:'popoverData>ConversionRate', formatter: '.Formatter.fromatNumber'}"
                            />
                            <ObjectNumber
                                number="{parts: [{ path: 'popoverData>Currency' },{ path: 'popoverData>TotalAmount' },{ path: 'popoverData>AmountInINR' }], formatter: '.Formatter.fromatNumber'}"
                                unit="INR"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Text text="{i18n>totalAmount} : " />
                <ObjectNumber
                    number="{parts: [{ path: 'popoverData>/AllTotalAmount' }], formatter: '.Formatter.fromatNumber'}"
                    unit="INR"
                />
            </Toolbar>
        </footer>
    </Dialog>
</core:FragmentDefinition>
