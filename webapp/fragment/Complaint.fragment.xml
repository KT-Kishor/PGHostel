<core:FragmentDefinition 
    xmlns="sap.m" 
    xmlns:core="sap.ui.core" 
    xmlns:f="sap.ui.layout.form" 
    xmlns:u="sap.ui.unified">
    <Dialog title="Raise New Complaint" contentWidth="450px" afterClose="onCloseComplaintDialog">
        <content>
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
                <f:content>
                <Label text="Branch" required="true"/>

<ComboBox
    id="idBranchCombo"
   selectedKey="{complaintTemp>/BranchCode}"
    items="{
        path: 'profileData>/BranchCombo'
    }"
    required="true"
    width="100%"    
    valueStateText="Please Select  Branch"
    change="onComBranch"
>

    <core:Item
        key="{profileData>BranchCode}"
        text="{profileData>BranchName}" />

</ComboBox>
 <Label text="Room No" required="true" />
                    <ComboBox
                        id="idComplaintRoom"
                        selectedKey="{complaintTemp>/RoomNo}"
                        items="{
                            path: 'complaintTemp>/RoomCombo'
                        }"
                        required="true"
                        change="onComplaintRoomChange"
                        valueStateText="{i18n>selectRoomNo}"
                    >
                        <core:Item
                            key="{complaintTemp>RoomNo}"
                            text="{complaintTemp>RoomNo}" />
                    </ComboBox>
                    <!-- <Label text="Complaint Type" required="true" />
                    <ComboBox
                        id="idComplaintType"
                        required="true"
                        valueStateText="Please select complaint type"
                    >
                        <items>
                            <core:Item key="Bathroom Issue" text="Bathroom Issue"/>
                            <core:Item key="Electrical Issue" text="Electrical Issue"/>
                            <core:Item key="Room Cleaning" text="Room Cleaning"/>
                        </items>
                    </ComboBox> -->
                    <Label text="Complaint Type" required="true" />

<ComboBox
    id="idComplaintType"
    required="true"
    selectedKey="{complaintTemp>/ComplaintType}"
    value="{complaintTemp>/ComplaintType}"
    valueStateText="Please select complaint type"
    change="onComplaintTypeChange"
    items="{
        path: 'ComplaintTypeModel>/'
    }">
    <core:Item
        key="{ComplaintTypeModel>key}"
        text="{ComplaintTypeModel>text}" />
</ComboBox>

                   

                    <Label text="Description" required="true" />
                    <TextArea
                        id="idComplaintDesc"
                        rows="4"
                        growing="true"
                        width="100%"
                        placeholder="Please describe your issue..."
                        value="{complaintTemp>/Description}"
                        liveChange="onComplaintDescLiveChange"
                        valueStateText="Please enter complaint description"
                        maxLength="200"
                    />

                    <Label text="Upload Image" />
                    <VBox width="100%">
                        <MessageStrip
                            text="{i18n>messageComplaintAttachment}"
                            showIcon="true"
                            type="Warning"
                        />
                        <Table
                            id="idComplaintAttachmentTable"
                            items="{complaintTemp>/Documents}"
                            width="100%"
                            noDataText="No document uploaded"
                        >
                            <headerToolbar>
                                <OverflowToolbar>
                                    <Title text="Image" />
                                    <ToolbarSpacer />
                                    <u:FileUploader
                                        id="idComplaintFileUploader"
                                        buttonOnly="true"
                                        buttonText="Upload"
                                        uploadOnChange="false"
                                        fileType="jpg,jpeg,png"
                                        change="onComplaintFileChange"
                                    />
                                </OverflowToolbar>
                            </headerToolbar>
                            <columns>
                                <Column>
                                    <Text text="{i18n>filename}" />
                                </Column>
                                <!-- <Column minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
                                    <Text text="{i18n>image}" />
                                </Column> -->
                                <Column minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
                                    <Text text="{i18n>size}" />
                                </Column>
                                <Column hAlign="Center" width="3rem">
                                    <Text text="" />
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Link
                                            text="{complaintTemp>FileName}"
                                            press="onComplaintPreviewDoc"
                                            tooltip="{path:'complaintTemp>', formatter:'.Formatter.fileTooltip'}"
                                            wrapping="true"
                                        />
                                        <!-- <Text text="{complaintTemp>DocType}" /> -->
                                        <Text text="{path:'complaintTemp>size', formatter:'.Formatter.formatFileSize'}" />
                                        <Button
                                            icon="sap-icon://decline"
                                            type="Transparent"
                                            press="onComplaintDeleteDoc"
                                            tooltip="Remove"
                                        />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </f:content>
            </f:SimpleForm>
        </content>
        <beginButton>
           <Button 
    text="{= ${complaintTemp>/isEditMode} ? 'Update' : 'Submit' }"
    type="Emphasized" 
    press="onSaveComplaint" 
/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCloseComplaintDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
