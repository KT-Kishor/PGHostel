<core:FragmentDefinition
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
>
    <m:Dialog
        id="demoFormDialog"
        class="demoFormDialog"
        draggable="true"
        title="Demo Form"
    >
        <m:VBox class="dialogContentBox">
            <!-- Header -->
            <m:VBox
                alignItems="Center"
                class="dialogHeader"
            >
                <m:Title
                    text="{i18n>demoFormtitle}"
                    level="H2"
                    class="dialogTitle"
                />
                <m:Text
                    text="Fill in your details below and our team will get back to you."
                    class="dialogSubtitle"
                />
            </m:VBox>

            <!-- Form with modern look -->
            <m:VBox
                class="formContainer"
                renderType="Bare"
            >
                <m:Label text="Company Name" />
                <m:Input
                    value="{formData>/CompanyName}"
                    id="idCompanyname"
                    liveChange="validateCompnayname"
                    placeholder="{i18n>placeCompany}"
                    required="true"
                    maxLength="50"
                    valueStateText="{i18n>placeCompany}"
                />

                <m:Label text="Customer Name" />
                <m:Input
                    value="{formData>/CustomerName}"
                    liveChange="validateName"
                    id="idcustomername"
                    maxLength="50"
                    placeholder="{i18n>placeholderCustName}"
                    required="true"
                    valueStateText="{i18n>placeholderCustName}"
                />

                <m:Label text="Email" />
                <m:Input
                    value="{formData>/Email}"
                    placeholder="{i18n>placeEmailId}"
                    type="Email"
                    maxLength="50"
                    id="idCustmailid"
                    liveChange="validateEmail"
                    required="true"
                    valueStateText="Enter Valid Email"
                />

                <m:Label text="Preferred Time Slot" />
                <m:DateTimePicker
                    value="{formData>/TimeSlot}"
                    placeholder="{i18n>placeholdertimeslote}"
                    required="true"
                    liveChange="ValidateCommonFields"
                    id="idtimeslot"
                    valueFormat="yyyy-MM-dd HH:mm"
                    displayFormat="dd/MM/yyyy HH:mm"
                />

                <m:Label text="Mobile Number" />
                <m:Input
                    value="{formData>/MobileNo}"
                    placeholder="{i18n>placeholderMobileNo}"
                    liveChange="validateMobileNo"
                    id="idmobilenumber"
                    valueStateText="Enter Atleast 10 digit number"
                    required="true"
                    maxLength="10"
                />

                <m:Label text="Address" />
                <m:TextArea
                    value="{formData>/Address}"
                    placeholder="{i18n>placeAddress}"
                    rows="2"
                    id="idCustaddress"
                    valueStateText="{i18n>placeAddress}"
                    liveChange="ValidateCommonFields"
                    required="true"
                    maxLength="120"
                />

                <m:Label text="Comments" />
                <m:TextArea
                    value="{formData>/Comments}"
                    placeholder="{i18n>enterComments}"
                    rows="2"
                    valueStateText="{i18n>enterComments}" 
                    id="idcomment"
                    maxLength="120"
                    liveChange="ValidateCommonFields"
                />
            </m:VBox>
        </m:VBox>

        <m:beginButton>
            <m:Button
                text="Submit"
                class="FOOTER"
                press="onDemoformSave"
            />
        </m:beginButton>
        <m:endButton>
            <m:Button
                text="Cancel"
                press="onCloseDemoForm"
            />
        </m:endButton>
    </m:Dialog>
</core:FragmentDefinition>