<Dialog

    contentWidth="420px"
    id="couponShareDialog"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    afterClose="onShareDialogAfterClose"
>
    <customHeader>
            <Bar class="barheader">
                    <contentMiddle>
                <Title text="{i18n>CDShareCoupons}" />
            </contentMiddle>
              
            </Bar>
        </customHeader>
    <f:SimpleForm
        editable="true"
        layout="ResponsiveGridLayout"
        labelSpanL="12"
        labelSpanM="12"
        columnsL="1"
        columnsM="1"
        width="100%"
    >
        <VBox class="sapUiSmallMarginBottom">
            <Title
                text="{= 'Coupon : ' + ${CouponView>/ShareCoupon/CouponCode} }"
                wrapping="true"
                class="sapUiTinyMarginBottom"
            />
            <Title
                text="{= 'Branch : ' + ${CouponView>/ShareCoupon/BranchCode} }"
                wrapping="true"
            />
        </VBox>
        <!-- Role -->
        <Label
            text="{i18n>recipientrole}"
            required="true"
        />
        <ComboBox
            id="cbRole"
            width="100%"
            placeholder="{i18n>selectrole}"
            items="{RoleModel>/}"
            selectionChange="onRoleChange"
            change="onRoleLiveChange"
            required="true"
            valueStateText="{i18n>selectrole}"
        >
            <core:Item
                key="{RoleModel>}"
                text="{RoleModel>}"
            />
        </ComboBox>
        <!-- Contact recipients -->
        <Label text="{i18n>selectrecipients}" />
        <MultiComboBox
            selectionChange="onUserSelectionChange"
            valueStateText="{i18n>selectrecipients}"
            id="cbUser"
            width="100%"
            items="{RecipientModel>/}"
            selectedKeys="{CouponView>/SelectedUsers}"
            showSelectAll="true"
            showSecondaryValues="true"
        >
            <core:ListItem
                key="{RecipientModel>Email}"
                text="{RecipientModel>UserName}"
                additionalText="{RecipientModel>Email}"
            />
        </MultiComboBox>
        <!-- Manual email entry -->
        <Label text="{i18n>addmail}" />
        <Input
            id="inpManualEmail"
            width="100%"
            placeholder="{i18n>checkEmail}"
            liveChange="onManualEmailLiveChange"
            valueStateText="{i18n>checkEmail}"
        />
    </f:SimpleForm>
    <beginButton>
        <Button
            text="{i18n>sendCoupon}"
            tooltip="{i18n>sendCoupon}"
            class="myUnifiedBtn"
            press="onConfirmShareCoupon"
        />
    </beginButton>
    <endButton>
        <Button
            text="{i18n>CancelButton}"
            tooltip="{i18n>CancelButton}"
            class="myUnifiedBtn"
            press="onCloseShareDialog"
        />
    </endButton>
</Dialog>