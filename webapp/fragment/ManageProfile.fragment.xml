<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
    xmlns:m="sap.m"
    xmlns:uxap="sap.uxap"
>
    <Dialog
        id="id_dialog"
        stretch="{= ${device>/system/phone} }"
        draggable="true"
        resizable="true"
        horizontalScrolling="false"
        contentWidth="{= ${device>/system/phone} ? '100%' : '80%'}"
        initialFocus="id_dialog"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title
                        text="{i18n>myAccount}"
                        level="H4"
                    />
                </contentMiddle>
                <contentRight>
                    <m:Button
                        text="{= ${profileData>/isEditMode} ? 'Save' : 'Edit'}"
                        class="myUnifiedBtn"
                        tooltip="{i18n>MSedit}"
                        press="onEditSaveProfile"
                    />
                    <m:Button
                        icon="sap-icon://decline"
                        tooltip="{i18n>close}"
                        press="onProfileDialogClose"
                    />
                </contentRight>
            </Bar>
        </customHeader>
        <FlexBox
            direction="Row"
            class="myclass"
            justifyContent="Center"
            alignItems="Center"
        >
            <VBox>
                <m:Avatar
                    src="{path: 'profileData>/photo'}"
                    initials="{profileData>/initials}"
                    displayShape="Circle"
                    displaySize="XL"
                    press="onPreviewProfilePhoto"
                    class="sapUiTinyMargin myavatar"
                />
                <Button
                    icon="sap-icon://edit"
                    tooltip="{i18n>setProfilePhoto}"
                    press="onPressAvatarEdit"
                    class="avatarEditIcon"
                />

                <u:FileUploader
                    id="id_fileUploaderAvatar"
                    uploadOnChange="false"
                    change="onAvatarFileSelected"
                    fileType="png,jpg,jpeg"
                    class="hiddenUploader"
                    buttonOnly="true"
                    iconOnly="true"
                />
            </VBox>
            <VBox>
                <f:SimpleForm
                    layout="ColumnLayout"
                    columnsM="3"
                    class="sapUiTinyMarginTop"
                    columnsL="4"
                    visible="{= !${profileData>/isEditMode}}"
                >
                    <f:content>
                        <m:Label text="{i18n>fullname}" />
                        <m:Text
                            text="{= ${profileData>/Salutation} + ' ' + ${profileData>/name}}"
                        />

                        <m:Label text="{i18n>email}" />
                        <Text text="{profileData>/email}" />

                        <m:Label text="{i18n>MVDDOB}" />
                        <Text text="{profileData>/dob}" />

                        <m:Label text="{i18n>MVDcountry}" />
                        <Text text="{profileData>/Country}" />

                        <m:Label text="{i18n>MVDstate}" />
                        <Text text="{profileData>/State}" />

                        <m:Label text="{i18n>city}" />
                        <Text text="{profileData>/City}" />

                        <m:Label text="{i18n>MSmobileNo}" />
                        <m:Text
                            text="{= ${profileData>/STDCode} + ' ' + ${profileData>/phone}}"
                        />

                        <m:Label text="{i18n>MVgender}" />
                        <Text text="{profileData>/gender}" />
                        <m:Label text="{i18n>address}" />
                        <Text
                            text="{profileData>/address}"
                            wrapping="true"
                            width="100%"
                        />
                    </f:content>
                </f:SimpleForm>
                <f:SimpleForm
                    layout="ColumnLayout"
                    columnsM="3"
                    class="sapUiTinyMarginTop"
                    columnsL="4"
                    visible="{profileData>/isEditMode}"
                >
                    <f:content>
                        <m:Label
                            text="{i18n>fullname}"
                            required="{profileData>/isEditMode}"
                        />
                        <Select selectedKey="{profileData>/Salutation}">
                            <core:Item
                                key="Mr."
                                text="Mr."
                            />
                            <core:Item
                                key="Mrs."
                                text="Mrs."
                            />
                            <core:Item
                                key="Miss"
                                text="Miss"
                            />
                        </Select>
                        <m:Input
                            id="id_Name"
                            maxLength="20"
                            placeholder="{i18n>enterFullName}"
                            value="{profileData>/name}"
                            valueStateText="{i18n>enterFullName}"
                            liveChange="onNameInputLiveChange"
                        />

                        <m:Label
                            text="{i18n>email}"
                            required="{profileData>/isEditMode}"
                        />
                        <m:Input
                            id="id_mail"
                            placeholder="{i18n>enterEmailId}"
                            value="{profileData>/email}"
                            type="Email"
                            maxLength="30"
                            valueStateText="{i18n>enterEmailId}"
                            liveChange="onEmailliveChange"
                        />

                        <m:Label
                            text="{i18n>MVDDOB}"
                            required="{profileData>/isEditMode}"
                        />
                        <DatePicker
                            id="id_dob"
                            value="{profileData>/dob}"
                            displayFormat="dd/MM/yyyy"
                            valueFormat="dd/MM/yyyy"
                            valueStateText="{i18n>enterDateofBirth}"
                            change="onChangeDOB"
                        />

                        <m:Label
                            text="{i18n>MVDcountry}"
                            required="{profileData>/isEditMode}"
                        />
                        <ComboBox
                            id="id_country"
                            items="{path:'CountryModel>/',length:1000}"
                            selectedKey="{profileData>/Country}"
                            showSecondaryValues="true"
                            selectionChange="onCountrySelectionChange"
                            change="MC_onChangeCountry"
                            placeholder="{i18n>enterCountry}"
                            valueStateText="{i18n>selectCountry}"
                        >
                            <core:ListItem
                                key="{CountryModel>countryName}"
                                text="{CountryModel>countryName}"
                                additionalText="{CountryModel>code}"
                            />
                        </ComboBox>

                        <m:Label
                            text="{i18n>MVDstate}"
                            required="{profileData>/isEditMode}"
                        />
                        <ComboBox
                            id="id_state"
                            change="CC_onChangeState"
                            placeholder="{i18n>enterState}"
                            valueStateText="{i18n>selectState}"
                            showSecondaryValues="true"
                            items="{path:'StateModel>/',length:1000}"
                            selectedKey="{profileData>/State}"
                        >
                            <core:ListItem
                                key="{StateModel>stateName}"
                                text="{StateModel>stateName}"
                            />
                        </ComboBox>

                        <m:Label
                            text="{i18n>city}"
                            required="{profileData>/isEditMode}"
                        />
                        <ComboBox
                            id="id_city"
                            change="onChange"
                            valueStateText="{i18n>cityValueText}"
                            placeholder="{i18n>enterCity}"
                            showSecondaryValues="true"
                            items="{path:'CityModel>/',length:1000}"
                            selectedKey="{profileData>/City}"
                            selectionChange="CC_onChangeCity"
                        >
                            <core:ListItem
                                key="{CityModel>cityName}"
                                text="{CityModel>cityName}"
                                additionalText="{CityModel>branchCode}"
                            />
                        </ComboBox>

                        <m:Label
                            text="{i18n>MSmobileNo}"
                            required="{profileData>/isEditMode}"
                        />

                        <ComboBox
                            change="_onProfileSTDChange"
                            id="id_std"
                            placeholder="{i18n>code}"
                            valueStateText="{i18n>MSselectCode}"
                            showSecondaryValues="true"
                            items="{path:'CountryModel>/', length:1000}"
                            selectedKey="{profileData>/STDCode}"
                            filterSecondaryValues="true"
                        >
                            <core:ListItem
                                key="{CountryModel>stdCode}"
                                text="{CountryModel>stdCode}"
                                additionalText="{CountryModel>code}"
                            />
                        </ComboBox>
                        <Input
                            id="id_phone"
                            value="{profileData>/phone}"
                            placeholder="{i18n>enterContactNumber}"
                            maxLength="18"
                            liveChange="MPonMobileLivechnage"
                            valueStateText="{i18n>enterContactNumber}"
                        />

                        <m:Label
                            text="{i18n>MVgender}"
                            required="{profileData>/isEditMode}"
                        />
                        <ComboBox
                            id="id_gender"
                            placeholder="{i18n>selectGender}"
                            selectedKey="{profileData>/gender}"
                            valueStateText="{i18n>pleaseselectGender}"
                            change="onChange"
                        >
                            <core:Item
                                key="Male"
                                text="Male"
                            />
                            <core:Item
                                key="Female"
                                text="Female"
                            />
                            <core:Item
                                key="Other"
                                text="Other"
                            />
                        </ComboBox>
                        <m:Label
                            text="{i18n>address}"
                            required="{profileData>/isEditMode}"
                        />
                        <TextArea
                            id="id_address"
                            placeholder="{i18n>enterAddress}"
                            value="{profileData>/address}"
                            rows="3"
                            maxLength="120"
                            liveChange="MPonAddressChange"
                            growing="false"
                            width="100%"
                        />
                    </f:content>
                </f:SimpleForm>
            </VBox>
        </FlexBox>
        <FlexBox
            direction="Row"
            justifyContent="SpaceBetween"
            alignItems="Center"
            wrap="Wrap"
            class="responsiveFlex"
        >
            <IconTabHeader
                id="id_tabBar"
                mode="Standard"
                select="onTableSelect"
            >
                <items>
                    <IconTabFilter
                        key="Booking History"
                        text="Booking History ({profileData>/bookingCount})"
                    />
                    <IconTabFilter
                        key="Payment"
                        text="Payment ({= ${profileData>/paymentCount} })"
                    />
                </items>
            </IconTabHeader>
            <ToolbarSpacer />

            <SearchField
                width="auto"
                class="sapUiSmallMargin searchField"
                liveChange="onGlobalSearch"
                placeholder="{i18n>search}"
            />
        </FlexBox>
        <Table
            id="Id_ProfileaTable"
            visible="{= ${profileData>/selectedTab} !== 'Payment' }"
            busy="{profileData>/isTableBusy}"
            updateFinished="onTableUpdateFinished"
            busyIndicatorDelay="0"
            noDataText="No booking history found"
            items="{
                    path: 'profileData>/bookings',
                    sorter: [
                        { path: 'bookingGroup', descending: false, group: true },
                        { path: 'BookingDate', descending: true }
                    ]
                }"
        >
            <columns>
                <Column demandPopin="true">
                    <Text text="{i18n>customerName}" />
                </Column>
                <Column demandPopin="true">
                    <Text text="{i18n>bookingDate}" />
                </Column>
                <Column demandPopin="true">
                    <Text text="{i18n>room}" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                >
                    <Text text="{i18n>amount}" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                >
                    <Text text="{i18n>status}" />
                </Column>
            </columns>

            <items>
                <ColumnListItem
                    type="Navigation"
                    press="onPressBookingRow"
                >
                    <cells>
                        <ObjectIdentifier
                            title="{profileData>customerName}"
                            text="{profileData>BookingID}"
                        />
                        <Text text="{profileData>BookingDate}" />
                        <Text text="{profileData>room}" />
                        <Text
                            text="{ parts: [ 'profileData>amount', 'profileData>currency' ], formatter: '.Formatter.formatCurrency' }"
                        />
                        <ObjectStatus
                            inverted="false"
                            text="{profileData>status}"
                            state="{ path: 'profileData>status', formatter: '.Formatter.formatObjectStatus'}"
                        />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
        <Table
            id="Id_PaymentTable"
            visible="{= ${profileData>/selectedTab} === 'Payment' }"
            updateFinished="onTableUpdateFinished"
            items="{ 
                     path:'profileData>/Payments',
                     sorter: [{ path: 'PaymentGroup', group: true, descending: false }]}"
        >
            <columns>
                <Column demandPopin="true">
                    <Text text="{i18n>bookingID}" />
                </Column>
                <Column demandPopin="true">
                    <Text text="{i18n>invoiceNo}" />
                </Column>
                <Column demandPopin="true">
                    <Text text="{i18n>invoiceDate}" />
                </Column>
                <Column demandPopin="true">
                    <Text text="{i18n>customerName}" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                >
                    <Text text="{i18n>totalAmount}" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                >
                    <Text text="{i18n>invoiceDueAmount}" />
                </Column>
            </columns>

            <items>
                <ColumnListItem
                    type="Navigation"
                    press="onPressManageInvoice"
                >
                    <cells>
                        <Text text="{profileData>BookingID}" />
                        <Text text="{profileData>InvNo}" />
                        <Text
                            text="{path:'profileData>InvoiceDate',formatter: '.Formatter.formatDate'}"
                        />
                        <Text text="{profileData>CustomerName}" />

                        <Text
                            text="{path: 'profileData>TotalAmount', formatter: '.Formatter.fromatNumber'} {profileData>currency}"
                            textAlign="End"
                        />
                        <Text text="{profileData>DueAmount}" />

                        <!-- <Text
                            text="{ parts: [ 'profileData>TotalAmount', 'profileData>currency' ], formatter: '.Formatter.formatCurrency' }"
                        /> -->
                        <!-- <Text
                            text="{ parts: [ 'profileData>DueAmount', 'profileData>currency' ], formatter: '.Formatter.formatCurrency' }"
                        /> -->
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </Dialog>
</core:FragmentDefinition>