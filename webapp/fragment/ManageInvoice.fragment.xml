<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:core="sap.ui.core"
>
    <Dialog>
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title text="{i18n>invoicePaymentTitle}" />
                </contentMiddle>
            </Bar>
        </customHeader>
        <VBox visible="{visiablityPlay>/Form}">
            <f:SimpleForm
                editable="true"
                visible="{VisibleModel>/invoicePaymentTitle}"
                layout="ResponsiveGridLayout"
                labelSpanXL="4"
                labelSpanL="3"
                labelSpanM="4"
                labelSpanS="12"
                emptySpanXL="0"
                emptySpanL="4"
                emptySpanM="0"
                emptySpanS="0"
                columnsXL="2"
                columnsL="1"
                columnsM="1"
            >
                <f:content>
                 <Label
                   id="id_Payment"
                    text="Payment Mode"
                    required="true"
                />
                <ComboBox
                    id="idInvoicePaymentMode"
                    placeholder="Select payment mode"
                    selectedKey="{PaymentModel>/PaymentType}"
                    valueStateText="Select payment mode"
                    change="onPaymentModeChange"

                >
                    <core:ListItem
                        key="UPI"
                        text="UPI"
                    />
                      <core:ListItem
                        key="Cash"
                        text="Cash"
                    />
                </ComboBox>

                 <Label
                        text="{i18n>recievedby}"
                    />
                    <Input
                        value="{PaymentModel>/ReceivedBy}"
                        id="idrecivedby"
                        editable="false"
                        visible="false"
                    />

                
                    <Label
                        text="{i18n>invoiceTransactionID}"
                        required="true"
                    />
                    <Input
                        value="{PaymentModel>/TransactionId}"
                        id="MI_id_TransactionID"
                        liveChange="onLiveTransactionID"
                        placeholder="{i18n>enterTransactionID}"
                        valueStateText="{i18n>invoiceTransactionIDValueText}"
                        visible="false"
                        maxLength="30"
                    />
                    <Label
                        text="{i18n>invoiceReceivedDate}"
                        required="true"
                    />
                    <DatePicker
                        displayFormat="dd/MM/yyyy"
                        id="idReceivedDate"
                        valueFormat="dd/MM/yyyy"
                        value="{PaymentModel>/ReceivedDate}"
                        change="onReceivedDateDatePickerChange"
                        valueStateText="{i18n>dateValueState}"
                    />
                    <Label
                        text="{i18n>invoiceReceivedAmount}"
                        required="true"
                    />
                    <Input
                        value="{PaymentModel>/ReceivedAmount}"
                        id="idReceivedAmount"
                        change="onChangeReceivedAmount"
                        valueStateText="{i18n>invoiceRecievedAmountMessage}"
                        placeholder="{i18n>enterReceivedAmount}"
                        maxLength="15"
                    />
                    <Label text="" />
                    <HBox
                        width="100%"
                        justifyContent="SpaceBetween"
                        visible="{= ${PaymentModel>/Currency} !== 'INR'}"
                    >
                        <VBox width="calc(50% - 10px)">
                            <Label
                                text="{i18n>expConversionRate}"
                                required="true"
                            />
                            <Input
                                value="{PaymentModel>/ConversionRate}"
                                placeholder="{i18n>expConversionRate}"
                                id="idFrgConvertionRate"
                                change="onChangePaymentConvertionRate"
                                maxLength="15"
                                valueStateText="{i18n>ammountValuState}"
                            />
                        </VBox>
                        <VBox width="calc(50% - 10px)">
                            <Label text="{i18n>amountInINR}" />
                            <Input
                                value="{path:'PaymentModel>/AmountInINR', formatter:'.Formatter.numberFormater'}"
                                editable="false"
                            />
                        </VBox>
                    </HBox>
                    <Label
                        text="{i18n>totalAmount}"
                        required="true"
                    />
                    <HBox
                        width="100%"
                        justifyContent="SpaceBetween"
                    >
                        <VBox width="calc(50% - 10px)">
                            <Input
                                value="{path:'PaymentModel>/TotalAmount', formatter:'.Formatter.numberFormater'}"
                                editable="false"
                            />
                        </VBox>
                        <VBox width="calc(50% - 10px)">
                            <Input
                                value="{PaymentModel>/Currency}"
                                editable="false"
                            />
                        </VBox>
                    </HBox>
                    <Label
                        text="{i18n>invoiceDueAmount}"
                        required="true"
                    />
                    <HBox
                        width="100%"
                        justifyContent="SpaceBetween"
                    >
                        <VBox width="calc(50% - 10px)">
                            <Input
                                value="{path:'PaymentModel>/DueAmount' , formatter:'.Formatter.numberFormater'}"
                                editable="false"
                            />
                        </VBox>
                        <VBox width="calc(50% - 10px)">
                            <Input
                                value="{PaymentModel>/Currency}"
                                editable="false"
                            />
                        </VBox>
                    </HBox>
                </f:content>
            </f:SimpleForm>
        </VBox>
        <VBox visible="{visiablityPlay>/Table}">
            <Table
                items="{PaymentDetailModel>/InvoicePaymentDetail}"
                sticky="ColumnHeaders"
            >
                <columns>
                    <Column minScreenWidth="Tablet">
                        <Text text="{i18n>invoiceTransactionIDpersonname}" />
                    </Column>
                    <Column minScreenWidth="Tablet">
                        <Text text="{i18n>invoiceReceivedDate}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text text="{i18n>totalAmount}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text text="{i18n>invoiceReceivedRefundAmount}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text text="{i18n>invoiceDueAmount}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        visible="{= ${PaymentModel>/Currency} !== 'INR'}"
                    >
                        <Text text="{i18n>expConversionRate}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        visible="{= ${PaymentModel>/Currency} !== 'INR'}"
                    >
                        <Text text="{i18n>amountInINR}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{= ${PaymentDetailModel>TransactionId}? ${PaymentDetailModel>TransactionId} : ${PaymentDetailModel>ReceivedBy} }" />
                            <Text
                                text="{path:'PaymentDetailModel>ReceivedDate', formatter:'.Formatter.formatDate'}"
                            />
                            <Text
                                text="{path:'PaymentDetailModel>TotalAmount',formatter: '.Formatter.fromatNumber'}"
                            />
                            <Text
                                text="{path:'PaymentDetailModel>ReceivedAmount',formatter: '.Formatter.fromatNumber'}"
                            />
                            <Text
                                text="{path:'PaymentDetailModel>DueAmount',formatter: '.Formatter.fromatNumber'}"
                            />
                            <Text
                                text="{path:'PaymentDetailModel>ConversionRate',formatter: '.Formatter.fromatNumber'}"
                            />
                            <Text
                                text="{path:'PaymentDetailModel>AmountInINR',formatter: '.Formatter.fromatNumber'}"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </VBox>
        <footer>
            <Toolbar>
                <VBox
                    alignContent="End"
                    width="100%"
                >
                    <HBox
                        justifyContent="End"
                        width="100%"
                        visible="{visiablityPlay>/Form}"
                    >
                        <Button
                            text="{i18n>submit}"
                            tooltip="{i18n>submit}"
                            class="sendMail"
                            press="onChangePaymentRecived"
                        />
                        <Button
                            text="{i18n>close}"
                            tooltip="{i18n>close}"
                            class=""
                            press="onPressInvClose"
                        />
                    </HBox>
                    <HBox
                        justifyContent="End"
                        width="100%"
                        visible="{visiablityPlay>/Table}"
                    >
                        <Button
                            text="{i18n>close}"
                            tooltip="{i18n>close}"
                            class="myUnifiedBtn"
                            press="onPressInvClose"
                        />
                    </HBox>
                </VBox>
            </Toolbar>
        </footer>
    </Dialog>
</core:FragmentDefinition>
