<core:FragmentDefinition
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core" >
	<Dialog 
        title="{i18n>custDetails}">
		<f:SimpleForm 
            id="MC_id_SimpleFormAddToolbar"
            editable="true"
			layout="ResponsiveGridLayout"
			labelSpanXL="4"
			labelSpanL="3"
			labelSpanM="4"
			labelSpanS="12"
			emptySpanXL="0"
			emptySpanL="4"
			emptySpanM="0"
			emptySpanS="0"
			columnsXL="2"
			columnsL="1"
			columnsM="1">
			<f:content>
				<Label text="{i18n>companyName}"  />
				<Input id="MC_id_CustCompanyName" liveChange="MC_ValidateCommonFields"  value="{CreateCustomerModel>/CompanyName}" required="true" maxLength="50" placeholder="{i18n>companyNamePlace}" valueStateText="{i18n>placeCompany}"/>
				<Label text="{i18n>customerName}" required="true"/>
				<HBox width="100%" justifyContent="Start" alignItems="Center">
					<VBox width="22%">
						<Select id="MC_id_SelectReportingManagerSalutation" selectedKey="{CreateCustomerModel>/Salutation}"
                                   items="{NameSalutation>/items}" width="100%">
							<core:Item key="{NameSalutation>Salutationname}" text="{NameSalutation>Salutationname}" />
						</Select>
					</VBox>
					<VBox width="78%">
						<Input id="MC_id_CustCustomerName" value="{CreateCustomerModel>/Name}" maxLength="20" placeholder="{i18n>placeholderCustName}" liveChange="MC_ValidateCommonFields" valueStateText="{i18n>placeholderCustName}" />
					</VBox>
				</HBox>
				<Label text="{i18n>panCardCommon}" />
				<Input value="{CreateCustomerModel>/PAN}" placeholder="{i18n>panCardPlaceholder}" maxLength="50" id="MC_id_CustomPan" liveChange="MC_ValidatePanCard" valueStateText="{i18n>panCardValueState}" />
				<Label text="{i18n>gstNo}" />
				<Input value="{CreateCustomerModel>/GST}" maxLength="15" placeholder="{i18n>placeholderGST}" id="MC_id_CustomGst"  liveChange="MC_ValidateGstNumber" valueStateText="{i18n>gstNoValueState}" />
				<Label text="{i18n>type}" labelFor="groupC" />
				<RadioButtonGroup visible="{visiblePlay>/CC_id_CustInput}" select="onRadioButtonChange"  id="MC_id_groupCustGst" columns="2" selectedIndex="{visiblePlay>/selectedIndex}">
					<RadioButton text="{i18n>cgst}" />
					<RadioButton text="{i18n>igst}" />
				</RadioButtonGroup>
				<Label visible="{visiblePlay>/CC_id_CustInput}" text="{i18n>custValue}" />
				<Input visible="{visiblePlay>/CC_id_CustInput}" value="{CreateCustomerModel>/Value}" maxLength="5" />
				<Label text="{i18n>emailId}" required="true" />
				<Input value="{CreateCustomerModel>/MailID}" placeholder="{i18n>placeEmailId}" id="MC_id_CustMail"  maxLength="190" liveChange="MC_ValidateEmail" valueStateText="{i18n>emailValueState}" />
				<Label text="{i18n>emailId}" required="true"/>
				<Input value="{CreateCustomerModel>/CustomerEmail}" id="MC_id_FinanceEmail" placeholder="{i18n>placeholderFinanceEmail}" maxLength="190" liveChange="MC_ValidateEmail" valueStateText="{i18n>emailValueState}" />
				<Label text="{i18n>mobileNo}"/>
				<Input value="{CreateCustomerModel>/MobileNo}" id="MC_id_CustMob" placeholder="{i18n>placeholderMobileNo}" maxLength="10" liveChange="MC_ValidateMobileNo" valueStateText="{i18n>mobileNoValueState}" />
				<Label text="{i18n>custLut}" />
				<Input value="{CreateCustomerModel>/LUT}" maxLength="20" placeholder="{i18n>placeholderLUT}"/>
				<Label text="{i18n>address}" required="true" />
				<TextArea id="MC_id_CustAddress" value="{CreateCustomerModel>/Address}" placeholder="{i18n>addressPlaceholder}" maxLength="200" liveChange="MC_ValidateCommonFields" valueStateText="{i18n>addressValueState}" ></TextArea>
			</f:content>
		</f:SimpleForm>
		<HBox justifyContent="End" >
			<Button text="{i18n>save}" type="Emphasized" press="MC_onPressSave" class="submit" visible="{visiblePlay>/save}"></Button>
			<Button text="{i18n>submit}" type="Emphasized" press="MC_onPressSubmit" class="submit"  visible="{visiblePlay>/submit}"></Button>
			<Button text="{i18n>close}" press="MC_onPressClose" class="sendMail"></Button>
		</HBox>
	</Dialog>
</core:FragmentDefinition>