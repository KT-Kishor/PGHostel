
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">
    
    <l:Grid defaultSpan="L6 M6 S12" hSpacing="1" vSpacing="1">
        
        <!-- Left Side - Content Section -->
        <l:content>
            <l:Grid defaultSpan="L12 M12 S6">
                <l:content>
                    <VBox>
                        <Title text="Choose your path. Grow your career." level="H4" class="T_class"   />
                        <Text text="Learn the skills you need to take the next step. Adopting ethical behavior, corporate values, and professional communication. " class="T_textclass" />
                        <Label text=""/>
                        <Text text="If You are Interested"/>
                        <Button text="Contact us" type="Emphasized" press="Tbtn_onPress"/>
                    </VBox>
                </l:content>
            </l:Grid>
        </l:content>
        
        <!-- Right Side - Image Upload Section -->
        <l:content>
            <l:Grid defaultSpan="L12 M12 S12">
                <l:content>
                    <VBox>
                        <Title text="" level="H2"/>
                        
                        <Image id="imgDisplay" class="T_imageclass" width="100%" height="30%" src="../image/training.jpg"/>
                        <!-- <FileUploader
                            id="fileUploader"
                            change="onFileUpload"
                            fileType="jpg,png,jpeg"
                            mimeType="image/jpg,image/png,image/jpeg"
                            buttonText="Upload Image"/>  -->
                    </VBox>
                </l:content>
            </l:Grid>
        </l:content>
        
    </l:Grid>
    
</core:FragmentDefinition>
