<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">
    
    <l:Grid defaultSpan="XL6 L6 M12 S12" class="grid-container">
        
                <!-- SAP UI5 Section -->
                <VBox class="content-box"  backgroundDesign="Solid" >
                    <Text class="custom-trainee-title sapUiTinyMargin " text="Master SAP UI5 for your college project and internship"/>
                    <Text class="description-text" text="Learn the skills you need to take the next step. Adopting ethical behavior, corporate values, and professional communication."/>
                    <Text class="highlight-text" text="Kalpavriksha Technologies - Transform Your Career With Expert-led Project Training With Certificate of Internship!"/>
                    
                    <Text class="checkmark-text" text="✅ Hands-on, Project-Based Learning"/>
                    <Text class="checkmark-text" text="✅ Expert Trainings and Mentorship"/>
                    <Text class="checkmark-text" text="✅ Job-Ready Skills and Certification"/>
                    
                    <Text class="section-title" text="Training Includes"/>
                    <Text class="training-text" text="▪ SAP UI5, HANA, and OData Integration"/>
                    <Text class="training-text" text="▪ Build Responsive Enterprise Applications"/>
                    <Text class="training-text" text="▪ Real-World Project Portfolio"/>
                </VBox>

                
                <VBox class="content-box"  backgroundDesign="Solid">
                    <Text class="custom-trainee-title sapUiTinyMargin " text="Master CAPM for your career Growth and leadership"/>
                    <Text class="description-text" text="Get certified in CAPM with hands-on experience, live projects, and industry-recognized certification."/>
                    <Text class="highlight-text" text="Kalpavriksha Technologies - Advance Your Career with CAPM Training and Certification!"/>
                    
                    <Text class="checkmark-text" text="✅ Comprehensive CAPM Training"/>
                    <Text class="checkmark-text" text="✅ Industry-Recognized Certification"/>
                    <Text class="checkmark-text" text="✅ Project Management Skills"/>

                    <Text class="section-title" text="Training Includes"/>
                    <Text class="training-text" text="▪ CAPM Fundamentals and Exam Preparation"/>
                    <Text class="training-text" text="▪ Agile and Traditional Project Management"/>
                    <Text class="training-text" text="▪ Real-World Case Studies"/>
                </VBox>

             </l:Grid>
            <!-- Common Apply Now Button -->
       <FlexBox alignItems="Center" justifyContent="Center" class="btnclass" >
            <Button text="Apply Now" class="apply-button" press="Tbtn_onPress" type="Emphasized"/>
              </FlexBox>
        

   
</core:FragmentDefinition>
