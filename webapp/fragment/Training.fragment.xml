
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">
    
    <l:Grid defaultSpan="L6 M6 S12" hSpacing="1" vSpacing="1">
        
        <!-- Left Side - Content Section -->
        <l:content>
            <l:Grid defaultSpan="L12 M12 S12">
                <l:content>
                    <VBox>
                        <Title text="Content Section" level="H2"/>
                        <Label text="Enter Name:"/>
                        <Input placeholder="Enter your name here"/>
                        <Label text=""/>
                        <Button text="Contact us"/>
                    </VBox>
                </l:content>
            </l:Grid>
        </l:content>
        
        <!-- Right Side - Image Upload Section -->
        <l:content>
            <l:Grid defaultSpan="L12 M12 S12">
                <l:content>
                    <VBox>
                        <Title text="Image Section" level="H2"/>
                        <Image id="imgDisplay" width="100%" height="200px" src="../image/contactPage.jpg"/>
                        <!-- <FileUploader
                            id="fileUploader"
                            change="onFileUpload"
                            fileType="jpg,png,jpeg"
                            mimeType="image/jpg,image/png,image/jpeg"
                            buttonText="Upload Image"/>  -->
                    </VBox>
                </l:content>
            </l:Grid>
        </l:content>
        
    </l:Grid>
    
</core:FragmentDefinition>
