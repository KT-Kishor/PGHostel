<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">
    
    <l:Grid defaultSpan="XL6 L6 M12 S12" class="grid-container">
        
                <!-- SAP UI5 Section -->
                <VBox class="HRSolution sapUiSmallMargin"  backgroundDesign="Solid" >
                <HBox justifyContent="Center" class="section-image">
                <Image src="../image/SAPUI5 (1).png" width="auto" height="200px" visible="true" class="section-image"/>
                  </HBox>

                    <Text class="custom-trainee-title sapUiSmallMarginBegin" text="{i18n>traineesapui5}"/>
                    <Text class="description-text sapUiSmallMarginBegin" text="{i18n>traineeDes1}"/>
                    <Text class="highlight-text sapUiSmallMarginBegin" text="{i18n>traineeDes2}"/>
                    
                    <Text class="checkmark-text sapUiSmallMarginBegin" text="✅ {i18n>traineeUi5highlight}"/>
                    <Text class="checkmark-text sapUiSmallMarginBegin" text="✅ {i18n>traineeUi5highlight2}"/>
                    <Text class="checkmark-text sapUiSmallMarginBegin" text="✅ {i18n>traineeUi5highlight3}"/>
                    
                    <Text class="section-title sapUiSmallMarginBegin" text="{i18n>traineeInclude}"/>
                    <Text class="training-text sapUiSmallMarginBegin" text="▪ {i18n>traineeInclude1}"/>
                    <Text class="training-text sapUiSmallMarginBegin" text="▪ {i18n>traineeInclude2}"/>
                    <Text class="training-text sapUiSmallMarginBegin" text="▪ {i18n>traineeInclude3}"/>
                    <Link class="training_Course sapUiSmallMarginBegin" text="View Course Details!" press="onSapui5coursepress"/>
                    <HBox justifyContent="End" >
                <Button text="{i18n>careersapply}"  press="onUI5ress" class="big-apply-button sapUiLargeMarginEnd" type="Emphasized"/>
            </HBox> 
                </VBox>
                <VBox class="HRSolution sapUiSmallMargin"  backgroundDesign="Solid">
                <HBox justifyContent="Center" class="section-image">
                <Image src="../image/SAP CAPM.jpg" width="auto" height="200px" visible="true" class="section-image"/>
                  </HBox>
                    <Text class="custom-trainee-title sapUiSmallMarginBegin" text="{i18n>traineeCapmtitle}"/>
                    <Text class="description-text sapUiSmallMarginBegin" text="{i18n>traineeCapmhighlight}"/>
                    <Text class="highlight-text sapUiSmallMarginBegin" text="{i18n>traineeCapmhighlight2}"/>
                    
                    <Text class="checkmark-text sapUiSmallMarginBegin" text="✅ {i18n>traineeCapmDes1}"/>
                    <Text class="checkmark-text sapUiSmallMarginBegin" text="✅ {i18n>traineeCapmDes2}"/>
                    <Text class="checkmark-text sapUiSmallMarginBegin" text="✅ {i18n>traineeCapmDes3}"/>

                    <Text class="section-title sapUiSmallMarginBegin" text="{i18n>traineeInclude}"/>
                    <Text class="training-text sapUiSmallMarginBegin" text="▪ {i18n>traineeCapminclude}"/>
                    <Text class="training-text sapUiSmallMarginBegin" text="▪ {i18n>traineeCapminclude2}"/>
                    <Text class="training-text sapUiSmallMarginBegin" text="▪ {i18n>traineeCapminclude3}"/>
                     <Link class="training_Course sapUiSmallMarginBegin" text="View Course Details!" press="onCapmCoursepress"/>
                     <HBox justifyContent="End">
                <Button text="{i18n>careersapply}"  press="onCapmpress" class="big-apply-button sapUiLargeMarginEnd" type="Emphasized"/>
            </HBox>
                </VBox>
             </l:Grid>
</core:FragmentDefinition>
