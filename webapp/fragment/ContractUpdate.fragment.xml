<core:FragmentDefinition
    displayBlock="true"
	xmlns:f="sap.ui.layout.form"
	xmlns="sap.uxap"
	xmlns:m="sap.m"
	xmlns:core="sap.ui.core">
	<m:Page id="CUF_id_pageTrainee" title="{i18n>contractDetails}" navButtonPress="CU_onBack" showNavButton="true">
		<ObjectPageLayout id="CU_id_ObjectPage"
            useIconTabBar="true"
            showTitleInHeaderContent="true"
            class="sapUiSmallmarginResponsive">
			<headerTitle>
				<ObjectPageDynamicHeaderTitle>
					<!-- Expanded heading to display Consultant Name and consulting service -->
					<expandedHeading>
						<m:Title text="{oFilteredContractModel>/ConsultantNameSalutation} {oFilteredContractModel>/ConsultantName}" wrapping="true" width="100%" />
					</expandedHeading>
					<expandedContent>
						<m:Label text="{oFilteredContractModel>/ConsultingService}" wrapping="true" width="100%" />
					</expandedContent>
				</ObjectPageDynamicHeaderTitle>
			</headerTitle>
			<!-- Object Page Sections -->
			<sections>
				<ObjectPageSection >
					<subSections>
						<!-- Sub-section for displaying contract basic information -->
						<ObjectPageSubSection  title="{i18n>contractsBasic}">
							<blocks>
								<!-- SimpleForm for displaying and editing contract details -->
								<f:SimpleForm 
                                 editable="true" layout="ColumnLayout"
              labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
              adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"
              emptySpanM="0" emptySpanS="0" columnsXL="2" columnsL="2" columnsM="1">
									<f:content>
										<!-- Agreement Number -->
										<m:Label text="{i18n>contractNo}"/>
										<m:Text text="{oFilteredContractModel>/ContractNo}" />
										<!-- Consultant Name -->
										<m:Label text="{i18n>consultantName}" required="true"/>
                                         <m:Select
                                               editable="{simpleForm>/editable}"
                                               selectedKey="{oFilteredContractModel>/Salutation}"
                                               items="{Salutation>/salutation}"
                                               width="100%">
												<!-- Binding the key and text of the Select control to the NameSalutation model -->
												<core:Item key="{Salutation>text}" text="{Salutation>text}"/>
												</m:Select>
										<m:Input value="{oFilteredContractModel>/ConsultantName}" liveChange="CD_validateName" maxLength="50" id="CU_id_ConsultantName" valueStateText="{i18n>nameConsultantValueState}" editable="{simpleForm>/editable}"  />
										<!-- Consulting Service -->
										<m:Label text="{i18n>consultingService}" required="true"/>
										<m:Input value="{oFilteredContractModel>/ConsultingService}" liveChange="CD_ValidateCommonFields" maxLength="50" valueStateText="{i18n>roleValueState}" id="CU_id_ConsultingService" editable="{simpleForm>/editable}" />
										<!-- Consultant Email -->
										<m:Label text="{i18n>consultantEmailID}" required="true"/>
										<m:Input value="{oFilteredContractModel>/ContarctEmail}" liveChange="CD_validateEmail"  valueStateText="{i18n>emailValueState}" id="CU_id_ContractEmailID" editable="{simpleForm>/editable}" maxLength="100" />
										<!-- Agreement Date -->
										<m:Label text="{i18n>agreementDate}" required="true"/>
										<m:DatePicker value="{path:'oFilteredContractModel>/AgreementDate' ,formatter:'.Formatter.formatDate'}" editable="{simpleForm>/editable}" id="CU_id_AgreementDate" valueFormat="dd/MM/yyyy" displayFormat="dd/M/yyyy" change="CD_validateDate" valueStateText="{i18n>dateValueState}"/>
										<!-- Consultant Address -->
										<m:Label text="{i18n>consultantAddress}" required="true"/>
										<m:TextArea value="{oFilteredContractModel>/ConsultantAddress}" valueStateText="{i18n>addressValueState}" liveChange="CD_ValidateCommonFields" id="CU_id_ContractAddress" maxLength="120" editable="{simpleForm>/editable}"/>
										<!-- End Client -->
										<m:Label text="{i18n>endClient}" required="true"/>
										<m:ComboBox items="{CreateCustomerModel>/}" valueState="None" value="{oFilteredContractModel>/EndClient}" id="CU_id_EndClient" change="CD_validateName"  editable="{simpleForm>/editable}">
										<core:Item key="{CreateCustomerModel>Salutation} {CreateCustomerModel>name}" text="{CreateCustomerModel>companyName}" />
										</m:ComboBox>	
										<!-- <m:Input value="{oFilteredContractModel>/EndClient}" liveChange="onLiveValidation" id="idEndClient"  editable="{simpleForm>/editable}" maxLength="50" /> -->

										<m:Label text="{i18n>clientReportContact}" required="true"/>
                                            <m:Select
                                               editable="{simpleForm>/editable}"
                                               selectedKey="{oFilteredContractModel>/Salutation2}" 
                                                items="{Salutation>/salutation}" width="100%">
												<!-- Binding the key and text of the Select control to the NameSalutation model -->
												<core:Item key="{Salutation>text}" text="{Salutation>text}" />
												</m:Select>		
										<!-- Client Report Contact Name -->
										<m:Input value="{oFilteredContractModel>/ClientReportContact}" id="CU_id_ClientReportContact" editable="{simpleForm>/editable}" maxLength="50" liveChange="CD_validateName" valueStateText="{i18n>commonNameValueState}"/>
										<!-- Location where services are provided -->
										<m:Label text="{i18n>locationswhereServices}" required="true"></m:Label>
										<m:Select selectedKey="{oFilteredContractModel>/Location}" items="{WorkingMode>/location}" editable="{simpleForm>/editable}">
											<core:Item key="{WorkingMode>Location}" text="{WorkingMode>Location}" />
										</m:Select>
										<!-- Contract Status -->
										<m:Label text="{i18n>contractStatus}" required="true"/>
										<m:ComboBox value="{oFilteredContractModel>/ContractStatus}" items="{AssignmentStatus>/assignmentStatus}" editable="{simpleForm>/Status}" change="onChangeStartEndDate">
											<core:Item key="{AssignmentStatus>ID}" text="{AssignmentStatus>Value}"/>
										</m:ComboBox>										
										<!-- Assignment Start Date -->
										<m:Label text="{i18n>assignmentStartDate}" required="true"/>
										<m:DatePicker value="{path:'oFilteredContractModel>/AssignmentStartDate' ,formatter:'.Formatter.formatDate'}"  id="CU_id_AssignmentStartDate" displayFormat="dd/M/yyyy" editable="{simpleForm>/editable}" change="CD_validateDate" valueStateText="{i18n>dateValueState}" valueFormat="dd/MM/yyyy" />
										<!-- Assignment End Date -->
										<m:Label text="{i18n>assignmentEndDate}" required="true"/>
										<m:DatePicker value="{path:'oFilteredContractModel>/AssignmentEndDate' ,formatter:'.Formatter.formatDate'}" id="CU_id_AssignmentEndDate" displayFormat="dd/M/yyyy" editable="{simpleForm>/editable}" valueFormat="dd/MM/yyyy" change="CD_validateDate" valueStateText="{i18n>dateValueState}"/>
										<!-- Consultant Rate -->
										<!-- <m:Label text="{i18n>consultantRate}" required="true"/>
										<m:Input value="{oFilteredContractModel>/ConsultantRate}" liveChange="onLiveValidation" id="idConsultantRate" editable="{simpleForm>/editable}" maxLength="50"/> -->
										<m:Label text="{i18n>rate}" required="true" />
										<m:RadioButtonGroup id="CU_id_rbg3" columns="3" selectedIndex="{oFilteredContractModel>/HrDaliyMonth}" select="RadioButtonSelect" editable="{simpleForm>/editable}" >
											<m:RadioButton id="CU_id_RB3-1" text="{i18n>rateHour}" />
											<m:RadioButton id="CU_id_RB3-2" text="{i18n>rateDaily}" />
											<m:RadioButton id="CU_id_RB3-3" text="{i18n>rateMonthly}" />
										</m:RadioButtonGroup>
										<!-- Input for Amount -->
										<m:Label text="{i18n>amount}" required="true" />
										<m:Input value="{oFilteredContractModel>/Amount}" valueState="None" id="CU_id_EditAmountInput"  placeholder="{i18n>amountPlaceholder}" liveChange="CD_validateAmount"  maxLength="15" valueStateText="{i18n>ammountValuState}"  editable="{simpleForm>/editable}" />
										<m:Select items="{CurrencyModel>/}" selectedKey="{oFilteredContractModel>/currency}" visible="true" width="100%" class="marginLeft" editable="{simpleForm>/editable}">
											<core:Item key="{CurrencyModel>currency}" text="{CurrencyModel>currency}" />
										</m:Select>
										<!-- Payment Terms -->
										<m:Label text="{i18n>paymentterms}" required="true"></m:Label>
										<m:Select selectedKey="{oFilteredContractModel>/PaymentTerms}" items="{ContractpaymentModel>/}" editable="{simpleForm>/editable}">
											<core:Item key="{ContractpaymentModel>days}" text="{ContractpaymentModel>days}" />
										</m:Select>									
										<!-- Specific Insurance Requirement -->
										<m:Label text="{i18n>specificInsuranceRequirement}" required="true"></m:Label>
										<m:Select id="CU_id_InsuranceRequirement" selectedKey="{oFilteredContractModel>/SpecificInsuranceRequirement}" editable="{simpleForm>/editable}">
											<core:Item key="Yes" text="{i18n>yes}" />
											<core:Item key="No" text="{i18n>no}" />
										</m:Select>
										<!-- Contract Period -->
										<m:Label text="{i18n>contractPeriod}" required="true" />
										<m:Select id="CU_id_WarrantyDate" selectedKey="{oFilteredContractModel>/WarrantyDate}" items="{ContractPeriod>/ContractPeriod}" editable="{simpleForm>/editable}">
											<core:Item key="{ContractPeriod>Months}" text="{ContractPeriod>Months}" />
										</m:Select>
										<!-- Expenses Claim -->
										<m:Label text="{i18n>expensesClaim}" required="true"/>
										<m:Select selectedKey="{oFilteredContractModel>/ExpensesClaim}" editable="{simpleForm>/editable}">
											<core:Item key="Yes" text="{i18n>yes}" />
											<core:Item key="No" text="{i18n>no}" />
										</m:Select>
										<m:Label text="{i18n>contractLocation}" required="true"/>
										<m:ComboBox  change="onLiveValidation"  items="{BaseLocationModel>/}" id="CU_id_ContractCity" value="{oFilteredContractModel>/ContractLocation}" editable="{simpleForm>/editable}">
											 <core:ListItem key="{BaseLocationModel>city}" text="{BaseLocationModel>city}" additionalText="{BaseLocationModel>branchCode}" />
										</m:ComboBox>

										<m:Label text="Comments" />
										<m:TextArea  value="{oFilteredContractModel>/Comments}" id="CU_id_Comments" editable="{simpleForm>/Status}" liveChange="CD_ValidateCommonFields" valueStateText="{i18n>commentsValueState}"  maxLength="200"/>
									</f:content>
								</f:SimpleForm>
							</blocks>
						</ObjectPageSubSection>
					</subSections>
				</ObjectPageSection>
			</sections>
		</ObjectPageLayout>
		<m:footer>
			<!-- button with expression binding for visibility -->
			<m:Bar>
				<m:contentRight>
					<m:Button text="{= ${viewModel>/isEditMode} ? ${i18n>save} : ${i18n>edit} }" press=".onEditOrSavePress" visible="{ContractStatus>/status}" />
					<m:Button text="{i18n>tileFooter}" id="CU_id_Mail" press="onPressSendEmail" visible="{ContractStatus>/status}"/>
					<m:Button text="{i18n>GeneratePDF}" id="CU_id_Merge" press="onPressMerge" visible="{ContractStatus>/status}" />
				</m:contentRight>
			</m:Bar>
		</m:footer>
	</m:Page>
</core:FragmentDefinition>