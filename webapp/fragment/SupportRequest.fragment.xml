<c:FragmentDefinition
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified">

	<Dialog id="HF_id_HostelFeaturesDialog1"
		type="Message"
		class="sapUiContentPadding"
		contentWidth="28rem"
		resizable="true"
		draggable="true">

		<customHeader>
			<Bar class="barheader">
				<contentMiddle>
					<Title text="Support Request"/>
				</contentMiddle>
			</Bar>
		</customHeader>

		<f:SimpleForm
			editable="true"
			layout="ResponsiveGridLayout"
			labelSpanXL="4"
			labelSpanL="3"
			labelSpanM="4"
			labelSpanS="12"
			columnsXL="2"
			columnsL="2"
			columnsM="1">

			<f:content>

				<!-- Issue Name -->
				<Label text="{i18n>issuename}" required="true"/>
				<Input
					id="SR_id_IssueName"
					placeholder="{i18n>enterissuename}"
                    valueStateText="Enter Issue Name"
					value="{SupportModel>/IssueName}"
                    liveChange="onIssuenamechanges"
					maxLength="100"/>

				<!-- Issue Type -->
				<Label text="{i18n>issuecategory}" required="true"/>
				<ComboBox
					id="SR_id_IssueType"
                    valueStateText="{i18n>enterissuetype}"
					placeholder="Select Issue Type"
                    value="{SupportModel>/IssueType}"
                    change="onissuetypechanges"
                     items="{SupportRequest>/}">
					<core:Item key="{SupportRequest>ID}" text="{SupportRequest>IssueType}"/>
					
				</ComboBox>

				<!-- Issue Description -->
				<Label text="{i18n>issuedetails}" required="true"/>
				<TextArea
					id="SR_id_IssueDescription"
					rows="4"
                    liveChange="ondescriptionchnages"
                    valueStateText="{i18n>enterdetails}"
					placeholder="Enter Issue Description"
					value="{SupportModel>/IssueDescription}"
					maxLength="500"/>

				<!-- Raised By -->
				<Label text="{i18n>raisedby}" required="true"/>
				<Input
					id="SR_id_RaisedBy"
                    liveChange="onchangesRaisedby"
                    valueStateText="{i18n>enteryourname}"
					value="{SupportModel>/RaisedBy}"
					placeholder="Enter Name"/>

				<!-- Email -->
				<Label text="{i18n>contactemail}" required="true"/>
				<Input
					id="SR_id_Email"
                    liveChange="onEmailchange"
					type="Email"
                    valueStateText="{i18n>enteremailis}"
					value="{SupportModel>/Email}"
					placeholder="Enter Email"/>

				<!-- Upload Image (UNCHANGED) -->
				<Label text="{i18n>addImage}" required="true"/>
				  <MessageStrip
                    text=" Image files larger than 2 MB are not allowed."
                    type="Warning"
                    showIcon="true"
                    enableFormattedText="true"
                    class="sapUiSmallMarginBottom"
                />

			<VBox alignItems="Start" width="100%" renderType="Bare">

    <!-- Upload Button -->
    <HBox width="100%">
        <u:FileUploader
            id="HFF_id_FileUploader1"
            fileSizeExceed="onFileSizeExceed"
            maximumFileSize="2"
            typeMissmatch="onFileTypeMissmatch"
            fileType="jpg,jpeg,png"
            change="onSupportrequestChange"
            buttonOnly="true"
            sameFilenameAllowed="true"
            iconFirst="true"
            buttonText="Upload Images"
            multiple="true"
            uploadOnChange="false"/>
    </HBox>

    <!-- Tokens -->
    <Tokenizer
        id="HFF_id_TokenList1"
        width="100%"
        class="sapUiSmallMarginTop"
        tokens="{tokenModel>/tokens}"
        tokenDelete="onTokenDelete">

        <Token
            key="{tokenModel>key}"
            text="{tokenModel>text}" />

    </Tokenizer>

</VBox>

			</f:content>
		</f:SimpleForm>

		<footer>
			<Toolbar>
				<ToolbarSpacer/>
				<Button
					text="Submit"
					press="onSupportSubmit"
					class="marginRight myUnifiedBtn"/>
				<Button
					text="Cancel"
					press="HF_onCancelButtonPress"
					class="marginRight myUnifiedBtn"/>
			</Toolbar>
		</footer>

	</Dialog>

</c:FragmentDefinition>