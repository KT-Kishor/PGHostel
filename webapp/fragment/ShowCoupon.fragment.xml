<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="SC_id_ValueHelpDialog"
        title="{i18n>couponDetails}"
        contentWidth="50%"
    >
        <content>
            <Table
            sticky="ColumnHeaders"
                noDataText="{i18n>noCouponsAvailable}"
                class="couponTitle"
                items="{ShowCouponDetails>/}"
            >
                <columns>
                    <Column>
                        <Text class="couponTitleOpp" text="{i18n>CDCouponCode}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text class="couponTitleOpp" text="{i18n>CDMinOrderValue}" />
                    </Column>
                    <!-- <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text text="{i18n>CDDiscountType}" />
                    </Column> -->
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text class="couponTitleOpp" text="{i18n>CouponOffer}" />
                    </Column>
                    <Column
                        minScreenWidth="Desktop"
                        demandPopin="true"
                    >
                        <Text class="couponTitleOpp" text="{i18n>Description}" />
                    </Column>
                    
                </columns>
                <items>
                    <ColumnListItem
                        type="Active"
                        press="SC_onVHDPick"
                    >    
                        <cells>
                            <Title class="couponTitle" text="{ShowCouponDetails>CouponCode}" />
                            <Text
                                text="{ShowCouponDetails>MinOrderValue}"
                                wrapping="true"
                                class="couponTitleOpp"
                            />
                            <!-- <Text
                                text="{ShowCouponDetails>DiscountType}"
                                wrapping="true"
                            /> -->
                            <Text
                                text="{
                                    parts: [
                                        { path: 'ShowCouponDetails>DiscountType' },
                                        { path: 'ShowCouponDetails>DiscountValue' }
                                        
                                    ],
                                    formatter: '.Formatter.formatDiscount'
                                } OFF" class="couponTitle"
                                wrapping="true"
                            />
                            <Text
                                text="{ShowCouponDetails>Description}"
                                wrapping="true"
                                class="couponTitleOpp"
                            />


                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <beginButton>
            <Button
                text="{i18n>close}"
                press="SC_onVHDClose"
                class="myUnifiedBtn"
            />
        </beginButton>
    </Dialog>
</core:FragmentDefinition>
