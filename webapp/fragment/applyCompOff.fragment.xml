<core:FragmentDefinition 
	xmlns:odata="sap.ui.comp.odata" 
	xmlns="sap.m" 
	xmlns:f="sap.ui.layout.form" 
	xmlns:core="sap.ui.core">
	<Dialog title="{i18n>applycomp}">
		<f:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="12" adjustLabelSpan="false" emptySpanXL="4" emptySpanL="4" emptySpanM="4" emptySpanS="0" columnsXL="1" columnsL="1" columnsM="1" singleContainerFullSize="false">
			<f:content>
				<!-- Employee ID -->
				<Label text="{i18n>employeeID}"/>
				<Input value="{LeaveTempModel>/employeeID}" editable="false"/>
				<!-- Employee Name -->
				<Label text="{i18n>employeeName}"/>
				<Input value="{LeaveTempModel>/employeeName}" editable="false"/>
				<!-- Email -->
				<Label text="{i18n>emailId}"/>
				<Input value="{LeaveTempModel>/email}" editable="false"/>
				<!-- Leave Type -->
				<Label text="{i18n>type}" />
				<ComboBox selectedKey="CompOff" editable="false" id="AL_id_compoff_Leavetype">
					<core:Item key="CompOff" text="CompOff" />
				</ComboBox>
				<VBox>
					<!-- From Date -->
					<Label text="{i18n>fromDate}" required="true" />
					<DatePicker value="{LeaveTempModel>/fromDate}" id="AL_id_CF_FromDate" displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy" change="AL_ValidateFromDate" valueStateText="{i18n>dateValueState}" maxDate="{LeaveTempModel>/maxDate}" liveChange="onLiveChange" legend="legend" minDate="{LeaveTempModel>/minDate}"/>
					<!-- To Date -->
					<Label text="{i18n>toDate}" required="true" />
					<DatePicker minDate="{LeaveTempModel>/MinToDate}" id="AL_id_CF_ToDate" value="{LeaveTempModel>/toDate}" displayFormat="dd/MM/yyyy" maxDate="{LeaveTempModel>/maxDate}" valueFormat="dd/MM/yyyy" change="AL_ValidateToDate" valueStateText="{i18n>dateValueState}" liveChange="onLiveChange" legend="legend" />
					<!-- Half Day CheckBox -->
					<CheckBox text="{i18n>halfDay}" select="onHalfDaySelect" selected="{LeaveTempModel>/halfDay}"/>
				</VBox>
				<!-- Number of Days -->
				<Label text="{i18n>noOfDays}"/>
				<Input value="{LeaveTempModel>/NoofDays}" editable="false"/>
				<!-- Add Feedback -->
				<Label text="{i18n>comments}" required="true"></Label>
				<TextArea value="{LeaveTempModel>/Comments}" rows="2" id="AL_id_CompoffComments" liveChange="AL_ValidateCommonFields" valueStateText="{i18n>commentsValueState}" maxLength="200" placeholder="{i18n>enterComments}"/>
			</f:content>
		</f:SimpleForm>
		<!-- Buttons for Submit and Close actions -->
		<footer>
			<Toolbar>
				<ToolbarSpacer/>
				<Button text="{i18n>submit}" type="Accept" press="AL_onPressSubmit" class="sendMail" visible="{= !${LeaveTempModel>/isUpdate} }"/>
				<Button text="{i18n>save}" type="Accept" press="AL_onPressSave" class="sendMail" visible="{= ${LeaveTempModel>/isUpdate} }"/>
				<Button text="{i18n>close}" class="sendMail" press="AL_onPressClose" type="Reject"/>
			</Toolbar>
		</footer>
	</Dialog>
</core:FragmentDefinition>