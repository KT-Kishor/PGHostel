<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    displayBlock="true"
    xmlns:g="sap.f"
>
    <Dialog
        id="idPaymentDialog1"
        draggable="true"
        resizable="true"
        class="paymentDialogRoot"
        contentWidth="32rem"
        contentHeight="auto"
    >
        <customHeader>
            <Bar class="barheader">
                    <contentMiddle>
                <Title text="{i18n>proceedtoPayment}" />
            </contentMiddle>
              
            </Bar>
        </customHeader>
        
        <f:SimpleForm
            id="Exp_id_SimpleFrom1"
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="12"
            labelSpanL="12"
            labelSpanM="12"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <VBox>
                <!-- ===== GRAND TOTAL ===== -->
                <HBox>
                    <Label
                        text="{i18n>grandTotal}"
                        class="sapUiTinyMargin"
                    />
                    <Text
                        text="{parts: ['HostelModel>/GrandTotal','HostelModel>/Currency'],formatter: '.Formatter.formatCurrency'}"
                    />
                </HBox>

                <!-- ===== PAYMENT TYPE (Radio) ===== -->
                <Label
                    text="{i18n>paymentType}"
                    design="Bold"
                />
                <RadioButtonGroup
                    id="idPaymentTypeGroup1"
                    columns="1"
                    select="onPaymentTypeSelect"
                    selectedIndex="2"
                    class="paymentTypeGroup"
                >
                    <RadioButton text="{i18n>payatcheckintime}" />
                    <!-- <RadioButton text="{i18n>uPI}" /> -->
                    <!-- <RadioButton text="{i18n>creditDebitCard}" /> -->
                </RadioButtonGroup>

                <!-- MAIN GRID -->
                <l:Grid
                    defaultSpan="L6 M12 S12"
                    hSpacing="2"
                    vSpacing="2"
                >
                    <!-- LEFT COLUMN -->
                    <VBox
                        id="idLeftColumn1"
                        class="sapUiSmallMargin"
                    >
                        <!-- UPI SECTION -->
                        <VBox
                            id="idUPISection1"
                            visible="true"
                        >
                            <Title
                                text="{i18n>uPIPayment}"
                                level="H4"
                            />
                            <Image
                                src="image/UPI.jpg"
                                width="150px"
                                class="UPIQRCodeBox"
                            />
                            <Text text="{i18n>scanusinganyUPIapp}" />

                          
                        </VBox>

                        <!-- CARD SECTION -->
                        <VBox
                            id="idCardSection1"
                            visible="false"
                        >
                            <Label text="{i18n>cardNumber}" />
                            <Input
                                id="idCardNumber1"
                                maxLength="16"
                                placeholder="{i18n>enterCardNumber}"
                            />

                            <Label text="{i18n>expiry}" />
                            <Input
                                id="idCardExpiry1"
                                maxLength="5"
                                placeholder="MM/YY"
                            />

                            <Label text="{i18n>cVV}" />
                            <Input
                                id="idCardCVV1"
                                type="Password"
                                maxLength="3"
                                placeholder="***"
                            />
                        </VBox>
                    </VBox>

                    <!-- RIGHT COLUMN -->
                    <VBox
                        id="idRightPanel1"
                        class="sapUiSmallMargin"
                    >
                        <Title
                            text="{i18n>paymentVerification}"
                            level="H4"
                        />


                        <Label
                            text="{i18n>amount}"
                           
                        />      
                        <Input
                            id="idAmount1"
                            type="Number"
                            value="{HostelModel>/PerMonthNoPerson}"
                            placeholder="{i18n>enterAmount}"
                            maxLength="15"
                            editable="false"
                        />

                        <Label
                            text="{i18n>paymentType}"
                           
                        />
                        <Input
                            id="idPaymentTypeField1"
                            placeholder="{i18n>enterPaymentType}"
                            value="{PaymentModel>/PaymentType}"
                            maxLength="20"
                            editable="false"
                          
                        />

                        <Label
                            text="{i18n>bankTransactionID}"
                            required="true"
                        />
                        <Input
                            id="idTransactionID1"
                            placeholder="{i18n>enterTransactionID}"
                            liveChange="onTransactionIDChange"
                            valueStateText="Enter Transaction ID"
                            maxLength="25"
                        />

                        <Label
                            text="{i18n>date}"
                        />
                        <DatePicker
                            id="idPaymentDate1"
                            displayFormat="dd/MM/yyyy"
                            valueFormat="dd/MM/yyyy"
                            value="{PaymentModel>/PaymentDate}"
                            change=".onPaymentDateChange"
                            valueStateText="{i18n>selectPaymentDate}"
                            editable="false"
                        />
                    </VBox>
                </l:Grid>
            </VBox>
          
        </f:SimpleForm>
       
        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Button
                    text="{i18n>submitPayment}"
                    tooltip="{i18n>submitPayment}"
                    class="myUnifiedBtn"
                    press="onSubmitPress"
                />
                <Button
                    text="{i18n>CancelButton}"
                    tooltip="{i18n>CancelButton}"
                    press="onPaymentClose"
                    class="myUnifiedBtn"
                />
            </Toolbar>
        </footer>
    </Dialog>
</core:FragmentDefinition>