<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">
    
    <l:Grid defaultSpan="XL6 L6 M12 S12" class="grid-container">
        
                <!-- HR solution -->
              <VBox class="HRSolution sapUiSmallMargin" backgroundDesign="Solid" >
            
            <!-- IMAGE OR ICON AT TOP -->
            <HBox justifyContent="Center" class="section-image">
                <Image src="../image/HR.webp" width="auto" height="250px" visible="true" class="section-image"/>
            </HBox>
            <Text class="hr-text sapUiSmallMargin" text="HR Solution" />
            <Text class="description-text sapUiSmallMargin" text="{i18n>HRsolution}"/>
              
            <!-- BUTTON BOTTOM-ALIGNED -->
                 <HBox justifyContent="End" >
                <Button text="Take a Product Tour"
                        press="onHRSolutionPress"
                        class="Takeatour sapUi-Std-PaddingS"
                        type="Emphasized" width="200px" />
          </HBox>
        </VBox>
                <VBox class="HRSolution sapUiSmallMargin" backgroundDesign="Solid" >
            
            <!-- Invoice management -->
            <HBox justifyContent="Center" class="section-image">
                <Image src="../image/Invoice .png" width="auto" height="250px" visible="true" class="section-image"/>
            </HBox>
          <Text class="hr-text sapUiSmallMargin" text="Invoice Manage" />
            <Text class="description-text sapUiSmallMargin" text="{i18n>invoicemanage}"/>
              
          
             <HBox justifyContent="End" >
                <Button text="Take a Product Tour"
                        press="onInvoiceManagePress"
                        class="Takeatour sapUi-Std-PaddingS"
                        type="Emphasized" width="200px"/>
            </HBox>
        </VBox>
                 <VBox class="HRSolution sapUiSmallMargin" backgroundDesign="Solid" >
            
            <!-- Company Asset Management -->
            <HBox justifyContent="Center" class="section-image">
                <Image src="../image/Asset.jpg" width="auto" height="250px" visible="true" class="section-image"/>
            </HBox>
            <Text class="hr-text sapUiSmallMargin" text="Company Asset Management" />
            <Text class="description-text sapUiSmallMargin" text="{i18n>Companyassetmanage}"/>
              
            <!-- BUTTON BOTTOM-ALIGNED -->
             <HBox justifyContent="End" >
                <Button text="Take a Product Tour"
                        press="onAssetPress"
                        class="Takeatour sapUi-Std-PaddingS"
                        type="Emphasized" width="200px"/>
         </HBox>
        </VBox>
                 <VBox class="HRSolution sapUiSmallMargin" backgroundDesign="Solid" >
            
            <!--Recruitment  -->
            <HBox justifyContent="Center" class="section-image">
                <Image src="../image/Interview.jpg" width="auto" height="250px" visible="true" class="section-image"/>
            </HBox>
            <Text class="hr-text sapUiSmallMargin" text="Recruitment" />
            <Text class="description-text sapUiSmallMargin " text="{i18n>recruitmentmanage}"/>
              
            <!-- BUTTON BOTTOM-ALIGNED -->
             <HBox justifyContent="End" >
                <Button text="Take a Product Tour"
                        press="onrecruitmentPress"
                      class="Takeatour sapUi-Std-PaddingS"
                        type="Emphasized" width="200px"/>
           </HBox>
        </VBox>
                 <VBox class="HRSolution sapUiSmallMargin" backgroundDesign="Solid" >
            
            <!-- Automotive -->
            <HBox justifyContent="Center" class="section-image">
                <Image src="../image/Automotive.jpg" width="auto" height="250px" visible="true" class="section-image"/>
            </HBox>
            <Text class="hr-text sapUiSmallMargin" text="Automotive Solution" />
            <Text class="description-text sapUiSmallMargin" text="{i18n>AutomobileSolution}"/>
           
           <HBox justifyContent="End" >
                <Button text="Take a Product Tour"
                        press="onAutoMotivePress"
                     class="Takeatour sapUi-Std-PaddingS"
                        type="Emphasized" width="200px"/>
          </HBox>
        </VBox>
          <VBox class="HRSolution sapUiSmallMargin" backgroundDesign="Solid" >
            
            <!-- ID card  -->
            <HBox justifyContent="Center" class="section-image">
                <Image src="../image/IDcard1.png" width="auto" height="250px" visible="true" class="section-image"/>
            </HBox>
            <Text class="hr-text sapUiSmallMargin" text="ID Card Generation" />
            <Text class="description-text sapUiSmallMargin" text="{i18n>idcardgeneration}"/>
              
         
          <HBox justifyContent="End" >
                <Button text="Take a Product Tour"
                        press="onIdCardPress"
                     class="Takeatour sapUi-Std-PaddingS"
                        type="Emphasized" width="200px"/>
          </HBox>
        </VBox>
             </l:Grid>
</core:FragmentDefinition>
