<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <SelectDialog
        id="TSF_id_Dialog"
        title="{i18n>selectAss}"
        items="{oAssignmentModel>/}"
        confirm=".onValueHelpDialogClose"
        cancel=".onValueHelpCancel">
        <StandardListItem
            iconDensityAware="false"
            iconInset="false"
            title="{oAssignmentModel>TaskName}"
            description="{oAssignmentModel>TaskID}" />
    </SelectDialog>
</core:FragmentDefinition>
