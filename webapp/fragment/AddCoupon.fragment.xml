<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="ApplyNowDialog"
        title="Apply Coupon"
        contentWidth="20rem"
        draggable="true"
        resizable="true">

        <VBox class="sapUiSmallMargin">
            
            <Label text="{i18n>couponCode}"/>
            
            <Input
            value="{HostelModel>/CouponCode}"
               valueHelpIconSrc="sap-icon://decline"
                 valueHelpRequest="oncancelCoupon"
                  change="onCouponLiveChange"
                id="BookingcouponInput"
                 placeholder="{i18n>enterCoupon}"/>

        </VBox>

        <beginButton>
            <Button
                text="Apply Now"
                type="Emphasized"
                press="onChangeCouponCode"/>
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press="onCloseApplyNow"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>