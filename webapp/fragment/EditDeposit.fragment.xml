<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <Dialog
        id="DepositDialog"
        title="Deposit Details"
        contentWidth="35rem"
        contentHeight="auto"
        draggable="true"
        resizable="true">

        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="4"
            labelSpanM="6"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="0"
            emptySpanL="0"
            emptySpanM="0"
            emptySpanS="0"
            columnsXL="2"
            columnsL="2"
            columnsM="1">

            <f:content>

                <!-- Booking ID -->
                <Label text="Booking ID"/>
                <Text id="depositBookingID" text="{DepositModel>BookingID}"/>

                <!-- Customer Name -->
                <Label text="Customer Name"/>
                <Text id="depositCustomerName" text="{DepositModel>CustomerName}"/>

                <!-- Deposit Date -->
                <Label text="Deposit Date" required="true"/>
                <DatePicker
                    id="depositDate"
                    value="{DepositModel>DepositDate}"
                    displayFormat="dd/MM/yyyy"
                    change="ondepositdate"
                    valueFormat="yyyy-MM-dd"
                    valueStateText="Enter deposit date"
                    />

                <!-- Deposit Amount -->
                <Label text="Deposit Amount"/>
                <Input
                    id="depositAmount"
                    value="{DepositModel>DepositAmount}"
                    type="Number"
                    placeholder="Enter Deposit Amount" editable="false"/>

                <!-- Return Date -->
                <Label text="Return Date" required="true"/>
                <DatePicker
                    id="returnDate"
                    visible="{=${DepositModel>Status} === 'Returned'}"
                    change="onreturndate"
                    value="{DepositModel>ReturnDepositDate}"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="yyyy-MM-dd"
                    valueStateText="Enter return date"
                    />

                <!-- Deposit Mode / Transaction ID -->
                <Label text="Deposit Mode / Transaction ID" required="true"/>
                 <ComboBox
                    id="depositModeTxn"
                    selectedKey="{DepositModel>DepositMode}"
                     change="onDepositmodeChange"
                    placeholder="Cash / UPI / Transaction ID"
                    valueStateText="Select Deposit Mode"
                    >
                    <core:ListItem
                        key="UPI"
                        text="UPI"
                    />
                      <core:ListItem
                        key="Cash"
                        text="Cash"
                    />
                    <core:ListItem
                        key="Card"
                        text="Card"
                    />
                    
                    </ComboBox>
              

                <!-- Taken By -->
                <Label text="Received By"/>
                <Input
                    id="takenBy"
                    value="{DepositModel>DepositTakenBy}"
                    placeholder="Enter Staff Name" editable="false"/>

                <!-- Return Amount -->
                <Label text="Return Amount"/>
                <Input
                visible="{=${DepositModel>Status} === 'Returned'}"
                    id="returnAmount"
                    type="Number"
                    value="{DepositModel>ReturnDepositAmount}"
                    placeholder="Enter Return Amount" editable="false"/>

                <!-- Return Mode / Transaction ID -->
                <Label text="Return Mode / Transaction ID" required="true"/>
                <ComboBox
                visible="{=${DepositModel>Status} === 'Returned'}"
                    id="returnModeTxn"
                    change="onreturnModechange"
                    valueStateText="Select return mode"
                    selectedKey="{DepositModel>ReturnDepositMode}"
                    placeholder="Cash / UPI / Transaction ID">
                    <core:ListItem
                        key="UPI"
                        text="UPI"
                    />
                      <core:ListItem
                        key="Cash"
                        text="Cash"
                    />
                    <core:ListItem
                        key="Card"
                        text="Card"
                    />
                    
                    </ComboBox>

                <!-- Return By -->
                <Label text="Return By"/>
                <Input
                visible="{=${DepositModel>Status} === 'Returned'}"
                    id="returnBy"
                    value="{DepositModel>ReturnDepositBy}"
                    placeholder="Enter Staff Name" editable="false"/>

            </f:content>
        </f:SimpleForm>

        <beginButton>
            <Button
                text="Save"
                class="myUnifiedBtn"
                press="onSaveDeposit"/>
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                class="myUnifiedBtn"
                press="onCancelDeposit"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>