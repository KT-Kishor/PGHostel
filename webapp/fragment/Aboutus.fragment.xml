<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core">
	<l:VerticalLayout  width="98%" class="sapUiTinyMargin Aboutus" >
		<l:BlockLayout background="Dashboard" >
			<l:BlockLayoutRow rowColorSet="ColorSet4">
				<l:BlockLayoutCell title="We At Kalpavriksha Technologies" colspan="2"
					>
			<Text text="{i18n>aboutUscontent1}"  class="cell_Title"></Text>
					</l:BlockLayoutCell>
			</l:BlockLayoutRow>
			<l:BlockLayoutRow>
			<l:BlockLayoutCell title="Products">
				<VBox >
        <Link text="HR Solution" press=".onNavToHrSolution"  class="aboutTitle"/>
        <Text text="Automate HR  from offers to expenses  with a self-service portal that empowers employees and ensures seamless, error-free operations anytime, anywhere." wrapping="true" class="Recuritmentclass"/>
    </VBox>
     <VBox >
        <Link text="Invoice Solution" press=".onNavToInvoiceSolution"  class="aboutTitle"/>
        <Text text="Streamline invoicing with automated agreements and real-time tracking for accuracy, compliance, and faster payments with Remiders" wrapping="true" class="Recuritmentclass"/>
    </VBox>
     <VBox >
        <Link text="Company Asset Management" wrapping="true" press=".onNavToCompanySolution" class="aboutTitle"/>
        <Text text="Manage and track all assets in one place with complete lifecycle visibility, including seamless employee assignments" class="Recuritmentclass" wrapping="true"/>
    </VBox>
     <VBox >
        <Link text="Recruitment" press=".onNavToRecruitmentSolution"  class="aboutTitle"/>
        <Text text="Simplify hiring with smart job postings, effortless applications, and fast onboarding to attract the right talent." class="Recuritmentclass" wrapping="true"/>
    </VBox>
     <VBox >
        <Link text="Automobile Solution" press=".onNavToAutomobileSolution"  class="aboutTitle"/>
        <Text text="Easily manage and share car and bike quotations with customers through a fast, automated, and error-free solution." class="Recuritmentclass" wrapping="true"/>
    </VBox>
</l:BlockLayoutCell>

				<l:BlockLayoutCell title="{i18n>recruitment}">
				<VBox >
       <Link text="Building Strong and Capable Teams"  wrapping="true" class="aboutTitle" />
        <Text text="We are efficient resource provider to deliver exceptional recruitment, services providing end-to-end hiring solutions that align with our clients goals,   enabling them to build strong and capable teams" wrapping="true" class="Recuritmentclass"/>
    </VBox>
	<VBox >
       <Link text="Leading Recruitment Service Provider"  wrapping="true" class="aboutTitle" />
        <Text text="Kalpavriksha Technologies is a leading recruitment service provider, We specialize in extensive experience in SAP, Java, Nodejs, C++, SQL, JavaScript Salesforces and other Technologies with a proven track record of delivering high-quality recruitment solutions, we help businesses thrive by sourcing the right talent." wrapping="true" class="Recuritmentclass"/>
    </VBox>
	<VBox >
     <Link text="Executive Search" wrapping="true"  class="aboutTitle" />
        <Text text=" Finding top-level leaders and executives to drive growth." wrapping="true" class="Recuritmentclass"/>
    </VBox>
	<VBox >
      <Link text="Talent Mapping and Sourcing" wrapping="true" class="aboutTitle" />
        <Text text=" Proactively identifying and engaging with high potential talent. 
" wrapping="true" class="Recuritmentclass"/>
    </VBox>
	<VBox >
      <Link text="Candidate Screening and Assessment" wrapping="true"  class="aboutTitle" />
        <Text text=" Rigorous vetting for skill and cultural fit, we screening the profile take one round of interview to make sure it a best fit." wrapping="true" class="Recuritmentclass"/>
    </VBox>
					<!-- <core:HTML content='&lt;div class=&quot;content&quot;&gt;&lt;gt;&lt;div&gt;{i18n>aboutUsSecondcontent5}&lt;br&gt;&lt;br&gt;{i18n>aboutUsSecondcontent9}&lt;br&gt;&lt;br&gt;{i18n>aboutSecondDes}&lt;br&gt;&lt;br&gt;{i18n>aboutSecondDes1}&lt;br&gt;&lt;br&gt;{i18n>aboutSecondDes2}&lt;/a&gt;&lt;/div&gt;'></core:HTML> -->
				</l:BlockLayoutCell>
			</l:BlockLayoutRow>
		</l:BlockLayout>
	</l:VerticalLayout>
     <!-- Footer -->
    <HBox class="footer-bar" alignItems="Center" justifyContent="SpaceBetween" >
        <!-- Left: Copyright -->
        <Text text="{i18n>companynameKT}" class="footer-text"/>
        <!-- Middle: Links -->
        <!-- <HBox class="footer-links" justifyContent="Center">
            <Link text="Disclaimer" href="#" target="_blank" class="footer-link"/>
            <Link text="Privacy" href="#" target="_blank" class="footer-link"/>
            <Link text="Modern Slavery Statement" href="#" target="_blank" class="footer-link"/>
        </HBox> -->

        <!-- Right: Social Icons -->
        <HBox class="footer-social" justifyContent="End">
            <core:HTML content="&lt;a href='https://www.instagram.com/kalpavrikshatechnologies/' target='_blank'&gt;
                                  &lt;i class='fab fa-instagram social-icon'&gt;&lt;/i&gt;
                                &lt;/a&gt;"/>
            <core:HTML content="&lt;a href='https://www.linkedin.com/company/kalpavriksha-technologies/' target='_blank'&gt;
                                  &lt;i class='fab fa-linkedin-in social-icon'&gt;&lt;/i&gt;
                                &lt;/a&gt;"/>
            <core:HTML content="&lt;a href='https://www.youtube.com/@KalpavrikshaTechnologies' target='_blank'&gt;
                                  &lt;i class='fab fa-youtube social-icon'&gt;&lt;/i&gt;
                                &lt;/a&gt;"/>
        </HBox>
    </HBox>
</mvc:View>