<core:FragmentDefinition
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core" >
	<!-- Dialog container for Employee Details -->
	<Dialog 
        title="{i18n>onBoardTrainee}">
		<!-- SimpleForm with ResponsiveGridLayout -->
		<f:SimpleForm 
			editable="false"
			layout="ResponsiveGridLayout"
			labelSpanXL="3"
			labelSpanL="3"
			labelSpanM="3"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="4"
			emptySpanL="4"
			emptySpanM="4"
			emptySpanS="0"
			columnsXL="1"
			columnsL="1"
			columnsM="1"
			singleContainerFullSize="false" >
			<f:content>
				<Label text="{i18n>traineeId}"  />
				<Input value="{oTraineeDetailsModel>/TraineeId}"   editable="false"/>
				<Label text="{i18n>companyMailid}" required="true"/>
				<Input value="{oTraineeDetailsModel>/CompanyEmailID}" id="OTF_id_TraineeMail" maxLength="50" liveChange="validateEmail" placeholder="{i18n>companyMailid}" valueStateText="{i18n>mobileNoValueState}"/>
				
			</f:content>
		</f:SimpleForm>
		<HBox justifyContent="End" >
			<!-- OnBoard button  -->
			<Button text="{i18n>onboard}" type="Accept" press="OTF_onPressOnboard" class="submit" />
			<!-- Close button -->
			<Button text="{i18n>close}" press="OTF_onPressClose" class="sendMail" type="Reject"/>
		</HBox>
	</Dialog>
</core:FragmentDefinition>