<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <VBox
        id="footerWrapper"
        class="footer-wrapper"
    >
        <OverflowToolbar class="footer-shell">
            <content>
<HBox
                    width="100%"
                    class="footer-inner"
                    alignItems="Center"
                    justifyContent="SpaceBetween"
                    wrap="NoWrap"
                >
                    <HBox
                        class="footer-scroll-text"
                        alignItems="Center"
                    >
                        <core:HTML
                            content="&lt;div class='footer-marquee'&gt;&lt;img src='' style='height:20px; vertical-align: middle; margin-right: 5px;'&gt; &lt;a href='https://www.kalpavrikshatechnologies.com/' class='footer-text' target='_blank'&gt;Developed by Kalpavriksha Technologies&lt;/a&gt;&lt;/div&gt;"
                        />
                    </HBox>
                    <HBox
                        class="footer-right-items"
                        alignItems="Center"
                        justifyContent="End"
                        shrinkable="false"
                    >
                        <Button
                            press="onAdminSIGNUP"
                            tooltip="{i18n>adminVendorRegistration}"
                            icon="sap-icon://employee"
                            text="Vendor Registration"
                            class="fa-admin-btn"
                        />
                        <core:HTML
                            content="&lt;a href='https://www.instagram.com/stayvriksha/' target='_blank'&gt;&lt;i class='fab fa-instagram social-icon'&gt;&lt;/i&gt;&lt;/a&gt;"
                        />
                    </HBox>
                     <!-- <core:HTML
                        content="&lt;a href='https://www.facebook.com/' target='_blank'&gt;&lt;i class='fab fa-facebook-f social-icon'&gt;&lt;/i&gt;&lt;/a&gt;"
                    />
                    <core:HTML
                        content="&lt;a href='https://youtu.be/PdBkOcrmqbo?si=g48Lminu94ubTCYK' target='_blank'&gt;&lt;i class='fab fa-youtube social-icon'&gt;&lt;/i&gt;&lt;/a&gt;"
                    /> -->
                </HBox>
            </content>
        </OverflowToolbar>
    </VBox>
</core:FragmentDefinition>