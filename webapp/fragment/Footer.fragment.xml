<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <VBox
        id="footerWrapper"
        class="footer-wrapper"
    >
        <OverflowToolbar class="footer-shell">
            <HBox
                width="100%"
                class="footer-inner"
                alignItems="Center"
                justifyContent="SpaceBetween"
            >
<core:HTML
    content="&lt;img src='image/HPFooter.png' style='height:20px; vertical-align: middle; margin-right: 5px;'&gt; &lt;a href='https://www.kalpavrikshatechnologies.com/' class='footer-text' target='_blank'&gt;Developed by Kalpavriksha Technologies&lt;/a&gt;"
/>

                <HBox
                    class="footer-social"
                    alignItems="Center"
                    justifyContent="End"
                >
                    <Button
                        press="onAdminSIGNUP"
                        tooltip="{i18n>adminVendorRegistration}"
                        type="Transparent"
                        icon="sap-icon://employee"
                        class="fa-admin-btn"
                    />
                    <core:HTML
                        content="&lt;a href='https://www.instagram.com/' target='_blank'&gt;&lt;i class='fab fa-instagram social-icon'&gt;&lt;/i&gt;&lt;/a&gt;"
                    />
                    <core:HTML
                        content="&lt;a href='https://www.facebook.com/' target='_blank'&gt;&lt;i class='fab fa-facebook-f social-icon'&gt;&lt;/i&gt;&lt;/a&gt;"
                    />
                    <core:HTML
                        content="&lt;a href='https://www.youtube.com/' target='_blank'&gt;&lt;i class='fab fa-youtube social-icon'&gt;&lt;/i&gt;&lt;/a&gt;"
                    />
                </HBox>
            </HBox>
        </OverflowToolbar>
    </VBox>
</core:FragmentDefinition>