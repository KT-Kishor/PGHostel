<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
>
    <Dialog
        class="sapUiContentPadding sapUiSmallMargin"
        id="id_enq_Dialog"
        contentWidth="28rem"
        contentHeight="auto"
        stretch="{= ${device>/system/phone} }"
        draggable="true"
        resizable="true"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title text="Enquiry Form" />
                </contentMiddle>
            </Bar>
        </customHeader>

        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            adjustLabelSpan="false"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <f:content>
                <Label text="Room" />
                <Input
                    value="{EnquiryModel>/RoomType}"
                    editable="false"
                />
                <Label
                    required="true"
                    text="Name"
                />
                <HBox
                    width="100%"
                    justifyContent="Start"
                    alignItems="Center"
                >
                    <VBox width="35%">
                        <ComboBox
                            id="id_Salutation"
                            selectedKey="{EnquiryModel>/Salutation}"
                            change="onAdminChangeSalutation"
                            placeholder="Mr./ Ms./ Dr."
                            valueStateText="{i18n>MVDsalutation}"
                        >
                            <core:ListItem
                                key="Mr."
                                text="Mr."
                            />
                            <core:ListItem
                                key="Ms."
                                text="Ms."
                            />
                            <core:ListItem
                                key="Mrs."
                                text="Mrs."
                            />
                            <core:ListItem
                                key="Dr."
                                text="Dr."
                            />
                        </ComboBox>
                    </VBox>
                    <VBox
                        width="65%"
                        class="sapUiTinyMarginBegin"
                    >
                        <Input
                            id="id_enq_Name"
                            value="{EnquiryModel>/UserName}"
                            placeholder="{i18n>enteryourname}"
                            liveChange="onAdminLiveValidate"
                            valueStateText="{i18n>MSenterValidName}"
                            maxLength="25"
                        />
                    </VBox>
                </HBox>
                <Label
                    text="Mobile No"
                    required="true"
                />
                <HBox width="100%">
                    <VBox width="35%">
                        <ComboBox
                            id="id_enq_STD"
                            selectedKey="{EnquiryModel>/STDCode}"
                            change="ADMIN_onChangeSTD"
                            placeholder="isd"
                            showSecondaryValues="true"
                            width="100%"
                            items="{path:'CountryModel>/', length:1000}"
                            filterSecondaryValues="true"
                            valueStateText="Select ISD Code"
                        >
                            <core:ListItem
                                key="{CountryModel>stdCode}"
                                text="{CountryModel>stdCode}"
                                additionalText="{CountryModel>code}"
                            />
                        </ComboBox>
                    </VBox>
                    <VBox
                        width="65%"
                        class="sapUiTinyMarginBegin"
                    >
                        <Input
                            id="id_enq_MobileNo"
                            value="{EnquiryModel>/Mobile}"
                            liveChange="ADMIN_onMobileLiveChange"
                            maxLength="18"
                            placeholder="Enter mobile number"
                            width="100%"
                            valueStateText="Enter valid mobile number"
                        />
                    </VBox>
                </HBox>
                <Label
                    text="{i18n>email}"
                    required="true"
                />
                <Input
                    maxLength="50"
                    placeholder="{i18n>enteryourEmail}"
                    value="{EnquiryModel>/Email}"
                    id="id_enq_Email"
                    type="Email"
                    liveChange="onmailvalidate"
                    valueStateText="{i18n>MSenterValidEmail}"
                />
                <Label
                    text="Comments"
                    required="true"
                />

                <TextArea
                    id="id_enq_Comments"
                    value="{EnquiryModel>/Comments}"
                    rows="3"
                    width="100%"
                    placeholder="Enter comments"
                    maxLength="120"
                    valueStateText="Enter comments"
                    liveChange="onEnqCommentsChange"
                />
            </f:content>
        </f:SimpleForm>
        <beginButton>
            <Button
                text="Send"
                tooltip="Send"
                press="E_onsavebuttonpress"
                id="E_id_saveButton"
                class="marginRight myUnifiedBtn"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>CancelButton}"
                tooltip="{i18n>CancelButton}"
                press="E_onCancelButtonPress"
                id="E_id_CancelButton"
                class="marginRight myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>