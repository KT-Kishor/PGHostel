<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.f"
>
    <VBox class="sapUiSmallMargin">
        <!-- GridContainer for Tables -->
        <l:GridContainer columnsChange=".onGridColumnsChange">
            <l:layout>
                <l:GridContainerSettings
                    columnSize="49.5%"
                    gap="10px"
                />
            </l:layout>
            <l:layoutXS>
                <l:GridContainerSettings
                    columnSize="100%"
                    gap="10px"
                />
            </l:layoutXS>
            <l:layoutS>
                <l:GridContainerSettings
                    columnSize="100%"
                    gap="10px"
                />
            </l:layoutS>
            <l:layoutM>
                <l:GridContainerSettings
                    columnSize="100%"
                    gap="10px"
                />
            </l:layoutM>
            <!-- Earnings Table -->
            <VBox class="sapUiTinyMarginBeginEnd">
                <!-- <Toolbar>
                    <ToolbarSpacer />
                    <Button
                        type="Transparent"
                        icon="sap-icon://add"
                        tooltip="{i18n>addSalaryField}"
                        press="APD_onAddSalaryField"
                    />
                    <ToolbarSeparator />
                </Toolbar> -->
                <Table
                    id="APD_id_SalaryTable"
                    items="{EarningModel>/SalaryFields}"
                    mode="Delete"
                    delete="onPressDeleteSalaryFields"
                >
                <headerToolbar>
                    <OverflowToolbar>
                        <Title
                            text="{i18n>salaryDetails}"
                            level="H2"
                        />
                        <ToolbarSpacer />
                        <Button
                            text="{i18n>add}"
                            type="Accept"
                            press="Q_onPressCreate"
                        />
                    </OverflowToolbar>
                </headerToolbar>
                    <columns>
                        <Column
                            minScreenWidth="Tablet"
                            demandPopin="true"
                        >
                            <Text text="{i18n>desc}" />
                        </Column>
                        <Column
                            minScreenWidth="Tablet"
                            demandPopin="true"
                        >
                            <Text text="{i18n>amount}" />
                        </Column>
                        <Column
                            minScreenWidth="Tablet"
                            demandPopin="true"
                        >
                            <Text text="{i18n>yearlyAmount}" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Input
                                    value="{EarningModel>Description}"
                                    maxLength="25"
                                    editable="{= ${EarningModel>Flag} === true }"
                                />
                                <Input
                                    value="{EarningModel>Amount}"
                                    change="onEarningAmountChange"
                                    textAlign="End"
                                    type="Number"
                                />
                                <Input
                                    value="{EarningModel>Year}"
                                    editable="false"
                                    textAlign="End"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
                <HBox
                    class="customEarningBox"
                    width="100%"
                >
                    <Text
                        class="boldBlackText"
                        text="{i18n>totalEarningAmount} :"
                        textAlign="End"
                    />
                    <Text
                        class="boldBlackText"
                        text="{path:'EarningModel>/TotalEarningMonth', formatter: '.Formatter.numberFormater'}"
                        textAlign="End"
                    />
                    <Text
                        class="boldBlackText"
                        text="{path:'EarningModel>/TotalEarningYearly', formatter: '.Formatter.numberFormater'}"
                        textAlign="End"
                    />
                </HBox>
            </VBox>
            <!-- Deductions Table -->
            <VBox class="sapUiTinyMarginBeginEnd">
                <!-- <Toolbar>
                    <ToolbarSpacer />
                    <Button
                        type="Transparent"
                        icon="sap-icon://add"
                        tooltip="{i18n>addDeductionField}"
                        press="APD_onAddDeductionField"
                    />
                    <ToolbarSeparator />
                </Toolbar> -->
                <Table
                    items="{DeductionModel>/DeductionFields}"
                    mode="Delete"
                    delete="onPressDeleteDeductionFields"
                >
                <headerToolbar>
                    <OverflowToolbar>
                        <Title
                            text="{i18n>deductionDetails}"
                            level="H2"
                        />
                        <ToolbarSpacer />
                        <Button
                            text="{i18n>add}"
                            type="Accept"
                            press="Q_onPressCreate"
                        />
                    </OverflowToolbar>
                </headerToolbar>
                    <columns>
                        <Column
                            minScreenWidth="Tablet"
                            demandPopin="true"
                        >
                            <Text text="{i18n>desc}" />
                        </Column>
                        <Column
                            minScreenWidth="Tablet"
                            demandPopin="true"
                        >
                            <Text text="{i18n>amount}" />
                        </Column>
                        <Column
                            minScreenWidth="Tablet"
                            demandPopin="true"
                        >
                            <Text text="{i18n>yearlyAmount}" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Input
                                    value="{DeductionModel>Description}"
                                    maxLength="25"
                                    editable="{= ${DeductionModel>Flag} === true }"
                                />
                                <Input
                                    value="{DeductionModel>Amount}"
                                    change="onDeductionAmountChange"
                                    textAlign="End"
                                    type="Number"
                                />
                                <Input
                                    value="{DeductionModel>Year}"
                                    editable="false"
                                    textAlign="End"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
                <HBox
                    class="customDeductionBox"
                    width="100%"
                >
                    <Text
                        class="boldBlackText"
                        text="{i18n>totalDeductionAmount} :"
                        textAlign="End"
                    />
                    <Text
                        class="boldBlackText"
                        text="{path:'DeductionModel>/TotalDeductionMonth', formatter: '.Formatter.numberFormater'}"
                        textAlign="Right"
                    />
                    <Text
                        class="boldBlackText"
                        text="{path:'DeductionModel>/TotalDeductionYearly', formatter: '.Formatter.numberFormater'}"
                        textAlign="Right"
                    />
                </HBox>
            </VBox>
        </l:GridContainer>
        <HBox
            class="customNetPayBox"
            width="100%"
        >
            <Text
                text="Net Pay ( INR ) :  {path: 'DeductionModel>/totalNetPay', formatter: '.Formatter.numberFormater'} ({DeductionModel>/totalNetPayText})"
                class="boldBlackText"
                width="100%"
            />
        </HBox>
    </VBox>
</core:FragmentDefinition>
