<core:FragmentDefinition 
	xmlns:odata="sap.ui.comp.odata" id="jobFormFrag" 
	xmlns="sap.m" 
	xmlns:core="sap.ui.core" 
	xmlns:u="sap.ui.unified" 
	xmlns:l="sap.ui.layout" 
	xmlns:mvc="sap.ui.core.mvc">
	<Dialog id="jobFormDialog" draggable="true" resizable="true" title="Job Application — {JobApplicationModel>JobTitle}" stretch="true" contentWidth="auto" contentHeight="100%" verticalScrolling="true">
		<l:Grid defaultSpan="L6 M12 S12" hSpacing="2" class="sapUiSmallMargin">
			<l:content>
				<!-- Left Column -->
				<VBox class="sapUiSmallMargin" width="100%">
					<Title text="Personal Information" level="H3" class="sapUiSmallMarginTop"/>
					<Label text="Full Name" required="true" class="sapUiSmallMarginTop"/>
					<Input id="fullNameInput" liveChange=".onLiveChangeFullName" valueStateText="{i18n>fullNameInvalid}" required="true" placeholder="Enter your Full Name"/>
					<Label class="sapUiSmallMarginTop" text="Gender" required="false"/>
					<ComboBox id="genderCombo" width="100%" required="false" change="onGenderChange" placeholder="Male / Female ?" valueStateText="{i18n>genderInvalid}">
						<core:Item key="Male" text="Male"/>
						<core:Item key="Female" text="Female"/>
					</ComboBox>
					<Label class="sapUiSmallMarginTop" text="Email Address" required="true"/>
					<Input id="emailInput" type="Email" liveChange="onEmailChange" maxLength="50" required="true" placeholder="Enter email" valueStateText="{i18n>emailValueState}" />
					<Label class="sapUiSmallMarginTop" text="Country of Residence" />
					<ComboBox change="MC_onChangeCountry" width="100%" valueStateText="{i18n>expValStaCountry}" id="countryCombo" items="{path:'CountryModel>/',length:1000}" selectedKey="{JobModel>/country}" showSecondaryValues="true">
						<core:ListItem key="{CountryModel>code}" text="{CountryModel>countryName}" additionalText="{CountryModel>code}"/>
					</ComboBox>
					<Label text="City" class="sapUiSmallMarginTop" />
					<ComboBox width="100%" items="{BaseLocationModel>/}" change="MC_onBaseLocationChange" id="LocationComboBox" showSecondaryValues="true" selectedKey="{JobModel>/baseLocation}" valueStateText="{i18n>JAcombovalueState}">
						<core:ListItem key="{BaseLocationModel>city}" text="{BaseLocationModel>city}" additionalText="{BaseLocationModel>branchCode}" />
					</ComboBox>
					<Label class="sapUiSmallMarginTop" text="Address" required="false"/>
					<TextArea id="addressInput" placeholder="Enter your detailed address here" required="false" maxLength="300" liveChange=".onAddressChange" rows="2" width="100%" valueStateText="{i18n>JAaddressVal}" />
					<HBox alignItems="Center" renderType="Bare">
						<VBox width="25%">
							<Label text="ISD Code" required="true" class="sapUiSmallMarginTop"/>
						</VBox>
						<Label text="Mobile Number" required="true" class="sapUiMediumMarginBegin sapUiSmallMarginTop"/>
					</HBox>
					<HBox alignItems="Center" renderType="Bare">
						<VBox width="25%">
							<ComboBox selectedKey="{JobModel>/stdCode}" showSecondaryValues="true" change="MC_ValidateComboBox" id="isd_code" items="{codeModel>/}" filterSecondaryValues="true" valueStateText="{i18n>JAcombovalueState}">
								<core:ListItem key="{codeModel>calling_code}" text="{codeModel>calling_code}" additionalText="{codeModel>country_code}" />
							</ComboBox>
						</VBox>
						<VBox width="75%">
							<Input id="mobileInput" width="92%" maxLength="10" class="sapUiMediumMarginBegin" liveChange=".onMobileChange" required="true" valueStateText="{i18n>JAmobileVal}" placeholder="Enter Mobile Number"/>
						</VBox>
					</HBox>
					<Label class="sapUiSmallMarginTop" text="Date of Birth" required="false"/>
					<DatePicker id="dobPicker" required="false" change=".onDOBChange" valueStateText="{i18n>JAdobVal}" displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy"/>
					<Title text="Education" class="sapUiLargeMarginTop" level="H3"/>
					<Label class="sapUiSmallMarginTop" text="Highest Qualification" required="true"/>
					<ComboBox id="qualificationCombo" width="100%" required="true" change="onQalificationChange" valueStateText="{i18n>qualificationVal}" items="{qualifications>/qualification}" placeholder="Select Qualification">
						<core:Item key="{qualifications>}" text="{qualifications>}" />
					</ComboBox>
					<Label class="sapUiSmallMarginTop" text="Select University" required="false"/>
					<ComboBox id="universityCombo" width="100%" required="false" change="onUniversityChange" items="{universities>/universities}" placeholder="Select University">
						<core:Item key="{universities>}" text="{universities>}" />
					</ComboBox>
					<Label class="sapUiSmallMarginTop" text="Year of Passing" required="false"/>
					<DatePicker id="PassingYear" valueFormat="yyyy" displayFormat="yyyy" placeholder="Select Year of Passing" change="onPassingYearChange" required="false"/>
				</VBox>
				<!-- Right Column -->
				<VBox class="sapUiSmallMargin" width="100%">
					<Title text="Technology &amp; Skills" level="H3" class="sapUiSmallMarginTop"/>
					<Label text="Programming Languages &amp; Other Skills" required="true" class="sapUiSmallMarginTop"/>
					<TextArea id="skillsInput" width="100%" required="true" rows="2" maxLength="300" placeholder="Example: SAP UI5, CAPM, JavaScript" liveChange="onSkillsChange"/>
					<HBox class="sapUiMediumMarginTop" alignItems="Center">
						<Label design="Bold" text="Are you an experienced professional?"/>
						<Switch id="experienceSwitch" state="false" change=".onExperienceToggle" customTextOn="Yes" customTextOff="No"/>
					</HBox>
					<VBox id="experienceSection" visible="false">
						<Title text="Work Experience" level="H3" class="sapUiSmallMarginTop"/>
						<Label text="Total Experience (Years/Months)" required="true" class="sapUiTinyMarginTop"/>
						<Input id="experienceInput" required="true" maxLength="5" placeholder="2.2" liveChange="onExperienceChange" />
						<Label text="Previous Company Name" required="true" class="sapUiSmallMarginTop"/>
						<Input id="companyInput" required="true" maxLength="50" placeholder="Previous Employer" liveChange="onCompanyChange" valueStateText="{i18n>companyVal}" />
						<Label text="Current Designation / Role" required="false" class="sapUiSmallMarginTop"/>
						<ComboBox id="previousJobTitleCombo" width="100%" required="false" placeholder="Select / Enter title" items="{ path: 'DesignationModel>/', sorter: { path: 'department', descending: false, group: true } }" value="{DesignationModel>/PreviousJobTitle}" change=".onDesignationChange" showSecondaryValues="true" valueStateText="{i18n>designationVal}">
							<core:ListItem key="{DesignationModel>id}" text="{DesignationModel>designationName}" additionalText="{DesignationModel>department}" />
						</ComboBox>
						<Label text="Current Annual Salary (INR)" required="true" class="sapUiSmallMarginTop"/>
						<Input id="salaryInput" maxLength="12" required="true" placeholder="500000" liveChange=".onSalaryChange" showValueHelp="true" valueHelpRequest="SalaryInfoPress"
                    valueHelpIconSrc="sap-icon://message-information"/>
						<Label text="Expected Salary (Annual INR)" required="true" class="sapUiSmallMarginTop"/>
						<Input id="expectedSalaryInput" maxLength="12" required="true" placeholder="950000" liveChange=".onSalaryChange" showValueHelp="true" valueHelpRequest="SalaryInfoPress"
                    valueHelpIconSrc="sap-icon://message-information"/>
						<Label text="Employment Type" required="false" class="sapUiSmallMarginTop"/>
						<ComboBox id="employmentTypeCombo" width="100%" required="false" change="onEmpTypeChange" valueStateText="{i18n>employmentVal}" placeholder="Select Type">
							<core:Item key="full" text="Full-Time"/>
							<core:Item key="contract" text="Contractual"/>
						</ComboBox>
						<Label text="Notice Period (in days)" required="true" class="sapUiSmallMarginTop"/>
						<ComboBox id="noticePeriodCombo" width="100%" required="true" change="onNoticePeriodChange" placeholder="Select Notice Period" items="{noticePeriod>/}" valueStateText="{i18n>noticeVal}">
							<core:Item key="{noticePeriod>key}" text="{noticePeriod>text}" />
						</ComboBox>
					</VBox>
					<VBox id="fresherSection" visible="true">
						<Title text="For Freshers" level="H3" class="sapUiSmallMarginTop"/>
						<Label text="Expertise in your field" required="true" class="sapUiSmallMarginTop"/>
						<TextArea id="fresherExpertiseInput" valueStateText="{i18n>fresherExpert}" width="100%" rows="6" required="true" maxLength="300" liveChange="onExpertiseChange" placeholder="{i18n>fresherExpert}"/>
						<Title text="Learning Journey" class="sapUiMediumMarginTop"/>
						<Label text="(Internships / Academic Projects / Courses / Events)" required="false" wrapping="true"/>
						<TextArea id="fresherSelfDesc" valueStateText="{i18n>fresherJourney}" width="100%" rows="6" required="false" maxLength="300" liveChange="onLearningChange" placeholder="{i18n>fresherJourney}"/>
					</VBox>
				</VBox>
			</l:content>
		</l:Grid>
		<!-- Attachment Upload -->
		<VBox class="sapUiLargeMarginBegin sapUiLargeMarginEnd sapUiResponsivePadding">
			<Title text="Attachment" level="H3" class="sapUiSmallMarginBegin" />
			<l:VerticalLayout visible="true" width="auto">
				<MessageStrip visible="true" text="{i18n>uploadCandidateMessage}" type="Warning" enableFormattedText="true" showIcon="true" class="sapUiSmallMargin" />
			</l:VerticalLayout>
			<Label text="Upload Resume" required="true" class="sapUiSmallMarginBegin"/>
		</VBox>
		<VBox class="sapUiLargeMarginBegin sapUiLargeMarginEnd sapUiSmallMarginBottom sapUiResponsivePadding" width="90%">
			<HBox width="100%" alignItems="Center" justifyContent="Start" renderType="Bare" class="sapUiTinyMarginTop">
				<u:FileUploader class="sapUiSmallMarginBegin sapUiMediumMarginBottom" id="jobFileUploader" fileSizeExceed="onFileSizeExceeds" maximumFileSize="5MB" typeMissmatch="onFileTypeMissmatch" fileType="pdf,md,doc,docx" change="onFileChange" buttonOnly="true" sameFilenameAllowed="true" iconFirst="true" buttonText="Upload Resume" icon="sap-icon://attachment"/>
				<l:VerticalLayout id="fileErrorLayout" visible="false" width="78%">
					<MessageStrip id="fileErrorText" visible="false" text="" type="Error" enableFormattedText="true" showIcon="true" class="sapUiSmallMarginBegin sapUiMediumMarginBottom"/>
				</l:VerticalLayout>
				<Tokenizer id="id_tokenizer" width="100%" tokenDelete="onTokenDelete" tokens="{tokenModel>/tokens}">
					<Token key="{tokenModel>key}" text="{tokenModel>text}" class="sapUiSmallMarginBegin sapUiMediumMarginBottom sapThemeTextColorError"/>
				</Tokenizer>
			</HBox>
		</VBox>
		<beginButton>
			<Button text="Submit" type="Accept" press=".onSubmit"/>
		</beginButton>
		<endButton>
			<Button text="Close" type="Reject" press="onClose"/>
		</endButton>
	</Dialog>
</core:FragmentDefinition>