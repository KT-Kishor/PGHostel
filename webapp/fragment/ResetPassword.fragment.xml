<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core">
	<Dialog title="{i18n>reset}">
		<VBox>
			<f:SimpleForm editable="true"
    layout="ResponsiveGridLayout"
    labelSpanXL="4"
    labelSpanL="3"
    labelSpanM="4"
    labelSpanS="12"
    emptySpanXL="0"
    emptySpanL="4"
    emptySpanM="0"
    emptySpanS="0"
    columnsXL="2"
    columnsL="1"
    columnsM="1">
				<f:content>
					<Label text="{i18n>userId}" required="true" />
					<Input id="RP_id_userid"  placeholder="{i18n>placeUserId}" maxLength="10" />
					<Label text="{i18n>userName}" required="true" />
					<Input id="RP_id_userName" placeholder="{i18n>placeUserName}" />
					<Label text="{i18n>inpNewpassword}" required="true" />
					<Input 
    id="RP_id_NewPW" 
    placeholder="{i18n>placenewpass}"  
    liveChange="onChangeSetAndConfirm" 
    showValueHelp="true" 
    valueHelpIconSrc="sap-icon://show" 
    valueHelpRequest="onTogglePasswordVisibility"  maxLength="50"/>
					<Label text="{i18n>inpConpassword}" required="true" />
					<Input 
    id="RP_id_ConfirmPW"  
    placeholder="{i18n>placeconpass}" 
    liveChange="onChangeSetAndConfirm"   
    showValueHelp="true" 
    valueHelpIconSrc="sap-icon://show" 
    valueHelpRequest="onTogglePasswordVisibility" maxLength="50" />
				</f:content>
			</f:SimpleForm>
		</VBox>
		<footer>
			<Toolbar>
				<ToolbarSpacer />
				<!-- This pushes the buttons to the right -->
				<Button text="{i18n>save}" class="marginRigth" type="Accept" id="RP_id_SavePW" press="RP_onPressSetSave"/>
				<Button text="{i18n>btnCancel}" class="marginRigth" press="RP_onPressCanclePW" type="Negative" />
			</Toolbar>
		</footer>
	</Dialog>
</core:FragmentDefinition>
