<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout" 
    xmlns:f="sap.ui.layout.form">
    
    <Dialog title="Training enquiry" stretch="false" >
        <content>
            <f:SimpleForm layout="ResponsiveGridLayout" editable="true">
                <Label text="{i18n>name}" required="true"/>
                <Input id="FTF_idName" liveChange="FTF_onlivename" value="{TraineeData>/Name}" placeholder="{i18n>placeName}" valueStateText="{i18n>placeName}" maxLength="40"/>

                <Label text="{i18n>collegeName}" required="true"/>
                <Input id="FTF_idClgname" liveChange="FTF_onliveclg"  value="{TraineeData>/CollegeName}" placeholder="{i18n>placeclg}"  valueStateText="{i18n>placeclg}" maxLength="50"/>   

                <Label text="{i18n>email}" required="true"/>
                <Input id="FTF_idmail" type="Email" liveChange="FTF_onlivemail"  value="{TraineeData>/EmailID}" placeholder="{i18n>placeEmailId}"  valueStateText="{i18n>placeEmailId}" maxLength="50"/>

                <Label text="{i18n>mobileNo}" required="true"/>
                <Input id="FTF_idMobnumber" type="Number" liveChange="FTF_onlivemobile" value="{TraineeData>/MobileNo}" placeholder="{i18n>placeholderMobileNo}"  valueStateText="{i18n>placeholderMobileNo}"/>
                <Label  text="{i18n>selectcourse}" required="true"/>
             
              <MultiComboBox id="FTF_idMultiSelectCourse"
    selectedKeys="{TraineeData>/SelectCourse}"
    items="{TraineeCourse>/Course}" change="FTF_onSelectionchange" valueStateText="{i18n>placecourse}" width="600px" placeholder="{i18n>placecourse}">
    <core:Item key="{TraineeCourse>name}" text="{TraineeCourse>name}"/>
</MultiComboBox>

                <Label text="{i18n>comments}" required="true"/>
                <TextArea id="FTF_idcomments" liveChange="FTF_onlivecomment"  value="{TraineeData>/Comments}" placeholder="{i18n>enterComments}"  valueStateText="{i18n>enterComments}" maxLength="120"/>
            </f:SimpleForm>
        </content>
        
        <buttons>
            <Button text="Submit" type="Emphasized" press="FTF_onSubmitForm"/>
            <Button text="Cancel" type="Reject" press="FTF_onCancelform"/>
        </buttons>
    </Dialog>

</core:FragmentDefinition>
