<core:FragmentDefinition 
	xmlns="sap.m" 
	xmlns:core="sap.ui.core">
	<Table id="AL_id_compOffTableStandard" sticky="ColumnHeaders,HeaderToolbar" mode="SingleSelectLeft" selectionChange="onSelectionChange" busyIndicatorDelay="0" width="auto" items="{path: 'LeaveModel>/', sorter: {path: 'Status',group: true},groupHeaderFactory: '.getGroupHeader'}" growing="true" growingThreshold="100" alternateRowColors="true" class="sapUiResponsiveContentPadding centeredTable">
		<headerToolbar>
			<OverflowToolbar >
				<Title id="Al_id_compoffTitle" text="{i18n>appliedCompOff} ({= ${LeaveModel>/}.length })"/>
				<ToolbarSpacer/>
				<Button visible="false" press="AL_onPressBarChart" text="{i18n>openBarCharts}" type="Transparent" />
				<Button press="AL_onPressApplyLeave" text="{i18n>applycomp}" type="Transparent"/>
				<Button id="AL_id_compoffUpdatebtn" text="{i18n>editcompoff}" press="AL_onPressUpdate" visible="{= ${LeaveModel>Status} === 'Submitted' }" type="Transparent"/>
				<Button id="AL_id_compoffDeletebtn" text="{i18n>deleteCompOff}" press="AL_onPressDelete" visible="{= ${LeaveModel>Status} === 'Submitted' }" type="Transparent"/>
				<Button visible="false" text="{i18n>download}" press="AL_DownalodTableData"></Button>
			</OverflowToolbar>
		</headerToolbar>
		<columns>
			<Column demandPopin="true" visible="{viewData>/isAdmin}">
				<Text text="Employee" />
			</Column>
			<Column demandPopin="true">
				<Text text="{i18n>fromDate}" />
			</Column>	
			<Column demandPopin="true">
				<Text text="{i18n>toDate}" />
			</Column>
			<Column demandPopin="true">
				<Text text="{i18n>noOfDays}" />
			</Column>
			<Column minScreenWidth="Tablet" demandPopin="true">
				<Text text="{i18n>typeOfLeave}" />
			</Column>
			<Column minScreenWidth="Tablet" demandPopin="true">
				<Text text="{i18n>halfDay}" />
			</Column>
			<Column minScreenWidth="Tablet" demandPopin="true">
				<Text text="{i18n>comments}" />
			</Column>
		</columns>
		<items>
			<ColumnListItem>
				<cells>
					<VBox visible="{viewData>/isAdmin}">
						<Text text="{LeaveModel>EmpID}" class="bold"/>
						<Label text="{LeaveModel>EmpName}" wrapping="true"/>
					</VBox>
					<Text text="{path:'LeaveModel>StartDate' ,formatter:'.Formatter.formatDate'}" />
					<Text text="{path:'LeaveModel>EndDate' ,formatter:'.Formatter.formatDate'}" />
					<Text text="{LeaveModel>NoofDays}" />
					<Text text="{LeaveModel>SubType}" />
					<CheckBox selected="{= ${LeaveModel>HalfDay} === 'true'}" editable="false"/>
					<Button icon="sap-icon://display-more" text="{i18n>View}" press="AL_onShowEmployeeComments" />
				</cells>
			</ColumnListItem>
		</items>
	</Table>
</core:FragmentDefinition>