<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>
    <Dialog
        id="sds1"
        type="Message"
        class="sapUiContentPadding"
        contentWidth="28rem"
        contentHeight="auto"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title text="{i18n>manageRoomDetails}" />
                </contentMiddle>
            </Bar>
        </customHeader>

        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <f:content>
                <Label
                    text="{i18n>MSbranchCode}"
                    required="true"
                />
                <ComboBox
                    id="idRoomType12"
                    placeholder="Select Property Name"
                    selectedKey="{RoomModel>/BranchCode}"
                    selectionChange=".onBranchChange"
                    valueStateText="Select Property Name"
                    items="{BranchModel>/}"
                    showSecondaryValues="true"
                    editable="{= !${RoomModel>/_isEditing} }"
                >
                    <core:ListItem
                        key="{BranchModel>BranchID}"
                        text="{BranchModel>BranchID} - {BranchModel>Name}"
                        additionalText="{BranchModel>City}"
                    />
                </ComboBox>

                <Label
                    text="{i18n>bedType}"
                    required="true"
                />
                <ComboBox
                    id="idBedType"
                    placeholder="{i18n>selectBedType}"
                    width="100%"
                    selectedKey="{RoomModel>/BedTypeName}"
                    items="{BedTypeModel>/}"
                    selectionChange=".onBedTypeChange"
                    valueStateText="{i18n>pleaseSelectValidBedType}"
                    editable="{= !${RoomModel>/_isEditing} }"
                >
                    <core:ListItem
                        key="{= ${BedTypeModel>Name} + ' - ' + ${BedTypeModel>ACType} }"
                        text="{= ${BedTypeModel>Name} + ' - ' + ${BedTypeModel>ACType} }"
                    />
                </ComboBox>
                <Label
                    text="{i18n>aCType}"
                    required="true"
                />
                <ComboBox
                    id="idAcType"
                    placeholder="{i18n>selectBedType}"
                    width="100%"
                    visible="false"
                    selectedKey="{RoomModel>/ACType}"
                    items="{BedTypeModel>/}"
                    valueStateText="{i18n>pleaseSelectValidACType}"
                    change="onACtypeChange"
                >
                    <core:Item
                        key="{BedTypeModel>ACType}"
                        text="{BedTypeModel>ACType}"
                    />
                </ComboBox>
                <Label
                    text="{i18n>roomNo}"
                    required="true"
                />
                <Input
                    id="idRoomNumber"
                    value="{RoomModel>/RoomNo}"
                    placeholder="{i18n>enterRoomNo}"
                    maxLength="36"
                    liveChange="onRoomNoInputLiveChange"
                    valueStateText="{i18n>roomNocannotbeEmpty}"
                />
                <!-- <Label text="No Of person" required="true" />
                <Input id="idRoomNumber13" value="{RoomModel>/NoofPerson}" placeholder="Enter No of person" type="Number" liveChange="onRoomNoInputLiveChange" valueStateText="No of person cannot be empty" /> -->

                <!-- <Label text="{i18n>extraBed}" />
                <Input
                    id="idExtrabed"
                    value="{RoomModel>/ExtraBed}"
                    placeholder="{i18n>enterNoofExtraBed}"
                    liveChange="onPriceInputLiveChange"
                    maxLength="2"
                /> -->

                <Label text="{i18n>dailyPrice}" />
                <Input
                    id="idPrice"
                    value="{RoomModel>/Price}"
                    placeholder="{i18n>enterPrice}"
                    maxLength="10"
                    liveChange="onPriceInputLiveChange"
                    valueStateText="{i18n>pleaseenterValidAmount}"
                    editable="{RoomModel>/editable}"
                />
                <!-- <HBox
                    width="100%"
                    justifyContent="Start"
                    alignItems="Center"
                >
                    <VBox width="50%">
                        <Input
                            id="idPrice"
                            value="{RoomModel>/Price}"
                            placeholder="Enter Price"
                            maxLength="7"
                            liveChange="onPriceInputLiveChange"
                            valueStateText="Please enter a valid amount"
                        />
                    </VBox>
                    <VBox width="50%">
                        <ComboBox
                            id="FO_id_PriceType"
                            selectedKey="Per Day"
                            value="{RoomModel>/PriceType}"
                        >
                            <core:Item
                                key="Per Day"
                                text="Per Day"
                            />
                            <core:Item
                                key="Per Month"
                                text="Per Month"
                            />
                        </ComboBox>
                    </VBox>
                </HBox> -->
                <Label text="{i18n>monthlyPrice}" />
                <Input
                    id="id_MonthlyPrice"
                    value="{RoomModel>/MonthPrice}"
                    placeholder="{i18n>enterMonthPrice}"
                    maxLength="10"
                    liveChange="onPriceInputLiveChange"
                    valueStateText="{i18n>pleaseenterValidAmount}"
                    editable="{RoomModel>/editable}"
                />
                <Label text="{i18n>yearlyPrice}" />
                <Input
                    id="id_YearlyPrice"
                    value="{RoomModel>/YearPrice}"
                    placeholder="{i18n>enterYearPrice}"
                    maxLength="10"
                    liveChange="onPriceInputLiveChange"
                    valueStateText="{i18n>pleaseenterValidAmount}"
                    editable="{RoomModel>/editable}"
                />
                <Label
                    text="{i18n>currency}"
                    required="true"
                />
                <ComboBox
                    id="FO_id_Currency"
                    selectedKey="{RoomModel>/Currency}"
                    items="{path:'CountryModel>/',length:1000}"
                    valueStateText="{i18n>selectCurrency}"
                    width="100%"
                    change="onACtypeChange"
                    placeholder="{i18n>selectCurrency}"
                    showSecondaryValues="true"
                    editable="{RoomModel>/editable}"
                >
                    <core:ListItem
                        key="{CountryModel>currency}"
                        text="{CountryModel>currency}"
                        additionalText="{CountryModel>countryName}"
                    />
                </ComboBox>
            </f:content>
        </f:SimpleForm>
        <beginButton>
            <Button
                text="{i18n>save}"
                tooltip="{i18n>save}"
                press="AR_onsavebuttonpress"
                id="AR_id_saveButton"
                class="marginRight myUnifiedBtn"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>CancelButton}"
                tooltip="{i18n>CancelButton}"
                press="AR_onCancelButtonPress"
                id="AR_id_CancelButton"
                class="marginRight myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</c:FragmentDefinition>