<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:f="sap.ui.layout.form"
	xmlns:l="sap.ui.layout"
>
	<Dialog
        id="MS_id_authDialog"
        draggable="true"
        resizable="true"
        class="authDialog"
       contentWidth="34%"
        contentHeight="auto"
    >
		<customHeader>
			<Bar class="barheader">
				<contentMiddle>
					<Title text="{i18n>MSaddStaff}" />
				</contentMiddle>
			</Bar>
		</customHeader>
		<content>
        
			<f:SimpleForm
                id="MS_id_signUpForm"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanL="3"
                labelSpanM="3"
                emptySpanL="1"
                emptySpanM="1"
                columnsL="2"
                columnsM="1"
                class="sapUiNoContentPadding"
            >
				<!-- <Label text=""/> -->
				<HBox
                    width="100%"
                    justifyContent="Start"
                    alignItems="Center"
                >
					<VBox width="25%">
						<Label
                            text="{i18n>MSsalutation}"
                            required="true"
                        />
						<ComboBox
                            id="MS_id_signUpSalutation"
                            selectedKey="{MDmodel>/Salutation}"
                            change="onChangeSalutation"
                            placeholder="{i18n>mr}"
                            valueStateText="{i18n>MVDsalutation}"
                        >
							<core:ListItem
                                key="Mr."
                                text="Mr."
                            />
							<core:ListItem
                                key="Ms."
                                text="Ms."
                            />
							<core:ListItem
                                key="Mrs."
                                text="Mrs."
                            />
							<core:ListItem
                                key="Dr."
                                text="Dr."
                            />
						</ComboBox>
					</VBox>
					<VBox width="75%" class="sapUiTinyMarginBegin">
						<Label
                            text="{i18n>fullname}"
                            required="true"
                        />
						<Input
                            id="MS_id_signUpName"
                            value="{MDmodel>/UserName}"
                            placeholder="{i18n>enterFullName}"
                            required="true"
                            liveChange="_LCvalidateName"
                            valueStateText="{i18n>MSenterValidName}" maxLength="50"
                        />
					</VBox>
				</HBox>
				<Label
                    text="{i18n>MVDDOB}"
                    required="true"
                />
				<DatePicker
                    id="MS_id_signUpDOB"
                    value="{MDmodel>/DateOfBirth}"
                    valueStateText="{i18n>MVDdob}"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="dd/MM/yyyy"
                    change="onChangeDOB"
                    initialFocusedDateValue="{controller>/focusedDate}"
                    minDate="{controller>/minDate}"
                />
				<Label
                    text="{i18n>MVgender}"
                    required="true"
                />
				<Select
                    id="MS_id_signUpGender"
                    selectedKey="{MDmodel>/Gender}"
                    change="onChangeGender"
                >
					<core:Item
                        key=""
                        text="Select Gender"
                    />
					<core:Item
                        key="Male"
                        text="Male"
                    />
					<core:Item
                        key="Female"
                        text="Female"
                    />
					<core:Item
                        key="Other"
                        text="Other"
                    />
				</Select>
				<!-- ================== 2) CONTACT DETAILS ================== -->
				<Label
                    text="{i18n>emailId}"
                    required="true"
                    class="sapUiTinyMarginTop"
                />
				<Input
                    id="MS_id_signUpEmail"
                    value="{MDmodel>/Email}"
                    placeholder="{i18n>enterEmailId}"
                    type="Email"
                    required="true"
                    liveChange="onEmailliveChange"
                    valueStateText="{i18n>MSenterValidEmail}" maxLength="50"
                />
				<Label
                    text="{i18n>MSbranchCode}"
                    required="true"
                />
				<MultiComboBox
                    id="MS_id_Branchcode"
                    placeholder="{i18n>placeSelectBranchCode}"
                    selectedKeys="{MDmodel>/BranchCode}"
                    items="{BranchModel>/}"
                    showSecondaryValues="true"
                    selectionChange=".onbranchChange"
                    valueStateText="{i18n>selectBranchCode}"
                >
					<core:ListItem
                        key="{BranchModel>BranchID}"
                        text="{BranchModel>BranchID}"
                        additionalText="{BranchModel>Name}"
                    />
				</MultiComboBox>
				<Label
                    text="{i18n>MVrole}"
                    required="true"
                />
				<ComboBox
                    id="MS_id_Role"
                    width="100%"
                    items="{path: 'Role>/'}"
                    selectedKey="{MDmodel>/Role}"
                    change=".onRoleChange"
                    placeholder="{i18n>selectRole}"
                    valueStateText="{i18n>selectRole}"
                >
					<core:Item
                        key="{Role>RoleName}"
                        text="{Role>RoleName}"
                    />
				</ComboBox>
				<Label
                    text="{i18n>MVDcountry}"
                    required="true"
                />
				<ComboBox
                    id="MS_id_signUpCountry"
                    change="onChangeCountry"
                    selectionChange="onChangeCountry"
                    placeholder="{i18n>selectCountry}"
                    valueStateText="{i18n>MVDselectcountry}"
                    items="{path:'CountryModel>/', length:1000}"
                    showSecondaryValues="true"
                    selectedKey="{MDmodel>/Country}"
                >
					<core:ListItem
                        key="{CountryModel>countryName}"
                        text="{CountryModel>countryName}"
                        additionalText="{CountryModel>code}"
                    />
				</ComboBox>
				<Label
                    text="{i18n>MVDstate}"
                    required="true"
                />
				<ComboBox
                    id="MS_id_signUpState"
                    change="onChangeState"
                    selectionChange="onChangeState"
                    placeholder="{i18n>selectState}"
                    valueStateText="{i18n>MSselectState}"
                    items="{path:'StateModel>/', length:1000}"
                    showSecondaryValues="true"
                    selectedKey="{MDmodel>/State}"
                >
					<core:ListItem
                        key="{StateModel>stateName}"
                        text="{StateModel>stateName}"
                    />
				</ComboBox>
				<Label
                    text="{i18n>city}"
                    required="true"
                />
				<ComboBox
                    selectionChange="onCitySelect"
                    id="MS_id_signUpCity"
                    change="onChangeCity"
                    placeholder="{i18n>cityValueText}"
                    valueStateText="{i18n>MSselectCity}"
                    items="{path:'CityModel>/', length:1000}"
                    showSecondaryValues="true"
                    selectedKey="{MDmodel>/City}"
                >
					<core:ListItem
                        key="{CityModel>cityName}"
                        text="{CityModel>cityName}"
                        additionalText="{CityModel>branchCode}"
                    />
				</ComboBox>
				<Label text="" />
				<HBox width="100%">
					<VBox width="25%">
						<Label
                            text="{i18n>MSisdCode}"
                            required="true"
                        />
						<ComboBox
                            change="onSTDChange"
                            id="MS_id_signUpSTD"
                            placeholder="{i18n>code}"
                            valueStateText="{i18n>MSselectCode}"
                            showSecondaryValues="true"
                            items="{path:'CountryModel>/', length:1000}"
                            selectedKey="{MDmodel>/STDCode}"
                            filterSecondaryValues="true"
                        >
							<core:ListItem
                                key="{CountryModel>stdCode}"
                                text="{CountryModel>stdCode}"
                                additionalText="{CountryModel>code}"
                            />
						</ComboBox>
					</VBox>
						<VBox width="75%" class="sapUiTinyMarginBegin">
						<Label
                            text="{i18n>MSmobileNo}"
                            required="true"
                        />
						<Input
                            id="MS_id_signUpPhone"
                            type="Tel"
                            value="{MDmodel>/MobileNo}"
                            placeholder="{i18n>enterMobileNumber}"
                            maxLength="18"
                            liveChange="onMobileLivechnage"
                            valueStateText="{i18n>MSmobileNoValueState}"
                        />
					</VBox>
				</HBox>
				<Label
                    text="{i18n>address}"
                    required="true"
                />
				<TextArea
                    id="MS_id_signUpAddress"
                    rows="3"
                    maxLength="120"
                    value="{MDmodel>/Address}"
                    liveChange="onAddressChange"
                    placeholder="{i18n>address}"
                />
				<!-- <HBox width="100%"><Label
                        text="{i18n>MSaccountSecurity}"
                        design="Bold"
                        class="sapUiSmallMarginTop"
                    /></HBox><MessageStrip
                    id="MS_id_passwordHelpStrip"
                    type="Information"
                    showIcon="false"
                    text="{i18n>msgStrip}"
                /><Label
                    text="{i18n>MScreatePassword}"
                    required="true"
                /><HBox width="100%"><Input
                        showValueStateMessage="false"
                        id="MS_id_signUpPassword"
                        width="100%"
                        placeholder="{i18n>enterPassword}"
                        value="{MDmodel>/password}"
                        type="Password"
                        liveChange="SM_onChnageSetAndConfirm"
                        showValueHelp="true"
                        valueHelpIconSrc="sap-icon://show"
                        valueHelpRequest="SM_onTogglePasswordVisibility"
                        maxLength="50"
                    ><layoutData><FlexItemData growFactor="1" /></layoutData></Input></HBox><HBox
                    width="100%"
                    justifyContent="SpaceBetween"
                ><Text
                        id="MS_id_passwordStrengthText"
                        class="pwdMinFail"
                    /><Button
                        text="{i18n>MSgeneratePassword}"
                        type="Transparent"
                        tooltip="{i18n>MSgeneratePassword}"
                        icon="sap-icon://refresh"
                        press="SM_onGeneratePassword"
                    /></HBox><Label
                    text="{i18n>MSconfirmPassword}"
                    required="true"
                /><Input
                    id="MS_id_signUpConfirmPassword"
                    placeholder="{i18n>MSenterConfirmPassword}"
                    value="{MDmodel>/comfirmpass}"
                    type="Password"
                    change="FSM_onConfirm"
                    liveChange="FSM_onConfirm"
                    showValueHelp="true"
                    valueStateText="{i18n>MSenterConfirmPassword}"
                    valueHelpIconSrc="sap-icon://show"
                    valueHelpRequest="SM_onTogglePasswordVisibility"
                    maxLength="50"
                /> -->
			</f:SimpleForm>
            
		</content>
		<footer>
			<Toolbar>
				<ToolbarSpacer />
				<Button
                    text="{i18n>MSsignUp}"
                    tooltip="{i18n>MSsignUp}"
                    class="myUnifiedBtn"
                    press="onSignUp"
                />
				<Button
                    text="{i18n>CancelButton}"
                    tooltip="{i18n>close}"
                    class="myUnifiedBtn"
                    press="FD_onCancelButtonPress"
                />
			</Toolbar>
		</footer>
	</Dialog>
</core:FragmentDefinition>