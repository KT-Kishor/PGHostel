<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:f="sap.ui.layout.form"
	xmlns:l="sap.ui.layout"
>
	<Dialog
        id="MS_id_authDialog"
        draggable="true"
        resizable="true"
        class="authDialog"
    >
		<customHeader>
			<Bar class="barheader">
				<contentMiddle>
					<Title text="{i18n>MSaddStaff}" />
				</contentMiddle>
			</Bar>
		</customHeader>
		<content>
        
			<f:SimpleForm
              id="MS_id_signUpForm"
    editable="true"
            layout="ColumnLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="0"
            emptySpanL="0"
            emptySpanM="0"
            emptySpanS="0"
            columnsXL="2"
            columnsL="2"
            columnsM="2"
            singleContainerFullSize="false"
            >
				<Label text=""/>
				<!-- Empty label to align properly -->
<Label text=""/>

<!-- Salutation -->


	<Label text="{i18n>fullname}" required="true"/>

<ComboBox
    id="MS_id_signUpSalutation"
    selectedKey="{MDmodel>/Salutation}"
    change="onChangeSalutation"
    placeholder="{i18n>mr}"
    valueStateText="{i18n>MVDsalutation}">
    
    <layoutData>
        <l:GridData span="XL3 L3 M3 S12"/>
    </layoutData>

    <core:ListItem key="Mr." text="Mr."/>
    <core:ListItem key="Ms." text="Ms."/>
    <core:ListItem key="Mrs." text="Mrs."/>
    <core:ListItem key="Dr." text="Dr."/>
    <core:ListItem key="Other." text="Other."/>
</ComboBox>

<Input
    id="MS_id_signUpName"
    value="{MDmodel>/UserName}"
    placeholder="{i18n>enterFullName}"
    required="true"
    liveChange="_LCvalidateName"
    valueStateText="{i18n>MSenterValidName}"
    maxLength="50">
    
    <layoutData>
        <l:GridData span="XL9 L9 M9 S12"/>
    </layoutData>

</Input>
                
				<Label
                    text="{i18n>MVDDOB}"
                    required="true"
                />
				<DatePicker
                    id="MS_id_signUpDOB"
                    value="{MDmodel>/DateOfBirth}"
                    valueStateText="{i18n>MVDdob}"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="dd/MM/yyyy"
                    change="onChangeDOB"
                    initialFocusedDateValue="{controller>/focusedDate}"
                    minDate="{controller>/minDate}"
                />
				<Label
                    text="{i18n>MVgender}"
                    required="true"
                />
				<Select
                    id="MS_id_signUpGender"
                    selectedKey="{MDmodel>/Gender}"
                    change="onChangeGender"
                >
					<core:Item
                        key=""
                        text="Select Gender"
                    />
					<core:Item
                        key="Male"
                        text="Male"
                    />
					<core:Item
                        key="Female"
                        text="Female"
                    />
					<core:Item
                        key="Other"
                        text="Other"
                    />
				</Select>
				<!-- ================== 2) CONTACT DETAILS ================== -->
				<Label
                    text="{i18n>emailId}"
                    required="true"
                    class="sapUiTinyMarginTop"
                />
				<Input
                    id="MS_id_signUpEmail"
                    value="{MDmodel>/Email}"
                    placeholder="{i18n>enterEmailId}"
                    type="Email"
                    required="true"
                    liveChange="onEmailliveChange"
                    valueStateText="{i18n>MSenterValidEmail}" maxLength="50"
                />
				<Label
                    text="{i18n>MSbranchCode}"
                    required="true"
                />
				<MultiComboBox
                    id="MS_id_Branchcode"
                    placeholder="{i18n>placeSelectBranchCode}"
                    selectedKeys="{MDmodel>/BranchCode}"
                    items="{BranchModel>/}"
                    showSecondaryValues="true"
                    selectionChange=".onbranchChange"
                    valueStateText="{i18n>selectBranchCode}"
                >
					<core:ListItem
                        key="{BranchModel>BranchID}"
                        text="{BranchModel>BranchID}"
                        additionalText="{BranchModel>Name}"
                    />
				</MultiComboBox>
				<Label
                    text="{i18n>MVrole}"
                    required="true"
                />
				<ComboBox
                    id="MS_id_Role"
                    width="100%"
                    items="{path: 'Role>/'}"
                    selectedKey="{MDmodel>/Role}"
                    change=".onRoleChange"
                    placeholder="{i18n>selectRole}"
                    valueStateText="{i18n>selectRole}"
                >
					<core:Item
                        key="{Role>RoleName}"
                        text="{Role>RoleName}"
                    />
				</ComboBox>
				<Label
                    text="{i18n>MVDcountry}"
                    required="true"
                />
				<ComboBox
                    id="MS_id_signUpCountry"
                    change="onChangeCountry"
                    selectionChange="onChangeCountry"
                    placeholder="{i18n>selectCountry}"
                    valueStateText="{i18n>MVDselectcountry}"
                    items="{path:'CountryModel>/', length:1000}"
                    showSecondaryValues="true"
                    selectedKey="{MDmodel>/Country}"
                >
					<core:ListItem
                        key="{CountryModel>countryName}"
                        text="{CountryModel>countryName}"
                        additionalText="{CountryModel>code}"
                    />
				</ComboBox>
				<Label
                    text="{i18n>MVDstate}"
                    required="true"
                />
				<ComboBox
                    id="MS_id_signUpState"
                    change="onChangeState"
                    selectionChange="onChangeState"
                    placeholder="{i18n>selectState}"
                    valueStateText="{i18n>MSselectState}"
                    items="{path:'StateModel>/', length:1000}"
                    showSecondaryValues="true"
                    selectedKey="{MDmodel>/State}"
                >
					<core:ListItem
                        key="{StateModel>stateName}"
                        text="{StateModel>stateName}"
                    />
				</ComboBox>
				<Label
                    text="{i18n>city}"
                    required="true"
                />
				<ComboBox
                    selectionChange="onCitySelect"
                    id="MS_id_signUpCity"
                    change="onChangeCity"
                    placeholder="{i18n>cityValueText}"
                    valueStateText="{i18n>MSselectCity}"
                    items="{path:'CityModel>/', length:1000}"
                    showSecondaryValues="true"
                    selectedKey="{MDmodel>/City}"
                >
					<core:ListItem
                        key="{CityModel>cityName}"
                        text="{CityModel>cityName}"
                        additionalText="{CityModel>branchCode}"
                    />
				</ComboBox>
				<Label text="" />
		<Label text="{i18n>MSmobileNo}" required="true"/>

<!-- STD (small) -->
<ComboBox
    id="MS_id_signUpSTD"
    placeholder="ISD"
    selectedKey="{MDmodel>/STDCode}"
    width="100%"
    class="smallSTD">
    
    <layoutData>
        <l:GridData span="XL2 L2 M3 S12"/>
    </layoutData>

    <core:ListItem
        key="{CountryModel>stdCode}"
        text="{CountryModel>stdCode}" />
</ComboBox>

<!-- Mobile (big) -->
<Input
    id="MS_id_signUpPhone"
    type="Tel"
    value="{MDmodel>/MobileNo}"
    placeholder="Enter mobile number"
    width="100%">
    
    <layoutData>
        <l:GridData span="XL10 L10 M9 S12"/>
    </layoutData>

</Input>
				<Label
                    text="{i18n>address}"
                    required="true"
                />
				<TextArea
                    id="MS_id_signUpAddress"
                    rows="3"
                    maxLength="120"
                    value="{MDmodel>/Address}"
                    liveChange="onAddressChange"
                    placeholder="{i18n>placeHolderAddress}"
                />
			
			</f:SimpleForm>
            
		</content>
		<footer>
			<Toolbar>
				<ToolbarSpacer />
				<Button
                    text="Save"
                    tooltip="Save"
                    class="myUnifiedBtn"
                    press="onSignUp"
                />
				<Button
                    text="{i18n>CancelButton}"
                    tooltip="{i18n>close}"
                    class="myUnifiedBtn"
                    press="FD_onCancelButtonPress"
                />
			</Toolbar>
		</footer>
	</Dialog>
</core:FragmentDefinition>