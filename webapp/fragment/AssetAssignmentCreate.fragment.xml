<core:FragmentDefinition
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        title="{i18n>form}"
        contentWidth="50%"
    >
        <f:SimpleForm
            id="FAA_id_FormFrag"
            editable="true"
            layout="ColumnLayout"
            labelSpanXL="4"
            labelSpanL="4"
            labelSpanM="12"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="0"
            emptySpanL="0"
            emptySpanM="0"
            emptySpanS="0"
            columnsXL="2"
            columnsL="2"
            columnsM="2"
            singleContainerFullSize="false"
        >
            <f:content>
                <Label text="{i18n>employeeID}" />
                <ComboBox
                    required="true"
                    id="FAA_id_employeeID"
                    showSecondaryValues="true"
                    items="{EmpModel>/}"
                    editable="true"
                    change="FAS_onchange"
                    value="{myform>/formData/data/EmployeeId}"
                >
                    <core:ListItem
                        key="{EmpModel>EmployeeID}"
                        text="{EmpModel>EmployeeID}"
                        additionalText="{EmpModel>EmployeeName}"
                    />
                </ComboBox>

                <Label text="{i18n>employeeName}" />
                <Input
                    editable="false"
                    id="FAA_id_Name"
                    value="{myform>/formData/data/EmployeeName}"
                />

                <Label text="{i18n>type}" />
                <ComboBox
                    id="FAA_id_Type"
                    items="{incomeModel>/}"
                    selectionChange=".onTypeSelect"
                    change="onTypeChange"
                    required="true"
                    value="{myform>/formData/data/Type}"
                >
                    <core:ListItem
                        key="{incomeModel>Type}"
                        text="{incomeModel>Type}"
                        additionalText="{incomeModel>Type}"
                    />
                </ComboBox>

                <Label text="{i18n>model}" />
                <Input
                    required="true"
                    editable="true"
                    id="FAA_id_Model"
                    liveChange=".onModelChange"
                    value="{myform>/formData/data/Model}"
                    showValueHelp="true"
                    valueHelpRequest="onOpenVHD"
                />

                <Label text="{i18n>branch}" />
                <ComboBox
                    required="true"
                    id="FAA_branch_Id"
                    showSecondaryValues="true"
                    selectionChange=".onBranchChange"
                    items="{BaseLocationModel>/}"
                    value="{myform>/formData/data/Branch}"
                >
                    <core:ListItem
                        key="{BaseLocationModel>city}"
                        text="{BaseLocationModel>city}"
                        additionalText="{BaseLocationModel>branchCode}"
                    />
                </ComboBox>

                <Label text="{i18n>assignedBy}" />
                <Input
                    required="true"
                    id="FAA_id_AssignedBy"
                    maxLength="20"
                    value="{myform>/formData/data/AssignedBy}"
                    liveChange="_LCvalidateName"
                />
                <Label text="{i18n>equipmentNumber}" />
                <Input
                    required="true"
                    editable="false"
                    id="FAA_id_EquipmentNumber"
                    value="{myform>/formData/data/EquipmentNumber}"
                    liveChange="onEquipmentNumberChange"
                />
                <Label text="{i18n>serialNumber}" />
                <Input
                    required="true"
                    editable="false"
                    id="FAA_id_SerialNumber"
                    value="{myform>/formData/data/SerialNumber}"
                    liveChange=".onSerialNumberChange"
                />
                <Label text="{i18n>assetValue}" />
                <Input
                    required="true"
                    editable="false"
                    id="FAA_id_AssetValue"
                    value="{myform>/formData/data/AssignedValue}"
                    liveChange=".onAssetValueChange"
                />
                <Label text="{i18n>assignedDate}" />
                <DatePicker
                    id="FAA_id_AssignedDate"
                    required="true"
                    change="onAssignedDateChange"
                    valueFormat="dd/MM/yyyy"
                    displayFormat="dd/MM/yyyy"
                    value="{path:'myform>/formData/data/AssignedDate',formatter:'.Formatter.formatDate'}"
                />
            </f:content>
        </f:SimpleForm>
        <beginButton>
            <Button
                text="{i18n>save}"
                press="onPressSave"
                type="Accept"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>close}"
                press="onPressClose"
                type="Reject"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
