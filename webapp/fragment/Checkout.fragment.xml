<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>
    <Dialog
        type="Message"
        class="sapUiContentPadding"
        contentWidth="28rem"
        contentHeight="auto"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title text="{i18n>manageRoomDetails}" />
                </contentMiddle>
            </Bar>
        </customHeader>

        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <f:content>
                <Label
                    text="{i18n>startDate}"
                    required="true"
                />

                <DatePicker
                    id="Ck_id_editStartDate"
                    editable="false"
                    value="{Bookingmodel>/StartDate}"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="dd/MM/yyyy"
                    change="onBookingEditDateChange"
                    valueStateText="{i18n>selectStartDate}"
                />
                <Label
                    text="{i18n>endDate}"
                    required="true"
                />
                <DatePicker
                    id="Ck_id_editEndDate"
                    value="{Bookingmodel>/EndDate}"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="dd/MM/yyyy"
                />
            </f:content>
        </f:SimpleForm>

        <beginButton>
            <Button
                text="{i18n>save}"
                tooltip="{i18n>save}"
                press="Ck_onsavebuttonpress"
                id="Ck_id_saveButton"
                class="marginRight myUnifiedBtn"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>CancelButton}"
                tooltip="{i18n>CancelButton}"
                press="Ck_onCancelButtonPress"
                id="Ck_id_CancelButton"
                class="marginRight myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</c:FragmentDefinition>