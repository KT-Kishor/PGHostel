<c:FragmentDefinition
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
    xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core"
	xmlns:f="sap.ui.layout.form">
	
<f:SimpleForm
                                        editable="true" layout="ColumnLayout"
                                         labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                                         adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"                           
                                         emptySpanM="0" emptySpanS="0" columnsXL="2" columnsL="2"
                                         columnsM="1" singleContainerFullSize="false">
							<f:toolbar>
								<Toolbar>
									<Title text="{i18n>basicDetails}" />
										<ToolbarSpacer />
									<Button tooltip="{i18n>terminateLetter}" id="SS_idTerminate" press="SS_onDownloadTerminateLetter"  visible="{modelButtonVisible>/TerminationButt}" icon="sap-icon://document-text" />
									<Button tooltip="{i18n>relievingletter}" id="SS_idExperience" press="SS_onDownloadExperienceLetter"  visible="{modelButtonVisible>/RelivingExpeButt}" icon="sap-icon://create"/>
									<Button tooltip="{i18n>resignationletter}" id="SS_idResignation" press="SS_onDownloadResignationLetter"  visible="true" icon="sap-icon://request" />
								</Toolbar>
							</f:toolbar>
							<f:content>
								<Label text="{i18n>employeeID}"/>
								<Input value="{sEmployeeModel>/0/EmployeeID}" editable="false"/>
								<Label text="{i18n>employeeName}"  />
								<Input value="{sEmployeeModel>/0/Salutation} {sEmployeeModel>/0/EmployeeName}" editable="false"/>
								<Label  text="{i18n>joiningDate}"/>
								<DatePicker value="{sEmployeeModel>/0/AppraisalDate}" displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy" id="SS_id_Joinn" editable="false"/>
								<Label text="{i18n>dateOfBirth}" required="true" id="SS_id_ldob" />
								<DatePicker value="{sEmployeeModel>/0/DateOfBirth}" displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy" change="SS_validateDate"
                                id="SS_id_Dob" editable="{viewModel>/isEditMode}" initialFocusedDateValue="{controller>/focusedDate}" valueStateText="{i18n>dateValueState}"
	                             maxDate="{controller>/maxDate}" />
								<Label text="{i18n>bloodGroup}" required="true" id="SS_id_lb"/>
								<Select  selectedKey="{sEmployeeModel>/0/BloodGroup}" items="{BloodGroup>/bloodgroup}" id="SS_id_BloodGroup"  editable="{viewModel>/isEditMode}">
								<core:Item key="{BloodGroup>Code}" text="{BloodGroup>Code}" />
								</Select>
								<Label text="{i18n>companyMailid}"  />
								<Input value="{sEmployeeModel>/0/CompanyEmailID}" editable="false" id="SS_id_Compmail"  placeholder="{i18n>companyMailid}" maxLength="100"/>
								<Label text="{i18n>permanentAddress}" required="true" id="SS_id_lpa"/>
								<TextArea value="{sEmployeeModel>/0/PermanentAddress}" editable="{viewModel>/isEditMode}" id="SS_id_PAddress" placeholder="{i18n>permanentAddress}" maxLength="120" liveChange="SS_ValidateCommonFields" valueStateText="{i18n>addressValueState}"/>
								<Label text="{i18n>correspondenceAddress}" required="true" id="SS_id_lca"/>
								<TextArea value="{sEmployeeModel>/0/CorrespondenceAddress}" editable="{viewModel>/isEditMode}" id="SS_id_CAdress" placeholder="{i18n>correspondenceAddress}" maxLength="120" liveChange="SS_ValidateCommonFields" valueStateText="{i18n>addressValueState}"/>
								<Label text="{i18n>baseLocation}" />
								<Select items="{sBaseLocationModel>/}" id="SS_id_BaseL" showSecondaryValues="true" selectedKey="{sEmployeeModel>/BaseLocation}" editable="false">
								<items>
								<core:ListItem key="{sBaseLocationModel>city}" text="{sBaseLocationModel>city}" additionalText="{sBaseLocationModel>branchCode}" />
								</items>
								</Select>
								<Label text="{i18n>designation}"/>
								<Select items="{sDesignationModel>/}" id="SS_id_Desi" showSecondaryValues="true" selectedKey="{sEmployeeModel>/Designation}" editable="false">
									<items>
									<core:ListItem key="{sDesignationModel>designationName}" text="{sDesignationModel>designationName}" additionalText="{sDesignationModel>department}" />
									</items>
								</Select>
								<Label text="{i18n>manager}"/>
								<ComboBox value="{sEmployeeModel>/0/ManagerName}"
				             showSecondaryValues= "true"
				              id="SS_id_Manager"
							  editable="false"
				             items="{idModel>/results}"
				           filterSecondaryValues="true">
									<core:ListItem key="{idModel>ID}" text="{idModel>EmployeeName}" additionalText="{idModel>ID}"/>
								</ComboBox>
								<Label text="{i18n>mobileNo}" required="true" id="SS_id_Lmo"/>
								<Input value="{sEmployeeModel>/0/MobileNo}" editable="{viewModel>/isEditMode}" maxLength="10" id="SS_id_MobileNo" placeholder="{i18n>mobileNo}" liveChange="SS_validateMobileNo" valueStateText="{i18n>mobileNoValueState}"/>
								<Label text="{i18n>role}"/>
									<Input value="{sEmployeeModel>/0/Role}" editable="false" maxLength="10" id="SS_id_RoleEmpSele" placeholder="{i18n>mobileNo}"/>
										<!-- <Select
								editable="false"
									width="100%"
									id="SS_id_RoleEmpSele"
									selectedKey="{sEmployeeModel>/Role}">
									<core:Item key="{roleModel>Role}" text="{roleModel>Role}" />
								</Select> -->
								<Label text="{i18n>employeeStatus}" />
								<Select
									change="SS_onStatusChange"
									id="SS_id_StatusSelf"
									editable="false"
					selectedKey="{sEmployeeModel>/0/EmployeeStatus}"
					items="">
									<core:Item key="Active" text="{i18n>active}" />
									<core:Item key="Inactive" text="{i18n>inactive}" />
								</Select>
							</f:content>
						</f:SimpleForm>
						<f:SimpleForm
                                         editable="true" layout="ColumnLayout"  title="{i18n>bankDetails}" class="sapUiSmallMarginTop"
                                         labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                                         adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"                           
                                         emptySpanM="0" emptySpanS="0" columnsXL="2" columnsL="2"
                                         columnsM="1" singleContainerFullSize="false">
							<f:content>
								<Label text="{i18n>accountHolder}" required="true" id="SS_id_Ah"/>
								<Input value="{sEmployeeModel>/0/AccountHolderName}" editable="{viewModel>/isEditMode}" id="SS_id_AcName" liveChange="SS_validateName" maxLength="50" placeholder="{i18n>placeAccountHolder}" valueStateText="{i18n>accountHolderValueState}" />
								<Label text="{i18n>accountNo}" required="true" id="SS_id_An"/>
								<Input value="{sEmployeeModel>/0/AccountNo}" editable="{viewModel>/isEditMode}" id="SS_id_Acno" liveChange="SS_validateAccountNo" maxLength="18" placeholder="{i18n>placeAccountNo}" valueStateText="{i18n>accountnoValueState}"/>
								<Label text="{i18n>bankName}" required="true" id="SS_id_Bn"/>
								<Input value="{sEmployeeModel>/0/BankName}" editable="{viewModel>/isEditMode}" id="SS_id_BankName" maxLength="50" liveChange="SS_ValidateCommonFields" placeholder="{i18n>placeBankName}" valueStateText="{i18n>bankNameValueState}"/>
								<Label text="{i18n>bankBranch}" required="true" id="SS_id_Bb"/>
								<Input value="{sEmployeeModel>/0/BankBranch}" editable="{viewModel>/isEditMode}" id="SS_id_Branch" maxLength="50" liveChange="SS_ValidateCommonFields" placeholder="{i18n>placeBankBranch}" valueStateText="{i18n>placeBankBranch}"/>
								<Label text="{i18n>ifscCode}" required="true" id="SS_id_Ifc"/>
								<Input value="{sEmployeeModel>/0/IFSCCode}" editable="{viewModel>/isEditMode}" id="SS_id_IfcsCode" liveChange="SS_validateIfcCode" maxLength="11" placeholder="{i18n>placeIfscCode}" valueStateText="{i18n>ifcsCodeValueState}"/>
								<Label text="{i18n>bankAddress}" required="true" id="SS_id_Ba"/>
								<TextArea value="{sEmployeeModel>/0/BankAddress}" editable="{viewModel>/isEditMode}" id="SS_id_Address" maxLength="120" liveChange="SS_ValidateCommonFields" placeholder="{i18n>placeBankAddress}" valueStateText="{i18n>addressValueState}" />
								<Label text=""/>
								<Button text="{i18n>upload}" press="SS_handleUploadPress" tooltip="{i18n>bankAttachment}" width="18%"/>
								<Label text=""/>
								<Text text="{i18n>uploadNote}"/>
							</f:content>
						</f:SimpleForm>
						<MessageStrip
				text="{i18n>uploadDocmsg}"
				type="Information"
				showIcon="true"
				class="sapUiSmallMarginTop"/>
						<f:SimpleForm
                                         editable="true" layout="ColumnLayout" title="{i18n>docDetails}"  class="sapUiSmallMarginTop"
                                         labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                                         adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"                           
                                         emptySpanM="0" emptySpanS="0" columnsXL="2" columnsL="2"
                                         columnsM="1" singleContainerFullSize="false">
							<f:content>
								<Label text="{i18n>panCardCommon}" required="true" id="SS_id_LPan"/>
								<Input value="{sEmployeeModel>/0/PANCard}" editable="{viewModel>/isEditMode}" id="SS_id_Pan" maxLength="10" liveChange="SS_validatePanCard" placeholder="{i18n>placePan}" valueStateText="{i18n>panCardValueState}"/>
								<Label text="{i18n>adharCard}"/>
								<Input value="{sEmployeeModel>/0/AdharCard}" editable="{viewModel>/isEditMode}" id="SS_idAdhar" maxLength="12"  liveChange="SS_validateAadharCard" placeholder="{i18n>placeAdhar}" valueStateText="{i18n>aadharNoValueState}"/>
								<Label text="{i18n>passport}"/>
								<Input value="{sEmployeeModel>/0/Passport}" editable="{viewModel>/isEditMode}" id="SS_id_Passport" maxLength="8" liveChange="SS_validatePassport" placeholder="{i18n>placePassport}" valueStateText="{i18n>passportNoValueState}"/>
								<Label text="{i18n>voterId}"/>
								<Input value="{sEmployeeModel>/0/VoterId}" editable="{viewModel>/isEditMode}" id="SS_id_Voterid" maxLength="10" liveChange="SS_validateVoterId" placeholder="{i18n>placeVoterId}" valueStateText="{i18n>voterIdValueState}"/>
							</f:content>
						</f:SimpleForm>
						<f:SimpleForm
                                         editable="true" layout="ColumnLayout"  title="{i18n>emergencyDetails}" class="sapUiSmallMarginTop"
                                         labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                                         adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"                           
                                         emptySpanM="0" emptySpanS="0" columnsXL="2" columnsL="2"
                                         columnsM="1" singleContainerFullSize="false">
							<f:content>
								<core:Title class="emerContClass" text="{i18n>personOne}" />
								<Label text="{i18n>name}" required="true" id="SS_id_Pf" />
								<Select id="SS_idEmeSalF" editable="{viewModel>/isEditMode}" 
                                               selectedKey="{sEmployeeModel>/0/EmergencyContactPerson1Salutation}"
                                               items="{Salutation>/salutation}"
                                               width="100%">
									<!-- Binding the key and text of the Select control to the NameSalutation model -->
									<core:Item key="{Salutation>text}" text="{Salutation>text}"/>
										<layoutData>
										<l:GridData span="XL2 L1 M3 S4" />
									</layoutData>
								</Select>
								<Input  value="{sEmployeeModel>/0/EmergencyContactPerson1Name}"  editable="{viewModel>/isEditMode}" liveChange="SS_validateName" id="SS_id_EmeNameF" placeholder="{i18n>placeName}" maxLength="50" valueStateText="{i18n>commonNameValueState}"/>
								<Label text="{i18n>realtion}" required="true" id="SS_id_Rf"/>
								<Select id="SS_idRelF"  items="{EmployeeRelationShip>/}" selectedKey="{sEmployeeModel>/0/EmergencyContactPerson1Realtion}" editable="{viewModel>/isEditMode}">
									<core:Item key="{EmployeeRelationShip>Relationship}" text="{EmployeeRelationShip>Relationship}"/>
								</Select>
								<Label text="{i18n>mobileNo}" required="true" id="SS_id_Mf" />
								<Input value="{sEmployeeModel>/0/EmergencyContactPerson1ContactNo}" placeholder="{i18n>mobileNo}"  editable="{viewModel>/isEditMode}"   maxLength="10" liveChange="SS_validateMobileNo" id="SS_id_EmpMoF" valueStateText="{i18n>mobileNoValueState}"/>
								<Label text="{i18n>address}" required="true" id="SS_id_Af"/>
								<TextArea value="{sEmployeeModel>/0/EmergencyContactPerson1Address}" placeholder="{i18n>address}"  id="SS_id_AddF" editable="{viewModel>/isEditMode}" liveChange="SS_ValidateCommonFields" maxLength="120" valueStateText="{i18n>addressValueState}"/>
								<core:Title class="emerContClass" text="{i18n>personTwo}" />
								<Label text="{i18n>name}" required="true" id="SS_id_Ps" />
								<Select id="SS_idEmeSalS" editable="{viewModel>/isEditMode}"
                                               selectedKey="{sEmployeeModel>/0/EmergencyContactPerson2Salutation}"
											   items="{Salutation>/salutation}"
                                               width="100%">
									<!-- Binding the key and text of the Select control to the NameSalutation model -->
									<core:Item key="{Salutation>text}" text="{Salutation>text}"/>
										<layoutData>
										<l:GridData span="XL2 L1 M3 S4" />
									</layoutData>
								</Select>
								<Input value="{sEmployeeModel>/0/EmergencyContactPerson2Name}"  editable="{viewModel>/isEditMode}" liveChange="SS_validateName" id="SS_id_NameS" placeholder="{i18n>placeName}" maxLength="50" valueStateText="{i18n>commonNameValueState}"/>
								<Label text="{i18n>realtion}" required="true" id="SS_id_Rs"/>
								<Select  id="SS_idRelS" items="{EmployeeRelationShip>/}" selectedKey="{sEmployeeModel>/0/EmergencyContactPerson2Realtion}" editable="{viewModel>/isEditMode}">
									<core:Item key="{EmployeeRelationShip>Relationship}" text="{EmployeeRelationShip>Relationship}"/>
								</Select>
								<Label text="{i18n>mobileNo}" required="true" id="SS_id_Ms"/>
								<Input value="{sEmployeeModel>/0/EmergencyContactPerson2ContactNo}" placeholder="{i18n>mobileNo}" editable="{viewModel>/isEditMode}" maxLength="10" liveChange="SS_validateMobileNo" id="SS_id_EmpMoS" valueStateText="{i18n>mobileNoValueState}"/>
								<Label text="{i18n>address}" required="true" id="SS_id_As"/>
								<TextArea value="{sEmployeeModel>/0/EmergencyContactPerson2Address}" placeholder="{i18n>address}" editable="{viewModel>/isEditMode}" maxLength="120" id="SS_id_EmpAddS" liveChange="SS_ValidateCommonFields" valueStateText="{i18n>addressValueState}"/>
							</f:content>
						</f:SimpleForm>
				
</c:FragmentDefinition>