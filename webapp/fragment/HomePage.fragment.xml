<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:layout="sap.ui.layout"
>
    <VBox class="hostelPageContainer">
        <Carousel
            id="customSlideCarousel"
            width="95%"
            height="500px"
            loop="true"
            showPageIndicator="true"
            class="HostelFacilityCarousel"
        >
            <VBox
                class="facilitySlide slide1"
                width="100%"
                height="100%"
            />
            <VBox
                class="facilitySlide slide2"
                width="100%"
                height="100%"
            />
            <VBox
                class="facilitySlide slide3"
                width="100%"
                height="100%"
            />
            <VBox
                class="facilitySlide slide4"
                width="100%"
                height="100%"
            />
            <VBox
                class="facilitySlide slide5"
                width="100%"
                height="100%"
            />
        </Carousel>

        <!-- Common Hostel Services -->
        <VBox class="servicesContainer sapUiMediumMargin">
            <Title
                text="{i18n>shahHostelServicesandFacilities}"
                wrapping="true"
                class="sectionTitle"
            />
            <layout:Grid
                defaultSpan="L6 M6 S12"
                hSpacing="2"
                vSpacing="2"
                class="servicesGrid"
            >
                <!-- Basic Amenities -->
                <layout:content>
                    <VBox class="serviceSection">
                        <Title
                            text="{i18n>basicAmenities}"
                            level="H3"
                            class="serviceTitle"
                        />
                        <Text text="{i18n>247ElectricitySupply}" />
                        <Text text="{i18n>wiFiInternetAccess}" />
                        <Text text="{i18n>hotandColdWaterSupply}" />
                        <Text text="{i18n>roomCleaningHousekeeping}" />
                        <Text
                            text="{i18n>laundryServiceDrinkingWaterFacility}"
                        />
                    </VBox>
                </layout:content>
                <!-- Room Facilities -->
                <layout:content>
                    <VBox class="serviceSection">
                        <Title
                            text="{i18n>roomFacilities}"
                            level="H3"
                            class="serviceTitle"
                        />
                        <Text text="{i18n>bedMattressPillowBlanket}" />
                        <Text text="{i18n>studyTableandChair}" />
                        <Text text="{i18n>cupboardLocker}" />
                        <Text text="{i18n>ceilingFanAirConditioning}" />
                        <Text text="{i18n>attachedCommonBathroom}" />
                    </VBox>
                </layout:content>
                <!-- Recreation and Fitness -->
                <layout:content>
                    <VBox class="serviceSection">
                        <Title
                            text="{i18n>recreationandFitness}"
                            level="H3"
                            class="serviceTitle"
                        />
                        <Text text="{i18n>247SecurityGuard}" />
                        <Text text="{i18n>visitorSurveillance}" />
                        <Text text="{i18n>fireSafetyEquipment}" />
                        <Text text="{i18n>firstAidKit}" />
                    </VBox>
                </layout:content>
                <!-- Food and Dining -->
                <layout:content>
                    <VBox class="serviceSection">
                        <Title
                            text="{i18n>foodandDining}"
                            level="H3"
                            class="serviceTitle"
                        />
                        <Text text="{i18n>messCanteenFacility}" />
                        <Text text="{i18n>breakfastLunchandDinnerService}" />
                        <Text text="{i18n>nOWaterTVRoomLounge}" />
                        <Text text="{i18n>commonKitchenArea}" />
                    </VBox>
                </layout:content>
                <!-- Safety and Security -->
                <layout:content>
                    <VBox class="serviceSection">
                        <Title
                            text="{i18n>safetyandSecurity}"
                            level="H3"
                            class="serviceTitle"
                        />
                        <Text text="{i18n>twoWheelerCarParking}" />
                        <Text text="{i18n>cCTVSurveillance}" />
                    </VBox>
                </layout:content>
                <!-- Other Services -->
                <layout:content>
                    <VBox class="serviceSection">
                        <Title
                            text="{i18n>otherServices}"
                            level="H3"
                            class="serviceTitle"
                        />
                        <Text text="{i18n>maintenanceSupport}" />
                        <Text text="{i18n>wardenCaretakerSupport}" />
                    </VBox>
                </layout:content>
            </layout:Grid>
        </VBox>
        <!-- Footer -->
        <HBox
            class="footer-bar"
            alignItems="Center"
            justifyContent="SpaceBetween"
            width="100%"
        >
            <Text
                text="{i18n>companynameKT}"
                class="footer-text"
            />
            <HBox
                class="footer-social"
                justifyContent="End"
            >
                <core:HTML
                    content="&lt;a href='https://www.instagram.com/' target='_blank'&gt;
                                  &lt;i class='fab fa-instagram social-icon'&gt;&lt;/i&gt;
                                &lt;/a&gt;"
                />
                <core:HTML
                    content="&lt;a href='https://www.facebook.com/' target='_blank'&gt;
                              &lt;i class='fab fa-facebook-f social-icon'&gt;&lt;/i&gt;
                            &lt;/a&gt;"
                />
                <core:HTML
                    content="&lt;a href='https://youtu.be/PdBkOcrmqbo?si=g48Lminu94ubTCYK' target='_blank'&gt;
                                  &lt;i class='fab fa-youtube social-icon'&gt;&lt;/i&gt;
                                &lt;/a&gt;"
                />
            </HBox>
        </HBox>
    </VBox>
</core:FragmentDefinition>