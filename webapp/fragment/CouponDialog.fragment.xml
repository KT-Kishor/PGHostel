<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
>
    <Dialog
         draggable="true"
        resizable="true"
         title="{= ${CouponView>/DialogMode} === 'Add' ? 'Add Coupon' : 'Edit Coupon'}"
         contentWidth="80%"
    >
       
            <f:SimpleForm
                editable="true"
                layout="ColumnLayout"
               labelSpanXL="12" labelSpanL="12" labelSpanM="12"
         labelSpanS="12" adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0" emptySpanM="0" emptySpanS="0" columnsXL="2"
         columnsL="2" columnsM="1"
            >
                <f:content>
                    <Label
                        required="true"
                        text="{i18n>CDBranch}"
                    />
                    <ComboBox
                        valueStateText="{i18n>selectBranch}"
                        change="onBranchSelect"
                        id="cbBranchCode"
                        width="100%"
                        placeholder="{i18n>selectBranch}"
                        items="{Branchmodel>/}"
                        showSecondaryValues="true"
                        selectionChange="onBranchSelect"
                    >
                        <core:ListItem
                            key="{Branchmodel>Name}"
                            text="{Branchmodel>BranchID} - {Branchmodel>Name}"
                            additionalText="{Branchmodel>City}"
                        />
                    </ComboBox>
                    <Label
                        required="true"
                        text="{i18n>CDCouponCode}"
                    />
                    <Input
                        id="idCouponcode"
                        value="{CouponView>/CurrentCoupon/CouponCode}"
                        type="Text"
                        liveChange="onLiveChange_CouponCode"
                        placeholder="{i18n>enterCoupon}"
                        maxLength="10"
                        valueStateText="{i18n>pleaseEnterCoupon}"
                        editable="{= ${CouponView>/DialogMode} === 'Edit' ? false : true}"
                    />

                    <Label
                        required="true"
                        text="{i18n>CDDiscountType}"
                    />
                    <ComboBox
                        id="cbDiscountType"
                        placeholder="{i18n>selectDiscountType}"
                        selectedKey="{CouponView>/CurrentCoupon/DiscountType}"
                        change="onChange_DiscountType"
                        valueStateText="{i18n>selectDiscountType}"
                    >
                        <items>
                            <core:Item
                                key="Percentage"
                                text="Percentage"
                            />
                            <core:Item
                                key="Fixed Amount"
                                text="Fixed Amount"
                            />
                        </items>
                    </ComboBox>
                   <Label
    id="lblDiscountValue"
    required="true"
    text="{CouponView>/DiscountValueLabel}"
/>
                    <Input
                        id="inDiscountValue"
                        value="{CouponView>/CurrentCoupon/DiscountValue}"
                        type="Text"
                        liveChange="onLiveChange_DiscountValue"
                        placeholder="{i18n>enterDiscountValue}"
                        valueStateText="{i18n>enterDiscountValue}"
                    />

                    <Label
                        required="{CouponView>/isReq}"
                        text="{i18n>UptoValue}"
                    />
                    <Input
                        id="inUptoValue"
                        placeholder="{i18n>enterMaxDiscountValue}"
                        value="{CouponView>/CurrentCoupon/UptoValue}"
                        liveChange="onLiveChange_UptoValue"
                        maxLength="10"
                        valueStateText="{i18n>enterMaxDiscountValue}"
                        enabled="{CouponView>/isUptoEnabled}"
                    />

                    <Label
                        required="true"
                        text="{i18n>CDMaxUses}"
                    />
                    <Input
                        placeholder="{i18n>enterMaxUses}"
                        id="inMaxUses"
                        value="{CouponView>/CurrentCoupon/MaxUses}"
                        type="Text"
                        maxLength="8"
                        liveChange="onLiveChange_Number_MinOne"
                        valueStateText="{i18n>enterMaxUses}"
                    />
                    <Label
                        required="true"
                        text="{i18n>CDMinOrderValue}"
                    />
                    <Input
                        placeholder="{i18n>enterMinimumOrderValue}"
                        id="inMinOrderValue"
                        value="{CouponView>/CurrentCoupon/MinOrderValue}"
                        maxLength="8"
                        liveChange="onLiveChange_MinAmount"
                        valueStateText="{i18n>enterMinOrderValue}"
                    />
                    <Label
                        text="{i18n>status}"
                        visible="{= ${CouponView>/DialogMode} === 'Edit' }"
                        required="true"
                    />
                    <ComboBox
                        id="cbStatus"
                        selectedKey="{CouponView>/CurrentCoupon/Status}"
                        visible="{= ${CouponView>/DialogMode} === 'Edit' }"
                        change="onChange_Status"
                        valueStateText="{i18n>selectStatus}"
                    >
                        <core:Item
                            key="Active"
                            text="Active"
                        />
                        <core:Item
                            key="Inactive"
                            text="Inactive"
                        />
                    </ComboBox>
                    <Label
                        required="true"
                        text="{i18n>CDDescription}"
                    />
                    <TextArea
                        placeholder="{i18n>CDDescription}"
                        id="inDescription"
                        value="{CouponView>/CurrentCoupon/Description}"
                        liveChange="onLiveChange_Description"
                        maxLength="200"
                        rows="3"
                        valueStateText="{i18n>enterCouponDescription}"
                    />
                    <Label
                        required="true"
                        text="{i18n>startDate}"
                    />
                    <DatePicker
                        valueFormat="yyyy-MM-dd"
                        displayFormat="dd/MM/yyyy"
                        placeholder="{i18n>selectStartDate}"
                        id="dpStartDate"
                        value="{CouponView>/CurrentCoupon/StartDate}"
                        change="onChange_Date"
                        valueStateText="{i18n>selectStartDate}"
                    />

                    <Label
                        required="true"
                        text="{i18n>endDate}"
                    />
                    <DatePicker
                        placeholder="{i18n>selectEndDate}"
                        id="dpEndDate"
                        value="{CouponView>/CurrentCoupon/EndDate}"
                        valueFormat="yyyy-MM-dd"
                        displayFormat="dd/MM/yyyy"
                        change="onChange_Date"
                        valueStateText="{i18n>selectEndDate}"
                    />
                </f:content>
            </f:SimpleForm>
  
        <beginButton>
            <Button
                class="myUnifiedBtn"
                text="{= ${CouponView>/DialogMode} === 'Add' ? 'Create Coupon' : 'Update Coupon'}"
                tooltip="{= ${CouponView>/DialogMode} === 'Add' ? 'Create Coupon' : 'Update Coupon'}"
                press="onSaveCoupon"
            />
        </beginButton>
        <endButton>
            <Button
                class="myUnifiedBtn"
                text="{i18n>CancelButton}"
                tooltip="{i18n>CancelButton}"
                press="onDialogClose"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
