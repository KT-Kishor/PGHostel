<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
>
    <Dialog
        id="couponDialog"
        draggable="true"
        resizable="true"
        afterClose="onDialogAfterClose"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title
                        text="{= ${CouponView>/DialogMode} === 'Add' ? 'Add Coupon' : 'Edit Coupon'}"
                    />
                </contentMiddle>
                <contentRight>
                    <Button
                        class="myUnifiedBtn"
                        icon="sap-icon://decline"
                        tooltip="{i18n>close}"
                        type="Transparent"
                        press="onDialogClose"
                    />
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="3"
                emptySpanXL="4"
                emptySpanL="4"
                emptySpanM="4"
                columnsXL="2"
                columnsL="2"
                columnsM="1"
            >
                <f:content>
                    <Label
                        required="true"
                        text="{i18n>CDBranch}"
                    />
                    <ComboBox
                        valueStateText="{i18n>selectBranch}"
                        change="onChange_DiscountType"
                        id="cbBranchCode"
                        width="100%"
                        placeholder="{i18n>selectBranch}"
                        items="{Branchmodel>/}"
                        showSecondaryValues="true"
                        selectionChange="onBranchSelect"
                    >
                        <core:ListItem
                            key="{Branchmodel>Name}"
                            text="{Branchmodel>BranchID} - {Branchmodel>Name}"
                            additionalText="{Branchmodel>City}"
                        />
                    </ComboBox>
                    <Label
                        required="true"
                        text="{i18n>CDDiscountType}"
                    />
                    <ComboBox
                        id="cbDiscountType"
                        placeholder="{i18n>selectDiscountType}"
                        selectedKey="{CouponView>/CurrentCoupon/DiscountType}"
                        change="onChange_DiscountType"
                        valueStateText="{i18n>selectDiscountType}"
                    >
                        <items>
                            <core:Item
                                key="Percentage"
                                text="Percentage"
                            />
                            <core:Item
                                key="Fixed Amount"
                                text="Fixed Amount"
                            />
                        </items>
                    </ComboBox>
                    <Label
                        required="true"
                        text="{i18n>CDDiscountValue}"
                    />
                    <Input
                        placeholder="{i18n>enterDiscountValue}"
                        id="inDiscountValue"
                        value="{CouponView>/CurrentCoupon/DiscountValue}"
                        type="Number"
                        liveChange="onLiveChange_DiscountValue"
                        valueStateText="{i18n>enterDiscountValue}"
                    />
                    <Label
                        required="true"
                        text="{i18n>CDMaxUses}"
                    />
                    <Input
                        placeholder="{i18n>enterMaxUses}"
                        id="inMaxUses"
                        value="{CouponView>/CurrentCoupon/MaxUses}"
                        type="Number"
                        liveChange="onLiveChange_Number_MinOne"
                        valueStateText="{i18n>enterMaxUses}"
                    />
                    <Label
                        required="true"
                        text="{i18n>CDMinOrderValue}"
                    />
                    <Input
                        placeholder="{i18n>enterMinimumOrderValue}"
                        id="inMinOrderValue"
                        value="{CouponView>/CurrentCoupon/MinOrderValue}"
                        type="Number"
                        liveChange="onLiveChange_MinAmount"
                        valueStateText="{i18n>enterMinOrderValue}"
                    />
                    <Label
                        text="{i18n>status}"
                        visible="{= ${CouponView>/DialogMode} === 'Edit' }"
                        required="true"
                    />
                    <ComboBox
                        id="cbStatus"
                        selectedKey="{CouponView>/CurrentCoupon/Status}"
                        visible="{= ${CouponView>/DialogMode} === 'Edit' }"
                        change="onChange_Status"
                        valueStateText="{i18n>selectStatus}"
                    >
                        <core:Item
                            key="Active"
                            text="Active"
                        />
                        <core:Item
                            key="Inactive"
                            text="Inactive"
                        />
                        <core:Item
                            key="Expired"
                            text="Expired"
                        />
                    </ComboBox>
                    <Label
                        required="true"
                        text="{i18n>startDate}"
                    />
                    <DatePicker
                        valueFormat="yyyy-MM-dd"
                        displayFormat="dd/MM/yyyy"
                        placeholder="{i18n>selectStartDate}"
                        id="dpStartDate"
                        value="{CouponView>/CurrentCoupon/StartDate}"
                        change="onChange_Date"
                        valueStateText="{i18n>selectStartDate}"
                    />

                    <Label
                        required="true"
                        text="{i18n>endDate}"
                    />
                    <DatePicker
                        placeholder="{i18n>selectEndDate}"
                        id="dpEndDate"
                        value="{CouponView>/CurrentCoupon/EndDate}"
                        valueFormat="yyyy-MM-dd"
                        displayFormat="dd/MM/yyyy"
                        change="onChange_Date"
                        valueStateText="{i18n>selectEndDate}"
                    />
                </f:content>
            </f:SimpleForm>
        </content>
        <beginButton>
            <Button
                type="Emphasized"
                class="myUnifiedBtn"
                text="{= ${CouponView>/DialogMode} === 'Add' ? 'Create Coupon' : 'Update Coupon'}"
                tooltip="{= ${CouponView>/DialogMode} === 'Add' ? 'Create Coupon' : 'Update Coupon'}"
                press="onSaveCoupon"
            />
        </beginButton>
    </Dialog>
</core:FragmentDefinition>