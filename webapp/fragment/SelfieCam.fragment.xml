<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog >
        <customHeader>
            <Bar class="barheader">
                    <contentMiddle>
                <Title text="{i18n>cameraCapture}" />
            </contentMiddle>
              
            </Bar>
        </customHeader>
        <VBox class="sapUiSmallMargin">
             <HBox class="sapUiTinyMarginTop">
            <core:HTML
                content="
                    &lt;div style='position:relative;display:inline-block;'&gt;
                    &lt;video id='video' autoplay class='squareVideo' style='border:2px solid #fff;border-radius:10px;'&gt;&lt;/video&gt;
                    &lt;img src='image/cameraBg.png' style='position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;' /&gt;
                    &lt;/div&gt;"
                />
            </HBox>
            <FlexBox
                class="sapUiTinyMarginTop"
                justifyContent="SpaceAround"
            >
                <Button
                    text="{i18n>capture}"
                    tooltip="{i18n>capture}"
                    press="IC_onCapturePress"
                    class="myUnifiedBtn"
                    width="8rem"
                />
                <Button
                    text="{i18n>close}"
                    tooltip="{i18n>close}"
                    press="IC_onPressCloseCameraDialog"
                    class="myUnifiedBtn"
                    width="8rem"
                />
            </FlexBox>
        </VBox>
    </Dialog>
</core:FragmentDefinition>