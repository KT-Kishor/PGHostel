<c:FragmentDefinition
	xmlns:odata="sap.ui.comp.odata"
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified"
>
	<Dialog
        title="{i18n>branchDetails}"
        resizable="true"
        draggable="true"
        contentWidth="80%"
    >
		<f:SimpleForm
            editable="true"
            layout="ColumnLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="2"
        >
			<f:content>
				<Label
                    text="{i18n>branchName}"
                    required="true"
                />
				<Input
                    id="BD_idBName"
                    value="{MDmodel>/Name}"
                    placeholder="{i18n>enterBranchName}"
                    maxLength="60"
                    liveChange="onNameInputLiveChange"
                    valueStateText="{i18n>enterBranchName}"
                />
				<Label
                    text="{i18n>branchProperty}"
                    required="true"
                />
				<ComboBox
                    id="BD_id_Type"
                    required="true"
                    placeholder="{i18n>enterBranchType}"
                    valueStateText="{i18n>enterBranchName}"
                    value="{MDmodel>/PropertyType}"
                    items="{PropertyType>/}"
                    change="onPropertyTypeChange"
                >
					<core:Item
                        key="{PropertyType>PropertyType}"
                        text="{PropertyType>PropertyType}"
                    />
				</ComboBox>
				<Label
                    text="{i18n>address}"
                    required="true"
                />
				<TextArea
                    id="BD_idAddress"
                    value="{MDmodel>/Address}"
                    placeholder="{i18n>enterAddress}"
                    rows="2"
                    width="100%"
                    maxLength="120"
                    liveChange="onAddressInputLiveChange"
                    valueStateText="{i18n>enterAddress}"
                />
				<Label
                    text="Landmark"
                    required="true"
                />
				<Input
                    id="BD_idLandmark"
                    value="{MDmodel>/LandMark}"
                    placeholder="Enter landmark"
                    maxLength="60"
                    liveChange="onLandmarkInputLiveChange"
                    valueStateText="Enter Landmark"
                />
				<Label
                    text="{i18n>MapLink}"
                    required="true"
                />
				<Input
                    id="BD_idGeoLocation"
                    value="{MDmodel>/GeoLocation}"
                    placeholder="{i18n>GL_placeHolder}"
                    liveChange="onGeoLocationLiveChange"
                    valueStateText="{i18n>GL_error}"
                />
				<Label
                    text="{i18n>pinCode}"
                    required="true"
                />
				<Input
                    id="BD_idPin"
                    value="{MDmodel>/Pincode}"
                    placeholder="{i18n>enterPincode}"
                    maxLength="10"
                    liveChange="onPinInputLiveChange"
                    valueStateText="{i18n>enterPincode}"
                />
				<Label
                    text="{i18n>MVDcountry}"
                    required="true"
                />
				<ComboBox
                    id="MC_id_Country"
                    change="MC_onChangeCountry"
                    placeholder="{i18n>enterCountry}"
                    valueStateText="{i18n>selectCountry}"
                    items="{path:'CountryModel>/',length:1000}"
                    selectedKey="{MDmodel>/country}"
                    showSecondaryValues="true"
                >
					<core:ListItem
                        key="{CountryModel>countryName}"
                        text="{CountryModel>countryName}"
                        additionalText="{CountryModel>code}"
                    />
				</ComboBox>
				<Label
                    text="{i18n>MVDstate}"
                    required="true"
                />
				<ComboBox
                    id="MC_id_State"
                    change="MC_onChangeState"
                    placeholder="{i18n>enterState}"
                    valueStateText="{i18n>selectState}"
                    items="{path:'StateModel>/',length:1000}"
                    selectedKey="{MDmodel>/state}"
                    showSecondaryValues="true"
                >
					<core:ListItem
                        key="{StateModel>stateName}"
                        text="{StateModel>stateName}"
                    />
				</ComboBox>
				<Label
                    text="{i18n>city}"
                    required="true"
                />
				<ComboBox
                    id="MC_id_City"
                    change="MC_onChangeCity"
                    valueStateText="{i18n>cityValueText}"
                    placeholder="{i18n>enterCity}"
                    items="{path:'CityModel>/',length:1000}"
                    value="{MDmodel>/baseLocation}"
                    showSecondaryValues="true"
                >
					<core:ListItem
                        key="{CityModel>cityName}"
                        text="{CityModel>cityName}"
                        additionalText="{CityModel>branchCode}"
                    />
				</ComboBox>
				<Label
                    text="{i18n>gstNo}"
                    visible="{visiblePlay>/isIndia}"
                />
				<Input
                    value="{MDmodel>/GSTIN}"
                    maxLength="15"
                    placeholder="{i18n>enterGSTNo}"
                    id="MC_id_CustomGst"
                    liveChange="MC_ValidateGstNumber"
                    valueStateText="{i18n>gstError}"
                    visible="{visiblePlay>/isIndia}"
                />
				<Label
                    text="{i18n>type}"
                    labelFor="groupC"
                />
				<RadioButtonGroup
                    visible="{visiblePlay>/CC_id_CustInput}"
                    select="onRadioButtonChange"
                    selectedIndex="{visiblePlay>/selectedIndex}"
                    id="MC_id_groupCustGst"
                    columns="2"
                    editable="true"
                >
					<RadioButton text="{i18n>cgst}" />
					<RadioButton text="{i18n>igst}" />
				</RadioButtonGroup>
				<Label
                    visible="{visiblePlay>/CC_id_CustInput}"
                    text="{i18n>taxPercentage}"
                />
				<Input
                    visible="{visiblePlay>/CC_id_CustInput}"
                    id="CC_id_custValue"
                    value="{MDmodel>/Value}"
                    maxLength="2"
                    liveChange="onTaxPercentageChange"
                />
				<Label text="" />
				<Label
                            text="{i18n>MSisdCode}"
                            required="true"
                        />
				<ComboBox
                            change="onSTDChange"
                            id="MC_id_codeModel"
                            placeholder="{i18n>code}"
                            valueStateText="{i18n>MSselectCode}"
                            showSecondaryValues="true"
                            items="{path:'CountryModel>/', length:1000}"
                            selectedKey="{MDmodel>/stdCode}"
                            filterSecondaryValues="true"
                        >
					<core:ListItem
                                key="{CountryModel>stdCode}"
                                text="{CountryModel>stdCode}"
                                additionalText="{CountryModel>code}"
                            />
				</ComboBox>
				<Input
                            value="{MDmodel>/Contact}"
                            id="BD_idPhone"
                            placeholder="{i18n>enterContactNumber}"
                            maxLength="18"
                            liveChange="onMobileLivechnage"
                            valueStateText="{i18n>enterContactNumber}"
                        />
				<Label
                    text="{i18n>bdCheckIntime}"
                    required="true"
                />
				<TimePicker
                    id="BD_id_CheckInTime"
                    value="{MDmodel>/CheckinTime}"
                    change="onCheckInTimeChange"
                    displayFormat="hh a"
                    placeholder="e.g. 10 AM"
                    valueFormat="hh a"
                    valueStateText="Please select Check-In Time"
                />
				<Label
                    text="{i18n>bdCheckouttime}"
                    required="true"
                />
				<TimePicker
                    id="BD_id_CheckOutTime"
                    value="{MDmodel>/CheckoutTime}"
                    change="onCheckOutTimeChange"
                    displayFormat="hh a"
                    valueFormat="hh a"
                    placeholder="e.g. 10 AM"
                    valueStateText="Please select Check-Out Time"
                />
				<Label
                    text="{i18n>currency}"
                    required="true"
                />
				<ComboBox
                    id="Bd_id_DepositCurrency"
                    selectedKey="{MDmodel>/Currency}"
                    items="{path:'CountryModel>/',length:1000}"
                    valueStateText="{i18n>selectCurrency}"
                    width="100%"
                    change="onDepositCurrency"
                    placeholder="{i18n>selectCurrency}"
                    showSecondaryValues="true"
                >
					<core:ListItem
                        key="{CountryModel>currency}"
                        text="{CountryModel>currency}"
                        additionalText="{CountryModel>countryName}"
                    />
				</ComboBox>
				<Label
                    text="{i18n>penalty}"
                    required="true"
                />
				<Input
                    id="BD_idPenalty"
                    value="{MDmodel>/Penalty}"
                    placeholder="{i18n>enterPenalty}"
                    maxLength="10"
                    liveChange="onPenaltyInputLiveChange"
                    valueStateText="{i18n>enterPenalty}"
                />
				<Label
                 id="Bd_id_Mode_Label"
                    text="Mode"
                    required="true"
                    visible="{= ${LoginModel>/Role} === 'SuperAdmin'}"
                />
				<Select
                    id="Bd_id_Active"
                    selectedKey="{MDmodel>/Mode}"
                    valueStateText="{i18n>selectCurrency}"
                    width="100%"
                    showSecondaryValues="true"
                    visible="{= ${LoginModel>/Role} === 'SuperAdmin'}"
                    class="sapUiSmallMarginBottom"
                >
					<core:Item
                        key="Active"
                        text="Active"
                    />
					<core:Item
                        key="Inactive"
                        text="Inactive"
                    />
				</Select>

                <Label
                    text="{i18n>startingPrice}"
                    required="true"
                />
				<Input
                    id="BD_id_StartingPrice"
                    value="{MDmodel>/StartingPrice}"
                    placeholder="{i18n>enterStartingPrice}"
                    maxLength="10"
                    liveChange="onPriceInputLiveChange"
                    valueStateText="{i18n>enterStartingPrice}"
                />
			</f:content>
		</f:SimpleForm>
		<MessageStrip
                    text="For Logo and Image, files larger than 2 MB are not allowed."
                    type="Warning"
                    showIcon="true"
                    visible="{= !${editableModel>/isEdit}}"
                    enableFormattedText="true"
                    class="sapUiSmallMarginBottom sapUiSmallMarginEnd"
                />
		<Label text=""/>
		<!-- 🔹 SIDE BY SIDE LAYOUT -->
		<HBox width="100%" justifyContent="SpaceBetween">
			<!-- LEFT SIDE (LOGO) -->
			<VBox width="48%">
				<HBox justifyContent="End" class="sapUiSmallMarginBottom">
					<u:FileUploader
                        id="BD_id_FileUploader"
                        fileSizeExceed="onFileSizeExceeds"
                        maximumFileSize="2"
                        typeMissmatch="onFileTypeMissmatch"
                        fileType="jpg,jpeg,png"
                        change="onFacilityFileChange"
                        buttonOnly="true"
                        sameFilenameAllowed="true"
                        iconFirst="true"
                        buttonText="Upload Logo"
                        multiple="false"
                        uploadOnChange="false"
                        tooltip="Only JPG, PNG, or PDF files under 5MB allowed"      
                    />
				</HBox>
				<Table
                    items="{UploaderData>/attachmentslogo}"
                    mode="Delete"
                    delete="onTokenDelete"
                    width="100%"
                >
					<columns>
						<Column demandPopin="true" >
							<Text text="{i18n>filename}" />
						</Column>
						<Column hAlign="Center" demandPopin="true"  minScreenWidth="Tablet" >
							<Text text="{i18n>FileType}" />
						</Column>
						<Column hAlign="Center" demandPopin="true"  minScreenWidth="Tablet" >
							<Text text="{i18n>FileSize}" />
						</Column>
					</columns>
					<items>
						<ColumnListItem>
							<cells>
								<Text text="{UploaderData>filename}" />
								<Text text="{UploaderData>fileType}" />
								<Text text="{path: 'UploaderData>size', formatter: '.Formatter.formatFileSize'}"/>
							</cells>
						</ColumnListItem>
					</items>
				</Table>
			</VBox>
			<!-- RIGHT SIDE (IMAGE) -->
			<VBox width="48%">
				<HBox justifyContent="End" class="sapUiSmallMarginBottom">
					<u:FileUploader
                        id="BD_id_FileUploader1"
                        fileSizeExceed="onFileSizeExceeds"
                        maximumFileSize="2"
                        typeMissmatch="onFileTypeMissmatch"
                        fileType="jpg,jpeg,png"
                        change="onImageChange"
                        buttonOnly="true"
                        sameFilenameAllowed="true"
                        iconFirst="true"
                        buttonText="Upload Image"
                        multiple="false"
                        uploadOnChange="false"
                        tooltip="Only JPG, PNG, or PDF files under 5MB allowed"
                        class="sapUiSmallMarginEnd"
                    />
				</HBox>
				<Table
                    items="{UploaderData>/attachmentimage}"
                    mode="Delete"
                    delete="onTokenImageDelete"
                    width="100%"
                >
					<columns>
						<Column demandPopin="true" >
							<Text text="{i18n>filename}" />
						</Column>
						<Column hAlign="Center" demandPopin="true"  minScreenWidth="Tablet" >
							<Text text="{i18n>FileType}" />
						</Column>
						<Column hAlign="Center" demandPopin="true"  minScreenWidth="Tablet" >
							<Text text="{i18n>FileSize}" />
						</Column>
					</columns>
					<items>
						<ColumnListItem>
							<cells>
								<Text text="{UploaderData>filename}" />
								<Text text="{UploaderData>fileType}" />
								<Text text="{path: 'UploaderData>size', formatter: '.Formatter.formatFileSize'}"/>
							</cells>
						</ColumnListItem>
					</items>
				</Table>
			</VBox>
		</HBox>
		<beginButton>
			<Button
                id="BD_id_saveButoon"
                text="{i18n>save}"
                tooltip="{i18n>save}"
                class="myUnifiedBtn"
                press="MD_onSaveButtonPress"
            />
		</beginButton>
		<endButton>
			<Button
                text="{i18n>CancelButton}"
                tooltip="{i18n>CancelButton}"
                class="myUnifiedBtn"
                press="MD_onCancelButtonPress"
            />
		</endButton>
	</Dialog>
</c:FragmentDefinition>
