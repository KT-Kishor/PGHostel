<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="YearlyInvoiceDialog"
        title="{i18n>yearlyinvoicefor} {dialogData>/year}"
        contentWidth="800px"
        contentHeight="400px"
        resizable="true"
        draggable="true">
        <content>
            <Table
            sticky="ColumnHeaders"
                items="{dialogData>/invoices}"
                noDataText="{i18n>noyearlydata}">
                <columns>
                 <Column><Text text="{i18n>invoiceNo}" /></Column>
                    <Column><Text text="{i18n>invoiceDate}" /></Column>
                     <Column><Text text="{i18n>customerName}" /></Column>
                    <Column hAlign="End"><Text text="{i18n>expConversionRate}" /></Column>
                    <!-- <Column hAlign="End"><Text text="{i18n>totalAmount}" /></Column> -->
                    <!-- <Column><Text text="{i18n>status}" /></Column> -->
                    <Column hAlign="End"><Text text="{i18n>yearlyinvoice}" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onPendingInvoicePress">
                        <cells>
                            <!-- <Text text="{dialogData>year}" /> -->
                            <Text text="{dialogData>InvNo}" />
                              <!-- <Text text="{popoverData>InvNo}" /> -->
                             <Text text="{
                                path: 'dialogData>InvoiceDate',
                             formatter:'.Formatter.formatDate'}" />
                            <Text text="{dialogData>CustomerName}" />
                           <ObjectIdentifier 
  title="{path:'dialogData>ConversionRate', formatter: '.Formatter.fromatNumber'}"
  text="{= ${dialogData>Currency} !== 'INR' ? ${dialogData>TotalAmount} : '' }" />


                           <ObjectNumber
    number="{
        parts: [
            { path: 'dialogData>Currency' },
            { path: 'dialogData>TotalAmount' },
            { path: 'dialogData>AmountInINR' }
        ], 
        formatter: '.Formatter.fromatNumber'
    }"
    unit="{dialogData>Currency}" />

                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <endButton>
            <Button text="{i18n>close}" type="Ghost" press="onCloseDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>