<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="YearlyInvoiceDialog"
        contentWidth="800px"
        contentHeight="400px"
        resizable="true"
        draggable="true">
           <customHeader >
        <Bar class="Coursetitle" >
        <contentLeft>
          <Title text="{i18n>yearlyinvoicefor} {dialogData>/year}"   />
        </contentLeft>
           
            <contentRight>
                <Button icon="sap-icon://decline" press="onCloseDialog" tooltip="Close"/>
            </contentRight>
        </Bar>
    </customHeader>
        <content>
            <Table
            sticky="ColumnHeaders"
                items="{dialogData>/invoices}"
                noDataText="{i18n>noyearlydata}">
                <columns>
                 <Column demandPopin="true" hAlign="Left"><Text text="{i18n>invoiceNo}" /></Column>
                    <Column demandPopin="true" hAlign="Left"><Text text="{i18n>invoiceDate}" /></Column>
                     <Column demandPopin="true" hAlign="Left" minScreenWidth="Desktop"><Text text="{i18n>customerName}" /></Column>
                    <Column demandPopin="true" hAlign="Left" minScreenWidth="Desktop"><Text text="{i18n>transactionAmount}" /></Column>
                    <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop"><Text text="{i18n>creditNotesAmount}" /></Column>
                    <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop"><Text text="{i18n>exchRate}" /></Column>
                    <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop"><Text text="{i18n>yearlyinvoice}" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onPendingInvoicePress">
                        <cells>
                            <!-- <Text text="{dialogData>year}" /> -->
                            <Text text="{dialogData>InvNo}" />
                            <Text text="{path: 'dialogData>InvoiceDate',formatter:'.Formatter.formatDate'}" />
                            <Text text="{dialogData>CustomerName}" />
                            <ObjectNumber number="{parts: [{ path: 'dialogData>TotalAmount' }], formatter: '.Formatter.fromatNumber'}" unit="{dialogData>Currency}" />
                            <!-- <ObjectNumber number="{parts: [{ path: 'dialogData>CreditNotesTotal' }],formatter: '.Formatter.fromatNumber'}"/> -->
                            <Link wrapping="true" class="creditLinkStyle" press="onInvoiceCreditNotesPress" text="{parts: [{ path: 'dialogData>CreditNotesTotal' },{ path: 'dialogData>Currency' }],formatter: '.Formatter.formatAmountWithCurrency'}"/>
                            <ObjectIdentifier title="{path:'dialogData>ConversionRate', formatter: '.Formatter.fromatNumber'}"/>
                           <ObjectNumber number="{parts: [{ path: 'dialogData>Currency' },{ path: 'dialogData>TotalAmount' },{ path: 'dialogData>AmountInINR' }], formatter: '.Formatter.fromatNumber'}" unit="INR" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
       <footer>
			<Toolbar>
				<ToolbarSpacer/>
				<Text text="Total Amount : "/>
				<ObjectNumber 
						number="{parts: [{ path: 'dialogData>/AllTotalAmount' }], formatter: '.Formatter.fromatNumber'}"
						unit="INR" />
        	</Toolbar>
		</footer>
    </Dialog>
</core:FragmentDefinition>