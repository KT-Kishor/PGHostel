<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>
    <Dialog
        id="VN_sds1"
        title="{i18n>uploadDocuments}"
        type="Standard"
        class="sapUiContentPadding"
    >
        <customHeader>
            <Bar class="barheader">
                <contentLeft>
                    <Title
                        text="{i18n>uploadDocuments}"
                        class="sapUiSmallMarginBegin"
                    />
                </contentLeft>

                <contentRight>
                    <Button
                        icon="sap-icon://decline"
                        press="onCloseDialog"
                        type="Transparent"
                    />
                </contentRight>
            </Bar>
        </customHeader>

        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <f:content>
                <Label
                    text="{i18n>iDProofType}"
                    required="true"
                />
                <ComboBox
                    id="VN_idProofType"
                    placeholder="{i18n>selectIDProof}"
                    value="{AdminSignupModel>/CurrentDocType}"
                    valueStateText="{i18n>selectIDProof}"
                    change="onidproofchange"
                >
                    <core:ListItem
                                                        key="Aadhar Card"
                                                        text="Aadhar Card"
                                                    />
                                                    <core:ListItem
                                                        key="PAN Card"
                                                        text="PAN Card"
                                                    />
                                                    <core:ListItem
                                                        key="Company Registration Certificate"
                                                        text="Company Registration Certificate"
                                                    />
                                                    <core:ListItem
                                                        key="Bank Account"
                                                        text="Bank Account"
                                                    />
                                                    <core:ListItem
                                                        key="Other"
                                                        text="Other"
                                                    />
                </ComboBox>
                <Label
                    text="{i18n>uploadDocument}"
                    required="true"
                />
                <u:FileUploader
                    id="VN_id_FileUploader"
                    fileType="jpg,jpeg,png,PDF"
                    sameFilenameAllowed="false"
                    change="onFacilityFileChange"
                    visible="{VisibleModel>/visible}"
                    class="myUnifiedBtn"
                    width="100%"
                />
            </f:content>
        </f:SimpleForm>
    </Dialog>
</c:FragmentDefinition>