<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
    xmlns:mvc="sap.ui.core.mvc"
>
    <Dialog
        id="FacilitiesDialog"
        title="Add facilities"
        type="Message"
        class="sapUiContentPadding"
        resizable="true"
        draggable="true"
        contentWidth="40%"
        contentHeight="auto"
    >
        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <f:content>
                <Label
                    text="{i18n>MSbranchCode}"
                    required="true"
                />
                <ComboBox
                    id="idRoomType123"
                    placeholder="Select Branch Code"
                    selectedKey="{FacilitiesModel>/BranchCode}"
                    items="{BranchModel>/}"
                    showSecondaryValues="true"
                    change=".onFacilitybranchChange"
                    valueStateText="{i18n>selectBranchCode}"
                >
                    <core:ListItem
                        key="{BranchModel>BranchID}"
                        text="{BranchModel>BranchID} - {BranchModel>Name}"
                        additionalText="{BranchModel>City}"
                    />
                </ComboBox>

                <Label
                    text="{i18n>facilityname}"
                    required="true"
                />
                <Input
                    id="idFacilityName"
                    value="{FacilitiesModel>/FacilityName}"
                    placeholder="Enter Facility Name"
                    valueStateText="{i18n>enterFacilityName}"
                    liveChange="onFacilityNameChange"
                />

                <Label
                    text="{i18n>type}"
                    required="true"
                />
                <ComboBox
                    id="idFacilityName1"
                    items="{FacilityType>/}"
                    value="{FacilitiesModel>/Type}"
                    placeholder="Enter Type"
                    valueStateText="{i18n>enterType}"
                    change="onFacilityTypeChange"
                >
                    <core:Item
                        key="{FacilityType>ID}"
                        text="{FacilityType>FacilityName}"
                    />
                </ComboBox>

                <Label text="{i18n>hourlyPrice}" />
                <Input
                    id="idPerHourPrice"
                    placeholder="Enter Per Hour Price"
                    value="{FacilitiesModel>/PerHourPrice}"
                    maxLength="10"
                    liveChange="onPriceChange"
                    valueStateText="{i18n>enterPerHourPrice}"
                />

                <Label text="{i18n>dailyPrice}" />
                <Input
                    id="idPerDayPrice"
                    placeholder="Enter Per Day Price"
                    value="{FacilitiesModel>/PerDayPrice}"
                    maxLength="10"
                    liveChange="onPriceChange"
                    valueStateText="{i18n>enterPerDayPrice}"
                />

                <Label text="{i18n>monthlyPrice}" />
                <Input
                    id="idPerMonthPrice"
                    placeholder="Enter Per Month Price"
                    value="{FacilitiesModel>/PerMonthPrice}"
                    maxLength="10"
                    liveChange="onPriceChange"
                    valueStateText="{i18n>enterPerMonthPrice}"
                />

                <Label text="{i18n>yearlyPrice}" />
                <Input
                    id="idPerYearPrice"
                    placeholder="Enter Per Year Price"
                    value="{FacilitiesModel>/PerYearPrice}"
                    maxLength="10"
                    liveChange="onPriceChange"
                    valueStateText="{i18n>enterPerYearPrice}"
                />

                <Label
                    text="{i18n>currency}"
                    required="true"
                />
                <ComboBox
                    id="FL_id_Currency"
                    selectedKey="{FacilitiesModel>/Currency}"
                    items="{path:'CountryModel>/',length:1000}"
                    placeholder="Select Currency"
                    showSecondaryValues="true"
                    valueStateText="{i18n>selectCurrency}"
                    change="onChangeCurrency"
                >
                    <core:ListItem
                        key="{CountryModel>currency}"
                        text="{CountryModel>currency}"
                        additionalText="{CountryModel>countryName}"
                    />
                </ComboBox>

                <Label text="" />
                <VBox width="100%">
                    <HBox
                        justifyContent="End"
                        width="100%"
                    >
                        <u:FileUploader
                            id="id_fileUploader"
                            buttonOnly="true"
                            sameFilenameAllowed="false"
                            buttonText="Upload Images"
                            fileType="jpg,jpeg,png"
                            multiple="true"
                            change="onFacilityFileChange"
                        />
                        <Text
                            text="*"
                            class="upload-star"
                        />
                    </HBox>
                    <Table
                        id="id_AttachmentTable"
                        items="{UploaderData>/attachments}"
                        mode="Delete"
                        delete="onTokenDelete"
                        width="100%"
                        popinLayout="Block"
                    >
                        <columns>
                            <Column
                                minScreenWidth="Phone"
                                demandPopin="false"
                            >
                                <Text text="{i18n>filename}" />
                            </Column>
                            <Column
                                hAlign="Center"
                                minScreenWidth="Tablet"
                                demandPopin="true"
                            >
                                <Text text="{i18n>FileType}" />
                            </Column>
                            <Column
                                hAlign="Center"
                                minScreenWidth="Tablet"
                                demandPopin="true"
                            >
                                <Text text="{i18n>FileSize}" />
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{UploaderData>filename}" />
                                    <Text text="{UploaderData>fileType}" />
                                    <Text text="{UploaderData>size}" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </VBox>
            </f:content>
        </f:SimpleForm>
        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Button
                    text="{i18n>save}"
                    tooltip="Save"
                    class="myUnifiedBtn"
                    press="FD_onsavebuttonpress"
                />
                <Button
                    text="{i18n>CancelButton}"
                    tooltip="Cancel"
                    class="myUnifiedBtn"
                    press="FD_onCancelButtonPress"
                />
            </Toolbar>
        </footer>
    </Dialog>
</c:FragmentDefinition>