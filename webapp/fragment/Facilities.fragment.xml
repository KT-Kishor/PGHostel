<c:FragmentDefinition
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified"
	xmlns:mvc="sap.ui.core.mvc">
	<Dialog id="FacilitiesDialog"
    title="{i18n>addfacilities}"
    contentWidth="80%"
        >
		
		<f:SimpleForm
            editable="true"
                layout="ColumnLayout"
               labelSpanXL="12" labelSpanL="12" labelSpanM="12"
         labelSpanS="12" adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0" emptySpanM="0" emptySpanS="0" columnsXL="2"
         columnsL="2" columnsM="1">
			<f:content>
				<Label
                    text="{i18n>MSbranchCode}"
                    required="true"
                />
				<ComboBox
                    id="idRoomType123"
                    placeholder="{i18n>placeSelectBranchCode}"
                    selectedKey="{FacilitiesModel>/BranchCode}"
                    items="{BranchModel>/}"
                    showSecondaryValues="true"
                    change=".onFacilitybranchChange"
                    valueStateText="{i18n>selectBranchCode}"
                >
					<core:ListItem
                        key="{BranchModel>BranchID}"
                        text="{BranchModel>BranchID} - {BranchModel>Name}"
                        additionalText="{BranchModel>City}"
                    />
				</ComboBox>
				<Label
                    text="{i18n>facilityname}"
                    required="true"
                />
				<Input
                    id="idFacilityName"
                    value="{FacilitiesModel>/FacilityName}"
                    placeholder="{i18n>placeEnterFacilityName}"
                    valueStateText="{i18n>enterFacilityName}"
                    liveChange="onFacilityNameChange"
                    maxLength="60"
                />
				<Label
                    text="{i18n>type}"
                    required="true"
                />
				<ComboBox
                    id="idFacilityName1"
                    items="{FacilityType>/}"
                    value="{FacilitiesModel>/Type}"
                    placeholder="{i18n>enterType}"
                    valueStateText="{i18n>enterType}"
                    change="onFacilityTypeChange"
                >
					<core:Item
                        key="{FacilityType>ID}"
                        text="{FacilityType>FacilityName}"
                    />
				</ComboBox>
				<Label
                    text="Selection Mode"
                    required="true"
                />
				<ComboBox
                    id="idSelectionMode"
                    selectedKey="{FacilitiesModel>/SelectionMode}"
                    items="{SelectionModeModel>/}"
                    placeholder="Select selection mode"
                    valueStateText="Select selection mode"
                    change="onSelectionModeChange"
                >
					<core:Item
                        key="{SelectionModeModel>key}"
                        text="{SelectionModeModel>text}"
                    />
				</ComboBox>
				<Label
                    text="{i18n>unitPrice}"
                    required="true"
                    visible="{= ${FacilitiesModel>/SelectionMode} === 'PERSON_QTY' || ${FacilitiesModel>/Type} === 'Laundry Service' || ${FacilitiesModel>/Type} === 'Ironing Service' }"
                />
				<Input
                    id="idUnitPrice"
                    placeholder="{i18n>enterUnitPrice}"
                    value="{FacilitiesModel>/UnitPrice}"
                    maxLength="7"
                    liveChange="onPriceChange"
                    valueStateText="{i18n>enterUnitPrice}"
                    visible="{= ${FacilitiesModel>/SelectionMode} === 'PERSON_QTY' || ${FacilitiesModel>/Type} === 'Laundry Service' || ${FacilitiesModel>/Type} === 'Ironing Service' }"
                />
				<Label
                    text="{i18n>hourlyPrice}"
                    visible="{= !(${FacilitiesModel>/SelectionMode} === 'PERSON_QTY' || ${FacilitiesModel>/Type} === 'Laundry Service' || ${FacilitiesModel>/Type} === 'Ironing Service') }"
                />
				<Input
                    id="idPerHourPrice"
                    placeholder="{i18n>enterPerHourPrice}"
                    value="{FacilitiesModel>/PerHourPrice}"
                    maxLength="10"
                    liveChange="onPriceChange"
                    valueStateText="{i18n>enterPerHourPrice}"
                    visible="{= !(${FacilitiesModel>/SelectionMode} === 'PERSON_QTY' || ${FacilitiesModel>/Type} === 'Laundry Service' || ${FacilitiesModel>/Type} === 'Ironing Service') }"
                />
				<Label
                    text="{i18n>dailyPrice}"
                    visible="{= !(${FacilitiesModel>/SelectionMode} === 'PERSON_QTY' || ${FacilitiesModel>/Type} === 'Laundry Service' || ${FacilitiesModel>/Type} === 'Ironing Service') }"
                />
				<Input
                    id="idPerDayPrice"
                    placeholder="{i18n>enterPerDayPrice}"
                    value="{FacilitiesModel>/PerDayPrice}"
                    maxLength="10"
                    liveChange="onPriceChange"
                    valueStateText="{i18n>enterPerDayPrice}"
                    visible="{= !(${FacilitiesModel>/SelectionMode} === 'PERSON_QTY' || ${FacilitiesModel>/Type} === 'Laundry Service' || ${FacilitiesModel>/Type} === 'Ironing Service') }"
                />
				<Label
                    text="{i18n>monthlyPrice}"
                    visible="{= !(${FacilitiesModel>/SelectionMode} === 'PERSON_QTY' || ${FacilitiesModel>/Type} === 'Laundry Service' || ${FacilitiesModel>/Type} === 'Ironing Service') }"
                />
				<Input
                    id="idPerMonthPrice"
                    placeholder="{i18n>enterPerMonthPrice}"
                    value="{FacilitiesModel>/PerMonthPrice}"
                    maxLength="10"
                    liveChange="onPriceChange"
                    valueStateText="{i18n>enterPerMonthPrice}"
                    visible="{= !(${FacilitiesModel>/SelectionMode} === 'PERSON_QTY' || ${FacilitiesModel>/Type} === 'Laundry Service' || ${FacilitiesModel>/Type} === 'Ironing Service') }"
                />
				<Label
                    text="{i18n>yearlyPrice}"
                    visible="{= !(${FacilitiesModel>/SelectionMode} === 'PERSON_QTY' || ${FacilitiesModel>/Type} === 'Laundry Service' || ${FacilitiesModel>/Type} === 'Ironing Service') }"
                />
				<Input
                    id="idPerYearPrice"
                    placeholder="{i18n>enterPerYearPrice}"
                    value="{FacilitiesModel>/PerYearPrice}"
                    maxLength="10"
                    liveChange="onPriceChange"
                    valueStateText="{i18n>enterPerYearPrice}"
                    visible="{= !(${FacilitiesModel>/SelectionMode} === 'PERSON_QTY' || ${FacilitiesModel>/Type} === 'Laundry Service' || ${FacilitiesModel>/Type} === 'Ironing Service') }"
                />
				<Label
                    text="{i18n>currency}"
                    required="true"
                />
				<ComboBox
                    id="FL_id_Currency"
                    selectedKey="{FacilitiesModel>/Currency}"
                    items="{path:'CountryModel>/',length:1000}"
                    placeholder="{i18n>selectCurrency}"
                    showSecondaryValues="true"
                    valueStateText="{i18n>selectCurrency}"
                    change="onChangeCurrency"
                >
					<core:ListItem
                        key="{CountryModel>currency}"
                        text="{CountryModel>currency}"
                        additionalText="{CountryModel>countryName}"
                    />
				</ComboBox>
			</f:content>
		</f:SimpleForm>
		<VBox
            class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop "
        >
			<!-- Informational Message Strip -->
			<MessageStrip
                text="Please upload only JPG, JPEG, or PNG images with a maximum file size of 2 MB."
                showIcon="true"
                type="Warning"
                class="sapUiTinyMarginBottom"
            />
		</VBox>
		<Label text="" />
		<VBox width="100%">
			<HBox
                justifyContent="End"
             class="sapUiSmallMarginEnd"
            >
				<u:FileUploader
                    id="id_fileUploader"
                    buttonOnly="true"
                    sameFilenameAllowed="false"
                    buttonText="Upload Images"
                    fileType="jpg,jpeg,png"
                    multiple="true"
                    change="onFacilityFileChange"
                    class="myUnifiedBtn"
                />
				<!-- <Text
                    text="*"
                    class="upload-star"
                /> -->
			</HBox>
			<Table
                id="id_AttachmentTable"
                items="{UploaderData>/attachments}"
                mode="Delete"
                delete="onTokenDelete"
                width="100%"
                popinLayout="Block"
            >
				<columns>
					<Column
                        minScreenWidth="Phone"
                        demandPopin="false"
                    >
						<Text text="{i18n>filename}" />
					</Column>
					<Column
                        hAlign="Center"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
						<Text text="{i18n>FileType}" />
					</Column>
					<Column
                        hAlign="Center"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
						<Text text="{i18n>FileSize}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem>
						<cells>
							<Text text="{UploaderData>filename}" />
							<Text text="{UploaderData>fileType}" />
							<Text text="{UploaderData>size}" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</VBox>
		<beginButton>
			<Button
                    text="{i18n>save}"
                    tooltip="{i18n>save}"
                    class="myUnifiedBtn"
                    press="FD_onsavebuttonpress"
                />
		</beginButton>
		<endButton>
			<Button
                    text="{i18n>CancelButton}"
                    tooltip="{i18n>CancelButton}"
                    class="myUnifiedBtn"
                    press="FD_onCancelButtonPress"
                />
		</endButton>
	</Dialog>
</c:FragmentDefinition>