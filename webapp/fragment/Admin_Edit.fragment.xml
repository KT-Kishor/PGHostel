<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>
    <Dialog
        id="editFacilityDialog"
        afterClose=".onEditDialogClose"
        contentWidth="28rem"
        contentHeight="auto"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title text="{i18n>editFacility}" />
                </contentMiddle>
            </Bar>
        </customHeader>
        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <f:content>
                <!-- Facility Name -->
                
                <Label
                    text="{i18n>facilityname}"
                    required="true"
                />
                <ComboBox
                    id="editFacilityName"
                    placeholder="{i18n>selectFacility}"
                    items="{Facilities>/}"
                    value="{edit>/FacilityName}"
                    selectionChange="onFacilityChange"
                    width="100%"
                    valueStateText="{i18n>pleaseSelectFacilityName}"
                    showSecondaryValues="true"
                >
                    <core:ListItem
                        key="{Facilities>FacilityName}"
                        text="{Facilities>FacilityName}"
                        additionalText="{Facilities>FacilityChargeType}"
                    />
                </ComboBox>

                  <Label
                    text="Name"
                    required="true"
                />
                <ComboBox
                    id="editMembername"
                    placeholder="Select Name"
                    items="{CustomerData>/AllMembers}"
                    value="{edit>/MemberName}"
                    change="onMemberNameChange"
                    width="100%"
                    valueStateText="Please Select Name"
                >
                    <core:Item
                        key="{CustomerData>Name}"
                        text="{CustomerData>Name}"
                    />
                </ComboBox>

                <!-- Unit Type -->
                <Label
                    text="{i18n>unitType}"
                    required="true"
                />
                <ComboBox
                    id="idUnitType"
                    visible="false"
                    placeholder="{i18n>selectUnitType}"
                    items="{RateType>/}"
                    value="{edit>/UnitText}"
                    change="onUnitTextChange"
                    width="100%"
                    valueStateText="{i18n>plaeseSelectUnit}"
                >
                    <core:Item
                        key="{RateType>RateType}"
                        text="{RateType>RateType}"
                    />
                </ComboBox>

                 
                <Label text="{i18n>quantity}"
                   required="true" />
                <Input
                    id="editquantity"
                    value="{edit>/quantity}"
                    maxLength="2"
                    visible="{= ${edit>/UnitText} === 'Unit Price' }"
                    placeholder="Enter Quantity"
                    valueStateText="Enter Quantity"
                    liveChange=".onQuantityLiveChange"

                />
                    <RadioButtonGroup id="id_Period" columns="2" select=".onPeriodTypeSelect" 
                        visible="{= ${edit>/UnitText} === 'Unit Price' }"
                        editable="false"

                  >
                                <buttons>
                                    <RadioButton text="Daily" />
                                    <RadioButton text="Entire_Booking" />
                                </buttons>
                            </RadioButtonGroup> 

                <!-- Facility Price -->
                <Label text="{i18n>faciltyprice}" />
                <Input
                    id="editPrice"
                    value="{edit>/Price}"
                    type="Number"
                    editable="false"
                />

                <!-- Currency -->
                <Label text="{i18n>currency}" />
                <ComboBox
                    enabled="false"
                    id="FU_id_Currency"
                    selectedKey="{edit>/Currency}"
                    items="{CurrencyModel>/}"
                    valueStateText="{i18n>selectCurrency}"
                    width="100%"
                    change=".onCurrecnyChange"
                    placeholder="{i18n>selectCurrency}"
                >
                    <core:Item
                        key="{CurrencyModel>currency}"
                        text="{CurrencyModel>currency}"
                    />
                </ComboBox>

                <!-- Start Date -->
                <Label
                    text="{i18n>startDate}"
                    required="true"
                />
                <DatePicker
                    id="editStartDate"
                    value="{edit>/StartDate}"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="yyyy-MM-dd"
                    change="onEditDateChange"
                    minDate="{CustomerData>/minStartDate}"
                    maxDate="{CustomerData>/minEndDate}"
                    valueStateText="{i18n>plaeseSelectDate}"
                />

                <Label
                    text="{i18n>howmany}"
                    visible="{= ${edit>/UnitText} !== 'Per Day' &amp;&amp; ${edit>/UnitText} !== 'Per Hour' &amp;&amp; ${edit>/UnitText} !== 'Unit Price' }"
                />

                <Select
                    id="idMonthYearSelectFragment"
                    width="100%"
                    visible="{= ${edit>/UnitText} !== 'Per Day' &amp;&amp; ${edit>/UnitText} !== 'Per Hour' &amp;&amp; ${edit>/UnitText} !== 'Unit Price' }"
                    selectedKey="{edit>/TotalUnits}"
                    change=".onMonthYearChange"
                >
                    <core:Item
                        key="1"
                        text="1"
                    />
                    <core:Item
                        key="2"
                        text="2"
                    />
                    <core:Item
                        key="3"
                        text="3"
                    />
                    <core:Item
                        key="4"
                        text="4"
                    />
                    <core:Item
                        key="5"
                        text="5"
                    />
                    <core:Item
                        key="6"
                        text="6"
                    />
                    <core:Item
                        key="7"
                        text="7"
                    />
                    <core:Item
                        key="8"
                        text="8"
                    />
                    <core:Item
                        key="9"
                        text="9"
                    />
                    <core:Item
                        key="10"
                        text="10"
                    />
                    <core:Item
                        key="11"
                        text="11"
                    />
                </Select>

                <!-- End Date -->
                <Label
                    text="{i18n>endDate}"
                    required="true"
                />
                <DatePicker
                    id="editEndDate"
                    editable="{= ${edit>/UnitText} !== 'Per Month' &amp;&amp; ${edit>/UnitText} !== 'Per Year' }"
                    value="{path:'edit>/EndDate'}"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="dd/MM/yyyy"
                    change="onEditDateChange"
                    minDate="{CustomerData>/minStartDate}"
                    maxDate="{CustomerData>/minEndDate}"
                    valueStateText="{i18n>plaeseSelectDate}"
                />
                <!-- Days -->
                <Label text="{i18n>days}" />
                <Input
                    id="editDays"
                    value="{edit>/TotalDays}"
                    editable="false"
                />
                <Label
                    text="{i18n>startTime}"
                    required="true"
                />

                <TimePicker
                    id="editStartTime"
                    value="{edit>/StartTime}"
                    change="onEditTimeChange"
                    displayFormat="HH"
                    valueFormat="HH"
                    valueStateText="{i18n>pleaseselectTime}"
                    visible="{= ${edit>/UnitText} === 'Per Hour'}"
                />
                <Label
                    text="{i18n>endTime}"
                    required="true"
                />

                <TimePicker
                    id="editEndTime"
                    value="{edit>/EndTime}"
                    displayFormat="HH"
                    valueFormat="HH"
                    change="onEditTimeChange"
                    valueStateText="{i18n>pleaseselectTime}"
                    visible="{= ${edit>/UnitText} === 'Per Hour'}"
                />
                <Label text="{i18n>hours}" />
                <Input
                    id="editHours"
                    value="{edit>/TotalHour}"
                    editable="false"
                    visible="{= ${edit>/UnitText} === 'Per Hour'}"
                />
                  <Label
        text="Add CouponCode"
        class="sapUiSmallMarginEnd"
    />
                  <HBox
    alignItems="Center"
    justifyContent="SpaceEvenly"
>
  

    <Input
        id="ID_editCouponCode"
        value="{edit>/CouponCode}"
        placeholder="Enter Coupon Code"
        width="200px"
        class="sapUiSmallMarginEnd"
        showValueHelp="true"
        valueHelpIconSrc="sap-icon://decline"
        valueHelpRequest="oncancelFacilityCoupon"
        liveChange="onCouponLiveChange"
    />

    <Button
        id="idApplyNowButton"
        text="{i18n>applyNow}"
        tooltip="{i18n>applyCoupon}"
        press=".onEditCouponCodeLiveChange"
        class="myUnifiedBtn"
     
    />
</HBox>

                 <Label text="Discount Value" />
                <Input
                    id="idD_editDiscountValue"
                    value="{edit>/CouponDiscount}"
                    editable="false"
                />

            </f:content>
        </f:SimpleForm>
        <beginButton>
            <Button
                text="{i18n>save}"
                tooltip="{i18n>save}"
                press=".onEditFacilitySave"
                class="myUnifiedBtn"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>CancelButton}"
                tooltip="{i18n>CancelButton}"
                press="onEditDialogClose"
                class="myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>