<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core" >
	<!-- Dialog container for Employee Details -->
	<Dialog id="AddEd_id_dialog"
        title="{i18n>educationalDetails}">
		<!-- SimpleForm with ResponsiveGridLayout -->
		<f:SimpleForm 
			editable="false"
			layout="ResponsiveGridLayout"
			labelSpanXL="3"
			labelSpanL="3"
			labelSpanM="3"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="4"
			emptySpanL="4"
			emptySpanM="4"
			emptySpanS="0"
			columnsXL="1"
			columnsL="1"
			columnsM="1"
			singleContainerFullSize="false" >
			<f:content>
				<Label text="{i18n>employeeID}"  />
				<Input value="{educationModel>/EmployeeID}"   maxLength="20"  editable="false"/>
				<Label text="{i18n>collegeName}" required="true" />
				<Input value="{educationModel>/CollegeName}" placeholder="{i18n>collegeName}" id="AddEd_id_College" maxLength="50" liveChange="ValidateCommonFields" valueStateText="{i18n>collegeNameValueState}"/>
				<Label text="{i18n>degree}" required="true" />
				<Select  selectedKey="{educationModel>/Degree}" items="{Degree>/degree}" id="AddEd_id_Degree" change="" >
					<core:Item key="{Degree>DegreeName}" text="{Degree>DegreeName}" />
				</Select>
				<Label text="{i18n>startDate}" required="true" />
				<DatePicker id="AddEd_id_StartEdu" 
				value="{educationModel>/EducationStartDate}"
            change="validateDate"
            displayFormat="dd/MM/yyyy" 
            valueFormat="dd/MM/yyyy"
           maxDate="{viewModel>/Max}"
		   valueStateText="{i18>dateValueState}" />
				<Label text="{i18n>endDate}" required="true" />
				<DatePicker id="AddEd_id_EndEdu" 
				value="{educationModel>/EducationEndDate}"
            change="validateDate"
            displayFormat="dd/MM/yyyy" 
            valueFormat="dd/MM/yyyy" 
			maxDate="{viewModel>/Max}"
            minDate="{startDate}" 
			valueStateText="{i18n>dateValueState}"/>
				<Label text="{i18n>grade}"  required="true" />
				<HBox width="70%" justifyContent="Start">
					<Input  value="{educationModel>/Grade}"   id="AddEd_id_Grade" liveChange="ValidateCommonFields" 
                 type="Number"   placeholder="{i18n>grade}"  valueStateText="{i18n>gradeValueState}" />
					<Select  selectedKey="{educationModel>/GradeType}" items="{CollegeGrade>/grade}" id="AddEd_id_GradeType" class="sapUiSmallMarginBegin">
						<core:Item key="{CollegeGrade>Value}" text="{CollegeGrade>Value}" />
					</Select>
				</HBox>
			</f:content>
		</f:SimpleForm>
		<HBox justifyContent="End" >
			<Button text="{i18n>Submit}" type="Accept" id="AddEd_id_Submit" press="AddEd_onSubmitEdDetails" class="submit"  visible="{viewModel>/fragmentSave}" />
			<!-- <Button text="{i18n>save}" type="Accept" press="AddEd_onUpdateEdDetails" class="submit" id="AddEd_id_Save" visible="{viewModel>/fragmentSubmit}"/> -->
			<Button text="{i18n>close}" press="AddEd_onCloseDial" class="sendMail" type="Reject"/>
		</HBox>
	</Dialog>
</core:FragmentDefinition>
