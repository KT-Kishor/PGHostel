<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core">
    
    <Dialog id="CommonDialog" title="Confirmation"
        afterClose="onDialogClose"
        class="sapUiResponsivePadding">
        
        <Text text="{i18n>backConfirmation}" class="sapUiSmallMarginBegin sapUiTinyMarginTop" />

        <beginButton>
            <Button text="Yes" press="onConfirmBack" type="Accept"/>
        </beginButton>

        <endButton>
            <Button text="No" press="onCancel" type="Reject"/>
        </endButton>
        
    </Dialog>
</c:FragmentDefinition>