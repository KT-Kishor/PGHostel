<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">

		<Table id="AL_id_LeaveTableStandard"
			mode="SingleSelectLeft"
			selectionChange="onSelectionChange"
			 width="auto"
             items="{path: 'LeaveModel>/'}"
             growing="true"
             growingThreshold="100"
            alternateRowColors="true"
			class="sapUiResponsiveContentPadding centeredTable">
			<headerToolbar>
				<Toolbar>
				 <Title id="Al_id_Title" text="{i18n>appliedLeave}"/>
					<ToolbarSpacer/>
					<ToolbarSeparator/>
					<Button icon="sap-icon://vertical-bar-chart" press="AL_onPressBarChart" tooltip="{i18n>openBarCharts}" />
					<Button icon="sap-icon://create-leave-request" tooltip="{i18n>applyLeave}" press="AL_onPressApplyLeave"/>
					<Button icon="sap-icon://edit" id="AL_id_Updatebtn" tooltip="{i18n>editDetails}" press="AL_onPressUpdate" visible="{= ${Leave>Status} === 'Submitted' }"/>
					<Button icon="sap-icon://delete" id="AL_id_Deletebtn" tooltip="{i18n>deleteDetails}" press="AL_onPressLeaveDetailsDelete" visible="{= ${Leave>Status} === 'Submitted' }"/>
					<ToolbarSeparator/>
				</Toolbar>
			</headerToolbar>
			<columns>
				<Column minScreenWidth="Tablet" demandPopin="true">
					<Text text="{i18n>fromDate}" />
				</Column>
				<Column minScreenWidth="Tablet" demandPopin="true">
					<Text text="{i18n>toDate}" />
				</Column>
				<Column minScreenWidth="Tablet" demandPopin="true">
					<Text text="{i18n>noOfDays}" />
				</Column>
				<Column minScreenWidth="Tablet" demandPopin="true">
					<Text text="{i18n>typeOfLeave}" />
				</Column>
				<Column minScreenWidth="Tablet" demandPopin="true">
					<Text text="{i18n>comments}" />
				</Column>
				<Column minScreenWidth="Tablet" demandPopin="true">
					<Text text="{i18n>status}" />
				</Column>
				<Column minScreenWidth="Tablet" demandPopin="true">
					<Text text="{i18n>halfDay}" />
				</Column>
				<Column minScreenWidth="Tablet" demandPopin="true">
					<Text text="{i18n>managerRemarksLeave}" />
				</Column>
			</columns>
			<items>
				<ColumnListItem>
					<cells>
					<Text text="{path:'LeaveModel>fromDate' ,formatter:'.Formatter.formatDate'}" />
					<Text text="{path:'LeaveModel>toDate' ,formatter:'.Formatter.formatDate'}" />
						<Text text="{LeaveModel>NoofDays}" />
						<Text text="{LeaveModel>typeOfLeave}" />
						<Text text="{LeaveModel>comments}" />
					<ObjectStatus inverted="true" text="{LeaveModel>status}" state="{path: 'LeaveModel>status', formatter: '.Formatter.formatObjectStatus'}" />
					<CheckBox selected="{= ${LeaveModel>halfDay} === 'true'}" editable="false"/>				
					<Button icon="sap-icon://display-more" text="{i18n>View}" press="onShowMore" />
					</cells>
				</ColumnListItem>
			</items>
		</Table>
</core:FragmentDefinition>
