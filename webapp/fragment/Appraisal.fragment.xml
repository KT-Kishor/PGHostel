<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core">
	<Dialog
        id="idDialogSalaryEdit" title="Salary Update Details">
		<f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1"
            singleContainerFullSize="false">
			<f:content>
                <Label text="CTC in Percentage/CTC" required="true" />
                <HBox width="100%" justifyContent="SpaceBetween" id="AF_id_CTCPercentage">
                    <VBox width="68%">
                        <Input value="{AppraisalModel>/CtcPercentage}" id="AF_id_CTC" placeholder="{i18n>placeCtc}" liveChange="EOD_validateAmount" maxLength="15" valueStateText="{i18n>ctcAndVariblePay}"/>                
                    </VBox>
                    <VBox width="30%">
                        <Select forceSelection="false" selectedKey="1" id="ED_Frg_idAppraisalType" change="onSelectChange">
                            <core:Item key="0" text="CTC" />
                            <core:Item key="1" text="Percentage" />
                        </Select>
                    </VBox>
                </HBox>
                <Label text="{i18n>EmpOfferVariablePay}" required="true" />
				<Input id="AF_id_VariablePay" value="{AppraisalModel>/VariablePay}" placeholder="{i18n>variablePayPer}" liveChange="EOD_validatevariable" maxLength="5" showValueHelp="false" valueStateText="{i18n>variabelPayValueStae}"/>  
                   
               <Label text="{i18n>grossPayTotal}" />
               <Text text="{AppraisalModel>/TotalCTC}" id="AF_idTextCTC"/>
                <Label text="{i18n>EmpOfferVariablePay}" />
               <Text text="{AppraisalModel>/TotalVariablePay}" id="AE_idTextVP" />
               <Label text="{i18n>pastGross}" />
               <Text text="{AppraisalModel>/PreviousGrossPay}" id="AF_idPastGross" />

               <Label text="{i18n>pastVP}" />
               <Text text="{AppraisalModel>/PreviousVariablePay}" id="AF_idPastVP" />

                <Label text="{i18n>EffectiveDate}" required="true" />
				<DatePicker minDate="{controller>/nextMonthMinDate}"  value="{path: 'AppraisalModel>/EffectiveDate', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'MM-yyyy' }, constraints: { displayFormat: 'MM-yyyy' }}" change="onChangeEffectiveDate" displayFormat="MM-yyyy" valueFormat="dd/MM/yyyy" id="SS_id_Joinn"/>

                <Label text="{i18n>salaryType}"/>
                <RadioButtonGroup id="AF_id_RadioButTds" columns="3" select="EOD_onTDSCheckboxChange" setSelectedIndex="0">
                <RadioButton id="AF_id_TDSRadio" text="{i18n>tds}" />
                <RadioButton text="{i18n>pf}" />
                </RadioButtonGroup>

                
			</f:content>
		</f:SimpleForm>
		<!-- Buttons for Ok and Close actions -->
		<FlexBox justifyContent="End" width="100%">
			<Button text="{i18n>save}" id="idSaveBtn" press="onPressAppraisalSave" class="sendMail" type="Accept"/>
			<Button text="{i18n>close}" id="idCloseBtn" press="onPressAppraisalClose" type="Reject" class="sendMail" />
		</FlexBox>
	</Dialog>
</core:FragmentDefinition>