<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>
    <Dialog
        id="sds12"
        type="Message"
        class="sapUiContentPadding"
        resizable="true"
        draggable="true"
        contentWidth="28rem"
        contentHeight="auto"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title text="{i18n>bedDetails}" />
                </contentMiddle>
            </Bar>
        </customHeader>

        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <f:content>
                <Label
                    text="{i18n>MSbranchCode}"
                    required="true"
                />
                <ComboBox
                    id="BD_id_RoomType12"
                    selectedKey="{BedModel>/BranchCode}"
                    items="{BranchModel>/}"
                    change="onbranchChange"
                    showSecondaryValues="true"
                    placeholder="{i18n>placeSelectBranchCode}"
                    valueStateText="{i18n>selectBranchCode}"
                >
                    <core:ListItem
                        key="{BranchModel>BranchID}"
                        text="{BranchModel>BranchID} - {BranchModel>Name}"
                        additionalText="{BranchModel>City}"
                    />
                </ComboBox>

                <Label
                    text="{i18n>bedType}"
                    required="true"
                />
                <Input
                    id="BD_idBedType"
                    value="{BedModel>/Name}"
                    placeholder="{i18n>enterBedType}"
                    valueStateText="{i18n>enterBedType}"
                    maxLength="50"
                    liveChange="onLivehange"
                />

                <Label
                    text="{i18n>roomtype}"
                    required="true"
                />
                <ComboBox
                    id="BD_id_Roomtype"
                    selectedKey="{BedModel>/ACType}"
                    change="onDepositCurrency"
                    placeholder="{i18n>selectRoomType}"
                    valueStateText="{i18n>selectRoomType}"
                >
                    <core:ListItem
                        key="AC"
                        text="AC"
                    />
                    <core:ListItem
                        key="NON-AC"
                        text="NON-AC"
                    />
                </ComboBox>

                <Label
                    text="{i18n>noofPerson}"
                    required="true"
                />
                <Input
                    id="BD_id_Person"
                    value="{BedModel>/NoOfPerson}"
                    placeholder="{i18n>enterNoofPerson}"
                    valueStateText="{i18n>enterNoofPerson}"
                    liveChange="onNoOfPersonInputLiveChange"
                    maxLength="2"
                />

                <Label
                    text="{i18n>noofRooms}"
                    required="true"
                />
                <Input
                    id="BD_id_MaxBeds"
                    value="{BedModel>/MaxBeds}"
                    placeholder="{i18n>enterNoofRooms}"
                    valueStateText="{i18n>enterNoofRooms}"
                    maxLength="3"
                    liveChange="onNoOfPersonInputLiveChange"
                />
                <Label
                    text="Deposit Amount"
                    required="true"
                />
                <Input
                    id="BD_id_DepositAmount"
                    value="{BedModel>/Deposit}"
                    placeholder="Enter deposit amount"
                    valueStateText="Enter Deposit Amount"
                    maxLength="7"
                    liveChange="onNoOfPersonInputLiveChange"
                />
                <Label
                    text="{i18n>currency}"
                    required="true"
                />
                <ComboBox
                    id="BD_id_DepositCurrency"
                    selectedKey="{BedModel>/DepositCurrency}"
                    items="{path:'CountryModel>/',length:1000}"
                    valueStateText="{i18n>selectCurrency}"
                    width="100%"
                    change="onDepositCurrency"
                    placeholder="{i18n>selectCurrency}"
                    showSecondaryValues="true"
                >
                    <core:ListItem
                        key="{CountryModel>currency}"
                        text="{CountryModel>currency}"
                        additionalText="{CountryModel>countryName}"
                    />
                </ComboBox>

                <Label
                    text="{i18n>description}"
                    required="true"
                />
                <TextArea
                    id="BD_id_Description"
                    value="{BedModel>/Description}"
                    maxLength="150"
                    placeholder="{i18n>enterDescription}"
                    valueStateText="{i18n>enterDescription}"
                    liveChange="onLivehange"
                    rows="4"
                    growing="false"
                    
                />
            </f:content>
        </f:SimpleForm>

        <VBox
            class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop "
        >
            <!-- Informational Message Strip -->
            <MessageStrip
                text="Please add at least one image. Only JPG, JPEG, or PNG files up to 2 MB are allowed."
                showIcon="true"
                type="Warning"
                class="sapUiTinyMarginBottom"
            />
        </VBox>
        <Label text=""/>
        <VBox width="100%">
            <HBox
                justifyContent="End"
                width="100%"
            >
                <u:FileUploader
                    id="BT_id_FileUploader"
                    fileType="jpg,jpeg,png"
                    multiple="true"
                    sameFilenameAllowed="false"
                    buttonOnly="true"
                    buttonText="Upload Images"
                    change="onFacilityFileChange"
                    class="myUnifiedBtn"
                />
                <!-- <Text
                    text="*"
                    class="upload-star"
                /> -->
            </HBox>
            <Table
                id="id_Bed_AttachmentTable"
                items="{UploaderData>/attachments}"
                mode="Delete"
                popinLayout="Block"
                delete="onTokenDelete"
                width="100%"
            >
                <columns>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Phone"
                    >
                        <Text text="{i18n>filename}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Center"
                        minScreenWidth="Tablet"
                    >
                        <Text text="{i18n>FileType}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Center"
                        minScreenWidth="Tablet"
                    >
                        <Text text="{i18n>FileSize}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{UploaderData>filename}" />
                            <Text text="{UploaderData>fileType}" />
                            <Text text="{UploaderData>size}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </VBox>

        <beginButton>
            <Button
                text="{i18n>save}"
                tooltip="{i18n>save}"
                press="BT_onsavebuttonpress"
                class="myUnifiedBtn"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>CancelButton}"
                tooltip="{i18n>CancelButton}"
                press="BT_onCancelButtonPress"
                class="myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</c:FragmentDefinition>