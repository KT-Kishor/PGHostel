<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>
    <Dialog
        id="sds12"
        title="{i18n>bedDetails}"
        type="Message"
        class="sapUiContentPadding"
        resizable="true"
        draggable="true"
        contentWidth="40%"
        contentHeight="auto"
    >
        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <f:content>
                <Label
                    text="{i18n>MSbranchCode}"
                    required="true"
                />
                <ComboBox
                    id="BD_id_RoomType12"
                    selectedKey="{BedModel>/BranchCode}"
                    items="{BranchModel>/}"
                    change="onbranchChange"
                    showSecondaryValues="true"
                    placeholder="{i18n>placeSelectBranchCode}"
                    valueStateText="{i18n>selectBranchCode}"
                >
                    <core:ListItem
                        key="{BranchModel>BranchID}"
                        text="{BranchModel>BranchID} - {BranchModel>Name}"
                        additionalText="{BranchModel>City}"
                    />
                </ComboBox>

                <Label
                    text="{i18n>bedType}"
                    required="true"
                />
                <Input
                    id="BD_idBedType"
                    value="{BedModel>/Name}"
                    placeholder="{i18n>enterBedType}"
                    valueStateText="{i18n>enterBedType}"
                    maxLength="50"
                    liveChange="onLivehange"
                />

                <Label
                    text="{i18n>roomtype}"
                    required="true"
                />
                <ComboBox
                    id="BD_id_Roomtype"
                    selectedKey="{BedModel>/ACType}"
                    change="onbranchChange"
                    placeholder="{i18n>selectRoomType}"
                    valueStateText="{i18n>selectRoomType}"
                >
                    <core:ListItem
                        key="AC"
                        text="AC"
                    />
                    <core:ListItem
                        key="Non-Ac"
                        text="Non-Ac"
                    />
                </ComboBox>

                <Label
                    text="{i18n>noofPerson}"
                    required="true"
                />
                <Input
                    id="BD_id_Person"
                    value="{BedModel>/NoOfPerson}"
                    placeholder="{i18n>enterNoofPerson}"
                    valueStateText="{i18n>enterNoofPerson}"
                    liveChange="onNoOfPersonInputLiveChange"
                    maxLength="2"
                />

                <Label
                    text="{i18n>noofRooms}"
                    required="true"
                />
                <Input
                    id="BD_id_MaxBeds"
                    value="{BedModel>/MaxBeds}"
                    placeholder="{i18n>enterNoofRooms}"
                    valueStateText="{i18n>enterNoofRooms}"
                    maxLength="3"
                    liveChange="onNoOfPersonInputLiveChange"
                />

                <Label
                    text="{i18n>description}"
                    required="true"
                />
                <TextArea
                    id="BD_id_Description"
                    value="{BedModel>/Description}"
                    maxLength="150"
                    placeholder="{i18n>enterDescription}"
                    valueStateText="{i18n>enterDescription}"
                    liveChange="onLivehange"
                />

                <Label text="" />
                <VBox width="100%">
                    <HBox
                        justifyContent="End"
                        width="100%"
                    >
                        <u:FileUploader
                            id="BT_id_FileUploader"
                            fileType="jpg,jpeg,png"
                            multiple="true"
                            sameFilenameAllowed="false"
                            buttonOnly="true"
                            buttonText="Upload Images"
                            change="onFacilityFileChange"
                        />
                        <Text
                            text="*"
                            class="upload-star"
                        />
                    </HBox>
                    <Table
                        id="id_Bed_AttachmentTable"
                        items="{UploaderData>/attachments}"
                        mode="Delete"
                        popinLayout="Block"
                        delete="onTokenDelete"
                        width="100%"
                    >
                        <columns>
                            <Column
                                demandPopin="true"
                                minScreenWidth="Phone"
                            >
                                <Text text="{i18n>filename}" />
                            </Column>
                            <Column
                                demandPopin="true"
                                hAlign="Center"
                                minScreenWidth="Tablet"
                            >
                                <Text text="{i18n>FileType}" />
                            </Column>
                            <Column
                                demandPopin="true"
                                hAlign="Center"
                                minScreenWidth="Tablet"
                            >
                                <Text text="{i18n>FileSize}" />
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{UploaderData>filename}" />
                                    <Text text="{UploaderData>fileType}" />
                                    <Text text="{UploaderData>size}" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </VBox>
            </f:content>
        </f:SimpleForm>
        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Button
                    text="{i18n>save}"
                    tooltip="{i18n>save}"
                    press="BT_onsavebuttonpress"
                    class="myUnifiedBtn"
                />
                <Button
                    text="{i18n>CancelButton}"
                    tooltip="{i18n>CancelButton}"
                    press="BT_onCancelButtonPress"
                    class="myUnifiedBtn"
                />
            </Toolbar>
        </footer>
    </Dialog>
</c:FragmentDefinition>