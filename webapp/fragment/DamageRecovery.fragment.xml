<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:form="sap.ui.layout.form">
    <Dialog
        id="DT_id_DamageRecoverDialog"
        title="Recover Damage"
        contentWidth="500px"
        stretch="false"
        afterClose="onDialogAfterClose">
        <content>
            <form:SimpleForm
                id="DT_id_DamageRecoveryForm"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="4"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="0"
                emptySpanL="0"
                emptySpanM="0"
                emptySpanS="0"
                columnsXL="1"
                columnsL="1"
                columnsM="1"
                singleContainerFullSize="false">

                <!-- Customer ID -->
                <Label text="Booking ID"/>
                <Text text="{DamageModel>/BookingID}"/>
                <!-- Customer Name -->
                <Label text="Customer Name"/>
                <Text text="{DamageModel>/CustomerName}"/>
                <!-- Damage Amount -->
                <Label text="Damage Amount"/>
                <Text text="{parts:[{path:'DamageModel>/TotalCost'},{path:'DamageModel>/Currency'}],formatter:'.Formatter.formatCurrency'}"/>
                <Label text="Due Amount" visible="{= ${DamageModel>/Status} === 'Partially Recovered' }"/>
                <Text visible="{= ${DamageModel>/Status} === 'Partially Recovered' }" text="{parts:[{path:'DamageModel>/DueAmount'},{path:'DamageModel>/Currency'}],formatter:'.Formatter.formatCurrency'}"/>
                <!-- Return Amount -->
                <Label text="Return Amount" required="true"/>
                <Input
                    id="DT_id_ReturnAmount"
                    type="Number"
                    value="{DamageModel>/ReturnDamageAmount}"
                    placeholder="Enter return amount"
                    liveChange="_validateReturnAmount"
                    valueStateText="Enter return amount"/>

                <!-- Return Mode -->
                <Label text="Return Mode" required="true"/>
                <ComboBox
                    id="DT_id_ReturnMode"
                    selectedKey="{DamageModel>/ReturnDamageMode}"
                    placeholder="Select return mode"
                    change="_onReturnModeChange" valueStateText="Select return mode">
                    <core:Item key="CASH" text="Cash"/>
                    <core:Item key="UPI" text="UPI"/>
                    <core:Item key="CARD" text="Card"/>
                </ComboBox>

                <!-- Transaction ID -->
                <Label text="Transaction ID/ Person Name"/>
                <Input
                    id="DT_id_ReturnTransactionID"
                    value="{DamageModel>/ReturnDamageTransactionID}"
                    placeholder="Enter transaction / person name"
                    liveChange="_validateTransactionID" valueStateText="Enter transaction / person name"/>

                <!-- Returning Employee -->
                <Label text="Returning To"/>
                <Text text="{LoginModel>/EmployeeName}"/>
            </form:SimpleForm>
        </content>
        <buttons>
            <Button text="Return Damage" press="onSaveReturn" class="marginRight myUnifiedBtn"/>
            <Button text="Cancel" press="onDialogClose" class="marginRight myUnifiedBtn"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>