<ActionSheet id="actionSheet"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	core:require="{ MessageToast: 'sap/m/MessageToast' }"
	title="Choose Your Action"
	showCancelButton="true"
	placement="Bottom">
	<Button text="{i18n>headerCompanyInvoice}" press="MsaE_GoToInvoice"/>
	<Button text="{i18n>addSOW}" press="MsaE_onPressCreateSow" />
	<Button text="{i18n>active}" id="MsaE_id_ActiveBtn" press="MsaE_onPressSOWActive"/>
	<Button text="{i18n>inactive}" id="Msa_id_InactiveBtn" press="MsaE_onPressSOWActive"/>
	<Button id="MsaE_id_RelesedBtn" press="MsaE_onPressRelesedSow" text="{i18n>ReleaseBtn}"/>
	<Button text="{i18n>ExpendBtn}" id="MsaE_id_ExpendBtn" press="MasE_onPressExpendSow"/>
	<Button id="MsaE_id_SowEmailBut" text="{i18n>tileFooter}" press="MsaE_onPressSendEmailSOW"/>
	<Button id="MsaE_id_SowMergeBut" text="{i18n>GeneratePDF}" press="MsaE_onPressMergeSow"/>
	<Button text="{i18n>edit}" id="MsaE_id_UpdateSow" press="MsaE_onPressUpdateSOW"/>
</ActionSheet>