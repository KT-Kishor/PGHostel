<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
>
    <Dialog
        class="sapUiContentPadding sapUiSmallMargin"
        id="adminSignupDialog"
        initialFocus="adminSalutation"
        contentWidth="60%"
        stretch="{= ${device>/system/phone} }"
        draggable="true"
        resizable="true"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title text="{i18n>adminVendorRegistration}" />
                </contentMiddle>
                <contentRight>
                    <Button
                        class="myUnifiedBtn"
                        icon="sap-icon://decline"
                        tooltip="{i18n>close}"
                        press="onCloseAdminSignup"
                    />
                </contentRight>
            </Bar>
        </customHeader>
        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="0"
            emptySpanL="0"
            emptySpanM="0"
            emptySpanS="0"
            columnsXL="2"
            columnsL="2"
            columnsM="2"
            singleContainerFullSize="false"
        >
            <f:content>
                <core:Title text="Personal Details" />

                <Label
                    required="true"
                    text="Name"
                />
                <HBox
                    width="100%"
                    justifyContent="Start"
                    alignItems="Center"
                >
                    <VBox width="35%">
                        <ComboBox
                            id="adminSalutation"
                            selectedKey="{AdminSignupModel>/Salutation}"
                            change="onAdminChangeSalutation"
                            placeholder="Mr. / Ms. / Dr."
                            valueStateText="{i18n>MVDsalutation}"
                        >
                            <core:ListItem
                                key="Mr."
                                text="Mr."
                            />
                            <core:ListItem
                                key="Ms."
                                text="Ms."
                            />
                            <core:ListItem
                                key="Mrs."
                                text="Mrs."
                            />
                            <core:ListItem
                                key="Dr."
                                text="Dr."
                            />
                        </ComboBox>
                    </VBox>
                    <VBox
                        width="65%"
                        class="sapUiTinyMarginBegin"
                    >
                        <Input
                            id="adminVendorName"
                            value="{AdminSignupModel>/VendorName}"
                            placeholder="{i18n>enteryourname}"
                            liveChange="onAdminLiveValidate"
                            valueStateText="{i18n>MSenterValidName}"
                            maxLength="50"
                        />
                    </VBox>
                </HBox>

                <Label
                    text="{i18n>MVDDOB}"
                    required="true"
                />
                <!-- <DatePicker
                    id="adminDOB"
                    value="{AdminSignupModel>/DOB}"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="yyyy-MM-dd"
                    change="ADMIN_onChangeDOB"
                /> -->

<DatePicker
    id="adminDOB"
    placeholder="DD/MM/YYYY"
    displayFormat="dd/MM/yyyy"
    valueFormat="yyyy-MM-dd"
    value="{AdminSignupModel>/DOB}"
    initialFocusedDateValue="{controller>/focusedDate}"
   
    maxDate="{controller>/maxDate}"
    change="ADMIN_onChangeDOB"
                    valueStateText="{i18n>agediff}"

/>


                <Label
                    text="{i18n>MVgender}"
                    required="true"
                />
                <Select
                    id="adminGender"
                    selectedKey="{AdminSignupModel>/Gender}"
                    forceSelection="false"
                    change="ADMIN_onChangeGender"
                    valueStateText="{i18n>pleaseselectGender}"
                >
                    <core:Item
                        key="Male"
                        text="Male"
                    />
                    <core:Item
                        key="Female"
                        text="Female"
                    />
                    <core:Item
                        key="Other"
                        text="Other"
                    />
                </Select>

                <Label
                    text="{i18n>email}"
                    required="true"
                />
                <Input
                    maxLength="50"
                    placeholder="{i18n>enteryourEmail}"
                    value="{AdminSignupModel>/Email}"
                    id="adminEmail"
                    type="Email"
                    liveChange="onAdminLiveValidate"
                    valueStateText="{i18n>MSenterValidEmail}"
                />

                <core:Title text="Contact Details" />
                <Label
                    text="{i18n>MVDcountry}"
                    required="true"
                />
                <ComboBox
                    id="adminsignUpCountry"
                    selectedKey="{AdminSignupModel>/Country}"
                    selectionChange="ADMIN_onChangeCountry"
                    placeholder="{i18n>selectCountry}"
                    valueStateText="{i18n>MVDselectcountry}"
                    items="{path:'CountryModel>/', length:1000}"
                    showSecondaryValues="true"
                    value="{AdminSignupModel>/Country}"
                >
                    <core:ListItem
                        key="{CountryModel>countryName}"
                        text="{CountryModel>countryName}"
                        additionalText="{CountryModel>code}"
                    />
                </ComboBox>
                <!-- State -->
                <Label
                    text="{i18n>MVDstate}"
                    required="true"
                />
                <ComboBox
                    id="adminsignUpState"
                    selectedKey="{AdminSignupModel>/State}"
                    change="ADMIN_onChangeState"
                    selectionChange="ADMIN_onChangeState"
                    placeholder="{i18n>selectState}"
                    valueStateText="{i18n>MSselectState}"
                    items="{path: 'StateModel>/filtered', length: 1000}"
                    showSecondaryValues="true"
                    value="{AdminSignupModel>/State}"
                >
                    <core:ListItem
                        key="{StateModel>stateName}"
                        text="{StateModel>stateName}"
                    />
                </ComboBox>
                <!-- City -->
                <Label
                    text="{i18n>city}"
                    required="true"
                />
                <ComboBox
                    id="adminsignUpCity"
                    selectedKey="{AdminSignupModel>/City}"
                    change="ADMIN_onChangeCity"
                    selectionChange="ADMIN_onChangeCity"
                    placeholder="{i18n>cityValueText}"
                    valueStateText="{i18n>MSselectCity}"
                    items="{path:'CityModel>/filtered', length:1000}"
                    showSecondaryValues="true"
                    value="{AdminSignupModel>/City}"
                >
                    <core:ListItem
                        key="{CityModel>cityName}"
                        text="{CityModel>cityName}"
                        additionalText="{CityModel>branchCode}"
                    />
                </ComboBox>

                <Label
                    text="Mobile No"
                    required="true"
                />
                <HBox width="100%">
                    <VBox width="35%">
<ComboBox 
id="adminsignUpSTD" 
value="{AdminSignupModel>/STDCode}" 
change="ADMIN_onChangeSTD" 
placeholder="ISD" 
showSecondaryValues="true" 
width="100%" 
items="{path:'CountryModel>/', length:1000}" 
filterSecondaryValues="true"
>
	<core:ListItem 
        key="{CountryModel>stdCode}" 
        text="{CountryModel>stdCode}" 
        additionalText="{CountryModel>code}" 
        />
</ComboBox>
                    </VBox>
                    <VBox
                        width="65%"
                        class="sapUiTinyMarginBegin"
                    >
                        <Input
                            id="adminMobileNo"
                            value="{AdminSignupModel>/Mobile}"
                            liveChange="ADMIN_onMobileLiveChange"
                            maxLength="18"
                            placeholder="Enter mobile number"
                            width="100%"
                            valueStateText="Enter valid mobile number"
                             autocomplete="false"
                             
                        >
                        <!-- <customData>
        <core:CustomData 
            key="autocomplete" 
            writeToDom="true" />
    </customData> -->
</Input>
                    </VBox>
                </HBox>

                <Label
                    text="{i18n>address}"
                    required="true"
                />

                <TextArea
                    id="adminAddress"
                    value="{AdminSignupModel>/Address}"
                    rows="3"
                    width="100%"
                    placeholder="Enter your full address"
                    maxLength="120"
                    liveChange="ADMIN_onAddressChange"
                />
            </f:content>
        </f:SimpleForm>

        <!-- ===== DOCUMENT UPLOAD SECTION (NEW) ===== -->
        <VBox
            class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop "
        >
            <!-- Informational Message Strip -->
            <MessageStrip
                text="{i18n>messageStrip}"
                showIcon="true"
                type="Warning"
                class="sapUiTinyMarginBottom"
            />
        </VBox>
        <Table
            id="adminAttachmentTable"
            items="{AdminSignupModel>/Documents}"
            mode="Delete"
            delete="onAdminDeleteDoc"
            sticky="ColumnHeaders,HeaderToolbar"
            width="100%"
        >
            <headerToolbar>
                <OverflowToolbar>
                    <Title text="{i18n>MVDdocument}" />
                    <Text
                        text="*"
                        class="requiredStar"
                    />
                    <ToolbarSpacer />
                    <!-- Dropdown for choosing type -->
                    <ComboBox
                        change="onAdminDocTypeChange"
                        id="adminDocType"
                        selectedKey="{AdminSignupModel>/CurrentDocType}"
                        enabled="{AdminSignupModel>/DocTypeEnabled}"
                        placeholder="{i18n>selectDocument}"
                        width="250px"
                    >
                        <core:ListItem
                            key="Aadhar Card"
                            text="Aadhar Card"
                        />
                        <core:ListItem
                            key="PAN Card"
                            text="PAN Card"
                        />
                        <core:ListItem
                            key="Company Registration Certificate"
                            text="Company Registration Certificate"
                        />
                        <core:ListItem
                            key="Bank Account"
                            text="Bank Account"
                        />
                        <!-- <core:ListItem key="Resume" text="Resume"/> -->
                        <core:ListItem
                            key="Other"
                            text="Other"
                        />
                    </ComboBox>
                    <!-- Upload button -->
                    <VBox id="adminUploaderWrapper">
                        <u:FileUploader
                            enabled="{= ${AdminSignupModel>/CurrentDocType} !== '' }"
                            id="adminFileUploader"
                            buttonOnly="true"
                            buttonText="Upload"
                            uploadOnChange="false"
                            change="onAdminFileSelect"
                            fileType="jpg,jpeg,png,pdf"
                        />
                    </VBox>
                </OverflowToolbar>
            </headerToolbar>
            <columns>
                <Column>
                    <Text text="{i18n>filename}" />
                </Column>
                <Column
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                >
                    <Text text="{i18n>document}" />
                </Column>
                <!-- <Column><Text text="File Type" /></Column> -->
                <Column
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                >
                    <Text text="{i18n>size}" />
                </Column>
            </columns>
            <items>
                <ColumnListItem>
                    <cells>
                        <!-- FILE NAME WITH ICON + PREVIEW LINK -->
                        <Link
                            wrapping="true"
                            text="{AdminSignupModel>FileName}"
                            press="onAdminPreviewDoc"
                            tooltip="{path:'AdminSignupModel>', formatter:'.Formatter.fileTooltip'}"
                        />
                        <!-- DOCUMENT TYPE (VdocType = Aadhaar/PAN/Resume) -->
                        <Text text="{AdminSignupModel>VdocType}" />

                        <Text
                            text="{path:'AdminSignupModel>size', formatter:'.Formatter.formatFileSize'}"
                        />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
        <!-- ACTIONS -->
        <beginButton>
            <Button
                text="{i18n>register}"
                tooltip="{i18n>register}"
                press="onSubmitAdminSignup"
                class="myUnifiedBtn sapUiSmallMargin"
                width="120px"
            />
        </beginButton>
    </Dialog>
</core:FragmentDefinition>