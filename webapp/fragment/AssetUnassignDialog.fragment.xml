<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="FAU_id_unassignDialog"
        title="{i18n>unAssign}"
        afterClose="onDialogClose"
    >
        <VBox class="sapUiResponsiveMargin">
            <Label
                text="{i18n>date}"
                showColon="true"
            />
            <DatePicker
                id="FAU_id_unassignDate"
                width="100%"
                valueFormat="yyyy-MM-dd"
                displayFormat="dd/MM/yyyy"
            />
        </VBox>
        <beginButton>
            <Button
                text="{i18n>save}"
                type="Accept"
                press="onSaveUnassign"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>cancel}"
                type="Reject"
                press="onCancelUnassign"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
