<core:FragmentDefinition
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="FAU_id_unassignDialog"
        busyIndicatorDelay="0"
        title="{i18n>returnDate}"
        afterClose="onDialogClose"
    >
            <VBox class="sapUiResponsiveMargin">
                <Label text="{i18n>date}" />
                <DatePicker
                    id="FAU_id_unassignDate"
                    width="100%"
                    required="true"
                    value="{myform>/formData/data/ReturnDate}"
                    valueFormat="yyyy-MM-dd"
                    displayFormat="dd/MM/yyyy"
                    change="FAU_onDateLiveChange"
                    valueStateText="{i18n>enterDate}"
                />
                </VBox>
                <!-- <Label text="{i18n>branch}" />
                <ComboBox
                    required="true"
                    id="FAU_id_branch"
                    showSecondaryValues="true"
                    change="FAU_onStrictValidationComboBox"
                    items="{BaseLocationModel>/}"
                    value="{myform>/formData/data/ReturnBranch}"
                >
                    <core:ListItem
                        key="{BaseLocationModel>city}"
                        text="{BaseLocationModel>city}"
                        additionalText="{BaseLocationModel>branchCode}"
                    />
                </ComboBox>-->
        <beginButton>
            <Button
                text="{i18n>save}"
                type="Accept"
                press="onSaveReturn"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>cancel}"
                type="Reject"
                press="onCancelReturn"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>