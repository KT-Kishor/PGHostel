<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:l="sap.ui.layout"
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <l:Grid defaultSpan="L6 M12 S12" hSpacing="1" vSpacing="0">
        
        <!-- Left Column - Form -->
        <l:content>
            <m:VBox  class="sapUiSmallMargin">
            <m:HBox  class="sapUiSmallMargin">
             <m:Carousel id="videoCarousel"  loop="true" showPageIndicator="true" class="sapUiMediumMargin"/>

                <f:SimpleForm editable="true" layout="ResponsiveGridLayout" 
                    labelSpanXL="3" labelSpanL="3"
                    labelSpanM="3" labelSpanS="12" backgroundDesign="Transparent" singleContainerFullSize="false">
    
                    <f:content>
                        
                        <m:Label text="{i18n>companyName}" required="true"/>
                        <m:Input id="idCompanyname" liveChange="validateCompnayname" maxLength="50" value="{formData>/CompanyName}" valueStateText="Invalid entry" width="80%"/>
                        <m:Label text="{i18n>customername}" required="true"/>
                        <m:Input id="idcustomername" liveChange="validateName" maxLength="50" value="{formData>/CustomerName}" valueStateText="Invalid entry" width="80%"/>
                        
                        <m:Label text="{i18n>email}" required="true"/>
                        <m:Input id="idCustmailid" liveChange="validateEmail" maxLength="50" value="{formData>/Email}" type="Email" valueStateText="Enter Valid Email" width="80%"/>
                        
                        
                        <m:Label text="{i18n>timeslot}" required="true"/>
                        <m:DateTimePicker id="idtimeslot" liveChange="ValidateCommonFields" value="{formData>/TimeSlot}" valueFormat="yyyy-MM-dd HH:mm"
                            displayFormat="dd/MM/yyyy HH:mm" valueStateText="Enter Timeslot" width="80%"/>
                        
                        <m:Label text="{i18n>mobilenumber}" required="true"/>
                        <m:Input id="idmobilenumber" liveChange="validateMobileNo" maxLength="10" value="{formData>/MobileNo}" valueStateText="Enter Atleast 10 digit number" width="80%"/>
                        
                        <m:Label text="{i18n>address}" required="true"/>
                        <m:TextArea id="idCustaddress" liveChange="ValidateCommonFields" maxLength="120" value="{formData>/Address}" rows="2" valueStateText="Invalid entry" width="80%"/>
                        <m:Label text="{i18n>comments}" required="true"/>
                        <m:TextArea id="idcomment" liveChange="ValidateCommonFields" maxLength="120" value="{formData>/Comments}" rows="2" valueStateText="Invalid entry" width="80%"/>
                        <m:Label text=""/>
                        <m:HBox justifyContent="End">
                            <m:Button text="{i18n>savebtn}" type="Accept" press=".onDemoformSave" class="btnrequest"/>
                        </m:HBox>
                    </f:content>
                </f:SimpleForm>
           

            <!-- Right Column - Video Carousel -->
            
                 </m:HBox>
            </m:VBox>
        </l:content>
    </l:Grid>

</mvc:View>
