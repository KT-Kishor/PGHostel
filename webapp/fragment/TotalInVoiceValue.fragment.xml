<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
>
    <Dialog
        id="TotalInvoicesvalueDialog"
        contentWidth="1000px"
        contentHeight="500px"
        resizable="true"
        draggable="true"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                 <Title text="{i18n>totalInvoiceValue} {dialogData>/customerName}"/>
                </contentMiddle>
                <contentRight>
                    <Button
                        icon="sap-icon://decline"
                        press="onCloseDialog"
                        tooltip="{i18n>close}"
                    />
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <Table
                sticky="ColumnHeaders"
                items="{dialogData>/invoices}"
                noDataText="{i18n>noInvoiceData}"
            >
                <columns>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                    >
                        <Text text="{i18n>invoiceNo}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                    >
                        <Text text="{i18n>invoiceDate}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                        minScreenWidth="Tablet"
                    >
                        <Text text="{i18n>bookingID}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>transactionAmount}" />
                    </Column>
                    <!-- <Column
                        demandPopin="true"
                        hAlign="End"
                    >
                        <Text text="{i18n>creditNotesAmount}" />
                    </Column> -->
                    <Column
                        hAlign="End"
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>exchRate}" />
                    </Column>
                    <Column
                        hAlign="End"
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>totalAmount}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                    >
                        <Text text="{i18n>status}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem
                        type="Navigation"
                        press="onInvoiceNumberPress"
                    >
                        <cells>
                            <Text text="{dialogData>InvNo}" />
                            <Text
                                text="{path: 'dialogData>InvoiceDate', formatter: '.Formatter.formatDate'}"
                            />
                            <Text text="{dialogData>BookingID}" />
                            <ObjectNumber
                                number="{parts: [{ path: 'dialogData>OldTotalAmount' }], formatter: '.Formatter.fromatNumber'}"
                                unit="{dialogData>Currency}"
                            />
                            <!-- <layout:VerticalLayout>
                                <Link
                                    wrapping="true"
                                    class="creditLinkStyle"
                                    press="onInvoiceCreditNotesPress"
                                    text="{parts: [{ path: 'dialogData>CreditNotesTotal' },{ path: 'dialogData>Currency' }], formatter: '.Formatter.formatAmountWithCurrency'}"
                                />
                                <Link
                                    wrapping="true"
                                    visible="{= ${dialogData>Currency} !== 'INR' }"
                                    class="creditLinkStyle"
                                    press="onInvoiceCreditNotesPress"
                                    text="{parts: [{ path: 'dialogData>CreditNotesTotalInINR' },{ value: 'INR' }], formatter: '.Formatter.formatAmountWithCurrency'}"
                                />
                            </layout:VerticalLayout> -->
                            <ObjectIdentifier
                                title="{path:'dialogData>ConversionRate', formatter: '.Formatter.fromatNumber'}"
                            />
                            <ObjectNumber
                                number="{parts: [{ path: 'dialogData>Currency' },{ path: 'dialogData>TotalAmount' },{ path: 'dialogData>AmountInINR' }], formatter: '.Formatter.fromatNumber'}"
                                unit="INR"
                            />
                            <!-- <ObjectStatus
                                text="{dialogData>Status}"
                                state="{path: 'dialogData>Status', formatter: '.Formatter.invoiceStatusState'}"
                            /> -->
                            <Text text="{dialogData>Status}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Text text="{i18n>totalAmount} : " />
                <ObjectNumber
                    number="{parts: [{ path: 'dialogData>/AllTotalAmount' }], formatter: '.Formatter.fromatNumber'}"
                    unit="INR"
                />
            </Toolbar>
        </footer>
    </Dialog>
</core:FragmentDefinition>