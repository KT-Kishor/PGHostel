<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="DocumentPreviewDialog"
      
        contentWidth="80%"
        contentHeight="80%"
        horizontalScrolling="false"
        verticalScrolling="false"
    >
        <customHeader>
            <Bar class="barheader">
                    <contentMiddle>
                <Title text="{i18n>documentPreview}" />
            </contentMiddle>
              
            </Bar>
        </customHeader>
        <VBox
            height="100%"
            fitContainer="true"
            width="100%"
            class="fullHeightBox"
        >
            <core:HTML
                id="pdfViewer"
                content=""
            />
        </VBox>
        <endButton>
            <Button
                text="{i18n>close}"
                tooltip="{i18n>close}"
                press="onClosePreview"
                class="myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>