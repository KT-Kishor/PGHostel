<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="previewDialog"
        title="Document Preview"
        draggable="true"
        resizable="true"
        stretchOnPhone="true"
        contentWidth="80%"
        contentHeight="85%"
        verticalScrolling="false"
        horizontalScrolling="false">

        <content>

            <Image
                id="previewImage"
                visible="false"
                width="100%"
                height="100%"
                densityAware="false"
                class="imagePreviewFit"/>

            <core:HTML
                id="previewHtml"
                preferDOM="false"
                content=""/>

        </content>

        <beginButton>
            <Button
                text="Download"
                type="Transparent"
                press=".onDownloadPreview"/>
        </beginButton>

        <endButton>
            <Button
                text="Close"
                press=".onClosePreview"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>