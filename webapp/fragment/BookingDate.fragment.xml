<core:FragmentDefinition 
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="idBookingDateDialog"
        title="Select Booking Date"
        stretchOnPhone="true">

        <VBox class="sapUiSmallMargin">
            <Label text="Booking Date" />
            <DatePicker
                id="idBookingDate"
                width="100%"
                displayFormat="dd/MM/yyyy"
                valueFormat="yyyy-MM-dd"
                change="onDatePickerChange"
            />
        </VBox>

        <beginButton>
            <Button
                text="Confirm"
                type="Emphasized"
                press="Bookingdatepress" />
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press=".onBookingDateCancel" />
        </endButton>

    </Dialog>
</core:FragmentDefinition>
