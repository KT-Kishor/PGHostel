<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout">

<Title level="H1" text="{i18n>ourProducts}" class="ProductDemoSection" wrapping="true"/>
    
    <l:Grid defaultSpan="XL6 L6 M6 S12" class="grid-container">
        <!-- Workzone -->
        <VBox class="ProductSoluction sapUiSmallMargin" backgroundDesign="Solid">
            <VBox justifyContent="Center" id="videoFrametour_WorkZone">
                <core:HTML id="videoFrameHtml_WorkZone"
                    content="&lt;div style='position:relative;width:100%;padding-top:56.25%;overflow:hidden;border-radius:10px;'&gt;
                                &lt; 
                                    style='position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;border:none;border-radius:10px;'&gt;
                                    &lt;source src='../Videos/Workzone.mp4' type='video/mp4'&gt;
                                    Your browser does not support the video tag.
                                &lt;/video&gt;
                            &lt;/div&gt;" />
            </VBox>
            <Text class="hr-text sapUiSmallMargin" text="Advance Workzone (Casestudy)" />
            <Text class="description-text sapUiSmallMargin" text="{i18n>workZone}" />
        </VBox>

