<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:l="sap.ui.layout"
	xmlns:mvc="sap.ui.core.mvc"
	displayBlock="true"
	xmlns:g="sap.f"
	xmlns:f="sap.ui.layout.form"
	height="100%"
	busyIndicatorDelay="0">
	<Title level="H1" text="{i18n>ourProducts}" class="ProductDemoSection" wrapping="true"/>
	<l:Grid defaultSpan="XL6 L6 M6 S12" class="grid-container">
		<!-- Workzone -->
		<VBox class="ProductSoluction sapUiSmallMargin" backgroundDesign="Solid">
			<VBox justifyContent="Center" id="videoFrametour_WorkZone">
				<core:HTML id="videoFrameHtml_WorkZone"
                    content="&lt;div style='position:relative;width:100%;padding-top:56.25%;overflow:hidden;border-radius:10px;'&gt;
                                &lt; 
                                    style='position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;border:none;border-radius:10px;'&gt;
                                    &lt;source src='../Videos/Workzone.mp4' type='video/mp4'&gt;
                                    Your browser does not support the video tag.
                                &lt;/video&gt;
                            &lt;/div&gt;" />
			</VBox>
			<Text class="hr-text sapUiSmallMargin" text="Advance Workzone" />
			<Text class="description-text sapUiSmallMargin" text="{i18n>workZone}" />
		</VBox>

		<!-- ChandraShilp Automotive LLP -->
		<VBox class="ProductSoluction sapUiSmallMargin" backgroundDesign="Solid">
			<VBox justifyContent="Center" id="videoFrametourl_Shah">
				<core:HTML id="videoFrameHtml_Shah"
                    content="&lt;div style='position:relative;width:100%;padding-top:56.25%;overflow:hidden;border-radius:10px;'&gt;
                                &lt;video controls autoplay muted playsinline 
                                    style='position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;border:none;border-radius:10px;'&gt;
                                    &lt;source src='../Videos/Shah H.mp4' type='video/mp4'&gt;
                                    Your browser does not support the video tag.
                                &lt;/video&gt;
                            &lt;/div&gt;" />
			</VBox>
			<Text class="hr-text sapUiSmallMargin" text="ChandraShilp Automotive LLP" />
			<Text class="description-text sapUiSmallMargin" text="{i18n>shahHyundai}" />
		</VBox>

		<!-- Customer Portal -->
		<VBox class="ProductSoluction sapUiSmallMargin" backgroundDesign="Solid">
			<VBox justifyContent="Center" id="videoFrametour_Customer">
				<core:HTML id="videoFrameHtml_Customer"
                    content="&lt;div style='position:relative;width:100%;padding-top:56.25%;overflow:hidden;border-radius:10px;'&gt;
                                &lt;video controls autoplay muted playsinline 
                                    style='position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;border:none;border-radius:10px;'&gt;
                                    &lt;source src='../Videos/Kvriksha Customer.mp4' type='video/mp4'&gt;
                                    Your browser does not support the video tag.
                                &lt;/video&gt;
                            &lt;/div&gt;" />
			</VBox>
			<Text class="hr-text sapUiSmallMargin" text="Enhancing Client Experience with the Customer Portal" />
			<Text class="description-text sapUiSmallMargin" text="{i18n>customerPortal}" />
		</VBox>

		<!-- Supplier Portal -->
		<VBox class="ProductSoluction sapUiSmallMargin" backgroundDesign="Solid">
			<VBox justifyContent="Center" id="videoFrametourl_Supplier">
				<core:HTML id="videoFrameHtml_Supplier"
                    content="&lt;div style='position:relative;width:100%;padding-top:56.25%;overflow:hidden;border-radius:10px;background:#f3f3f3;'&gt;
                                &lt;video controls autoplay muted playsinline 
                                    style='position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;border:none;border-radius:10px;'&gt;
                                    &lt;source src='../Videos/Kvriksha Supplier.mp4' type='video/mp4'&gt;
                                    Your browser does not support the video tag.
                                &lt;/video&gt;
                            &lt;/div&gt;" />
			</VBox>
			<Text class="hr-text sapUiSmallMargin" text="Streamlining Vendor Collaboration with the Supplier Portal" />
			<Text class="description-text sapUiSmallMargin" text="{i18n>supplierPortal}" />
		</VBox>
	</l:Grid>

    <!-- Intelligent Docket Automation -->
	<g:GridContainer class="carrer-office-tour sapUiSmallMargin">
		<g:layout>
			<g:GridContainerSettings columnSize="49.5%" gap="10px" />
		</g:layout>
		<g:layoutXS>
			<g:GridContainerSettings columnSize="100%" gap="10px" />
		</g:layoutXS>
		<g:layoutS>
			<g:GridContainerSettings columnSize="100%" gap="10px" />
		</g:layoutS>
		<g:layoutM>
			<g:GridContainerSettings columnSize="100%" gap="10px" />
		</g:layoutM>
		<!-- Left Column -->
		<VBox id="videoBoxOCR" class="sapUiMediumMarginTop">
			<core:HTML id="videoFrametourOCR"
                            content="&lt;div style='width:560px;height:315px;overflow:hidden;border-radius:15px;background:#f3f3f3;'&gt;&lt;iframe src='../Videos/KT OCR.mp4'  allowfullscreen 
                            style='width:100%;height:100%;border:none;'&gt;&lt;/iframe&gt; &lt;/div&gt;" />
			<Text class="description-text sapUiSmallMargin" text="{i18n>orcResult}" />
		</VBox>
		<!-- Right Column -->
		<VBox alignItems="Start" justifyContent="Center">
			<Text class="hr-text sapUiSmallMargin" text="Intelligent Docket Automation" />
			<Text class="description-text sapUiSmallMargin" text="{i18n>OCR}" />
		</VBox>
	</g:GridContainer>
	<!-- Footer -->
	<HBox class="footer-bar sapUiSmallMargin" alignItems="Center" justifyContent="SpaceBetween" >
		<!-- Left: Copyright -->
		<Text text="{i18n>companynameKT}" class="footer-text"/>
		<!-- Right: Social Icons -->
		<HBox class="footer-social" justifyContent="End">
			<core:HTML content="&lt;a href='https://www.instagram.com/kalpavrikshatechnologies/' target='_blank'&gt;
                                  &lt;i class='fab fa-instagram social-icon'&gt;&lt;/i&gt;
                                &lt;/a&gt;"/>
			<core:HTML content="&lt;a href='https://www.linkedin.com/company/kalpavriksha-technologies/' target='_blank'&gt;
                                  &lt;i class='fab fa-linkedin-in social-icon'&gt;&lt;/i&gt;
                                &lt;/a&gt;"/>
			<core:HTML content="&lt;a href='https://www.youtube.com/@KalpavrikshaTechnologies' target='_blank'&gt;
                                  &lt;i class='fab fa-youtube social-icon'&gt;&lt;/i&gt;
                                &lt;/a&gt;"/>
		</HBox>
	</HBox>
</core:FragmentDefinition>
