<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
>
    <Dialog
        contentWidth="1000px"
        contentHeight="500px"
        resizable="true"
        draggable="true"
    >
        <customHeader>
            <Bar class="Coursetitle">
                <contentLeft>
                    <Title
                        text="{i18n>invoiceForCredit} {popoverData>/status}"
                    />
                </contentLeft>
                <contentRight>
                    <Button
                        icon="sap-icon://decline"
                        press="onCloseDialog"
                        tooltip="{i18n>close}"
                    />
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <Table
                inset="false"
                sticky="ColumnHeaders"
                items="{popoverData>/invoices}"
                noDataText="{i18n>noInvoiceStatus}"
            >
                <columns>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                    >
                        <Text text="{i18n>invoiceNo}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>creditMemoNo}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                    >
                        <Text text="{i18n>invoiceDate}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>customerName}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>CustomerID}" />
                    </Column>
                    <Column
                        hAlign="End"
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>totalAmount}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem
                        type="Navigation"
                        press="onPressCreditNoteInvoice"
                    >
                        <cells>
                            <Text text="{popoverData>InvNo}" />
                            <Text text="{popoverData>CCInvNo}" />
                            <Text
                                text="{path: 'popoverData>InvoiceDate', formatter: '.Formatter.formatDate'}"
                            />
                            <Text text="{popoverData>CustomerName}" />
                            <Text text="{popoverData>CustomerID}" />
                            <layout:VerticalLayout>
                                <ObjectNumber
                                    number="{parts: [{ path: 'popoverData>TotalAmount' }], formatter: '.Formatter.fromatNumber'}"
                                    unit="{popoverData>Currency}"
                                />
                                <ObjectNumber
                                    visible="{= ${popoverData>Currency} !== 'INR' }"
                                    number="{parts: [{ path: 'popoverData>AmountInINR' }], formatter: '.Formatter.fromatNumber'}"
                                    unit="INR"
                                />
                            </layout:VerticalLayout>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Text text="{i18n>totalAmount} : " />
                <ObjectNumber
                    number="{parts: [{ path: 'popoverData>/AllTotalAmount' }], formatter: '.Formatter.fromatNumber'}"
                    unit="INR"
                />
            </Toolbar>
        </footer>
    </Dialog>
</core:FragmentDefinition>
