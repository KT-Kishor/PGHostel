<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="pendingInvoicesDialog"
     
        contentWidth="800px"
        contentHeight="400px"
        resizable="true"
        draggable="true">
          <customHeader >
        <Bar class="Coursetitle" >
        <contentLeft>
         <Title text="{i18n>pendingInvoicepayment} {dialogData>/companyName}"/>
        </contentLeft>
           
            <contentRight>
                <Button icon="sap-icon://decline" press="onCloseDialog" tooltip="Close"/>
            </contentRight>
        </Bar>
    </customHeader>
        <content>
            <Table
            sticky="ColumnHeaders"
                items="{dialogData>/invoices}"
                noDataText="{i18n>noPendingData}">
                <columns>
                    <Column demandPopin="true" hAlign="Left"><Text text="{i18n>invoiceNo}" /></Column>
                    <Column demandPopin="true" hAlign="Left"><Text text="{i18n>invoiceDate}" /></Column>
                    <Column demandPopin="true" hAlign="Left" minScreenWidth="Desktop"><Text text="{i18n>customerName}" /></Column>
                    <Column demandPopin="true" hAlign="Left" minScreenWidth="Desktop"><Text text="{i18n>transactionAmount}" /></Column>
                        <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop"><Text text="{i18n>exchRate}" /></Column>
                    <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop"><Text text="{i18n>pendingAmountInr}" /></Column>
                     <Column demandPopin="true" hAlign="Left"><Text text="{i18n>status}" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onPendingInvoicePress">
                        <cells>
                            <Text text="{dialogData>InvNo}" />
                            <Text text="{
                                path: 'dialogData>InvoiceDate',
                             formatter:'.Formatter.formatDate'}" />
                             <Text text="{dialogData>CustomerName}" />
                    <ObjectNumber
    number="{
        parts: [
          
            { path: 'dialogData>TotalAmount' }
        ], 
        formatter: '.Formatter.fromatNumber'
    }"
    unit="{dialogData>Currency}" />

                             <ObjectIdentifier 
  title="{path:'dialogData>ConversionRate', formatter: '.Formatter.fromatNumber'}"
 />
                             <ObjectNumber number="{
                                path: 'dialogData>pendingAmountInINR',
                               formatter: '.Formatter.fromatNumber'
                            }" unit="INR" />
                             <Text text="{dialogData>Status}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <!-- <endButton>
            <Button text="{i18n>close}" type="Ghost" press="onCloseDialog" />
        </endButton> -->
    </Dialog>
</core:FragmentDefinition>