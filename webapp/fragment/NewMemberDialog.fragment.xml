<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified"
    xmlns:f="sap.ui.layout.form"
>
    <Dialog
        id="newMemberDialog"
        class="newMemberDialog newMemberDialogWithMargin"
        contentWidth="32rem"
        stretch="{= ${device>/system/phone} }"
        draggable="true"
        resizable="false"
        showHeader="true"
        horizontalScrolling="false"
        afterClose="onNewMemberDialogAfterClose"
        escapeHandler=".onNewMemberDialogEscape"
    >
        <customHeader>
            <OverflowToolbar>
                <Title text="{BookingView>/NewMemberDialogTitle}" />
            </OverflowToolbar>
        </customHeader>

        <content>
            <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                width="100%"
                columnsXL="2"
                columnsL="2"
                columnsM="1"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="12"
                labelSpanS="12"
                emptySpanXL="1"
                emptySpanL="1"
                emptySpanM="0"
                emptySpanS="0"
                adjustLabelSpan="false"
                singleContainerFullSize="true"
                class="sapUiTinyMargin newMemberFormWithRightPadding"
            >
                <HBox
                    width="100%"
                    justifyContent="Start"
                    alignItems="Center"
                >
                    <VBox width="35%">
<Label
    text="Salutation"
    required="true"
/>

                    </VBox>
                    <VBox
                        width="65%"
                        class="sapUiTinyMarginBegin"
                    >
                        <Label
                            text="Full Name"
                            required="true"
                        />
                    </VBox>
                </HBox>
                <HBox
                    width="100%"
                    justifyContent="Start"
                    alignItems="Center"
                >
                    <VBox width="35%">
<ComboBox
    id="newMemberSalutationCombo"
    selectedKey="{BookingView>/NewMemberDraft/Salutation}"
    items="{BookingView>/SalutationOptions}"
    placeholder="Mr."
    valueStateText="Please select salutation"
    selectionChange="onNewMemberSalutationChange"
    change="onNewMemberSalutationChange"
    editable="{= ${BookingView>/NewMemberDraft/id} !== 'SELF' }"
>
    <core:Item
        key="{BookingView>key}"
        text="{BookingView>text}"
    />
</ComboBox>

                    </VBox>
                    <VBox
                        width="65%"
                        class="sapUiTinyMarginBegin"
                    >
                        <Input
                            id="newMemberNameInput"
                            value="{BookingView>/NewMemberDraft/Name}"
                            placeholder="Enter full name"
                            valueStateText="Please enter a valid full name"
                            liveChange="onNewMemberNameChange"
                            change="onNewMemberNameChange"
                            maxLength="35"
                            editable="{= ${BookingView>/NewMemberDraft/id} !== 'SELF' }"
                        />
                    </VBox>
                </HBox>

                <Label
                    text="Date of Birth"
                    required="true"
                />
                <DatePicker
                    id="newMemberDOB"
                    value="{BookingView>/NewMemberDraft/Age}"
                    placeholder="DD/MM/YYYY"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="yyyy-MM-dd"
                    change="onNewMemberDOBChange"
                    valueStateText="Age must be between 0 and 100 years"
                    editable="{= ${BookingView>/NewMemberDraft/id} !== 'SELF' }"
                />

                <Label
                    text="Gender"
                    required="true"
                />
                <ComboBox
                    id="newMemberGenderCombo"
                    selectedKey="{BookingView>/NewMemberDraft/Gender}"
                    items="{BookingView>/GenderOptions}"
                    placeholder="Select gender"
                    valueStateText="Please select gender"
                    selectionChange="onNewMemberGenderChange"
                    change="onNewMemberGenderChange"
                    editable="{= ${BookingView>/NewMemberDraft/id} !== 'SELF' }"
                >
                    <core:Item
                        key="{BookingView>key}"
                        text="{BookingView>text}"
                    />
                </ComboBox>

                <Label
                    text="Relationship"
                    required="true"
                />
                <ComboBox
                    id="newMemberRelationCombo"
                    selectedKey="{BookingView>/NewMemberDraft/Relation}"
                    value="{BookingView>/NewMemberDraft/Relation}"
                    items="{BookingView>/RelationshipOptions}"
                    placeholder="Select relationship"
                    valueStateText="Please select relationship"
                    selectionChange="onNewMemberRelationChange"
                    change="onNewMemberRelationChange"
                    editable="{= ${BookingView>/NewMemberDraft/id} !== 'SELF' }"
                >
                    <core:Item
                        key="{BookingView>key}"
                        text="{BookingView>text}"
                    />
                </ComboBox>

                <Label text="Upload Document" />
                <HBox
                    width="100%"
                    fitContainer="true"
                    wrap="NoWrap"
                    alignItems="Center"
                >
                    <ComboBox
                        id="newMemberDocumentTypeCombo"
                        selectedKey="{BookingView>/NewMemberDraft/DocumentType}"
                        items="{BookingView>/DocumentTypeOptions}"
                        placeholder="Select document type"
                        valueStateText="Please select a valid document type"
                        selectionChange="onNewMemberDocumentTypeChange"
                        change="onNewMemberDocumentTypeChange"
                        width="{= ${device>/system/phone} ? '45%' : '100%'}"
                        class="sapUiTinyMarginEnd"
                        visible="{= !${BookingView>/NewMemberDraft/DocumentName} }"
                    >
                        <core:Item
                            key="{BookingView>key}"
                            text="{BookingView>text}"
                        />
                    </ComboBox>

                    <unified:FileUploader
                        id="newMemberFileUploader"
                        width="{= ${device>/system/phone} ? '100%' : '100%'}"
                        visible="{= !${BookingView>/NewMemberDraft/DocumentName} }"
                        buttonOnly="true"
                        sameFilenameAllowed="true"
                        change="onNewMemberDocumentChange"
                        buttonText="Upload"
                        fileType="pdf,jpg,jpeg,png,webp"
                        class="sapUiTinyMarginBegin sapUiTinyMarginEnd myUnifiedBtn"
                    />
                    <core:Icon
                        id="newMemberDocumentInfoIcon"
                        src="sap-icon://hint"
                        size="1rem"
                        color="#0064d1"
                        hoverColor="DarkBlue"
                        press="onNewMemberDocumentInfoPress"
                        tooltip="Upload info"
                        visible="{= !${BookingView>/NewMemberDraft/DocumentName} }"
                        class="sapUiSmallMarginBegin"
                    />

                    <HBox
                        visible="{= !!${BookingView>/NewMemberDraft/DocumentName} }"
                        alignItems="Center"
                        wrap="{= ${device>/system/phone} ? 'Wrap' : 'NoWrap'}"
                        class="sapUiTinyMarginBegin"
                    >
                        <Link
                            text="{path: 'BookingView>/NewMemberDraft/DocumentName', formatter: '.formatDocumentFileName'}"
                            tooltip="{BookingView>/NewMemberDraft/DocumentName}"
                            press="onPreviewNewMemberDocument"
                            width="10rem"
                            class="automatedEllipsis documentLink"
                        />
                        <Button
                            text="Remove"
                            icon="sap-icon://delete"
                            press="onDeleteNewMemberDocument"
                            class="myUnifiedBtn"
                        />
                    </HBox>
                </HBox>
            </f:SimpleForm>
        </content>

        <beginButton>
            <Button
                text="{BookingView>/NewMemberDialogSaveText}"
                press="onSaveNewMember"
                class="myUnifiedBtn"
            />
        </beginButton>
        <endButton>
            <Button
                text="Cancel"
                press="onCloseNewMemberDialog"
                class="myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
