<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified"
>
    <Dialog
        id="newMemberDialog"
        contentWidth="38rem"
        stretchOnPhone="true"
        draggable="true"
        resizable="true"
    >
        <customHeader>
            <OverflowToolbar>
                <Title text="Add New Member" />
                <ToolbarSpacer />
                <Button
                    icon="sap-icon://decline"
                    type="Transparent"
                    press="onCloseNewMemberDialog"
                />
            </OverflowToolbar>
        </customHeader>

        <content>
            <VBox class="sapUiSmallMargin" width="100%">
                <Label text="Full Name" required="true" />
                <Input value="{BookingView>/NewMemberDraft/Name}" placeholder="Enter full name" />

                <Label text="Gender" required="true" class="sapUiTinyMarginTop" />
                <Select selectedKey="{BookingView>/NewMemberDraft/Gender}" items="{BookingView>/GenderOptions}">
                    <core:Item key="{BookingView>key}" text="{BookingView>text}" />
                </Select>

                <Label text="Relationship" required="true" class="sapUiTinyMarginTop" />
                <Select selectedKey="{BookingView>/NewMemberDraft/Relation}" items="{BookingView>/RelationshipOptions}">
                    <core:Item key="{BookingView>key}" text="{BookingView>text}" />
                </Select>

                <Label text="Document Type" required="true" class="sapUiTinyMarginTop" />
                <Select selectedKey="{BookingView>/NewMemberDraft/DocumentType}" items="{BookingView>/DocumentTypeOptions}">
                    <core:Item key="{BookingView>key}" text="{BookingView>text}" />
                </Select>

                <Label text="Upload Document" required="true" class="sapUiTinyMarginTop" />
                <HBox alignItems="Center" wrap="Wrap">
                    <unified:FileUploader
                        width="10rem"
                        buttonOnly="true"
                        maximumFileSize="2"
                        sameFilenameAllowed="true"
                        change="onNewMemberDocumentChange"
                        buttonText="Upload"
                        fileType="pdf,jpg,jpeg,png,webp"
                        class="myUnifiedBtn"
                    />
                    <Text text="{BookingView>/NewMemberDraft/DocumentName}" class="sapUiTinyMarginBegin" />
                </HBox>
            </VBox>
        </content>

        <beginButton>
            <Button
                text="Save Member"
                type="Emphasized"
                press="onSaveNewMember"
                class="myUnifiedBtn"
            />
        </beginButton>
        <endButton>
            <Button
                text="Cancel"
                press="onCloseNewMemberDialog"
                class="myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
