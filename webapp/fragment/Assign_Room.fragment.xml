<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="sds"
        type="Message"
        class="sapUiContentPadding"
        contentWidth="28rem"
        contentHeight="auto"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title text="{i18n>assignRoom}" />
                </contentMiddle>
            </Bar>
        </customHeader>

        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <f:content>
                <Label
                    text="{i18n>customerName}"
                    required="true"
                />
                <Text
                    id="idCustomerNameText"
                    text="{HostelModel>/CustomerName}"
                />
                <Label
                    text="{i18n>roomNo}"
                    required="true"
                />
                <ComboBox
                    id="idRoomNumber1"
                    placeholder="{i18n>selectRoomNumber}"
                    selectedKey="{HostelModel>/RoomNumber}"
                    items="{AvailableRoomsModel>/}"
                    valueStateText="{i18n>selectRoomNo}"
                    change="onRoomNoChange"
                >
                    <core:ListItem
                        key="{AvailableRoomsModel>RoomNo}"
                        text="{AvailableRoomsModel>RoomNo}"
                    />
                </ComboBox>

                <Label
                    text="{i18n>MSbranchCode}"
                    required="true"
                />
                <ComboBox
                    id="id_BranchCode"
                    placeholder="{i18n>placeSelectBranchCode}"
                    selectedKey="{RoomModel>/BranchCode}"
                    selectionChange=".onBranchChange"
                    valueStateText="{i18n>pleaseSelectValidBranchCode}"
                    items="{BranchModel>/}"
                    showSecondaryValues="true"
                    visible="{Visiblemodel>/Visible}"
                >
                    <core:ListItem
                        key="{BranchModel>BranchID}"
                        text="{BranchModel>BranchID}"
                        additionalText="{BranchModel>Name}"
                    />
                </ComboBox>
                <Label
                    text="{i18n>bedType}"
                    required="true"
                />
                <ComboBox
                    id="idBedType"
                    placeholder="{i18n>selectBedType}"
                    width="100%"
                    selectedKey="{HostelModel>/BedTypeName}"
                    items="{BedTypeModel>/}"
                    selectionChange=".onBedTypeChange"
                    valueStateText="{i18n>pleaseSelectValidBedType}"
                    visible="{Visiblemodel>/Visible}"
                >
                    <core:ListItem
                        key="{= ${BedTypeModel>Name} + ' - ' + ${BedTypeModel>ACType} }"
                        text="{= ${BedTypeModel>Name} + ' - ' + ${BedTypeModel>ACType} }"
                    />
                </ComboBox>

                <Label text="{i18n>startDate}" />
                <DatePicker
                    id="AR_id_StartDate"
                    value="{HostelModel>/StartDate}"
                    change="FCIA_ondatechange"
                    valueStateText="{i18n>selectdate}"
                    valueFormat="dd/MM/yyyy"
                    displayFormat="dd/MM/yyyy"
                    visible="{Visiblemodel>/Visible}"
                />

                <Label text="{i18n>endDate}" />
                <DatePicker
                    id="AR_id_EndDate"
                    value="{HostelModel>/EndDate}"
                    change="FCIA_ondatechange"
                    valueStateText="{i18n>selectdate}"
                    valueFormat="dd/MM/yyyy"
                    displayFormat="dd/MM/yyyy"
                    visible="{Visiblemodel>/Visible}"
                />
                <Label text="{i18n>addFacility}" />
                <MultiComboBox
                    id="id_facility"
                    placeholder="{i18n>selectFacility}"
                    selectedKey="{HostelModel>/Facility}"
                    items="{facilitymodel>/}"
                    valueStateText="{i18n>selectRoomNo}"
                    showSecondaryValues="true"
                    visible="{Visiblemodel>/Visible}"
                >
                    <core:ListItem
                        key="{facilitymodel>FacilityName}"
                        text="{facilitymodel>FacilityName}"
                        additionalText="{facilitymodel>UnitText}"
                    />
                </MultiComboBox>
            </f:content>
        </f:SimpleForm>

        <beginButton>
            <Button
                text="{i18n>save}"
                tooltip="{i18n>save}"
                press="ARNO_onsavebuttonpress"
                type="Accept"
                id="HM_id_saveButton"
                class="marginRight myUnifiedBtn"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>CancelButton}"
                tooltip="{i18n>CancelButton}"
                press="HM_onCancelButtonPress"
                type="Reject"
                id="HM_id_CancelButton"
                class="marginRight myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</c:FragmentDefinition>