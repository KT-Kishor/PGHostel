<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="sds"
        type="Message"
        class="sapUiContentPadding"
        contentWidth="28rem"
        contentHeight="auto"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title text="{i18n>assignRoom}" />
                </contentMiddle>
            </Bar>
        </customHeader>

        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <f:content>
                <Label
                    text="{i18n>customerName}"
                    required="true"
                />
                <Text
                    id="idCustomerNameText"
                    text="{HostelModel>/CustomerName}"
                />
              
                   <Label
                    text="Deposit Amount"
                />
                <Input
                    id="id_DepositAmount"
                    placeholder="Enter Deposit Amount"
                    value="{HostelModel>/DepositAmount}"
                    maxLength="6"
                    visible="{Visiblemodel>/Visible}"
                    liveChange="DepositAmountLiveChange"
                    valueStateText="Enter deposit amount"
                    editable="false"
                />

                 <Label
                    text="Actual Amount"
                    required="true"
                />
                <Input
                    id="id_ActualAmount"
                    placeholder="Enter Actual Amount"
                    value="{HostelModel>/ActualAmount}"
                    maxLength="6"
                    visible="{Visiblemodel>/Visible}"
                    liveChange="ActualAmountLiveChange"
                    valueStateText="Enter actual amount"
                />

                   <Label
                    text="Payment Mode"
                    required="true"
                />
                <ComboBox
                    id="idPaymentMode"
                    placeholder="Select Payment Mode"
                    selectedKey="{HostelModel>/PaymentMode}"
                    valueStateText="Select payment mode"
                    change="onPaymentModeChange"
                    visible="{Visiblemodel>/Visible}"

                >
                    <core:ListItem
                        key="UPI"
                        text="UPI"
                    />
                      <core:ListItem
                        key="Cash"
                        text="Cash"
                    />
                    <core:ListItem
                        key="Card"
                        text="Card"
                    />
                </ComboBox>

                  <Label
                    text="Transaction / Person Name"
                />
                <Input
                    id="id_TransactionID"
                    placeholder="Enter Transaction / Person Name"
                    value="{HostelModel>/TransactionID}"
                    visible="{Visiblemodel>/Visible}"
                    liveChange="DepositAmountLiveChange"
                    valueStateText="Enter Transaction / Person Name"
                    maxLength="20"

                />

                  <Label
                    text="{i18n>roomNo}"
                    required="true"
                />
                <ComboBox
                    id="idRoomNumber1"
                    placeholder="{i18n>selectRoomNumber}"
                    selectedKey="{HostelModel>/RoomNumber}"
                    items="{AvailableRoomsModel>/}"
                    valueStateText="{i18n>selectRoomNo}"
                    change="onRoomNoChange"

                >
                    <core:ListItem
                        key="{AvailableRoomsModel>RoomNo}"
                        text="{AvailableRoomsModel>RoomNo}"
                    />
                </ComboBox>

               

              
            </f:content>
        </f:SimpleForm>

        <beginButton>
            <Button
                text="Assign"
                tooltip="Assign"
                press="ARNO_onsavebuttonpress"
                type="Accept"
                id="HM_id_saveButton"
                class="marginRight myUnifiedBtn"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>CancelButton}"
                tooltip="{i18n>CancelButton}"
                press="HM_onCancelButtonPress"
                type="Reject"
                id="HM_id_CancelButton"
                class="marginRight myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</c:FragmentDefinition>