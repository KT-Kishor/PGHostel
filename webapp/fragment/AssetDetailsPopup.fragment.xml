<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="FDP_id_ValueHelpDialog"
        title="{i18n>selectEquipmentDetails}"
        contentWidth="50%"
    >
        <content>
            <Table
                id="FDP_id_VHDTable"
                items="{filteredAssetDetails>/}"
            >
                <columns>
                    <Column>
                        <Text text="{i18n>model}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>equipmentNumber}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>serialNumber}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>assetValue}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem
                        type="Active"
                        press="FDP_onVHDPick"
                    >
                        <cells>
                            <Text text="{filteredAssetDetails>Model}" />
                            <Text
                                text="{filteredAssetDetails>EquipmentNumber}"
                            />
                            <Text text="{filteredAssetDetails>SerialNumber}" />
                            <Text text="{filteredAssetDetails>AssetValue}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <beginButton>
            <Button
                text="{i18n>close}"
                type="Reject"
                press="FDP_onVHDClose"
            />
        </beginButton>
    </Dialog>
</core:FragmentDefinition>
