<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core">
	<Dialog title="{i18n>applyLeave}">
		<f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1"
            singleContainerFullSize="false">
			<f:content>
				<!-- Employee ID -->
				<Label text="{i18n>employeeID}"/>
				<Input  value="{LeaveTempModel>/EmployeeID}" editable="false"/>
				<!-- Employee Name -->
				<Label text="{i18n>employeeName}"/>
				<Input  value="{LeaveTempModel>/EmployeeName}" editable="false"/>
				<!-- Email -->
				<Label text="{i18n>emailId}"/>
				<Input value="{LeaveTempModel>/Email}" editable="false"/>
				<!-- Leave Type -->
				<Label text="{i18n>type}" required="true"/>
				<Select items="{leaveTypeModel>/results}"  selectedKey="{LeaveTempModel>/TypeOfLeave}" >
					<core:Item key="{leaveTypeModel>Name}" text="{leaveTypeModel>Name}" />
				</Select>
				<VBox>
					<!-- From Date -->
					<Label text="{i18n>fromDate}" required="true" />
					<DatePicker value="{LeaveTempModel>/FromDate}" id="AL_id_FromDate"  displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy" change="validateDate" valueStateText="{i18n>dateValueState}"  maxDate="{LeaveTempModel>/maxDate}"
                    liveChange="onLiveChange" legend="legend" afterValueHelpOpen="onInitializeLegend" minDate="{LeaveTempModel>/minDate}"/>
					<!-- To Date -->
					<Label text="{i18n>toDate}" required="true" />
					<DatePicker minDate="{LeaveTempModel>/MinToDate}" id="AL_id_ToDate" value="{LeaveTempModel>/ToDate}" displayFormat="dd/MM/yyyy" maxDate="{LeaveTempModel>/maxDate}" 
                valueFormat="dd/MM/yyyy" change="validateDate" valueStateText="{i18n>dateValueState}"  liveChange="onLiveChange" legend="legend" afterValueHelpOpen="onInitializeLegend"/>
					<!-- Half Day CheckBox -->
					<CheckBox text="{i18n>halfDay}" select="onHalfDaySelect" selected="{LeaveTempModel>/HalfDay}"/>
				</VBox>
				<!-- Number of Days -->
				<Label text="{i18n>noOfDays}"/>
				<Input  value="{LeaveTempModel>/NoofDays}" editable="false"/>
				<!-- Add Feedback -->
				<Label text="{i18n>comments}" required="true"></Label>
				<TextArea value="{LeaveTempModel>/Comments}" rows="2" id="AL_id_LeaveComments"  liveChange="ValidateCommonFields" valueStateText="{i18n>commentsValueState}"  maxLength="200" placeholder="{i18n>enterComments}"/>
			</f:content>
		</f:SimpleForm>
		<!-- Buttons for Submit and Close actions -->
		<FlexBox justifyContent="End">
			<Button text="{i18n>submit}" type="Emphasized" press="AL_onPressSubmit" class="sendMail" visible="{LeaveTempModel>/Submit}"/>
			<Button text="{i18n>save}" type="Emphasized" press="AL_onPressSave" class="sendMail" visible="{LeaveTempModel>/Save}"/>
			<Button text="{i18n>close}" class="sendMail" press="AL_onPressClose" />
		</FlexBox>
	</Dialog>
</core:FragmentDefinition>