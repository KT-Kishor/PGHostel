<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="paymentDetailsDialog"
        contentWidth="1000px"
        contentHeight="500px"
        resizable="true"
        draggable="true">
          <customHeader >
        <Bar class="Coursetitle" >
        <contentLeft>
           <Title text="{i18n>brktitle} {dialogData>/companyName}" />
        </contentLeft>
          
            <contentRight>
                <Button icon="sap-icon://decline" press="onCloseDialog" tooltip="Close"/>
            </contentRight>
        </Bar>
    </customHeader>
        <content>
            <Table
                items="{dialogData>/invoices}"
                sticky="ColumnHeaders"
                noDataText="{i18n>noBData}">
                <columns>
                    <Column demandPopin="true" hAlign="Left"><Text text="{i18n>invoiceNo}" /></Column>
                    <Column hAlign="End" demandPopin="true"><Text text="{i18n>taxableAmount}" /></Column>
                    <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop"><Text text="{i18n>creditNotesAmount}" /></Column>
                    <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop"><Text text="{i18n>gstAmount}" /></Column>
                    <Column hAlign="End" demandPopin="true" minScreenWidth="Desktop"><Text text="{i18n>colTotalAmount}" /></Column>
                  
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onPaymentBreakdownPress">
                        <cells>
                            <Text text="{dialogData>InvNo}" />
                            <ObjectNumber number="{path: 'dialogData>SubTotalInGST',formatter: '.Formatter.fromatNumber'}" unit="INR" />
                            <!-- <ObjectNumber number="{path: 'dialogData>gstAmount',formatter: '.Formatter.fromatNumber'}" unit="INR" /> -->
                            <Link wrapping="true" class="creditLinkStyle" press="onInvoiceCreditNotesPress" text="{parts: [{ path: 'dialogData>CreditNotesTotal' },{ value: 'INR' }],formatter: '.Formatter.formatAmountWithCurrency'}"/>
                           	<ObjectNumber number="{parts: [{ path: 'dialogData>gstAmount' }],formatter: '.Formatter.fromatNumber'}"/>
                            <ObjectNumber number="{path: 'dialogData>totalAmountInINR',formatter: '.Formatter.fromatNumber'}" unit="INR"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
         <footer>
			<Toolbar>
				<ToolbarSpacer/>
				<Text text="Total Amount : "/>
				<ObjectNumber 
						number="{parts: [{ path: 'dialogData>/AllTotalAmount' }], formatter: '.Formatter.fromatNumber'}"
						unit="INR" />
        	</Toolbar>
		</footer>
    </Dialog>
</core:FragmentDefinition>