<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="paymentDetailsDialog"
        title="{i18n>brktitle} {dialogData>/companyName}"
        contentWidth="800px"
        contentHeight="400px"
        resizable="true"
        draggable="true">
        <content>
            <Table
                items="{dialogData>/invoices}"
                sticky="ColumnHeaders"
                noDataText="{i18n>noBData}">
                <columns>
                    <Column><Text text="{i18n>invoiceNo}" /></Column>
                    <Column hAlign="End"><Text text="{i18n>taxableAmount}" /></Column>
                    <Column hAlign="End"><Text text="{i18n>gstAmount}" /></Column>
                    <Column hAlign="End"><Text text="{i18n>tdsAmount}" /></Column>
                    <Column hAlign="End"><Text text="{i18n>colTotalAmount}" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onPaymentBreakdownPress">
                        <cells>
                            <Text text="{dialogData>InvNo}" />
                            <ObjectNumber number="{
                                path: 'dialogData>SubTotalInGST',
                               formatter: '.Formatter.fromatNumber'
                            }" unit="INR" />
                             <ObjectNumber number="{
                                path: 'dialogData>gstAmount',
                       formatter: '.Formatter.fromatNumber'
                            }" unit="INR" />
                             <ObjectNumber number="{
                                path: 'dialogData>IncomeTax',
                         formatter: '.Formatter.fromatNumber'
                            }" unit="INR" />
                             <ObjectNumber number="{
                                path: 'dialogData>totalAmountInINR',
                           formatter: '.Formatter.fromatNumber'
                            }" unit="INR" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <endButton>
            <Button text="{i18n>close}" press="onCloseDialog" type="Reject" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>