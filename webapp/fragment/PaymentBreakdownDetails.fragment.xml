<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
>
    <Dialog
        id="paymentDetailsDialog"
        contentWidth="1000px"
        contentHeight="500px"
        resizable="true"
        draggable="true"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                <Title text="{i18n>brktitle} {dialogData>/customerName}" />
                </contentMiddle>
                <contentRight>
                    <Button
                        icon="sap-icon://decline"
                        press="onCloseDialog"
                        tooltip="{i18n>close}"
                    />
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <Table
                items="{dialogData>/invoices}"
                sticky="ColumnHeaders"
                noDataText="{i18n>noBData}"
            >
                <columns>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                    >
                        <Text text="{i18n>invoiceNo}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        hAlign="Left"
                        minScreenWidth="Tablet"
                    >
                        <Text text="{i18n>bookingID}" />
                    </Column>
                    <Column
                        hAlign="End"
                        demandPopin="true"
                    >
                        <Text text="{i18n>taxableAmount}" />
                    </Column>
                    <!-- <Column
                        hAlign="End"
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>creditNotesAmount}" />
                    </Column> -->
                    <Column
                        hAlign="End"
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>gstAmount}" />
                    </Column>
                    <Column
                        hAlign="End"
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>tdsAmount}" />
                    </Column>
                    <Column
                        hAlign="End"
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>colTotalAmount}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem
                        type="Navigation"
                        press="onPaymentBreakdownPress"
                    >
                        <cells>
                            <Text text="{dialogData>InvNo}" />
                            <Text text="{dialogData>BookingID}" />
                            <ObjectNumber
                                number="{path: 'dialogData>SubTotalInGST', formatter: '.Formatter.fromatNumber'}"
                                unit="INR"
                            />
                            <!-- <layout:VerticalLayout>
                                <Link
                                    wrapping="true"
                                    class="creditLinkStyle"
                                    press="onInvoiceCreditNotesPress"
                                    visible="{= ${dialogData>CreditNotesTotal} > 0 }"
                                    text="{parts: [{ path: 'dialogData>CreditNotesTotal' },{ value: 'INR' }], formatter: '.Formatter.formatAmountWithCurrency'}"
                                />
                                <Text
                                    visible="{= ${dialogData>CreditNotesTotal} === 0 }"
                                    text="-"
                                />
                            </layout:VerticalLayout> -->
                            <ObjectNumber
                                number="{parts: [{ path: 'dialogData>gstAmount' }], formatter: '.Formatter.fromatNumber'}"
                                unit="INR"
                            />
                            <ObjectNumber
                                number="{path: 'dialogData>IncomeTax', formatter: '.Formatter.fromatNumber'}"
                                unit="INR"
                            />
                            <ObjectNumber
                                number="{path: 'dialogData>totalAmountInINR', formatter: '.Formatter.fromatNumber'}"
                                unit="INR"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Text text="{i18n>totalAmount} : " />
                <ObjectNumber
                    number="{parts: [{ path: 'dialogData>/AllTotalAmount' }], formatter: '.Formatter.fromatNumber'}"
                    unit="INR"
                />
            </Toolbar>
        </footer>
    </Dialog>
</core:FragmentDefinition>
