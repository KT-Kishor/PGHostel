<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
>
    <Dialog
        id="EctraFaciliotiID"
        type="Message"
        class="sapUiContentPadding"
        contentWidth="28rem"
        contentHeight="auto"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title text="{i18n>addFacility}" />
                </contentMiddle>
            </Bar>
        </customHeader>

        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <f:content>
                <Label
                    text="{i18n>facilityname}"
                    required="true"
                />
                <ComboBox
                    id="idFacilityCombo"
                    placeholder="{i18n>selectFacility}"
                    items="{ExtraFacilitiModel>/}"
                    selectionChange=".onFacilitiSelectionChange"
                >
                    <core:ListItem
                        key="{ExtraFacilitiModel>ID}"
                        text="{ExtraFacilitiModel>FacilityName}"
                    />
                </ComboBox>

                <Label text="{i18n>price}" />
                <Input
                    id="idFacilityPrice"
                    value="{ExtraFacilitiModel>/Price}"
                    editable="false"
                />

                <Label text="{i18n>startDate}" />
                <DatePicker
                    id="idFacilityStartDate"
                    valueFormat="yyyy-MM-dd"
                    displayFormat="dd/MM/yyyy"
                    change=".onFacilityDateChange"
                />

                <Label text="{i18n>endDate}" />
                <DatePicker
                    id="idFacilityEndDate"
                    valueFormat="yyyy-MM-dd"
                    displayFormat="dd/MM/yyyy"
                    change=".onFacilityDateChange"
                />

                <Label text="{i18n>days}" />
                <Input
                    id="idFacilityDays"
                    value=""
                    editable="false"
                />
            </f:content>
        </f:SimpleForm>

        <beginButton>
            <Button
                text="{i18n>MSadd}"
                tooltip="{i18n>MSadd}"
                press=".onAddFacilitySave"
                class="myUnifiedBtn"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>CancelButton}"
                tooltip="{i18n>CancelButton}"
                press=".onAddFacilityCancel"
                class="myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>