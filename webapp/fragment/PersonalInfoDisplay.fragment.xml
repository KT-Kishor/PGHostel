<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
>
    <!-- Renders ONE person (context comes from the List item) -->
    <Panel
        headerText="{= 'Personal Information - ' + (${HostelModel>FullName} || 'Person') }"
        expandable="false"
        class="customPanelHeader"
    >
        <!-- Personal Info -->
        <f:SimpleForm
            editable="false"
            layout="ColumnLayout"
            columnsM="1"
            columnsL="2"
            columnsXL="2"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
        >
            <f:content>
                <Label text="{i18n>fullname}" />
                <Text text="{HostelModel>Salutation} {HostelModel>FullName}" />
                <Label text="{i18n>MVDDOB}" />
                <Text text="{path:'HostelModel>DateOfBirth'}" />
                <Label text="{i18n>MVgender}" />
                <Text text="{HostelModel>Gender}" />
                <Label text="{i18n>mobileNo}" />
                <Text text="{HostelModel>STDCode} {HostelModel>MobileNo}" />
                <Label text="{i18n>email}" />
                <Text text="{HostelModel>CustomerEmail}" />
                <Label text="{i18n>MVDcountry}" />
                <Text text="{HostelModel>Country}" />
                <Label text="{i18n>MVDstate}" />
                <Text text="{HostelModel>State}" />
                <Label text="{i18n>city}" />
                <Text text="{HostelModel>City}" />
                <Label text="{i18n>address}" />
                <Text text="{HostelModel>Address}" />
            </f:content>
        </f:SimpleForm>

        <VBox
            visible="{= ${HostelModel>Documents}.length > 0 }"
            class="sapUiSmallMargin"
        >
            <Toolbar>
                <Title
                    text="{i18n>uploadeddocument}"
                    level="H4"
                />
            </Toolbar>

            <!-- Wrap cards like facility layout -->
            <FlexBox
                wrap="Wrap"
                justifyContent="Start"
                class="sapUiSmallMarginTop"
                alignItems="Start"
                items="{
            path: 'HostelModel>Documents'
        }"
            >
                <VBox
                    width="200px"
                    height="200px"
                    class="serviceCard"
                    alignItems="Center"
                    justifyContent="Center"
                >
                    <!-- Image / PDF Thumbnail -->
                    <Image
                        src="{HostelModel>Thumbnail}"
                        width="180px"
                        height="140px"
                        densityAware="false"
                        press="onOpenDocumentPreview"
                        class="serviceImage"
                    />
                </VBox>
            </FlexBox>
        </VBox>

        <VBox visible="{= ${HostelModel>AllSelectedFacilities}.length > 0 }">
            <!-- Selected Facilities for THIS person -->
            <Toolbar>
                <Title
                    text="{i18n>selectedfacilities}"
                    level="H4"
                />
            </Toolbar>
            <FlexBox
                wrap="Wrap"
                alignItems="Start"
                justifyContent="Start"
                class="sapUiSmallMarginTop"
                items="{
                path: 'HostelModel>AllSelectedFacilities'
            }"
            >
                <VBox
                    width="200px"
                    height="200px"
                    class="sapUiSmallMargin serviceCard"
                    alignItems="Center"
                    justifyContent="Center"
                    visible="{= !!${HostelModel>FacilityName} }"
                >
                    <Image
                        src="{HostelModel>Image}"
                        width="180px"
                        height="140px"
                    />
                    <Text text="{HostelModel>FacilityName}" />
                    <Text
                        text="{= ${HostelModel>Price} ? ${HostelModel>Price}+ ' ' + ${HostelModel>Currency} + ' ' + ${HostelModel>UnitText} : '' }"
                    />
                </VBox>
            </FlexBox>

            <!-- Booking Details for THIS person -->
            <Table
                id="idFacilitySummaryTable"
                class="sapUiSmallMarginTop"
                items="{
                path: 'HostelModel>AllSelectedFacilities'
            }"
                mode="SingleSelectLeft"
                inset="false"
                selectionChange="onTableSelection"
            >
                <headerToolbar>
                    <Toolbar>
                        <Title
                            text="{i18n>bookingDetailsTitle}"
                            level="H5"
                        />
                        <ToolbarSpacer />
                        <Button
                            text="{i18n>MSedit}"
                            tooltip="{i18n>MSedit}"
                            press="onEditFacilityDetails"
                            class="myUnifiedBtn"
                        />
                        <Button
                            text="{i18n>MSdelete}"
                            tooltip="{i18n>MSdelete}"
                            press="onDeleteFacility"
                            class="myUnifiedBtn"
                        />
                    </Toolbar>
                </headerToolbar>

                <columns>
                    <Column demandPopin="true">
                        <Text text="{i18n>facilityname}" />
                    </Column>
                    <Column demandPopin="true">
                        <Text text="{i18n>faciltyprice}" />
                    </Column>
                    <Column
                        minScreenWidth="Desktop"
                        demandPopin="true"
                    >
                        <Text text="{i18n>startDate}" />
                    </Column>
                    <Column
                        demandPopin="true"
                        minScreenWidth="Desktop"
                    >
                        <Text text="{i18n>endDate}" />
                    </Column>
                    <Column
                        minScreenWidth="Desktop"
                        demandPopin="true"
                    >
                        <Text text="{i18n>days}" />
                    </Column>
                    <Column demandPopin="true">
                        <Text
                            class="sapUiSmallBold"
                            text="{i18n>total}"
                        />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{HostelModel>FacilityName}" />
                            <Text
                                text="{
        parts: [
            'HostelModel>Price',
            'HostelModel>Currency',
            'HostelModel>UnitText',
            'HostelModel>TotalTime'
        ],
        formatter: '.Formatter.formatFacilityPrice'
    }"
                            />

                            <Text text="{HostelModel>StartDate}" />
                            <Text text="{HostelModel>EndDate}" />
                            <Text
    text="{
        parts: [
            'HostelModel>/SelectedPriceType',
            'HostelModel>/TotalDays',
            'HostelModel>/SelectedMonths'
        ],
        formatter: '.Formatter.getDurationValue'
    }"
/>


                            <Text
                                class="totalColumnBold"
                                text="{
        parts: [
            'HostelModel>TotalAmount',
            'HostelModel>Currency'
        ],
        formatter: '.Formatter.formatCurrency'
    }"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>

            <!-- Totals for THIS person (NOTE: all RELATIVE, no leading "/") -->
</VBox>

            <HBox
                justifyContent="End"
                class="sapUiSmallMarginTop"
                visible="{= ${HostelModel>AllSelectedFacilities}.length > 0 }"
            >
                <Label
                    text="{i18n>totalfacilitycost}"
                    class="totalColumnBold1 sapUiTinyMarginEnd"
                />
                <Text
                    text="{
                   parts: [
        'HostelModel>TotalFacilityPrice',
        'HostelModel>/Currency'
    ], formatter: '.Formatter.formatCurrency'
                }"
                    class="totalColumnBold1"
                />
            </HBox>

            <HBox
                justifyContent="End"
                class="sapUiSmallMarginTop"
               
            > 
                <Label
                    text="Total Room Rent:"
                    class="totalColumnBold1 sapUiTinyMarginEnd"
                />
                <Text
                    text="{parts:['HostelModel>RoomRentPerPerson','HostelModel>/Currency'], formatter: '.Formatter.formatCurrency'}"
                    class="totalColumnBold1"
                />
            </HBox>
            <HBox
                justifyContent="End"
               visible="{= !${HostelModel>/GSTType} === 'CGST/SGST' &amp;&amp; !${HostelModel>/GSTType} === 'IGST' }"
                class="sapUiSmallMarginTop"
            >
                <Label
                    text="Sub-Total (Non-Taxable):"
                    class="totalColumnBold1 sapUiTinyMarginEnd"
                />
                <Text
                    text="{   parts: [
        'HostelModel>OverallTotalCost',
        'HostelModel>/Currency'
    ], formatter: '.Formatter.formatCurrency'}"
                    class="totalColumnBold1"
                />
            </HBox>

            <HBox
                justifyContent="End"
                class="sapUiSmallMarginTop"
                visible="{= ${HostelModel>/GSTType} === 'CGST/SGST' || ${HostelModel>/GSTType} === 'IGST' }"
            >
                <Label
                    text="Sub-Total (Taxable):"
                    class="totalColumnBold1 sapUiTinyMarginEnd"
                />
                <Text
                    text="{ parts: [
        'HostelModel>SubTotal',
        'HostelModel>/Currency'
    ], formatter: '.Formatter.formatCurrency'}"
                    class="totalColumnBold1"
                />
            </HBox>

           

            <HBox
                justifyContent="End"
                class="sapUiSmallMarginTop"
               visible="{= ${HostelModel>/GSTType} === 'CGST/SGST'}"
            >
                <Label
                    text="{
    parts: [
        { path: 'HostelModel>/GSTValue' }
    ],
    formatter: '.Formatter.formatCGSTLabel'
}"

                    class="totalColumnBold1 sapUiTinyMarginEnd"
                />
                <Text
                    text="{parts:['HostelModel>CGST','HostelModel>/Currency'], formatter: '.Formatter.formatCurrency'}"
                    class="totalColumnBold1"
                />
            </HBox>

            <HBox
                justifyContent="End"
                class="sapUiSmallMarginTop"
                visible="{= ${HostelModel>/GSTType} === 'CGST/SGST'}"
            >
                <Label
                   text="{
    parts: [
        { path: 'HostelModel>/GSTValue' }
    ],
    formatter: '.Formatter.formatSGSTLabel'
}"

                    class="totalColumnBold1 sapUiTinyMarginEnd"
                />
                <Text
                    text="{parts:['HostelModel>SGST','HostelModel>/Currency'], formatter: '.Formatter.formatCurrency'}"
                    class="totalColumnBold1"
                />
            </HBox>
             <HBox
                justifyContent="End"
                class="sapUiSmallMarginTop"
                visible="{= ${HostelModel>/GSTType} === 'IGST'}"
            >
                <Label
                    text="{
    parts: [
        { path: 'HostelModel>/GSTValue' }
    ],
    formatter: '.Formatter.formatIGSTLabel'
}"
                    class="totalColumnBold1 sapUiTinyMarginEnd"
                />
                <Text
                    text="{parts:['HostelModel>IGST','HostelModel>/Currency'], formatter: '.Formatter.formatCurrency'}"
                    class="totalColumnBold1"
                />
            </HBox>
             <HBox justifyContent="End"
             class="sapUiSmallMarginTop" visible="{= ${HostelModel>AppliedDiscount} > 0 }">
                <Label
                    text="Discount:"
                    class="totalColumnBold1 sapUiTinyMarginEnd"
                />
                <Text
                    text="{
            parts: ['HostelModel>AppliedDiscount','HostelModel>/Currency'],
            formatter: '.Formatter.formatCurrency'
        }"
                    class="totalColumnBold1"
                />
            </HBox>

            <HBox
                justifyContent="End"
                class="sapUiSmallMarginTop"
            >
                <Label
                    text="{i18n>totalCost}"
                    class="totalColumnBold1 sapUiTinyMarginEnd"
                />
                <Text
                    text="{parts:['HostelModel>FinalTotalCost','HostelModel>/Currency'], formatter: '.Formatter.formatCurrency'}"
                    class="totalColumnBold1"
                />
                </HBox>
            <HBox
                justifyContent="End"
                class="sapUiSmallMarginTop"
            >
                <Label
                    text="{i18n>securitydeposit}"
                    class="totalColumnBold1 sapUiTinyMarginEnd"
                />
                <Text
                    text="{parts:['HostelModel>/Deposit','HostelModel>/DepositCurrency'], formatter: '.Formatter.formatCurrency'}"
                    class="totalColumnBold1"
                />
            </HBox>
        
    </Panel>
    <!-- Grand Total section -->
</core:FragmentDefinition>