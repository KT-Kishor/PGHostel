<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>
     <Dialog
        id="sds12"
        class="newMemberDialog"
        contentWidth="32rem"
        stretch="{= ${device>/system/phone} }"
        draggable="true"
        resizable="false"
        showHeader="true"
        horizontalScrolling="false"
    >
        <customHeader>
            <Bar class="barheader">
                <contentLeft>
                    <Title text="{= ${viewModel>/mode} === 'CREATE' ? 'Add Member' : 'Update Member' }"
                    class="sapUiSmallMarginBegin"
                />
                </contentLeft>
            
            </Bar>
        </customHeader>
       <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                width="100%"
                columnsXL="2"
                columnsL="2"
                columnsM="1"
               >
            <f:content>
                <HBox
                    width="100%"
                    justifyContent="Start"
                    alignItems="Center"
                >
                    <VBox width="35%">
                        <Label
                            text="Salutation"
                            required="true"
                        />
                    </VBox>
                    <VBox
                        width="65%"
                        class="sapUiTinyMarginBegin"
                    >
                        <Label
                            text="Full Name"
                            required="true"
                        />
                    </VBox>
                </HBox>
                <HBox
                    width="100%"
                    justifyContent="Start"
                    alignItems="Center"
                >
                    <VBox width="35%">
                        <ComboBox
                            id="idSelect"
                            selectedKey="{Member>/Salutation}"
                            placeholder="Select salutation"
                            valueStateText="Please select salutation"
                            change="onNewMemberSalutationChange" editable="{= ${Member>/Relation} !== 'Self' }"
                        >
                            <core:Item
                                key="Mr."
                                text="Mr."
                            />
                            <core:Item
                                key="Ms."
                                text="Ms."
                            />
                            <core:Item
                                key="Mrs."
                                text="Mrs."
                            />
                            <core:Item
                                key="Dr."
                                text="Dr."
                            />
                          
                        </ComboBox>
                    </VBox>
                    <VBox
                        width="65%"
                        class="sapUiTinyMarginBegin"
                    >
                        <Input
                            id="MM_id_MemberName"
                            value="{Member>/Name}"
                            placeholder="Enter full name"
                            valueStateText="Please enter a valid full name"
                            liveChange="onNewMemberNameChange"
                            change="onNewMemberNameChange"
                            maxLength="35" editable="{= ${Member>/Relation} !== 'Self' }"
                        />
                    </VBox>
                </HBox>
                <Label
                    text="Date of Birth"
                    required="true"
                />
                <DatePicker
                    id="MemberDOB"
                    value="{Member>/DateOfBirth}"
                    placeholder="DD/MM/YYYY"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="dd/MM/yyyy"
                    change="onNewMemberDOBChange"
                    valueStateText="Age must be between 0 and 100 years" editable="{= ${Member>/Relation} !== 'Self' }"
                     initialFocusedDateValue="{controller>/focusedDate}"
                     minDate="{controller>/minDate}"
                    maxDate="{controller>/maxdate}"
                />
                <Label
                    text="Gender"
                    required="true"
                />
                <ComboBox
                    id="MemberGenderCombo"
                    selectedKey="{Member>/Gender}"
                    placeholder="Select gender"
                    valueStateText="Please select gender"
                    change="onNewMemberGenderChange" editable="{= ${Member>/Relation} !== 'Self' }"
                >
                    <core:Item
                        key="Male"
                        text="Male"
                    />
                    <core:Item
                        key="Female"
                        text="Female"
                    />
                    <core:Item
                        key="Other"
                        text="Other"
                    />
                </ComboBox>
                <Label
                    text="Relationship"
                    required="true"
                />
                <ComboBox
                    id="MemberRelationCombo"
                    selectedKey="{Member>/Relation}"
                    placeholder="Select relationship"
                    valueStateText="Please select relationship"
                    change="onNewMemberRelationChange" editable="{= ${Member>/Relation} !== 'Self' }"
                >
                 
                    <core:Item
                        key="Spouse"
                        text="Spouse"
                    />
                    <core:Item
                        key="Child"
                        text="Child"
                    />
                    <core:Item
                        key="Father"
                        text="Father"
                    />
                    <core:Item
                        key="Mother"
                        text="Mother"
                    />
                     <core:Item
                        key="Friend"
                        text="Friend"
                    />
                    <core:Item
                        key="Brother"
                        text="Brother"
                    />
                    <core:Item
                        key="Sister"
                        text="Sister"
                    />
                       <core:Item
                        key="Other"
                        text="Other"
                    />
                </ComboBox>
                <Label
                    text="{i18n>uploadDocument}"
                    required="true"
                />

                <HBox
                    width="100%"
                    fitContainer="true"
                    wrap="{= ${device>/system/phone} ? 'Wrap' : 'NoWrap'}"
                    alignItems="Center"
                >
                    <!-- Document Type -->
                    <ComboBox
                        id="idDocumentType"
                        selectedKey="{Member>/DocumentType}"
                        placeholder="{i18n>selectIDProof}"
                        valueStateText="{i18n>selectIDProof}"
                        selectionChange="onNewMemberDocumentTypeChange"
                        change="onNewMemberDocumentTypeChange"
                        width="{= ${device>/system/phone} ? '100%' : '12rem'}"
                        class="sapUiTinyMarginEnd"
                        visible="{VisibleModel>/visible}"
                    >
                        <core:Item
                            key="Aadhar Card"
                            text="Aadhar Card"
                        />
                        <core:Item
                            key="Pan Card"
                            text="Pan Card"
                        />
                        <core:Item
                            key="Driving License"
                            text="Driving License"
                        />
                        <core:Item
                            key="Passport"
                            text="Passport"
                        />
                    </ComboBox>

                    <!-- Upload Button -->
                    <u:FileUploader
                        id="MM_id_FileUploader"
                        width="{= ${device>/system/phone} ? '100%' : '8rem'}"
                        visible="{= !${Member>/DocumentName} }"
                        buttonOnly="true"
                        maximumFileSize="2"
                        sameFilenameAllowed="true"
                        change="onFacilityFileChange"
                        fileSizeExceed="onMemberFileSizeExceed"
                        buttonText="Upload"
                        fileType="pdf,jpg,jpeg,png,webp"
                        class="sapUiTinyMarginEnd myUnifiedBtn"
                    />

                    <!-- Info Icon -->
                    <core:Icon
                        id="memberDocumentInfoIcon"
                        size="1rem"
                        press="onMemberDocumentInfoPress"
                        tooltip="Upload info"
                        visible="{= !${Member>/DocumentName} }"
                        class="sapUiSmallMarginBegin"
                    />

                    <!-- Preview + Remove -->
                    <HBox
                        visible="{= !!${Member>/DocumentName} }"
                        alignItems="Center"
                        wrap="{= ${device>/system/phone} ? 'Wrap' : 'NoWrap'}"
                    >
                        <Link
                            text="{Member>/DocumentName}"
                            tooltip="{Member>/DocumentName}"
                            press="onPreviewMemberDocument"
                            width="10rem"
                            class="automatedEllipsis documentLink"
                        />

                        <Button
                            text="Remove"
                            icon="sap-icon://delete"
                            press="onDeleteMemberDocument"
                            class="myUnifiedBtn"
                        />
                    </HBox>
                </HBox>
            </f:content>
        </f:SimpleForm>
        <beginButton>
            <Button
                text="{i18n>save}"
                tooltip="{i18n>save}"
                press="savepress"
                class="marginRight myUnifiedBtn"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>CancelButton}"
                tooltip="{i18n>CancelButton}"
                press="onCloseDialog"
                class="marginRight myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</c:FragmentDefinition>