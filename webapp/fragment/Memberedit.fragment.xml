<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>
    <Dialog
        id="sds1"
        title="{i18n>uploadDocuments}"
        type="Standard"
        class="sapUiContentPadding"
    >
        <customHeader>
            <Bar class="barheader">
                <contentLeft>
                    <Title
                        text="{i18n>uploadDocuments}"
                        class="sapUiSmallMarginBegin"
                    />
                </contentLeft>
            
            </Bar>
        </customHeader>
        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <f:content>
                <HBox
                    width="100%"
                    justifyContent="Start"
                    alignItems="Center"
                >
                    <VBox width="35%">
                        <Label
                            text="Salutation"
                            required="true"
                        />
                    </VBox>
                    <VBox
                        width="65%"
                        class="sapUiTinyMarginBegin"
                    >
                        <Label
                            text="Full Name"
                            required="true"
                        />
                    </VBox>
                </HBox>
                <HBox
                    width="100%"
                    justifyContent="Start"
                    alignItems="Center"
                >
                    <VBox width="35%">
                        <ComboBox
                            id="idSelect"
                            selectedKey="{Member>/Salutation}"
                            placeholder="Select salutation"
                            valueStateText="Please select salutation"
                            change="onNewMemberSalutationChange"
                        >
                            <core:Item
                                key="Mr."
                                text="Mr."
                            />
                            <core:Item
                                key="Ms."
                                text="Ms."
                            />
                            <core:Item
                                key="Mrs."
                                text="Mrs."
                            />
                            <core:Item
                                key="Dr."
                                text="Dr."
                            />
                          
                        </ComboBox>
                    </VBox>
                    <VBox
                        width="65%"
                        class="sapUiTinyMarginBegin"
                    >
                        <Input
                            id="MM_id_MemberName"
                            value="{Member>/Name}"
                            placeholder="Enter full name"
                            valueStateText="Please enter a valid full name"
                            liveChange="onNewMemberNameChange"
                            change="onNewMemberNameChange"
                            maxLength="35"
                        />
                    </VBox>
                </HBox>
                <Label
                    text="Date of Birth"
                    required="true"
                />
                <DatePicker
                    id="MemberDOB"
                    value="{Member>/DateOfBirth}"
                    placeholder="DD/MM/YYYY"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="dd/MM/yyyy"
                    change="onNewMemberDOBChange"
                    valueStateText="Age must be between 0 and 100 years"
                />
                <Label
                    text="Gender"
                    required="true"
                />
                <ComboBox
                    id="MemberGenderCombo"
                    selectedKey="{Member>/Gender}"
                    placeholder="Select gender"
                    valueStateText="Please select gender"
                    change="onNewMemberGenderChange"
                >
                    <core:Item
                        key="Male"
                        text="Male"
                    />
                    <core:Item
                        key="Female"
                        text="Female"
                    />
                    <core:Item
                        key="Other"
                        text="Other"
                    />
                </ComboBox>
                <Label
                    text="Relationship"
                    required="true"
                />
                <ComboBox
                    id="MemberRelationCombo"
                    selectedKey="{Member>/Relation}"
                    placeholder="Select relationship"
                    valueStateText="Please select relationship"
                    change="onNewMemberRelationChange"
                >
                 
                    <core:Item
                        key="Spouse"
                        text="Spouse"
                    />
                    <core:Item
                        key="Child"
                        text="Child"
                    />
                    <core:Item
                        key="Father"
                        text="Father"
                    />
                    <core:Item
                        key="Mother"
                        text="Mother"
                    />
                     <core:Item
                        key="Friend"
                        text="Friend"
                    />
                    <core:Item
                        key="Brother"
                        text="Brother"
                    />
                    <core:Item
                        key="Sister"
                        text="Sister"
                    />
                       <core:Item
                        key="Other"
                        text="Other"
                    />
                </ComboBox>
                <Label
                    text="{i18n>iDProofType}"
                    required="true"
                />
                <ComboBox
                    id="idDocumentType"
                    placeholder="{i18n>selectIDProof}"
                    value="{Member>/DocumentType}"
                    visible="{VisibleModel>/visible}"
                    valueStateText="{i18n>selectIDProof}"
                    change="onNewMemberRelationChange"
                >
                    <core:ListItem
                        key="Aadhar Card"
                        text="Aadhar Card"
                    />
                    <core:ListItem
                        key="Pan Card"
                        text="Pan Card"
                    />
                    <core:ListItem
                        key="Driving License"
                        text="Driving License"
                    />
                    <core:ListItem
                        key="Passport"
                        text="Passport"
                    />
                </ComboBox>
                <Label
                    text="{i18n>uploadDocument}"
                    required="true"
                />
                <u:FileUploader
                    id="MM_id_FileUploader"
                    fileType="jpg,jpeg,png,PDF"
                    sameFilenameAllowed="false"
                    change="onFacilityFileChange"
                    visible="{VisibleModel>/visible}"
                    class="myUnifiedBtn"
                    width="100%"
                />
            </f:content>
        </f:SimpleForm>
        <beginButton>
            <Button
                text="{i18n>save}"
                tooltip="{i18n>save}"
                press="savepress"
                id="AR_id_saveButton"
                class="marginRight myUnifiedBtn"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>CancelButton}"
                tooltip="{i18n>CancelButton}"
                press="onCloseDialog"
                id="AR_id_CancelButton"
                class="marginRight myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</c:FragmentDefinition>