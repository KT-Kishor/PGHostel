<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:l="sap.ui.layout"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core">
	<Dialog showHeader="true"  title="{i18n>employmentDetails}" id="AddEmp_id_Dialog" >
		<f:SimpleForm
                                        editable="true" layout="ColumnLayout" 
                                         labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                                         adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"                           
                                         emptySpanM="0" emptySpanS="0" columnsXL="2" columnsL="2"
                                         columnsM="1" singleContainerFullSize="false">
			<f:content>
				<Label text="{i18n>employeeID}"/>
				<Input value="{employmentModel>/EmployeeID}" editable="false" />
				<Label text="{i18n>companyName}" required="true"/>
				<Input value="{employmentModel>/CompanyName}" id="AddEmp_id_Company" placeholder="{i18n>companyName}" maxLength="50" liveChange="SS_ValidateCommonFields" valueStateText="{i18n>companyNameValueState}"/>
				<Label text="{i18n>designation}" required="true" />
				<ComboBox items="{sDesignationModel>/}" id="AddEmp_id_Desig" change="SS_ValidateCommonFields" valueStateText="{i18n>designationValueState}" selectedKey="{employmentModel>Designation}" showSecondaryValues="true" placeholder="{i18n>plaseDesignation}" maxLength="50">
					<core:Item key="{sDesignationModel>designationName}" text="{sDesignationModel>designationName}" />
				</ComboBox>
				<Label text="{i18n>companyAddress}" required="true"/>
				<TextArea value="{employmentModel>/OfficeAddress}" id="AddEmp_id_OfcAddress" placeholder="{i18n>companyAddress}" maxLength="120"  liveChange="SS_ValidateCommonFields" valueStateText="{i18n>addressValueState}"/>
				<Label text="{i18n>startDate}" required="true"/>

				<DatePicker value="{path:'employmentModel>/StartDate',formatter:'.Formatter.formatDate'}" 
            maxDate="{viewModel>/Max}" 
            displayFormat="dd/MM/yyyy" 
            valueFormat="dd/MM/yyyy" 
            id="AddEmp_id_StartDate" 
            change="SS_validateDate"
			valueStateText="{i18n>dateValueState}"/>
				<Label text="{i18n>endDate}" required="true"/>
				<DatePicker value="{path:'employmentModel>/EndDate',formatter:'.Formatter.formatDate'}" 
            maxDate="{viewModel>/Max}" 
            displayFormat="dd/MM/yyyy" 
            valueFormat="dd/MM/yyyy"  
            id="AddEmp_id_EndDate" 
            change="SS_validateDate"
			valueStateText="{i18n>dateValueState}"/>
			</f:content>
		</f:SimpleForm>
		<f:SimpleForm
                                         editable="true" layout="ColumnLayout"  title="{i18n>referenceDetails}"
                                         labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12" class="sapUiZLargeMarginTop"
                                         adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"                           
                                         emptySpanM="0" emptySpanS="0" columnsXL="2" columnsL="2"
                                         columnsM="1" singleContainerFullSize="false">
			<f:content>
				<core:Title text="{i18n>referenceDetailsI}" />
				<Label text="{i18n>rcNameI}" required="true"/>
				<Select
                                               selectedKey="{employmentModel>/RCISal}" id="AddEmp_id_SalI"
                                               items="{Salutation>/salutation}"
                                               width="100%">
					<core:Item key="{Salutation>text}" text="{Salutation>text}" />
					<layoutData>
						<l:GridData span="XL2 L1 M3 S4" />
					</layoutData>
				</Select>
				<Input value="{employmentModel>/RCIName}" id="AdEmp_id_RCNameI" liveChange="SS_validateName" placeholder="{i18n>placeName}" maxLength="50" valueStateText="{i18n>commonNameValueState}"/>
				<Label text="{i18n>rcAddressI}" required="true" />
				<TextArea value="{employmentModel>/RCIAddress}" id="AdEmp_id_RCAddressI" placeholder="{i18n>placeAddress}" maxLength="120" liveChange="SS_ValidateCommonFields"  valueStateText="{i18n>addressValueState}"/>
				<Label text="{i18n>rcMailIdI}" required="true"  />
				<Input value="{employmentModel>/RCIEmailID}" id="AdEmp_id_RCMailI" liveChange="SS_validateEmail" placeholder="{i18n>placeEmailId}" maxLength="50" valueStateText="{i18n>emailValueState}"/>
				<Label text="{i18n>rcMobileNoI}" required="true" />
				<Input value="{employmentModel>/RCIMobileNo}"  liveChange="SS_validateMobileNo" maxLength="10" id="AdEmp_id_RCMobileI" placeholder="{i18n>placeholderMobileNo}" valueStateText="{i18n>mobileNoValueState}"/>
				<core:Title text="{i18n>referenceDetailsII}" />
				<Label text="{i18n>rcNameII}" required="true" />
				<Select
                                    
                                               selectedKey="{employmentModel>/RCIISal}"
                                               items="{Salutation>/salutation}" id="AdEmp_id_RCSalII"
                                               width="100%">
					<!-- Binding the key and text of the Select control to the NameSalutation model -->
					<core:Item key="{Salutation>text}" text="{Salutation>text}" />
					<layoutData>
						<l:GridData span="XL2 L1 M3 S4" />
					</layoutData>
				</Select>
				<Input value="{employmentModel>/RCIIName}" id="AdEmp_id_RCNameII" liveChange="SS_validateName" placeholder="{i18n>placeName}" maxLength="50" valueStateText="{i18n>commonNameValueState}" />
				<Label text="{i18n>rcAddressII}" required="true" />
				<TextArea value="{employmentModel>/RCIIAddress}" id="AdEmp_id_RCAddressII" placeholder="{i18n>placeAddress}" maxLength="120" liveChange="SS_ValidateCommonFields" valueStateText="{i18n>addressValueState}"/>
				<Label text="{i18n>rcMailIdII}" required="true" />
				<Input value="{employmentModel>/RCIIEmailID}" id="AdEmp_id_RCMailII" liveChange="SS_validateEmail" placeholder="{i18n>placeEmailId}" maxLength="50" valueStateText="{i18n>emailValueState}"/>
				<Label text="{i18n>rcMobileNoII}" required="true"  />
				<Input value="{employmentModel>/RCIIMobileNo}" maxLength="10" id="AdEmp_id_RCMobileII"  liveChange="SS_validateMobileNo" placeholder="{i18n>placeholderMobileNo}" valueStateText="{i18n>mobileNoValueState}" />
			</f:content>
		</f:SimpleForm>
		<FlexBox justifyContent="End">
			<Button text="{i18n>submit}" id="AddEmp_id_Submit" type="Accept" press="AddEmp_onSubmitEmpDetails" class="submit" visible="{viewModel>/fragmentSubmit}" ></Button>
			<Button text="{i18n>save}" type="Accept" id="AddEmp_id_Save" press="AddEmp_onUpdateEmpDetails" class="submit" visible="{viewModel>/fragmentSave}"></Button>
			<Button text="{i18n>close}" press="AddEmp_onClose" class="sendMail" type="Reject"></Button>
		</FlexBox>
	</Dialog>
</core:FragmentDefinition>  
