<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core">
    <Dialog title="{i18n>tileFooter}" contentWidth="60%">
        <MessageStrip class="sapUiTinyMarginBeginEnd sapUiTinyMarginTop" text="{i18n>sendMailFragMsg}" type="Information" showIcon="true" />
        <f:SimpleForm id="Mail_id_Form" busyIndicatorDelay="0" editable="true" layout="ResponsiveGridLayout">
            <f:content>
                <Label text="{i18n>fileUploader}" required="true"/>
                <VBox width="100%">
                    <u:FileUploader
                        id="Mail_id_FileUploader"
                        fileType="pdf,jpg,jpeg,png,doc,docx,xls,xlsx,ppt,pptx,txt.ppt"
                        name="myFileUpload"
                        multiple="true"
                        uploadUrl="upload/"
                        tooltip="{i18n>toolTipMsgSM}"
                        change="Mail_onUpload"
                        buttonOnly="true"
                        width="50%"
                    />
                    <Tokenizer
                        id="CM_tokenizer"
                        width="100%"
                        class="sapUiSmallMarginTop"
                        tokens="{UploaderData>/attachments}"
                        tokenDelete="onCommonTokenDelete">
                        <Token key="{UploaderData>filename}" text="{UploaderData>filename}" />
                    </Tokenizer>
                </VBox>
                <Label text="{i18n>toMailText}"/>
                <Text id="Mail_id_Text" text="{UploaderData>/ToEmail}"/>
                <Label text="{i18n>ccMailText}" required="true"/>
                <TextArea id="CCMail_TextArea" value="{UploaderData>/CCEmail}" maxLength="600" liveChange="Mail_onEmailChange" valueStateText="{i18n>emailValueState}"/>
            </f:content>
        </f:SimpleForm>
        <beginButton>
            <Button id="SendMail_Button" text="{i18n>tileFooter}" type="Ghost" press="Mail_onSendEmail" enabled="false"/>
        </beginButton>
        <endButton>
            <Button text="{i18n>close}" width="80px" press="Mail_onPressClose" type="Reject"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>