<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core">
    <Dialog title="Send Mail" contentWidth="60%" >
        <f:SimpleForm id="Mail_id_Form" busyIndicatorDelay="0" editable="true" layout="ResponsiveGridLayout">
            <f:content>
            <MessageStrip text="{i18n>sendMailFragMsg}" type="Information" showIcon="true" />    
                <Label text="{i18n>fileUploader}" required="true"/>
                    <HBox width="100%" justifyContent="Start" alignItems="Center">
                        <VBox width="20%">
                            <u:FileUploader  
                                id="Mail_id_FileUploader"                                     
                                name="myFileUpload"
                                multiple="true"
                                uploadUrl="upload/"
                                tooltip="{i18n>toolTipMsgSM}"
                                change="Mail_onUpload"
                                buttonOnly="true"                  />
                        </VBox>
                        <VBox width="80%" >
                            <Text text="{UploaderData>/name}"></Text>
                        </VBox>
                    </HBox>
            
                <Label text="{i18n>toMailText}"/>
                <Input id="Mail_id_Text" value ="{UploaderData>/ToEmail}" editable="false"/>

                <Label text="{i18n>ccMailText}" required="true"/>
                <TextArea id="CCMail_TextArea" value ="{UploaderData>/CCEmail}" maxLength="600" liveChange="Mail_onEmailChange" valueStateText="{i18n>emailValueState}"/>
            </f:content>
        </f:SimpleForm>

        <FlexBox justifyContent="End">
           <Button id="SendMail_Button" text="{i18n>tileFooter}" type="Emphasized" class="sendMail" press="Mail_onSendEmail" enabled="false"/>
           <Button text="{i18n>close}" width="80px" class="sendMail" press="Mail_onPressClose" type="Reject"/>
        </FlexBox>
    </Dialog>
</core:FragmentDefinition>