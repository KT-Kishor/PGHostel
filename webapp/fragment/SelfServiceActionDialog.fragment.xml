<ActionSheet
    id="actionBtn"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    core:require="{ MessageToast: 'sap/m/MessageToast' }"
    title="Choose Your Action"
    showCancelButton="true"
    placement="Bottom"
>
    <Button
        text="{i18n>headerIdCard}"
        type="Ghost"
        visible="{viewModel>/RelievingLetter}"
        tooltip="{i18n>headerIdCard}"
        id="IC_id_Idcard"
        press="CC_onPressIdCardDetails"
        enabled="{= ${viewModel>/isEditMode} === true ? false : true}"
    />
    <Button
        text="{i18n>visit}"
        press="onDownloadVisitCard"
        enabled="{= ${viewModel>/isEditMode} === true ? false : true}"
        type="Attention"
        tooltip="{i18n>visit}"
        visible="{= !${viewModel>/TraineeRole} }"
    />
    <Button
        text="{i18n>resignationletter}"
        press="onApplyResignation"
        type="Reject"
        tooltip="{i18n>resignationletter}"
        visible="{viewModel>/ResignationVisible}"
    />
    <Button
        text="{i18n>terminateLetter}"
        type="Reject"
        visible="{viewModel>/Letter}"
        tooltip="{i18n>terminateLetter}"
        id="SS_idTermination"
        press="SS_onDownloadTerminateLetter"
        enabled="{= ${viewModel>/isEditMode} === true ? false : true}"
    />
    <Button
        text="{i18n>relievingletter}"
        type="Accept"
        visible="{viewModel>/Letter}"
        tooltip="{i18n>relievingletter}"
        id="SS_idExperience"
        press="SS_onDownloadExperienceLetter"
        enabled="{= ${viewModel>/isEditMode} === true ? false : true}"
    />
    <Button
        text="{i18n>workCertificate}"
        type="Success"
        visible="{viewModel>/Letter}"
        tooltip="{i18n>workCertificate}"
        id="SS_idWorkBtn"
        press="SS_onDownloadRelLetter"
        enabled="{= ${viewModel>/isEditMode} === true ? false : true}"
    />
    <Button
        text="{i18n>salaryCertificate}"
        type="Ghost"
        visible="{viewModel>/Letter}"
        tooltip="{i18n>salaryCertificate}"
        id="SS_idSalarybtn"
        press="SS_onDownloadSalLetter"
        enabled="{= ${viewModel>/isEditMode} === true ? false : true}"
    />
</ActionSheet>
