<c:FragmentDefinition
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified"
	xmlns:mvc="sap.ui.core.mvc">
	<Dialog id="HF_id_HostelFeaturesDialog"  type="Message" class="sapUiContentPadding"    contentWidth="28rem"
    contentHeight="auto" resizable="true" draggable="true">
		<customHeader>
			<Bar class="barheader">
				<contentMiddle>
					<Title text="{i18n>hostelFeatures}" />
				</contentMiddle>
			</Bar>
		</customHeader>
		<f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1">
			<f:content>
				<!-- Branch Code -->
				<Label text="{i18n>MSbranchCode}" required="true"/>
				<ComboBox id="HFF_id_BranchCode" placeholder="Select property name" 
				selectedKey="{HostelFeaturesModel>/BranchCode}" items="{BranchModel>/}" showSecondaryValues="true" change=".onHostelbranchChange"
                valueStateText="Select property name">
					<core:ListItem key="{BranchModel>BranchID}" text="{BranchModel>BranchID} - {BranchModel>Name}"
                    additionalText="{BranchModel>City}"/>
				</ComboBox>
				<!-- Amenity Name -->
				<Label text="{i18n>amenitiesName}" required="true"/>
				<Input id="HFF_id_FacilityName" value="{HostelFeaturesModel>/FacilityName}"
                placeholder="{i18n>enterAmenitiesName}" maxLength="60" liveChange=".onFacilityNameChange" valueStateText="{i18n>enterAmenitiesName}"/>
                <!-- Amenity TYpe -->
				<Label text="{i18n>type}" required="true"/>
				<ComboBox id="HFF_id_Amenities" items="{AmenityNameModel>/}" value="{HostelFeaturesModel>/Type}"
                placeholder="{i18n>enterType}" valueStateText="{i18n>enterType}" change="onAmenitieTypeChange">
					<core:Item key="{AmenityNameModel>ID}" text="{AmenityNameModel>AmenitiName}"/>
				</ComboBox>
				<!-- Description -->
				<Label text="{i18n>description}" required="true"/>
				<TextArea id="HFF_id_Description" value="{HostelFeaturesModel>/Description}"
                placeholder="{i18n>enterDescription}" liveChange="onNameInputLiveChange"
                change="onNameInputLiveChange" valueStateText="{i18n>enterDescription}"
                maxLength="150"/>
				<!-- Upload -->
				<Label text="{i18n>addImage}" />
				<VBox alignItems="Start" width="100%" renderType="Bare">
					<HBox width="25%">
						<u:FileUploader
                            id="HFF_id_FileUploader"
                            fileType="jpg,jpeg,png"
                            change="onFacilityFileChange"
                            buttonOnly="true"
                            sameFilenameAllowed="true"
                            iconFirst="true"
                            buttonText="Upload Images"
                            multiple="true"
                            uploadOnChange="false"
                            tooltip="{i18n>allowedSize}"/>
					</HBox>
					<!-- Tokenizer -->
					<HBox width="75%">
						<ScrollContainer height="60px" width="100%" horizontal="false" vertical="true">
							<Tokenizer id="HFF_id_TokenList" width="100%" tokenDelete="onTokenDelete"
                            tokens="{tokenModel>/tokens}">
								<Token key="{tokenModel>key}" text="{tokenModel>text}"/>
							</Tokenizer>
						</ScrollContainer>
					</HBox>
				</VBox>
			</f:content>
		</f:SimpleForm>
		<footer>
			<Toolbar>
				<ToolbarSpacer />
				<Button text="{i18n>save}" tooltip="{i18n>save}" press="HF_onsavebuttonpress"
                id="HFF_id_saveButton" class="marginRight myUnifiedBtn"/>
				<Button text="{i18n>CancelButton}" tooltip="{i18n>CancelButton}" press="HF_onCancelButtonPress"
                id="HFF_id_CancelButton" class="marginRight myUnifiedBtn"/>
			</Toolbar>
		</footer>
	</Dialog>
</c:FragmentDefinition>