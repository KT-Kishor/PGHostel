<c:FragmentDefinition
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified"
	xmlns:mvc="sap.ui.core.mvc">
	<Dialog id="HF_id_HostelFeaturesDialog" title="{i18n>hostelFeatures}" type="Message" class="sapUiContentPadding"
    resizable="true" draggable="true">
		<f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1">
			<f:content>
				<!-- Branch Code -->
				<Label text="{i18n>MSbranchCode}" required="true"/>
				<ComboBox id="HFF_id_BranchCode" placeholder="{i18n>placeSelectBranchCode}" selectedKey="{HostelFeaturesModel>/BranchCode}" items="{BranchModel>/}" showSecondaryValues="true" change=".onHostelbranchChange"
                valueStateText="{i18n>selectBranchCode}">
					<core:ListItem key="{BranchModel>BranchID}" text="{BranchModel>BranchID}" additionalText="{BranchModel>Name}"/>
				</ComboBox>
				<!-- Facility Name -->
				<Label text="{i18n>facilityname}" required="true"/>
				<Input id="HFF_id_FacilityName" value="{HostelFeaturesModel>/FacilityName}"
                placeholder="{i18n>placeEnterFacilityName}" maxLength="60" liveChange=".onFacilityNameChange" valueStateText="{i18n>enterFacilityName}"/>
				<!-- Description -->
				<Label text="{i18n>description}" required="true"/>
				<TextArea id="HFF_id_Description" value="{HostelFeaturesModel>/Description}"
                placeholder="{i18n>enterDescription}" liveChange="onNameInputLiveChange" valueStateText="{i18n>enterDescription}"
                maxLength="150"/>
				<!-- Upload -->
				<Label text="{i18n>addImage}" required="true"/>
				<VBox alignItems="Start" width="100%" renderType="Bare">
					<HBox width="25%">
						<u:FileUploader
                            id="HFF_id_FileUploader"
                            fileSizeExceed="onFileSizeExceeds"
                            maximumFileSize="5MB"
                            typeMissmatch="onFileTypeMissmatch"
                            fileType="jpg,jpeg,png"
                            change="onFacilityFileChange"
                            buttonOnly="true"
                            sameFilenameAllowed="true"
                            iconFirst="true"
                            buttonText="Upload Images"
                            multiple="true"
                            uploadOnChange="false"
                            tooltip="{i18n>allowedSize}"/>
					</HBox>
					<!-- Tokenizer -->
					<HBox width="75%">
						<ScrollContainer height="60px" width="100%" horizontal="false" vertical="true">
							<Tokenizer id="HFF_id_TokenList" width="100%" tokenDelete="onTokenDelete"
                            tokens="{tokenModel>/tokens}">
								<Token key="{tokenModel>key}" text="{tokenModel>text}"/>
							</Tokenizer>
						</ScrollContainer>
					</HBox>
				</VBox>
			</f:content>
		</f:SimpleForm>
		<footer>
			<Toolbar>
				<ToolbarSpacer />
				<Button text="{i18n>save}" tooltip="{i18n>save}" press="HF_onsavebuttonpress"
                id="HFF_id_saveButton" class="marginRight myUnifiedBtn"/>
				<Button text="{i18n>CancelButton}" tooltip="{i18n>CancelButton}" press="HF_onCancelButtonPress"
                id="HFF_id_CancelButton" class="marginRight myUnifiedBtn"/>
			</Toolbar>
		</footer>
	</Dialog>
</c:FragmentDefinition>