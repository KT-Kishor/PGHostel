<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>
    <Dialog
        id="rejectRoomDialog"
        afterClose=".onRejectDialogClose"
        contentWidth="28rem"
        contentHeight="auto"
    >
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title text="Manage Booking" />
                </contentMiddle>
            </Bar>
        </customHeader>
        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="4"
            labelSpanL="3"
            labelSpanM="4"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <f:content>
                <!-- Facility Name -->
                  <Label text="Reason for Rejection" required="true"/>

        <TextArea
            id="idRejectReason"
            placeholder="Enter rejection reason..."
            rows="4"
            width="100%"
            liveChange="onRejectReasonChange"
            maxLength="200"
            valueStateText="Rejection reason is required"
        />
              

            </f:content>
        </f:SimpleForm>
        <beginButton>
            <Button
                text="{i18n>save}"
                tooltip="{i18n>save}"
                press=".onRejectSave"
                class="myUnifiedBtn"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>CancelButton}"
                tooltip="{i18n>CancelButton}"
                press=".onRejectCancel"
                class="myUnifiedBtn"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>