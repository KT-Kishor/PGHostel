<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        title="{i18n>TableColSkills}"
        contentWidth="30%">
        <content>
            <Text text="{DataTableModel>Skills}" class="sapUiSmallMargin"/>
        </content>
        <beginButton>
            <Button
                text="{i18n>close}"
                type="Reject"
                press="onCloseSkillsDialog"/>
        </beginButton>
    </Dialog>
</core:FragmentDefinition>