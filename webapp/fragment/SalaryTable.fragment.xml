<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:filterbar="sap.ui.comp.filterbar"
    xmlns:u="sap.ui.unified"
>
    <filterbar:FilterBar
        useToolbar="false"
        showClearOnFB="false"
        showGoOnFB="false"
        showFilterConfiguration="false"
        class="sapUiTinyMargin"
    >
        <filterbar:filterGroupItems>
            <filterbar:FilterGroupItem
                name="Branch"
                label="{i18n>branch} "
                groupName="Group1"
                visibleInFilterBar="true"
            >
                <filterbar:control>
                    <ComboBox
                        showClearIcon="true"
                        id="FST_id_FilterBranch"
                        name="Branch"
                        items="{
                                path: 'Payroll>/BaseLocationData',
                                length: 1000
                            }"
                        change=".FST_onEnableImport"
                    >
                        <core:Item
                            key="{Payroll>City}"
                            text="{Payroll>City}"
                        />
                    </ComboBox>
                </filterbar:control>
            </filterbar:FilterGroupItem>
            <filterbar:FilterGroupItem
                name="monthYearPicker"
                label="{i18n>monthAndYear} "
                groupName="Group1"
                visibleInFilterBar="true"
            >
                <filterbar:control>
                    <DatePicker
                        id="FST_id_MonthYearPicker"
                        value="{
                                path: '',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: {
                                    pattern: 'MM-yyyy'
                                }
                            }"
                        displayFormat="MM-yyyy"
                        placeholder="MM-yyyy"
                        change=".FST_onEnableImport"
                    />
                </filterbar:control>
            </filterbar:FilterGroupItem>
            <filterbar:FilterGroupItem
                name="uploadBtn"
                label=""
                groupName="Group1"
                visibleInFilterBar="{Payroll>/ShowOnGenerate}"
            >
                <filterbar:control>
                    <u:FileUploader
                        class="salUploadBtn"
                        id="FST_id_ImportBtn"
                        buttonText="{i18n>import}"
                        sameFilenameAllowed="true"
                        buttonOnly="true"
                        fileType="XLSX,xlsx,XLS,xls"
                        style="Emphasized"
                        icon="sap-icon://sys-next-page"
                        change="FST_onUpload"
                    />
                </filterbar:control>
            </filterbar:FilterGroupItem>
            <filterbar:FilterGroupItem
                name="goBtn"
                label=""
                groupName="Group1"
                visibleInFilterBar="{Payroll>/ShowOnPayroll}"
            >
                <filterbar:control>
                    <Button
                        id="MP_id_GoBtn"
                        class="salUploadBtn"
                        type="Emphasized"
                        text="Go"
                        press="MP_onPressGo"
                    />
                </filterbar:control>
            </filterbar:FilterGroupItem>
        </filterbar:filterGroupItems>
    </filterbar:FilterBar>
    <ScrollContainer
        height="100%"
        width="100%"
        vertical="true"
        focusable="true"
    >
