

<core:FragmentDefinition
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core" >
	<!-- Dialog container for Employee Details -->
	<Dialog 
        title="{i18n>generateCertificate}">
		<!-- SimpleForm with ResponsiveGridLayout -->
		<f:SimpleForm 
			editable="false"
			layout="ResponsiveGridLayout"
			labelSpanXL="3"
			labelSpanL="3"
			labelSpanM="3"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="4"
			emptySpanL="4"
			emptySpanM="4"
			emptySpanS="0"
			columnsXL="1"
			columnsL="1"
			columnsM="1"
			singleContainerFullSize="false" >
			<f:content>
				<Label text="{i18n>traineeName}"  />
				<Input value="{oTraineeDetailsModel>/NameSalutation} {oTraineeDetailsModel>/Name}"  editable="false"/>
				<Label text="{i18n>reportingManager}" />
				<Input value="{oTraineeDetailsModel>/ReportingManagerSalutation} {oTraineeDetailsModel>/ReportingManager}"   editable="false"/>
				<Label text="{i18n>role}" required="true" />
				<Select id="idRoleSelect"  items="{DesignationModel>/results}" selectedKey="{oTraineeDetailsModel>/Role}">
					<core:Item key="{DesignationModel>DesignationName}" text="{DesignationModel>DesignationName}"/>
				</Select>
				<Label text="{i18n>joiningDate}"  />
				<DatePicker 
    value="{oTraineeDetailsModel>/JoiningDate}" 
    displayFormat="dd/MM/yyyy" 
    valueFormat="dd/MM/yyyy"
    editable="false" 
    id="TCF_id_JoiningDate" />
				<Label text="{i18n>endDate}" required="true"/>
				<DatePicker   displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy"
    id="TCF_id_EndDate"
	 minDate="{= ${oTraineeDetailsModel>/EndDate} }" />
				<Label text="{i18n>department}"  required="true" />
				<Select id="TCF_id_Department"  items="{DepartmentModel>/results}" selectedKey="{oTraineeDetailsModel>/Department}">
					<core:Item key="{DepartmentModel>DepartmentName}" text="{DepartmentModel>DepartmentName}"/>
				</Select>
				<Label text="{i18n>projectName}"  required="true" />
				<TextArea id="TCF_id_ProjectName" rows="2" liveChange="ValidateCommonFields" value="{oTraineeDetailsModel>/ProjectName}" maxLength="100" />
			</f:content>
		</f:SimpleForm>
		<HBox justifyContent="End" >
			<Button text="{i18n>downloadcCertificate}" type="Accept" press="TCF_onPressDownload" class="submit"  />
			<Button text="{i18n>close}" press="TCF_onPressCloseDialog" class="sendMail" type="Reject"/>
		</HBox>
	</Dialog>
</core:FragmentDefinition>
