<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core" >
	<Dialog 
        title="{i18n>generateCertificate}">
		<f:SimpleForm 
			editable="true"
			layout="ResponsiveGridLayout"
			labelSpanXL="3"
			labelSpanL="3"
			labelSpanM="3"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="4"
			emptySpanL="4"
			emptySpanM="4"
			emptySpanS="0"
			columnsXL="1"
			columnsL="1"
			columnsM="1"
			singleContainerFullSize="false" >
			<f:content>
				<Label text="{i18n>traineeName}"  />
				<Input value="{traineeModel>NameSalutation} {traineeModel>TraineeName}"  editable="false"/>
				<Label text="{i18n>reportingManager}" />
				<Input value="{traineeModel>ReportingManagerSalutation} {traineeModel>ReportingManager}"   editable="false"/>
				<Label text="{i18n>role}" required="true" />
				<Select id="TCF_id_Role"  items="{DesignationModel>/}" selectedKey="{traineeModel>Role}">
					<core:Item key="{DesignationModel>designationName}" text="{DesignationModel>designationName}" additionalText="{DesignationModel>department}"/>
				</Select>
				<Label text="{i18n>joiningDate}"  />
				<DatePicker value="{path:'traineeModel>JoiningDate' ,formatter:'.Formatter.formatDate'}"
                 displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy" editable="false"  id="TCF_id_JoiningDate" />
				<Label text="{i18n>endDate}" required="true"/>
				<DatePicker   displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy"  id="TCF_id_EndDate" value="{path:'traineeModel>EndDate' ,formatter:'.Formatter.formatDate'}"   />
				<Label text="{i18n>department}"  required="true" />
				<Select id="TCF_id_Department"  items="{Departmentmodel>/}" selectedKey="{traineeModel>Department}">
					<core:Item key="{Departmentmodel>departmentName}" text="{Departmentmodel>departmentName}"/>
				</Select>
				<Label text="{i18n>projectName}"  required="true" />
				<TextArea id="TCF_id_ProjectName" rows="2" liveChange="T_ValidateCommonFields" value="{traineeModel>ProjectName}" maxLength="100" valueStateText="{i18n>projectValueState}" />
			</f:content>
		</f:SimpleForm>
		<HBox justifyContent="End" >
			<Button text="{i18n>downloadcCertificate}" type="Accept" press="TCF_onPressDownload" class="submit"  />
			<Button text="{i18n>close}" press="TCF_onPressCloseDialog" class="sendMail" type="Reject"/>
		</HBox>
	</Dialog>
</core:FragmentDefinition>
