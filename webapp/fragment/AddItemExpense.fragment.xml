<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core">
	<Dialog
        title="{i18n>addItemExpense}">		
		<VBox>
			<f:SimpleForm          
            editable="true"
			layout="ResponsiveGridLayout"
			labelSpanXL="4"
			labelSpanL="3"
			labelSpanM="4"
			labelSpanS="12"
			emptySpanXL="0"
			emptySpanL="4"
			emptySpanM="0"
			emptySpanS="0"
			columnsXL="2"
			columnsL="1"
			columnsM="1">
				<f:content>					
					<Label text="{i18n>itemID}"/>
					<Input value="{ExpenseCreateModel>/IndexNo}" editable="false" />
					<!-- Item Type -->
					<Label text="{i18n>expDetItemType}" required="true"/>
					<Select  items="{ItemTypeModel>/results}" change="onItemTypeChange"  selectedKey="{ExpenseCreateModel>/ItemType}">
						<core:Item key="{ItemTypeModel>ItemName}" text="{ItemTypeModel>ItemName}" />
					</Select>
					<!-- Mode Of Payment -->
					<Label text="{i18n>expModeOfPayment}" required="true"/>
					<Select  items="{paymentModeModel>/results}" selectedKey="{ExpenseCreateModel>/ModeOfPayment}" enabled="{EnableModel>/enable}">
						<core:Item key="{paymentModeModel>Code}" text="{paymentModeModel>Code}" />
					</Select>
					<!-- Expense Date -->
					<Label text="{i18n>expDetExpenseDate}" required="true" />
					<DatePicker minDate="{FilteredExpenseModel>/MinDate}" id="exp-id-ExpenseDate"  maxDate="{FilteredExpenseModel>/MaxDate}" displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy" value="{ExpenseCreateModel>/ExpenseDate}"  />
					<!-- Expense Amount -->
					<Label text="{i18n>expDetExpenseAmount}" required="true"/>
					<HBox width="100%">
						<VBox width="70%">
							<Input id="idExpAmount" valueState="None" value="{ExpenseCreateModel>/ExpenseAmount}" liveChange="onLiveValidationItem" placeholder="{i18n>placeAmount}" enabled="{EnableModel>/enable}" maxLength="15"/>
						</VBox>
						<VBox width="30%">
							<Select items="{currencyModel>/results}" change="onChangeCurrency" selectedKey="{ExpenseCreateModel>/Currency}"  id="idCurrency" enabled="{EnableModel>/enable}">
								<core:Item key="{currencyModel>Currency}" text="{currencyModel>Currency}" />
							</Select>
						</VBox>
					</HBox>
					<!-- Conversion Rate -->
					<Label text="{i18n>expConversionRate}" visible="{= ${ExpenseCreateModel>/Currency} !== 'INR' }"/>
					<Input id="idExpConversionRate" valueState="None" value="{ExpenseCreateModel>/ConversionRate}" liveChange="onLiveValidationItem" placeholder="{i18n>expenseConversionRatePlaceholder}" visible="{= ${ExpenseCreateModel>/Currency} !== 'INR' }" maxLength="15 " change="onChangeConverstionRate"/>
					<!-- ForeignAmount Label -->
					<!-- <Label text="{i18n>expenseForeignAmount}" visible="{ExpenseCreateModel>/DisplayForeignAmount}" />					 -->
					<Label text="{i18n>comments}" required="true" ></Label>
					<TextArea id="idExpItemComments"  liveChange="onLiveValidationItem" value="{ExpenseCreateModel>/Comments}" maxLength="120" rows="2" placeholder="{i18n>enterComments}" />
				</f:content>
			</f:SimpleForm>
		</VBox>
		<footer>
    <Toolbar>
        <ToolbarSpacer /> <!-- This pushes the buttons to the right -->
        <Button text="{i18n>submit}" type="Emphasized" press="onPressSubmit" visible="{viewModel>/SubmitBtn}" />
        <Button text="{i18n>save}" type="Emphasized" press="onPressSaveExpense" visible="{viewModel>/SaveBtn}" />
        <Button text="{i18n>close}" class="spaceBetween sendMail" press="onPressClose" />
    </Toolbar>
</footer>

	</Dialog>
</core:FragmentDefinition>