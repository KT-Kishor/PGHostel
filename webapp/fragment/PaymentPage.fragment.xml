<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    displayBlock="true"
    xmlns:g="sap.f"
>
    <Dialog
        id="idPaymentDialog"
        draggable="true"
        resizable="true"
        class="paymentDialogRoot"
        contentWidth="32rem"
        contentHeight="auto"
    >
        <customHeader>
            <Bar class="barheader">
                    <contentMiddle>
                <Title text="{i18n>proceedtoPayment}" />
            </contentMiddle>
              
            </Bar>
        </customHeader>
        
        <f:SimpleForm
            id="Exp_id_SimpleFrom"
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="12"
            labelSpanL="12"
            labelSpanM="12"
            labelSpanS="12"
            columnsXL="2"
            columnsL="2"
            columnsM="1"
        >
            <VBox>
                <!-- ===== GRAND TOTAL ===== -->
                <HBox>
                    <Label
                        text="{i18n>grandTotal}"
                        class="sapUiTinyMargin"
                    />
                    <Text
                        text="{parts: ['HostelModel>/FinalTotalCost','HostelModel>/Currency'],formatter: '.Formatter.formatCurrency'}"
                    />
                </HBox>

                <!-- ===== PAYMENT TYPE (Radio) ===== -->
                <Label
                    text="{i18n>paymentType}"
                    design="Bold"
                />
                <RadioButtonGroup
                    id="idPaymentTypeGroup"
                    columns="2"
                    select="onPaymentTypeSelect"
                    selectedIndex="0"
                    class="paymentTypeGroup"
                >
                    <RadioButton text="{i18n>uPI}" />
                    <RadioButton text="{i18n>creditDebitCard}" />
                    <RadioButton text="{i18n>payatcheckintime}" />
                </RadioButtonGroup>

                <!-- MAIN GRID -->
                <l:Grid
                    defaultSpan="L6 M12 S12"
                    hSpacing="2"
                    vSpacing="2"
                >
                    <!-- LEFT COLUMN -->
                    <VBox
                        id="idLeftColumn"
                        class="sapUiSmallMargin"
                    >
                        <!-- UPI SECTION -->
                        <VBox
                            id="idUPISection"
                            visible="true"
                        >
                            <Title
                                text="{i18n>uPIPayment}"
                                level="H4"
                            />
                            <Image
                                src="image/UPI.jpg"
                                width="150px"
                                class="UPIQRCodeBox"
                            />
                            <Text text="{i18n>scanusinganyUPIapp}" />

                          
                        </VBox>

                        <!-- CARD SECTION -->
                        <VBox
                            id="idCardSection"
                            visible="false"
                        >
                            <Label text="{i18n>cardNumber}" />
                            <Input
                                id="idCardNumber"
                                maxLength="16"
                                placeholder="{i18n>enterCardNumber}"
                            />

                            <Label text="{i18n>expiry}" />
                            <Input
                                id="idCardExpiry"
                                maxLength="5"
                                placeholder="MM/YY"
                            />

                            <Label text="{i18n>cVV}" />
                            <Input
                                id="idCardCVV"
                                type="Password"
                                maxLength="3"
                                placeholder="***"
                            />
                        </VBox>
                    </VBox>

                    <!-- RIGHT COLUMN -->
                    <VBox
                        id="idRightPanel"
                        class="sapUiSmallMargin"
                    >
                        <Title
                            text="{i18n>paymentVerification}"
                            level="H4"
                        />


                        <Label
                            text="{i18n>monthlyamount}"
                            required="true"
                        />
                        <Input
                            id="idAmount"
                            type="Number"
                            value="{PaymentModel>/Amount}"
                            placeholder="{i18n>enterAmount}"
                            liveChange=".onAmountChange"
                            maxLength="15"
                        />


                        <Label
                            text="{i18n>paymentType}"
                            required="true"
                        />
                        <Input
                            id="idPaymentTypeField"
                            placeholder="{i18n>enterPaymentType}"
                            liveChange=".onPaymentTypeChange"
                            value="{PaymentModel>/PaymentType}"
                            valueStateText="{i18n>enterPaymentType}"
                            maxLength="20"
                        />

                        <Label
                            text="{i18n>bankTransactionID}"
                            required="true"
                        />
                        <Input
                            id="idTransactionID"
                            placeholder="{i18n>enterTransactionID}"
                            liveChange=".onTransactionIDChange"
                            valueStateText="{i18n>enterTransactionID}"
                            maxLength="25"
                        />

                        <Label
                            text="{i18n>date}"
                        />
                        <DatePicker
                            id="idPaymentDate"
                            displayFormat="dd/MM/yyyy"
                            valueFormat="dd/MM/yyyy"
                            value="{PaymentModel>/PaymentDate}"
                            change=".onPaymentDateChange"
                            valueStateText="{i18n>selectPaymentDate}"
                            editable="false"
                        />
                    </VBox>
                </l:Grid>
            </VBox>
           <HBox>
                   <Label
    text="{
        path: 'HostelModel>/SelectedPerson',
        formatter: '.Formatter.formatMonthlyPaymentText'
    }"
    class="sapUiTinyMargin"
/>


                    <Text
                        text="{parts: ['HostelModel>/PerMonthNoPerson','HostelModel>/Currency'],formatter: '.Formatter.formatCurrency'}"
                    />
                </HBox>
        </f:SimpleForm>
       
        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Button
                    text="{i18n>submitPayment}"
                    tooltip="{i18n>submitPayment}"
                    class="myUnifiedBtn"
                    press=".onSubmitPress"
                />
                <Button
                    text="{i18n>CancelButton}"
                    tooltip="{i18n>CancelButton}"
                    press=".onPaymentClose"
                    class="myUnifiedBtn"
                />
            </Toolbar>
        </footer>
    </Dialog>
</core:FragmentDefinition>