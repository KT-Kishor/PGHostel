<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:rich="sap.ui.richtexteditor"
>
    <Dialog
        title="{i18n>applyResign}"
        contentWidth="85%"
        contentHeight="75%"
    >
        <f:SimpleForm
            editable="true"
            layout="ColumnLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="0"
            emptySpanL="0"
            emptySpanM="0"
            emptySpanS="0"
            columnsXL="4"
            columnsL="4"
            columnsM="2"
            singleContainerFullSize="false"
        >
            <f:content>
                <Label text="{i18n>employeeName}" />
                <Input
                    id="RF_id_TraineeName"
                    value="{sEmployeeModel>/0/Salutation} {sEmployeeModel>/0/EmployeeName}"
                    editable="false"
                />
                <Label text="{i18n>joiningDate}" />
                <DatePicker
                    value="{path:'sEmployeeModel>/0/JoiningDate' ,formatter:'.Formatter.formatDate'}"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="dd/MM/yyyy"
					editable="false"
                    id="RF_id_JoiningDate"
                />
                <Label
                    text="{i18n>designation}"
                    required="true"
                />
                <Input
                    id="RF_id_Designation"
                    value="{sEmployeeModel>/0/Designation}"
					editable="false"
                />
                <Label text="{i18n>startDate}" />
                <DatePicker
                value="{sEmployeeModel>/0/ResignationStartDate}"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="dd/MM/yyyy"
                    id="RF_id_StartDate"
                />
                <Label text="{i18n>reportingManager}" />
                <Input
                    value="{sEmployeeModel>/0/ManagerName}"
                    editable="false"
                    id="RF_id_ReportingManager"
                />
                <Label
                    text="{i18n>endDate}"
                    required="true"
                />
                <DatePicker
                    displayFormat="dd/MM/yyyy"
                    valueFormat="dd/MM/yyyy"
                    id="RF_id_EndDate"
                    value="{path:'sEmployeeModel>/0/ResignationEndDate' ,formatter:'.Formatter.formatDate'}"
                />
                <Label
                    text="{i18n>reasonForResign}"
                    required="true"
                />
                <TextArea
                    rows="4"
                    id="RF_id_ResignReason"
                    liveChange="T_ValidateCommonFields"
                    value="{sEmployeeModel>/0/ResignComment}"
                    maxLength="60"
                    valueStateText="{i18n>projectValueState}"
                    placeholder="{i18n>projectValueState}"
                />
            </f:content>
        </f:SimpleForm>
        <rich:RichTextEditor
            id="myRTE"
            width="100%"
            height="70vh"
            showGroupFontStyle="true"
            showGroupTextAlign="true"
            showGroupStructure="true"
            value="{PDFData>/RTEText}"
			visible="true"
        />
        <beginButton>
            <Button
                text="{= ${PDFData>/PreviewFlag} ? ${i18n>downloadcCertificate} : ${i18n>preview} }"
                type="{= ${PDFData>/PreviewFlag} ? 'Accept' : 'Emphasized' }"
                press="TCF_onPressHandlePreview"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>close}"
                press="TCF_onPressCloseDialog"
                type="Reject"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
