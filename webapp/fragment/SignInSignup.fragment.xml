<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
>
    <Dialog
        id="authDialog"
        initialFocus="initialfocus"
        draggable="true"
        resizable="true"
        class="authDialog"
        contentWidth="28rem"
        contentHeight="auto"
    >
        <!--stretch="{= ${device>/system/phone} }"-->
        <customHeader>
            <Bar class="barheader">
                <contentMiddle>
                    <Title text="{LoginViewModel>/dialogTitle}" />
                </contentMiddle>
                <contentRight>
                    <Button
                        type="Transparent"
                        icon="sap-icon://decline"
                        tooltip="{i18n>close}"
                        press="onDialogClose"
                    />
                </contentRight>
            </Bar>
        </customHeader>
        <VBox>
            <!-- Switch Button -->
            <HBox
                id="initialfocus"
                justifyContent="Start"
                class="switch-toggle-container"
                visible="{= ${LoginViewModel>/authFlow} === 'signin' || ${LoginViewModel>/authFlow} === 'signup' }"
            >
                <Button
                    text="{i18n>CapsIGNIN}"
					tooltip="{i18n>CapsIGNIN}"
                    id="signinvisible"
                    type="Transparent"
                    class="switch-toggle-btn {= ${LoginViewModel>/authFlow} === 'signin' ? 'active' : 'inactive'} "
                    press="onSwitchToSignIn"
                    visible="{= ${LoginViewModel>/authFlow} !== 'signin' }"
                />
                <Button
                    id="signupvisible"
                    text="{i18n>CapsIGNUP}"
					tooltip="{i18n>CapsIGNUP}"
                    type="Transparent"
                    class="switch-toggle-btn {= ${LoginViewModel>/authFlow} === 'signup' ? 'active' : 'inactive'} "
                    press="onSwitchToSignUp"
                    visible="{= ${LoginViewModel>/authFlow} !== 'signup' }"
                />
            </HBox>
            <!-- Sign In Panel -->
            <Panel
                width="100%"
                id="signInPanel"
                expandable="false"
                visible="{= ${LoginViewModel>/authFlow} === 'signin' }"
            >
                <f:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                    labelSpanL="12"
                    labelSpanM="12"
                    emptySpanL="0"
                    emptySpanM="0"
                    columnsL="1"
                    columnsM="1"
                >
                    <Label
                        text="{i18n>MVUserID}"
                        required="true"
                    />
                    <Input
                        id="signInuserid"
                        placeholder="{i18n>MVUserID}"
                        valueLiveUpdate="true"
                        liveChange="onUserlivechange"
                        valueStateText="{i18n>pleaseentervalidUserID}"
                        maxLength="6"
                    />
                    <Label
                        text="{i18n>MVusername}"
                        required="true"
                    />
                    <Input
                        id="signInusername"
                        placeholder="{i18n>MVusername}"
                        valueLiveUpdate="true"
                        liveChange="onUserlivechange"
                        valueStateText="{i18n>pleaseenteravalidUserName}"
                        maxLength="40"
                    />
                    <Label text="{i18n>loginwith}" />
                    <HBox
                        class="aleftMargin"
                        alignItems="End"
                        justifyContent="Start"
                    >
                        <RadioButton
                            text="{i18n>password}"
                            groupName="loginType"
                            selected="{= ${LoginViewModel>/loginMode} === 'password' }"
                            select="onSelectLoginMode"
                        />
                        <RadioButton
                            text="{i18n>otp}"
                            groupName="loginType"
                            selected="{= ${LoginViewModel>/loginMode} === 'otp' }"
                            select="onSelectLoginMode"
                        />
                        <!-- <Button id="btnSignInSendOTP" text="Send OTP" visible="{= ${LoginViewModel>/loginMode} === 'otp' }" press="onPressOTP"/> -->
                        <Button
                            id="btnSignInSendOTP"
                            text="{LoginViewModel>/otpButtonText}"
                            enabled="{LoginViewModel>/canResendOTP}"
                            visible="{= ${LoginViewModel>/loginMode} === 'otp' }"
                            press="onPressOTP"
                        />
                    </HBox>
                    <!-- PASSWORD SECTION -->
                    <Label
                        text="{i18n>password}"
                        required="true"
                        visible="{= ${LoginViewModel>/loginMode} === 'password' }"
                    />
                    <Input
                        id="signinPassword"
                        placeholder="{i18n>enterPassword}"
                        visible="{= ${LoginViewModel>/loginMode} === 'password' }"
                        submit="onSignIn"
                        type="Password"
                        showValueHelp="true"
                        valueHelpIconSrc="sap-icon://show"
                        valueHelpRequest="SM_onTogglePasswordVisibility"
                        liveChange="onSigninPasswordLive"
                        valueStateText="{i18n>pleaseEntervalidPassword}"
                        maxLength="40"
                    />
                    <!-- REUSED OTP FIELD FOR LOGIN -->
                    <VBox
                        id="signInOTPBox"
                        visible="{LoginViewModel>/showOTPField}"
                    >
                        <Label
                            text="{i18n>enterOTP}"
                            required="true"
                        />
                        <Input
                            id="signInOTP"
                            placeholder="{i18n>enterOTP}"
                            liveChange="onLoginOtpLive"
                            maxLength="6"
                            type="Text"
                        />
                    </VBox>
                </f:SimpleForm>
                <HBox
                    justifyContent="SpaceBetween"
                    class="sapUiSmallMargin"
                >
                    <Button
                        text="{i18n>setForgotPassword}"
						tooltip="{i18n>setForgotPassword}"
                        type="Transparent"
                        press="onForgotPassword"
                    />
                    <Button
                        class="myUnifiedBtn"
                        text="{i18n>signIn}"
						tooltip="{i18n>signIn}"
                        width="100px"
                        enabled="true"
                        press="onSignIn"
                    />
                </HBox>
            </Panel>
            <!-- FORGOT FLOW IN ONE PANEL -->
            <Panel
                id="forgotFlowPanel"
                expandable="false"
                visible="{= ${LoginViewModel>/authFlow} === 'forgot' }"
            >
                <!-- <HBox justifyContent="Center" class="switch-toggle-container" /> -->
                <f:SimpleForm
                    id="forgotVBox"
                    editable="true"
                    layout="ResponsiveGridLayout"
                    labelSpanL="12"
                    labelSpanM="12"
                    emptySpanL="0"
                    emptySpanM="0"
                    columnsL="1"
                    columnsM="1"
                >
                    <!-- STEP 1: SEND OTP -->
                    <VBox
                        id="fpStepUser"
                        visible="{= ${LoginViewModel>/forgotStep} >= 1 }"
                    >
                        <Label
                            text="{i18n>enterUserID}"
                            required="true"
                        />
                        <Input
                            id="fpUserId"
                            placeholder="{i18n>yourUserID}"
                            liveChange="onUserlivechange"
                            valueStateText="{i18n>pleaseentervalidUserID}"
                            enabled="{= ${LoginViewModel>/forgotStep} === 1 }"
                            maxLength="6"
                        />
                        <Label
                            class="sapUiSmallMarginTop"
                            text="{i18n>enterUserName}"
                            required="true"
                        />
                        <Input
                            id="fpUserName"
                            placeholder="{i18n>registeredName}"
                            liveChange="onUserlivechange"
                            valueStateText="{i18n>pleaseenteravalidUserName}"
                            enabled="{= ${LoginViewModel>/forgotStep} === 1 }"
                            maxLength="40"
                        />
                        <HBox justifyContent="End">
                            <Button
                                id="btnFPNext"
                                text="{LoginViewModel>/otpButtonText}"
                                press="onValidateUser"
                                enabled="{= ${LoginViewModel>/forgotStep} &lt;= 2 &amp;&amp; ${LoginViewModel>/canResendOTP} }"
                                class="myUnifiedBtn sapUiSmallMarginTop"
                            />
                            <!-- <Button id="btnFPNext" text="Send OTP" press="onValidateUser" enabled="{= ${LoginViewModel>/forgotStep} &lt;= 2 }" class="myUnifiedBtn sapUiSmallMarginTop"/> -->
                        </HBox>
                    </VBox>
                    <!-- STEP 2: OTP -->
                    <VBox
                        id="fpStepOtp"
                        visible="{= ${LoginViewModel>/forgotStep} >= 2 }"
                    >
                        <Label
                            text="{i18n>enterOTP}"
                            required="true"
                        />
                        <Input
                            id="fpOTP"
                            placeholder="{i18n>enterOTP}"
                            liveChange="onOtpLive"
                            maxLength="6"
                            type="Text"
                            valueStateText="{i18n>pleaseenteravalidOTP}"
                            enabled="{= ${LoginViewModel>/forgotStep} === 2 }"
                        />
                        <HBox justifyContent="End">
                            <Button
                                id="btnOtpVerify"
                                text="{i18n>verifyOTP}"
								tooltip="{i18n>verifyOTP}"
                                press="_onVerifyOTP"
                                enabled="{= ${LoginViewModel>/forgotStep} === 2 }"
                                class="myUnifiedBtn sapUiSmallMarginTop"
                            />
                        </HBox>
                    </VBox>
                    <!-- STEP 3: RESET PASSWORD -->
                    <VBox
                        id="fpStepReset"
                        visible="{= ${LoginViewModel>/forgotStep} >= 3 }"
                    >
                        <Label
                            class="sapUiSmallMarginTop sapTinyMarginBottom"
                            text="{i18n>createnewpassword}"
                            design="Bold"
                        />
                        <MessageStrip
                            type="Information"
                            showIcon="false"
                            text="{i18n>msgStrip}"
                        />
                        <Label
                            text="{i18n>newPassword}"
                            required="true"
                            class="sapUiSmallMarginTop"
                        />
                        <Input
                            id="newPass"
                            showValueStateMessage="false"
                            type="Password"
                            showValueHelp="true"
                            valueHelpIconSrc="sap-icon://show"
                            liveChange="SM_onChnageSetAndConfirm"
                            maxLength="50"
                            valueHelpRequest=".SM_onTogglePasswordVisibility"
                            enabled="{= ${LoginViewModel>/forgotStep} === 3 }"

                        />
                        <HBox
                            width="100%"
                            justifyContent="SpaceBetween"
                        >
                            <Text
                                id="fpPasswordStrengthText"
                                class="pwdMinFail"
                            />
                            <Button
                                text="{i18n>MSgeneratePassword}"
								tooltip="{i18n>MSgeneratePassword}"
                                type="Transparent"
                                icon="sap-icon://refresh"
                                press="SM_onGenerateForgotPassword"
                            />
                        </HBox>
                        <Label
                            class="sapUiSmallMarginTop"
                            text="{i18n>MSconfirmPassword}"
                            required="true"
                        />
                        <Input
                            id="confPass"
                            type="Password"
                            change="Forget_onConfirm"
                            liveChange="Forget_onConfirm"
                            showValueHelp="true"
                            valueHelpIconSrc="sap-icon://show"
                            valueHelpRequest="SM_onTogglePasswordVisibility"
                            valueStateText="{i18n>MSenterConfirmPassword}"
                            maxLength="50"
                            enabled="{= ${LoginViewModel>/forgotStep} === 3 }"
                        />
                        <HBox justifyContent="End">
                            <Button
                                id="btnUpdatePass"
                                text="{i18n>updatePassword}"
                                press="onSubmitNewPassword"
                                enabled="{= ${LoginViewModel>/forgotStep} === 3 }"
                                class="myUnifiedBtn sapUiSmallMarginTop"
                            />
                        </HBox>
                    </VBox>
                    <HBox alignContent="Start">
                        <Button
                            text="{i18n>backtoLogin}"
							tooltip="{i18n>backtoLogin}"
                            type="Transparent"
                            press="onBackToLogin"
                        />
                    </HBox>
                </f:SimpleForm>
            </Panel>
            <!-- Sign Up Panel -->
            <Panel
                id="signUpPanel"
                visible="{= ${LoginViewModel>/authFlow} === 'signup' }"
            >
                <content>
                    <f:SimpleForm
                        id="signUpForm"
                        editable="true"
                        layout="ResponsiveGridLayout"
                        labelSpanL="3"
                        labelSpanM="3"
                        emptySpanL="1"
                        emptySpanM="1"
                        columnsL="2"
                        columnsM="1"
                        class="sapUiNoContentPadding"
                    >
                        <!-- <Label text=""/> -->
                        <HBox
                            width="100%"
                            alignItems="Center"
                            class="isdMobileRow"
                        >
                            <VBox width="25%">
                                <Label
                                    text="{i18n>MSsalutation}"
                                    required="true"
                                />
                                <ComboBox
                                    id="signUpSalutation"
                                    selectedKey=""
                                    change="onChangeSalutation"
                                    placeholder="{i18n>mr}"
                                    valueStateText="{i18n>MVDsalutation}"
                                >
                                    <core:ListItem
                                        key="Mr."
                                        text="Mr."
                                    />
                                    <core:ListItem
                                        key="Ms."
                                        text="Ms."
                                    />
                                    <core:ListItem
                                        key="Mrs."
                                        text="Mrs."
                                    />
                                    <core:ListItem
                                        key="Dr."
                                        text="Dr."
                                    />
                                    <layoutData>
                                        <FlexItemData
                                            baseSize="30%"
                                            growFactor="0"
                                        />
                                    </layoutData>
                                </ComboBox>
                            </VBox>
                            <VBox
                                width="75%"
                                class="sapUiTinyMarginBegin"
                            >
                                <Label
                                    text="{i18n>fullname}"
                                    required="true"
                                />
                                <Input
                                    id="signUpName"
                                    value="{LoginMode>/fullname}"
                                    placeholder="{i18n>enterFullName}"
                                    required="true"
                                    liveChange="_LCvalidateName"
                                    valueStateText="{i18n>MSenterValidName}"
                                    maxLength="50"
                                />
                                <layoutData>
                                    <FlexItemData
                                        baseSize="70%"
                                        growFactor="1"
                                    />
                                </layoutData>
                            </VBox>
                        </HBox>
                        <Label
                            text="{i18n>MVDDOB}"
                            required="true"
                        />
                        <DatePicker
                            id="signUpDOB"
                            value="{LoginMode>/DateOfBirth}"
                            displayFormat="dd/MM/yyyy"
                            valueFormat="yyyy-MM-dd"
                            change="onChangeDOB"
                        />
                        <Label
                            text="{i18n>MVgender}"
                            required="true"
                        />
                        <Select
                            id="signUpGender"
                            selectedKey=""
                            change="onChangeGender"
                        >
                            <core:Item
                                key=""
                                text="Select Gender"
                            />
                            <core:Item
                                key="Male"
                                text="Male"
                            />
                            <core:Item
                                key="Female"
                                text="Female"
                            />
                            <core:Item
                                key="Other"
                                text="Other"
                            />
                        </Select>
                        <!-- ================== 2) CONTACT DETAILS ================== -->
                        <Label
                            text="{i18n>email}"
                            required="true"
                            class="sapUiTinyMarginTop"
                        />
                        <Input
                            id="signUpEmail"
                            value="{LoginMode>/Email}"
                            placeholder="{i18n>enterEmailId}"
                            type="Email"
                            required="true"
                            liveChange="onEmailliveChange"
                            valueStateText="{i18n>MSenterValidEmail}"
                            maxLength="50"
                        />
                        <Label
                            text="{i18n>MVDcountry}"
                            required="true"
                        />
                        <ComboBox
                            id="signUpCountry"
                            change="onChangeCountry"
                            selectionChange="onChangeCountry"
                            placeholder="{i18n>selectCountry}"
                            valueStateText="{i18n>MVDselectcountry}"
                            items="{path:'CountryModel>/', length:1000}"
                            showSecondaryValues="true"
                        >
                            <core:ListItem
                                key="{CountryModel>countryName}"
                                text="{CountryModel>countryName}"
                                additionalText="{CountryModel>code}"
                            />
                        </ComboBox>
                        <Label
                            text="{i18n>MVDstate}"
                            required="true"
                        />
                        <ComboBox
                            id="signUpState"
                            change="onChangeState"
                            selectionChange="onChangeState"
                            placeholder="{i18n>selectState}"
                            valueStateText="{i18n>MSselectState}"
                            items="{path:'StateModel>/', length:1000}"
                            showSecondaryValues="true"
                        >
                            <core:ListItem
                                key="{StateModel>stateName}"
                                text="{StateModel>stateName}"
                            />
                        </ComboBox>
                        <Label
                            text="{i18n>city}"
                            required="true"
                        />
                        <ComboBox
                            selectionChange="onCitySelect"
                            id="signUpCity"
                            change="onChangeCity"
                            placeholder="{i18n>cityValueText}"
                            valueStateText="{i18n>MSselectCity}"
                            items="{path:'CityModel>/', length:1000}"
                            showSecondaryValues="true"
                        >
                            <core:ListItem
                                key="{CityModel>cityName}"
                                text="{CityModel>cityName}"
                                additionalText="{CityModel>branchCode}"
                            />
                        </ComboBox>
                        <Label text="" />
                        <HBox
                            width="100%"
                            alignItems="Center"
                            class="isdMobileRow"
                        >
                            <VBox width="25%">
                                <Label
                                    text="{i18n>MSisdCode}"
                                    required="true"
                                />
                                <ComboBox
                                    change="onSTDChange"
                                    id="signUpSTD"
                                    placeholder="+91"
                                    valueStateText="{i18n>MSselectCode}"
                                    showSecondaryValues="true"
                                    items="{path:'CountryModel>/', length:1000}"
                                    filterSecondaryValues="true"
                                >
                                    <core:ListItem
                                        key="{CountryModel>stdCode}"
                                        text="{CountryModel>stdCode}"
                                        additionalText="{CountryModel>code}"
                                    />
                                    <layoutData>
                                        <FlexItemData
                                            baseSize="30%"
                                            growFactor="0"
                                        />
                                    </layoutData>
                                </ComboBox>
                            </VBox>
                            <VBox
                                width="75%"
                                class="sapUiTinyMarginBegin"
                            >
                                <Label
                                    text="{i18n>MSmobileNo}"
                                    required="true"
                                />
                                <Input
                                    id="signUpPhone"
                                    type="Tel"
                                    value="{LoginMode>/Mobileno}"
                                    placeholder="{i18n>enterMobileNumber}"
                                    maxLength="18"
                                    liveChange="onMobileLivechnage"
                                    valueStateText="{i18n>MSmobileNoValueState}"
                                />
                                <layoutData>
                                    <FlexItemData
                                        baseSize="70%"
                                        growFactor="1"
                                    />
                                </layoutData>
                            </VBox>
                        </HBox>
                        <Label
                            text="{i18n>address}"
                            required="true"
                        />
                        <TextArea
                            id="signUpAddress"
                            rows="3"
                            value="{LoginMode>/Address}"
                            liveChange="onAddressChange"
                            placeholder="{i18n>address}"
                            maxLength="120"
                        />
                        <HBox width="100%">
                            <Label
                                text="{i18n>MSaccountSecurity}"
                                design="Bold"
                                class="sapUiSmallMarginTop"
                            />
                        </HBox>
                        <!-- <Title text="Account Security" /> -->
                        <!-- <MessageStrip id="passwordHelpStrip" type="Information" showIcon="false" text="Password must be 6+ characters: upper/lowercase letters, a number, and a special character" /> -->
                        <MessageStrip
                            id="passwordHelpStrip"
                            type="Information"
                            showIcon="false"
                            text="{i18n>msgStrip}"
                        />
                        <Label
                            text="{i18n>MScreatePassword}"
                            required="true"
                        />
                        <HBox width="100%">
                            <Input
                                showValueStateMessage="false"
                                id="signUpPassword"
                                width="100%"
                                placeholder="{i18n>enterPassword}"
                                value="{LoginMode>/password}"
                                type="Password"
                                liveChange="SM_onChnageSetAndConfirm"
                                showValueHelp="true"
                                valueHelpIconSrc="sap-icon://show"
                                valueHelpRequest="SM_onTogglePasswordVisibility"
                                maxLength="50"
                            >
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                            </Input>
                        </HBox>
                        <HBox
                            width="100%"
                            justifyContent="SpaceBetween"
                        >
                            <Text
                                id="passwordStrengthText"
                                class="pwdMinFail"
                            />
                            <Button
                                text="{i18n>MSgeneratePassword}"
								tooltip="{i18n>MSgeneratePassword}"
                                type="Transparent"
                                icon="sap-icon://refresh"
                                press="SM_onGeneratePassword"
                            />
                        </HBox>
                        <Label
                            text="{i18n>MSconfirmPassword}"
                            required="true"
                        />
                        <Input
                            id="signUpConfirmPassword"
                            placeholder="{i18n>MSenterConfirmPassword}"
                            value="{LoginMode>/comfirmpass}"
                            type="Password"
                            change="FSM_onConfirm"
                            liveChange="FSM_onConfirm"
                            showValueHelp="true"
                            valueStateText="{i18n>MSenterConfirmPassword}"
                            valueHelpIconSrc="sap-icon://show"
                            valueHelpRequest="SM_onTogglePasswordVisibility"
                            maxLength="50"
                        />
                    </f:SimpleForm>
                    <HBox
                        justifyContent="End"
                        class="sapUiSmallMargin"
                    >
                        <Button
                            text="{i18n>MSsignUp}"
							tooltip="{i18n>MSsignUp}"
                            class="myUnifiedBtn sapUiSmallMarginEnd"
                            width="120px"
                            press="onSignUp"
                        />
                    </HBox>
                </content>
            </Panel>
        </VBox>
    </Dialog>
</core:FragmentDefinition>